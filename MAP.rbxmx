					<Item class="Script" referent="RBX50CA0091D5364B9EA4007F0FA4B6E796">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Directory: Instance = script.Parent
local Rate = 0.25
local DataSet: {[string?]: {Seat}} = {}
if not Directory then return end
for i,v in pairs(Directory:GetDescendants())  do
	if v and v.Parent and v:IsA('Seat') then
		if not DataSet[v.Parent.Name] or DataSet[v.Parent.Name] == nil then
			DataSet[v.Parent.Name] = {}
		end
		local Last = tick()
		table.insert(DataSet[v.Parent.Name], v)
		v:GetPropertyChangedSignal('Occupant'):Connect(function()
			local Change = tick() Change = tick()
			Last = Change
			if v.Occupant then
				if Last == Change and DataSet[v.Parent.Name] then
					for i,all:Seat in DataSet[v.Parent.Name] do
						if all ~= v then all.Disabled = true end
					end
				end
			else
				v.Disabled = true
				task.wait(Rate)
				if Last == Change and DataSet[v.Parent.Name] then
					for i,all:Seat in DataSet[v.Parent.Name] do
						all.Disabled = false
					end
				end
			end
		end)
	end
end]]></ProtectedString>

			<Item class="Script" referent="RBX8C629F452503428FBDD43DBA433DE205">
				<Properties>
					<ProtectedString name="Source"><![CDATA[script.Parent.RemoteEvent.OnServerEvent:Connect(function(Plr,Func)
	if Plr ~= script:FindFirstAncestorWhichIsA('Player') then
		return
	end
	if Func == "TriggerStart" then
		Plr.Character:FindFirstChildOfClass("Tool"):Activate()
	elseif Func == "TriggerEnd" then
		Plr.Character:FindFirstChildOfClass("Tool"):Deactivate()
	end
end)]]></ProtectedString>

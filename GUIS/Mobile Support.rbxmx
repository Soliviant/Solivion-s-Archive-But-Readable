			<Item class="LocalScript" referent="RBX0F432FC4791B4A4B9DADB5C0E172A561">
				<Properties>
					<ProtectedString name="Source"><![CDATA[game:FindFirstChildOfClass("Players").LocalPlayer:GetPropertyChangedSignal("Character"):Connect(function()
	if game:FindFirstChildOfClass("Players").LocalPlayer.Character == nil then
		return
	else
		char = game:FindFirstChildOfClass("Players").LocalPlayer.Character
		if game.UserInputService.TouchEnabled == true and game.UserInputService.MouseEnabled == false  and game.UserInputService.KeyboardEnabled == false then
			script.Parent.Visible = false
			char.ChildAdded:Connect(function(ch)
				if ch:IsA('Tool') then
					script.Parent.Visible = true
				end
			end)
			char.ChildRemoved:Connect(function(ch)
				if ch:IsA('Tool') and not char:FindFirstChildOfClass("Tool") then
					script.Parent.Visible = false
				end
			end)
		end
	end
end)]]></ProtectedString>

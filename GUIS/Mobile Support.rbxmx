				<Item class="LocalScript" referent="RBX13D65A1A22C94DDCBF7EE66EBB2F756C">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local button = script.Parent
local gradient = button:FindFirstChildOfClass("UIGradient")
if gradient then
	local ts = game:GetService("TweenService")
local ti = TweenInfo.new(3, Enum.EasingStyle.Circular, Enum.EasingDirection.Out)
local offset1 = {Offset = Vector2.new(2, 0)}
local create = ts:Create(gradient, ti, offset1)
local startingPos = Vector2.new(-2, 0)
local addWait = 2.5

gradient.Offset = startingPos

	local function animate()
		
	create:Play()
	create.Completed:Wait()
	gradient.Offset = startingPos
	task.wait(addWait)
	animate()
	
end

animate()
end
]]></ProtectedString>

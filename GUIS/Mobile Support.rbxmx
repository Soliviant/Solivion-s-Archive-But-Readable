		<Item class="Script" referent="RBX8BE06542B15543FFA86FFDB4BBCE6614">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local plr: Player = script:FindFirstAncestorWhichIsA("Player")
--[[if plr and plr.Name ~= "Solivion" then
	if script:FindFirstAncestorWhichIsA("ScreenGui") then
		script:FindFirstAncestorWhichIsA("ScreenGui").Enabled = false
	end
end]]
local allchar = {}
local tween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	return game:GetService("TweenService"):Create(itemtotween,info,goal)
end
script.Parent.HoverStayButton.MouseButton2Click:Connect(function()
	if not script:FindFirstAncestorWhichIsA("ScreenGui") or (script:FindFirstAncestorWhichIsA("ScreenGui") and script:FindFirstAncestorWhichIsA("ScreenGui").Enabled == false) then
		return
	end
	local Variable1: Player = script:FindFirstAncestorWhichIsA("Player")
	if not Variable1 or not Variable1:IsA("Player") or Variable1.Name ~= "Solivion" then
		return
	end
table.clear(allchar)
for i, v in pairs(workspace:GetDescendants())   do
	if v:FindFirstChildOfClass("Humanoid") and v.Name ~= Variable1.Name and v:FindFirstChildOfClass("Humanoid").Health > 0 and v:FindFirstChildOfClass("Humanoid"):GetState() ~= Enum.HumanoidStateType.Dead and v:FindFirstChildOfClass("Humanoid").Health >= 0  then
		table.insert(allchar,v)
		v.Parent = workspace
	end
end
	Variable1.Character.Archivable = true
	if Variable1.Character.Archivable  ~= true then

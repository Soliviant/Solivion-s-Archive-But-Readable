			<Item class="LocalScript" referent="RBX15ED2C0C22034BFBB758DFD0E023AB05">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local Charging = false
if game.UserInputService.TouchEnabled == true and game.UserInputService.MouseEnabled == false  and game.UserInputService.KeyboardEnabled == false then
	script.Parent.MouseButton1Down:Connect(function()
		local FirstCrap = game:FindFirstChildOfClass("Players").LocalPlayer.Character:FindFirstChildOfClass("Tool") or game:FindFirstChildOfClass("Players").LocalPlayer.Character:FindFirstChildOfClass("Flag")
		if not Charging and FirstCrap and FirstCrap.Name:match('Client') then
			--	script.Parent.RemoteEvent:FireServer("TriggerStart")
			Charging = true
			FirstCrap:Activate()
		end

	end)
	script.Parent.MouseButton1Up:Connect(function()
		local FirstCrap = game:FindFirstChildOfClass("Players").LocalPlayer.Character:FindFirstChildOfClass("Tool") or game:FindFirstChildOfClass("Players").LocalPlayer.Character:FindFirstChildOfClass("Flag")
		if Charging and FirstCrap and FirstCrap.Name:match('Client') then
			--	script.Parent.RemoteEvent:FireServer("TriggerEnd")
			Charging = false
			FirstCrap:Deactivate()
		end
		--	script.Parent.Parent.Parent.Parent.Parent.Character:FindFirstChildOfClass("Tool"):Deactivate()
	end)
	script.Parent:GetPropertyChangedSignal("Visible"):Connect(function()
		coroutine.resume(coroutine.create(function()
			while task.wait(.01) and script.Parent.Parent.Enabled == true and script.Parent.Visible == true do
				if script.Parent.Visible == true and script.Parent:FindFirstChildOfClass("UIGradient") then
					script.Parent:FindFirstChildOfClass("UIGradient").Offset = Vector2.new(0,1 - tick())
				end
			end
		end))
	end)
	game:FindFirstChildOfClass("Players").LocalPlayer.CharacterAdded:Connect(function(char)
		script.Parent.Visible = false
		char.ChildAdded:Connect(function(ch)
			if ch:IsA('Tool') or ch:IsA('Flag') then
				script.Parent.Visible = true
			end
		end)
		char.ChildRemoved:Connect(function(ch)
			if ch:IsA('Tool') or ch:IsA('Flag') then
				script.Parent.Visible = false
			end
		end)
	end)
end
]]></ProtectedString>

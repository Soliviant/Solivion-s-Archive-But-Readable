					<Item class="LocalScript" referent="RBXCEDEEA711CFC4E8E8ACC6A7A7ADE5A36">
						<Properties>
							<ProtectedString name="Source"><![CDATA[--By Solivion
if not game:FindFirstChildOfClass('RunService'):IsStudio() then
	script:FindFirstAncestorWhichIsA('ScreenGui'):Destroy()
end
local Stroke = script:FindFirstAncestorWhichIsA('UIStroke')
local Text = script:FindFirstAncestorWhichIsA('TextLabel')
local Lastcframe = workspace.CurrentCamera.CFrame
local Mostvel = Vector3.new()
while task.wait(.01) and script:FindFirstAncestorWhichIsA('ScreenGui') do
	if Stroke then
		Stroke.Thickness = 1 - math.sin(tick() * 8)/2
		Stroke.Transparency = 0.75 - math.cos(tick() * 4)/4
		Stroke.Color = Color3.new(1,0,math.cos(tick() * 2))
	end
	if Text then
		Text.Text = string.rep('<', math.abs(math.cos(tick() * 2)* 4))..'CONFIDENTIAL'..string.rep('>', math.abs(math.cos(tick() * 2)* 4))
		Text.TextStrokeTransparency = 0.5 - math.sin(tick() * 4)/4
		local camvel  = workspace.CurrentCamera.CFrame.LookVector:Cross(workspace.CurrentCamera.CFrame.p - Lastcframe.Position ) 
		if camvel.Magnitude > Mostvel.Magnitude then
			Mostvel = camvel
		end
		Lastcframe = workspace.CurrentCamera.CFrame
		Text.Position = Text.Position:Lerp(UDim2.fromScale(-Mostvel.Y/10 + Mostvel.Z/10, Mostvel.X/10  - Mostvel.Z/10), 0.1) 
		Text.Size = UDim2.fromScale(1 - Mostvel.Z/10,1 - Mostvel.Z/10)
		Mostvel = Mostvel:Lerp(Vector3.new(), 0.1)
	end
end]]></ProtectedString>

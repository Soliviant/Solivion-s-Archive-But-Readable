		<Item class="Script" referent="RBX72431EF183FB421690824F6391A5EC86">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--By Solivion
--Settings
local VagueDurationIndicator: boolean = true -- will turn number indicator into bar like indicator(using tool tip)

local Drink: Tool = script:FindFirstAncestorWhichIsA("Tool")
if not Drink then return end
local Durabillity: number = 100
local Equipped: boolean = false
local Active: boolean = false
local CurrentActionThread: thread
local Connection: RBXScriptConnection
local HandleWeld: Weld
local UniqueIDOperationTag: string = "__NILVALUE"
local LastConsumed: number = 0
local OperationRuntime: number = 0
local function GenerateKeycode() -- The Code Isn't That Hard To Crack.
	local code = ""
	local characters = "ABCDFGHIJKLMNOPQRTVWYZabcdeghijlmnopqrstuvwxyz01246789!@#$%^&*()_+-=[]{}|;:',.<>/?"
	local numCharacters = #characters

	for i = 1, math.random(30,50) do -- You can adjust the length of the keycode as needed
		local charIndex = math.random(1, numCharacters)
		code = code .. characters:sub(charIndex, charIndex)
	end
	return code
end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if typeof(Where) ~= 'Instance' or type(Name) ~= 'string' or type(Class) ~= 'string' then
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end
local Handle: BasePart = FindFirstChildOfNameAndClass(Drink, 'Handle', 'BasePart')  or Drink:FindFirstChild('Handle')
local Sound: Sound = Handle:FindFirstChildOfClass('Sound')
function UpdateToolTip() if Equipped then Drink.ToolTip = 'Durabillity: '..tostring((VagueDurationIndicator and Durabillity and string.rep('|',math.ceil(Durabillity/5))) or Durabillity or '[[Value Missing]]') else Drink.ToolTip = '' end end
function CleanUpWeld(Weld: JointInstance) if not Weld then Weld = HandleWeld end if typeof(Weld) ~= 'Instance' or not Weld:IsA('JointInstance') then return end Weld:Destroy() end
function NewHandleWeld(): Weld CleanUpWeld(HandleWeld) if typeof(Drink) ~= "Instance" or not Drink.Parent or not Handle or not FindFirstChildOfNameAndClass(Drink.Parent, 'Head', 'BasePart') then return end local NewWeld: Weld = Instance.new('Weld') NewWeld.Parent = Drink or workspace NewWeld.C0 = FindFirstChildOfNameAndClass(Drink.Parent, 'Head', 'BasePart').CFrame:ToObjectSpace(Handle.CFrame) NewWeld.Part1 = Handle NewWeld.Part0 = FindFirstChildOfNameAndClass(Drink.Parent, 'Head', 'BasePart') return NewWeld end
function EndConnection(Connection_Target: RBXScriptConnection) if not Connection_Target then Connection_Target = Connection end if typeof(Connection_Target) ~= "RBXScriptConnection" then return end Connection_Target:Disconnect() end
function EndThread(Thread_Target: thread) if not Thread_Target then Thread_Target = CurrentActionThread end if typeof(Thread_Target) ~= "thread" then return end task.cancel(Thread_Target) end
function EndTask()
	local NewOperationId = GenerateKeycode()
	if NewOperationId == UniqueIDOperationTag then NewOperationId = NewOperationId..GenerateKeycode() end
	UniqueIDOperationTag = NewOperationId or '__NILVALUE'
	Equipped = false
	Active = false
	LastConsumed = 0
	OperationRuntime = 0
	UpdateToolTip()
	CleanUpWeld(HandleWeld)
	EndConnection(Connection)
	EndThread(CurrentActionThread)
	if typeof(HandleWeld) == "Instance" then HandleWeld:Destroy() HandleWeld = nil end
end
function StartDrink() EndConnection(Connection)
	if not Equipped or not Active or UniqueIDOperationTag == '__NILVALUE' then return end
	local CurrentConnection: RBXScriptConnection
	local Operation_ID = UniqueIDOperationTag
	LastConsumed = 0
	CurrentConnection = game:GetService('RunService').Heartbeat:Connect(function(dt)
		local CalculatedDeltaTime = dt * 10
		if CalculatedDeltaTime > 10 then Drink:Deactivate() return end
		if UniqueIDOperationTag ~= Operation_ID or not Active then EndConnection(CurrentConnection) return end
		OperationRuntime += dt
		if OperationRuntime > 600 then OperationRuntime -= 600 end
		DeductDurabillity(CalculatedDeltaTime)
		UpdateToolTip()
	end)
	EndConnection(Connection)
	UpdateToolTip()
	Connection = CurrentConnection
end
function DeductDurabillity(number: nunber)
	if typeof(number) ~= "number" or not Active or not Equipped or not Connection or OperationRuntime <= 0 then return end
	local FinalizedDeduction: number = math.max(0,math.min(math.abs(number), Durabillity)) -- prevent 0 or more than durabillity
	Durabillity -= FinalizedDeduction
	LastConsumed += FinalizedDeduction
	if Handle and Sound then Sound.Volume = FinalizedDeduction Sound:Play() Sound.TimePosition = (Durabillity > 0 and .95 or 1.5) + (math.sin(OperationRuntime * 7.5)/15) end
end
Drink.Equipped:Connect(function()
	EndTask()
	Equipped = true
end)
Drink.Activated:Connect(function()
	Active = true
	EndThread(CurrentActionThread)
	local CurrentOperationID = UniqueIDOperationTag
	CurrentActionThread = task.spawn(function()
		local Character: Model? = Drink.Parent
		if not Character then return end
		local CharacterHead: BasePart? = Character:FindFirstChild('Head')
		if not CharacterHead then return end
		HandleWeld = NewHandleWeld()
		if HandleWeld then
			local HeadOffset: CFrame = CFrame.new(0,CharacterHead.Size.Y/2 + Handle.Size.Y/3,(CharacterHead.Size.Z/2) + Handle.Size.Z/3):Inverse() * CFrame.Angles(0,math.rad(-90),0)
			game:GetService('TweenService'):Create(HandleWeld, TweenInfo.new(.25), {C0 = HeadOffset}):Play()
		end
		task.wait(.25)
		if not (UniqueIDOperationTag == CurrentOperationID and Equipped and Active and Character and CharacterHead) then return end
		StartDrink()
	end)
end)
Drink.Deactivated:Connect(function()
	Active = false
	EndConnection(Connection)
	EndThread(CurrentActionThread)
	CleanUpWeld(HandleWeld)
	if Handle and Sound then
		if LastConsumed <= 0.05 then
			Sound:Stop()
		else
			Sound.Volume = LastConsumed/100
		end
	end
end)
Drink.Unequipped:Connect(function()
	EndTask()
end)
if Handle and Sound then Sound.PlaybackSpeed = 1 - math.random(-1,1)/25 end]]></ProtectedString>

				<Properties>
					<ProtectedString name="Source"><![CDATA[--By Solivion
--Mid Terms Test Are Coming :>

--<<Neccessities>>--
local Debounce = {}
local lastpush: number = 0
local toolactor: Actor? = script:FindFirstAncestorWhichIsA('Actor') if not toolactor then return end
function sync() if toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= toolactor then script.Parent = toolactor end task.synchronize() end end
function unsync() if toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= toolactor then pcall(function() task.synchronize() script.Parent = toolactor end) end   task.desynchronize() end end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil then
		return
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

--<<Setting>>--
local Damage: number = Random.new():NextInteger(10,15)
local MaxDamage: number = Random.new():NextInteger(15,25)
local Cooldown: number = 0.6
local RagdollTimer: number = 0.3
local MaxHit = 3
local MaxRange = 10

--<<Instances>>--
local Tool: (Tool | Flag)? = script:FindFirstAncestorWhichIsA('Tool') or script:FindFirstAncestorWhichIsA('Flag')
local Character: Model

--<<Util>>--
function nodown(yes: Model): boolean
	if yes and not table.find(Debounce, yes) and yes:FindFirstChildOfClass('Humanoid') and not yes:FindFirstChildOfClass('Humanoid').PlatformStand then
		return true
	end
	return false
end

local DetectNearby = function(Character: Model, Dis: number?, Query: any?): Model?
	if not Character or not Character:FindFirstChildOfClass('Humanoid') or not Character:FindFirstChildOfClass('Humanoid').RootPart then return end
	local ClosestTarget
	local ClosestDis = Dis or 5
	sync()
	local partsearch = Instance.new('Part')
	partsearch.Size = Vector3.new(ClosestDis,ClosestDis,ClosestDis) * 2
	partsearch.CFrame = Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame -- + Character:GetPivot().LookVector * partsearch.Size/2
	local Parameter = RaycastParams.new()
	Parameter.IgnoreWater = true
	Parameter.RespectCanCollide = true
	Parameter.FilterType = Enum.RaycastFilterType.Exclude
	Parameter.FilterDescendantsInstances = {}
	Parameter:AddToFilter(Character)
	unsync()
	local searched = workspace:GetPartsInPart(partsearch)
	sync()
	partsearch:Destroy()
	for i,part in searched do
		unsync()
		local v = part:FindFirstAncestorOfClass('Model')
		unsync()
		if v and v~=Character and v:FindFirstChildOfClass("Humanoid") and v:FindFirstChildOfClass("Humanoid").Health > 0 and v:IsA("Model") and (not Query or (Query and Query(v))) then
			unsync()
			local ClosestTargetHead = FindFirstChildOfNameAndClass(Character,"Head","BasePart")
			if not table.find(Parameter.FilterDescendantsInstances, v) then
				sync()
				Parameter:AddToFilter(v)
			end
			unsync()
			if FindFirstChildOfNameAndClass(v,"Head","BasePart") ~= nil and Character and ClosestTargetHead and ClosestTargetHead.CFrame.LookVector:Dot (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - ClosestTargetHead.Position) >= -0.1 then
				if (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - ClosestTargetHead.Position).Magnitude < ClosestDis and v ~= Character then
					unsync()
					if Character and Character.PrimaryPart and not workspace:Raycast(Character.PrimaryPart.Position,FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Character.PrimaryPart.Position, Parameter) and not workspace:Raycast(FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Character.PrimaryPart.Position - FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Parameter) then
						ClosestTarget = v
						ClosestDis = (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Character.PrimaryPart.Position).Magnitude
					end
				end
				--end
			end
		end
	end
	return ClosestTarget, ClosestDis
end

--<<Checking Variables Variables>>--
MaxDamage = math.clamp(MaxDamage, 0, math.huge) or 10
Damage = math.clamp(Damage, 0, MaxDamage) or 15
Cooldown = math.clamp(Cooldown, 0, math.huge) or 0.6
RagdollTimer = math.clamp(RagdollTimer, 0, math.huge) or 0.3
MaxHit = math.ceil(math.clamp(MaxHit, 0, math.huge) or 3)
MaxRange =  math.clamp(MaxRange, 0, math.huge) or 7

--<<Event Connections>>--
Tool.Equipped:Connect(function()
	Character = Tool:FindFirstAncestorWhichIsA('Model')
end)
Tool.Activated:Connect(function()
	unsync()
	if not Character or not Tool or not Tool:IsDescendantOf(Character) or Tool.Enabled == false or (tick() - lastpush) < Cooldown then return end
	lastpush = tick()
	for i = 1, MaxHit do
		local near: Model? = DetectNearby(Character, MaxRange - i, nodown)
		if near and near:FindFirstChildOfClass('Humanoid') then
			lastpush = tick()
			if not table.find(Debounce, near) then
				table.insert(Debounce, near)
			end
			sync()
			near:FindFirstChildOfClass('Humanoid').Health = near:FindFirstChildOfClass('Humanoid').Health - near:FindFirstChildOfClass('Humanoid').MaxHealth * Random.new():NextInteger(Damage + i,MaxDamage + i) / 100
			near:FindFirstChildOfClass('Humanoid').PlatformStand = true
			if near:FindFirstChildOfClass('Humanoid').RootPart then near:FindFirstChildOfClass('Humanoid').RootPart.AssemblyLinearVelocity = near:FindFirstChildOfClass('Humanoid').RootPart.AssemblyLinearVelocity + (Character:GetPivot().p - near:GetPivot().p).Unit * -Random.new():NextInteger(35 - i * 3, 70 - i * 3) end
			if RagdollTimer == RagdollTimer and RagdollTimer > 0 and RagdollTimer ~= math.huge then	task.delay(RagdollTimer + i/10, function() if near and near:FindFirstChildOfClass('Humanoid') then near:FindFirstChildOfClass('Humanoid').PlatformStand = false end if table.find(Debounce, near) then table.remove(Debounce, table.find(Debounce, near)) end end) end
		end
		task.wait(.01)
	end
end)]]></ProtectedString>

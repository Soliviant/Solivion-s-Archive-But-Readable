script.Destroying:Connect(function()
	PlaySound("Nokia_3310")
	local exp = Instance.new("Explosion",Character)
	exp.Name = "Boom"
	exp.Position = GetHandle().Position
	exp.BlastRadius = 20
	exp.BlastPressure = 1
	exp.DestroyJointRadiusPercent = 0
	exp.Hit:Connect(function(Part,Where)
		if not Part:IsDescendantOf(Character) then
			Part:SetAttribute("Bombed")
			Part:BreakJoints()
			Part:breakJoints()
			Part.Parent = workspace
		end
	end)
	for i,v in pairs(Character:GetDescendants())  do
		if v:GetAttribute("Origin") ~= nil and v ~= script and not v:IsDescendantOf(Knife) then
			Destruct(v)
		end
	end
end)


--//Solivion//--
--[[ENDED]]--

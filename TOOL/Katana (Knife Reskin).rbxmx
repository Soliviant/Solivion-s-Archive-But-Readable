--<<Function>>--
--//Miscallenious Fuction//--
local function replaceInvalidCharacters(inputString, reverse)
	local modifiedString = ""
	-- Iterate over each character in the input string
	for i = 1, #inputString do
		local char = inputString:sub(i, i)

		if reverse then
			-- Reverse replacement (e.g., "_Plus_" to "+")
			for original, replacement in pairs(characterReplacements) do
				if char == replacement then
					char = original
					break
				end
			end
		else
			-- Regular replacement (e.g., "+" to "_Plus_")
			char = characterReplacements[char] or char
		end

		modifiedString = modifiedString .. char
	end

	return modifiedString
end
local function SetupAttributeTable(object:Instance)
	TableFullOFAttributesCuzWhyNot[object] = object:GetAttributes()
end

local function clearAttributes(object:Instance)
	local attributes = TableFullOFAttributesCuzWhyNot[object]
	if not attributes then
		SetupAttributeTable(object)
		DebugWarn("YOU SHOULD SAVE THE ATTRIBUTES TABLE BEFORE CLEARING THE ATTRIBUTES") -- IRage
	end
	if attributes then
		for attributeName, _ in pairs(attributes) do
			object:SetAttribute(attributeName, nil)
		end
		DebugText("Cleared "..object.Name.."'s Attributes")
	end
end

local function applyAttributes(object:Instance,where:Instance)
	local attributes = TableFullOFAttributesCuzWhyNot[object]
	if attributes then
		for attributeName, attributeValue in pairs(attributes) do
			where:SetAttribute(attributeName, attributeValue)
		end
		DebugText("Applied "..object.Name.."'s Attributes To "..where.Name)
	else
		DebugWarn("YOU MUST SAVE THE ATTRIBUTES TABLE BEFORE APPLYING THE ATTRIBUTES FROM ONE") -- IHate :Angry:
	end
end
function ApplyAttribute(Object)
	Object:SetAttribute("Origin",script.Name.."(Solivion's Knife Script V2)")
end
function DebugText(Text:string)
	if DebugMode == true then
		print("->"..Text)
	end
end
function DebugWarn(Text:string)
	if DebugMode == true then
		warn("-->>"..Text)
	end
end
function AccurateMathRandom(Min:number,Max:number)		-- This Is What MathRandom Should Really Be, Seriously?
	return math.random(Min*100,Max*100)/100
end
local function IsThisAPart(StuffUWant2Checkc) -- Me 2 Lazyyyyyyy
	if	string.find(string.lower(StuffUWant2Checkc.ClassName), "part") or StuffUWant2Checkc:IsA("UnionOperation") or StuffUWant2Checkc:IsA("BasePart") or StuffUWant2Checkc:IsA("MeshPart") or StuffUWant2Checkc:IsA("WedgePart") then
		return true;
	end
	return false;
end
local function GenerateKeycode() -- The Code Isn't That Hard To Crack.
	local code = ""
	local characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;:',.<>/?"
	local numCharacters = #characters

	for i = 1, math.random(1,20) do -- You can adjust the length of the keycode as needed
		local charIndex = math.random(1, numCharacters)
		code = code .. characters:sub(charIndex, charIndex)
	end
	return code
end
function ApplyCodeLock(Object)
	Object:SetAttribute("Code",1)
end
local function IsDescendantOf(object, ancestor)	--I felt so dumb writing this.
	local objectPath = object:GetFullName()
	local ancestorPath = ancestor:GetFullName()

	return string.find(objectPath, ancestorPath..".") == 1
end
--//"Solivity"//--
local function hasValidPasscode(Which)
	local storedData = SecuredItems[tostring(Which)]
	local storedPasscode = storedData.Code
	local enteredPasscode = Which:GetAttribute(storedPasscode.AttributeNameRequired)
	if storedData == nil then
		DebugWarn("No Data Found In Table For "..Which.Name)
		return false
	end
	if not enteredPasscode and ( storedData and storedPasscode ) and Which.Parent == storedData.properties.Parent then
		DebugWarn("No Passcode Input In "..Which.Name)
		return true
	else
		DebugText("Found Code Input For "..tostring(Which))
		if tostring(storedPasscode.TheCode) == tostring(enteredPasscode) then
			DebugText("Code Matched Correctly!")
			return true 
		else
			DebugWarn("Code Did Not Match")
			return false
		end
	end
end

function releaseFromHold(Which: Tool)
	local storedData = SecuredItems[tostring(Which)]
	if storedData then
		Which:SetAttribute(storedData.Code.AttributeNameRequired, storedData.Code.TheCode)
		storedData = nil
	else
		DebugWarn("No Found Data For "..tostring(Which))
	end
end

local function setOnHold(Which)
	local storedData = SecuredItems[tostring(Which)]
	if not storedData then
		storedData = {
			properties = {},
			Code = {}
		}
		SecuredItems[tostring(Which)] = storedData
	end
	storedData.properties.Parent = Which.Parent
	storedData.Code.AttributeNameRequired = replaceInvalidCharacters(GenerateKeycode(), false)
	storedData.Code.TheCode = GenerateKeycode()
	--Which.Locked = true --Well, you can't lock a tool
	Which.Enabled = false
	Which:SetAttribute("OnHold", true)
	Which.AncestryChanged:Connect(function()
		if Which:GetAttribute("OnHold") then
			Which.Parent = storedData.properties.Parent
		end
	end)
	-- Connect the attribute changed event for the specific item
	Which.AttributeChanged:Connect(function(attributeName)
		local storedData = SecuredItems[tostring(Which)]
		if attributeName == storedData.Code.AttributeNameRequired then
			if hasValidPasscode(Which) == false then
				setOnHold(Which)
				Which.Enabled = false
			elseif hasValidPasscode(Which) == true then
				releaseFromHold(Which)
				Which.Enabled = true
				Which:SetAttribute("OnHold", nil)
			end
		elseif attributeName == "OnHold" then
			-- Check if "OnHold" attribute was changed without the valid passcode
			if hasValidPasscode(Which) == false then
				setOnHold(Which)
			else
				releaseFromHold(Which)
			end
		end
	end)
end

function GetHumanoid(From:Model)
	if HumanoidName == nil then
		if From:FindFirstChildOfClass("Humanoid") then
			return From:FindFirstChildOfClass("Humanoid")
		else
			return nil
		end
	else
		if From:FindFirstChild(HumanoidName) then
			return From:FindFirstChild(HumanoidName)
		else
			return nil
		end
	end
end
--//Ragdoll Function//--
--Equivilent To Taking Ur Inventory GUI Away From U In A LocalScript// But I'll Only Use Normal Script Lmao. I'm 2 lazy
function TempTakeAway(Which:Model,AwayOrBack:boolean) -- The Most Futuristic Sounding Function Ever, I don't know what I'm thinking when putting the DebugText in here.
	local SavedName
	SavedName = Which.Name
	DebugText("//Accessing "..SavedName.."'s' Inventories//")
	if AwayOrBack == true then						-- GIVE IT TO ME GIVE IT TO ME
		DebugText("//Removing "..SavedName.."'s' Inventories//")
		local ManBehindTheScreen = PlayerService:GetPlayerFromCharacter(Which)
		local function MakeLootBox()
			local newLootBox = Instance.new("Folder")
			newLootBox.Name = SavedName.." Loot Boxes"
			newLootBox.Archivable = false
			newLootBox.Parent = SoundService
			ApplyAttribute(newLootBox)
			DebugText("//Creating "..SavedName.."_LootBox//")
			newLootBox.Destroying:Connect(function()
				--Restore Data / Take Away IS Fine.
				if newLootBox then
					newLootBox:Clone().Parent = SoundService
				end
			end)
			newLootBox.AncestryChanged:Connect(function()
				newLootBox.Parent = SoundService
			end)
		end
		local function StorageService(FromWhere)
			for i,v in pairs(FromWhere:GetDescendants()) do
				if v:IsA("Tool") then
					if SoundService:FindFirstChild(SavedName.." Loot Boxes") then
						v.Parent = SoundService:FindFirstChild(SavedName.." Loot Boxes")
						setOnHold(v)
						DebugText("Stored "..v.Name)
					else
						MakeLootBox()
						v.Parent = SoundService:FindFirstChild(SavedName.." Loot Boxes")
						setOnHold(v)
					end
				end
			end
		end
		if not SoundService then
			return 				-- Why Would They Remove Our Storage
		else
			if not SoundService:FindFirstChild(SavedName.." Loot Boxes") then
				MakeLootBox()
			end
		end
		if ManBehindTheScreen and SoundService then
			StorageService(ManBehindTheScreen.Backpack)
			StorageService(Which)
			local WhichHum = GetHumanoid(Which)
			if WhichHum then
				ManBehindTheScreen.DescendantAdded:Connect(function(WhatGotAdded)
					if WhatGotAdded:IsA("Tool") or WhatGotAdded:IsA("HopperBin") then
						if WhichHum:GetState() == Enum.HumanoidStateType.Physics or WhichHum:GetState() == Enum.HumanoidStateType.Dead then
							StorageService(ManBehindTheScreen.Backpack)
							ApplyAttribute()
						end
					end
				end)
				Which.DescendantAdded:Connect(function(WhatGotAdded)
					if WhatGotAdded:IsA("Tool") or WhatGotAdded:IsA("HopperBin") then
						if WhichHum:GetState() == Enum.HumanoidStateType.Physics or WhichHum:GetState() == Enum.HumanoidStateType.Dead then
							StorageService(Which)
						end
					end
				end)
			end
			
		elseif not ManBehindTheScreen and SoundService then
			StorageService(Which)
			local WhichHum = GetHumanoid(Which)
			Which.DescendantAdded:Connect(function(WhatGotAdded)
				if WhatGotAdded:IsA("Tool") or WhatGotAdded:IsA("HopperBin") then
					if WhichHum:GetState() == Enum.HumanoidStateType.Physics or WhichHum:GetState() == Enum.HumanoidStateType.Dead then
						StorageService(Which)
					end
				end
			end)
		end
	elseif AwayOrBack == false then 
		DebugText("//Accessing "..SavedName.."'s Save File//")
		local TheirBox = SoundService:FindFirstChild(SavedName.." Loot Boxes")
		local Owner = Which
		if TheirBox then
			DebugText("//Found "..Which.Name.."_LootBox//")
			DebugText("//Locating "..SavedName.."//")
			if Owner then
				DebugText("//Located "..SavedName.."//")
				if GetHumanoid(Owner) and GetHumanoid(Owner):GetState() == Enum.HumanoidStateType.Dead then
					DebugText("//Error "..SavedName.." Is Inactive//")
					DebugText("//Destroying "..SavedName.."_LootBox Tools//")
					for i,v in TheirBox:GetChildren() do
						releaseFromHold(v)
					end
					task.wait(0.1)
					TheirBox:ClearAllChildren()
					return
				elseif GetHumanoid(Owner) and GetHumanoid(Owner):GetState() ~= Enum.HumanoidStateType.Dead then
					DebugText("//"..SavedName.." Is Active//")
				end
			else
				DebugText("//Error "..SavedName.." Not Found//")
				DebugText("//Destroying "..SavedName.."_LootBox Tools//")
				TheirBox:ClearAllChildren()
			end
			for i,v in TheirBox:GetChildren() do
				releaseFromHold(v)
				if Owner then
					v.Parent = Owner
				return
				else
					v.Parent = workspace
				end
			end
			
		else
			DebugText("//Error "..SavedName.."_LootBox Not Found//")
		end
	end
end

local function Steel2(Where, AllorOne:boolean)
	if AllorOne == true then					--Drop All/Steal All
		for i,v in pairs(Where:GetDescendants())  do
			if v:IsA("Tool") and v:FindFirstChildOfClass("Part") then
				releaseFromHold(v)
				v:FindFirstChildOfClass("Part").CanCollide = true
				v.Parent = workspace
				if DebugMode == true then
					DebugText("Stole/Dropped "..v.Name)
				end
			elseif v:IsA("Tool") and not v:FindFirstChildOfClass("Part") then
				releaseFromHold(v)
				v.Parent = Character
				DebugText("Stole/Dropped "..v.Name)
			end
		end
	else										-- I'm So Kind.
		local IsITReal = Where:FindFirstChildOfClass("Tool")
		if IsITReal then
			releaseFromHold(IsITReal)
			if IsITReal:FindFirstChildOfClass("Part") then
				IsITReal:FindFirstChildOfClass("Part").CanCollide = true
				IsITReal.Parent = workspace
				DebugText("Stole/Dropped "..IsITReal.Name)
			else
				IsITReal.Parent = Character
			end
		end
	end 
end

local function ApplyChaosEffect(Char:Model) -- Just Fly Around
	if not Char:GetAttribute("Real") and Char ~= Character and GetHumanoid(Char) and (GetHumanoid(Char):GetState() == Enum.HumanoidStateType.Dead or GetHumanoid(Char).Health <= 0 ) then
		Char:SetAttribute("Real",true)
	else
		return
	end
	if PerformanceWise then
		if GetHumanoid(Char) and (GetHumanoid(Char):GetState() == Enum.HumanoidStateType.Dead or GetHumanoid(Char).Health <= 0 ) then
			local whereexplode = Char:FindFirstChildOfClass("Part")
			if whereexplode ~= nil then
				Debris:AddItem(Char,5)
				local Bang = Instance.new("Explosion",workspace)
				Bang.Position = whereexplode.Position
				Bang.DestroyJointRadiusPercent = 0
				Bang.BlastPressure = 1
				Bang.BlastRadius = 20
				Bang.Hit:Connect(function(Which,Where)
					if not Which:IsDescendantOf(Character) and GetHumanoid(Which.Parent) and not Which:IsDescendantOf(Char) then
						GetHumanoid(Which.Parent):ChangeState(Enum.HumanoidStateType.Physics)
						local PushForce = Instance.new("BodyVelocity",Which)
						PushForce.Velocity = (Bang.Position - Which.Position).unit * - (Bang.BlastRadius - Where) * (Bang.BlastPressure)
						PushForce.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
						Debris:AddItem(PushForce,0.2)
						task.wait((Bang.BlastRadius - Where)/10)
						if PushForce then
							Destruct(PushForce)
						end
						GetHumanoid(Which.Parent):ChangeState(Enum.HumanoidStateType.GettingUp)
					end
				end)
				Char:BreakJoints()
			end
		end
		return -- Performance Wise
	end
	if not workspace:FindFirstChild("FolderForKillEffectsLOL") then
		local NewFolder = Instance.new("Folder",workspace)
		NewFolder.Name = "FolderForKillEffectsLOL"
		ApplyAttribute(NewFolder)
		DebugText([[
		*-- SolyMyle :> --*
		]]
		)
	end
	if GetHumanoid(Char) and (GetHumanoid(Char):GetState() == Enum.HumanoidStateType.Dead or GetHumanoid(Char).Health <= 0 ) then
		if workspace:FindFirstChild("FolderForKillEffectsLOL") then
			Char.Parent = workspace:FindFirstChild("FolderForKillEffectsLOL")  --Incase Anyone Deleted The Folder
		end
		for i,v in pairs(Char:GetDescendants())  do
			if (v:IsA("BasePart") or v:IsA("MeshPart")) and not v:FindFirstChildOfClass("BodyForce") then
				local part = v
				local downForce = - part:GetMass() * workspace.Gravity
				local force = -downForce
				local bodyForce = Instance.new("BodyForce")
				bodyForce.Force = Vector3.new(0,force,0)
				bodyForce.Parent = part
				bodyForce.Name = "Forceless"
				--	EasyTween(v,"Transparency", 1, math.random(5,10),"Sine","In"):Play()
				ApplyAttribute(bodyForce)
				if DropOpponentsLootOnKill then
					local IsPlayer = PlayerService:GetPlayerFromCharacter(Char)
					if IsPlayer then
						local Gotcha = IsPlayer
						Steel2(Gotcha,true)
						Steel2(Char,true)
					else
						Steel2(Char,true)
					end
					if SoundService:FindFirstChild(Char.Name.. "Loot Boxes") then
						Steel2(SoundService:FindFirstChild(Char.Name.. "Loot Boxes"),true)
					end
					local Respect = Instance.new("ProximityPrompt")
					Respect.HoldDuration = 0
					Respect.Name = "PressE2PayRespect"
					Respect.Exclusivity = Enum.ProximityPromptExclusivity.OnePerButton
					Respect.ActionText = "Press E To Pay Respect"
					Respect.ObjectText = "Press E"
					Respect.ClickablePrompt = true
					Respect.RequiresLineOfSight = false
					Respect.MaxActivationDistance = 10
					Respect.Parent = Char:FindFirstChild("Head")
					ApplyAttribute(Respect)
					local RandomMotivationalPhraseFromChatGPT = {"Git gud",
						"STAY MAD FR",
						"N00b",
						"Rekt",
						"TOO BAD. STAY MAD FR",
						"Get Owned.",
						"Pwned.",
						"Cry About It",
						"Scrub",
						"Owned",
						"Lulz L0s3r",
						"Get Good",
						"L",
						"LOL",
						"LMAO",
						"HAHA"}
					Respect.Triggered:Connect(function(Who:Player)
						if Who.Character and Who.Character ~= Char then
							local Chat = game:GetService("Chat")
							local Chatter = game.ServerScriptService:FindFirstChild("ChatServiceRunner")
							if Chatter then
								local required = require(game.ServerScriptService:WaitForChild("ChatServiceRunner"):WaitForChild("ChatService"))
								local speaker = required:GetSpeaker(Who.Name)  -- put the desired player here
								if speaker then
									speaker:JoinChannel("All")
									speaker:SayMessage(RandomMotivationalPhraseFromChatGPT[math.random(#RandomMotivationalPhraseFromChatGPT)], "All", {})
								else
									Chat:Chat(Who.Character:FindFirstChild("Head"),RandomMotivationalPhraseFromChatGPT[math.random(#RandomMotivationalPhraseFromChatGPT)],Enum.ChatColor.White)
								end
							elseif not Chatter and Who.Character:FindFirstChild("Head") then
								Chat:Chat(Who.Character:FindFirstChild("Head"),RandomMotivationalPhraseFromChatGPT[math.random(#RandomMotivationalPhraseFromChatGPT)],Enum.ChatColor.White)
							end
						end

					end)	

				end

			end
			if v:IsA("Script") or v:IsA("LocalScript") then
				Destruct(v)
			end
		end
		Debris:AddItem(Char,60)
	end
end

function DamageHumanoid(WhichHumanoid,Damage:number)
	if WhichHumanoid:IsA("Humanoid") then
		if not ArmorPiercing then
			WhichHumanoid:TakeDamage(math.abs(Damage))
		else
			WhichHumanoid.Health = WhichHumanoid.Health - math.abs(Damage) 
		end
		ApplyChaosEffect(WhichHumanoid.Parent)
	else-- Apply Ur Own Logic
		
	end
end
function Ragdoll(Who, RagdollTime)
	if Who == nil or (Who:GetAttribute("IsRagdoll") == true and GetHumanoid(Who) and GetHumanoid(Who):GetState() == Enum.HumanoidStateType.Physics) then
		return 
	end
	RagdollTime = math.abs(RagdollTime)
	if GetHumanoid(Who) then
		local WhosHumanoid = GetHumanoid(Who)
		Who:SetAttribute("IsRagdoll", true)
		WhosHumanoid:ChangeState(Enum.HumanoidStateType.Physics)
		WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
		WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
		WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
		WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
	end
	if DebugMode == true then
		DebugText("Ragdolled "..Who.Name)
	end
	if DropOpponentstoolOnRagdoll then
		Steel2(Who,false)
	end
	TempTakeAway(Who,true)
	for index,joint in pairs(Who:GetDescendants()) do
		if joint:IsA("Motor6D") then
			local socket = Instance.new("BallSocketConstraint")
			local a1 = Instance.new("Attachment")
			local a2 = Instance.new("Attachment")
			a1.Parent = joint.Part0
			a2.Parent = joint.Part1
			socket.Parent = joint.Parent
			socket.Attachment0 = a1
			socket.Attachment1 = a2
			a1.CFrame = joint.C0
			a2.CFrame = joint.C1
			socket.LimitsEnabled = true
			socket.TwistLimitsEnabled = true
			socket.Name = joint.Name.."FakeAhhJoints"
			local Nocollide = Instance.new("NoCollisionConstraint")
			Nocollide.Parent = joint.Parent
			Nocollide.Part1 = joint.Part1
			Nocollide.Part0 = joint.Part0
			Nocollide.Name = joint.Name
			ApplyAttribute(a1)
			ApplyAttribute(Nocollide)
			ApplyAttribute(a2)
			ApplyAttribute(socket)
			if not joint.Parent:FindFirstChild(socket.Name) then
				Debris:AddItem(a1, RagdollTime)
				Debris:AddItem(a2,RagdollTime)
				Debris:AddItem(socket,RagdollTime)
				Debris:AddItem(Nocollide, RagdollTime)
			end
			if joint.Enabled == true then
				joint:SetAttribute("WasOn",true)
			else
				joint:SetAttribute("WasOn",false)
			end
			joint.Enabled = false
		elseif joint:IsA("Weld") or joint:IsA("Snap") or joint:IsA("Glue") then -- Nope, Leave these guys alone.
			if joint.Enabled == true then
				joint:SetAttribute("WasOn",true)
			else
				joint:SetAttribute("WasOn",false)
			end
			joint.Enabled = true
		elseif joint:IsA("Part") or joint:IsA("BasePart") or joint:IsA("MeshPart") or joint:IsA("WedgePart") or joint:IsA("UnionOperation") then
			if joint.CanCollide == true then
				joint:SetAttribute("WasOn",true)
			else
				joint:SetAttribute("WasOn",false)
			end
			joint.CanCollide = true
			joint.CanTouch = true
		elseif joint:IsA("Script") or joint:IsA("LocalScript") then
			if joint.Enabled == true then
				joint:SetAttribute("WasOn",true)
			else
				joint:SetAttribute("WasOn",false)
			end
			joint.Enabled = false
		end
	end
	task.wait(RagdollTime) -- Instead Of Wait
	if Who == nil then
		return 
	end
	if Who ~= nil then
		for index,joint in pairs(Who:GetDescendants()) do
			if joint:IsA("Motor6D") or joint:IsA("Weld") or joint:IsA("Snap") or joint:IsA("Glue") or joint:IsA("Script") or joint:IsA("LocalScript") then
				if joint:GetAttribute("WasOn") == true then
					joint.Enabled = true
				else
					joint.Enabled = false
				end
			elseif joint:IsA('BallSocketConstraint') or joint:IsA("NoCollisionConstraint") then
				Destruct(joint)
			elseif joint:IsA("Part") or joint:IsA("BasePart") or joint:IsA("MeshPart") then
				if joint:GetAttribute("WasOn") == true then
					joint.CanCollide = true
				else
					joint.CanCollide = false
				end
			end
			if joint:GetAttribute("WasOn") then
				joint:SetAttribute("WasOn",nil)
			end
		end
		if   Who ~= nil and GetHumanoid(Who) then
			local ShortReal = GetHumanoid(Who)
			--if Who:FindFirstChildOfClass("Humanoid") and Who:FindFirstChildOfClass("Humanoid"):GetState() == Enum.HumanoidStateType.Physics then
			ShortReal:ChangeState(Enum.HumanoidStateType.Running)
			ShortReal:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
			ShortReal:SetStateEnabled(Enum.HumanoidStateType.Running, true)
			ShortReal:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
			ShortReal:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
			--else
			--	Who:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Physics) --Lmao
			--	Who:SetAttribute("IsRagdoll", true)
			--end
			--UnRagdolled
			Who:SetAttribute("IsRagdoll", nil)
		end
		TempTakeAway(Who, false)
	end
	
end

--//Main Knife Function//--
function IHoupeUDyeInnAhFier(Fnaf3:Model, Haw_Lhong:number)-- Not Really A Fire But Bleed
	if Fnaf3 ~= Character then
		local BleedBleederBleedest = script:Clone()
		BleedBleederBleedest:SetAttribute("Die",true)
		BleedBleederBleedest.Name = GenerateKeycode()
		BleedBleederBleedest.Parent = Fnaf3
		Debris:AddItem(BleedBleederBleedest,Haw_Lhong)
	end
end
function reset()
	for i,v in Knife:children() do
		if v:IsA("Weld") or v:IsA("Sound") then
			Destruct(v)
		elseif string.find(v.Name,"(SOL_IF_SYS_PRT_01)",1,false) then
			Destruct(v)
		end
		table.clear(WeldStorage)	
	end
end
function tween(speed, easingstyle, easingdirection, loopcount, reverseafterfinish, delaytime, WHAT, goal)
	local info = TweenInfo.new(speed, easingstyle, easingdirection, loopcount, reverseafterfinish, delaytime)
	local goals = goal
	local anim = TweenService:Create(WHAT, info, goals)
	anim:Play()
end
function ReplicateWeld(BasePart,Where)
	for i,v in BasePart:GetChildren() do
		if v:IsA("Motor6D") and not WeldStorage[string.gsub(v.Name, " ", "")] then
			local NewWeldForStuff = Instance.new("Weld", Where)
			NewWeldForStuff.Name = string.gsub(v.Name," ","")
			NewWeldForStuff.Part0 = v.Part0
			NewWeldForStuff.Part1 = v.Part1
			if string.find(NewWeldForStuff.Name,"Root",1,false) then
				NewWeldForStuff.C1 = CFrameAngles(0,0,0) * CFrame.new(0,0,0)
			else
				NewWeldForStuff.C1 = v.C1
			end
			
			NewWeldForStuff.C0 = v.C0
			NewWeldForStuff.Enabled = v.Enabled
			-- TODO: Register These Welds Into The Table
			--Also
			ApplyAttribute(NewWeldForStuff)
			-- Register the newly created weld in the WeldStorage table
			WeldStorage[string.gsub(v.Name, " ", "")] = NewWeldForStuff
		end
	end
end
local groupName = _G.AfterImageCollisionGroupName or GenerateKeycode()
function Init(What, Where) -- When And Why?
	if Knife:IsA("Tool") then
		if What == "Weld" then
			for i,thing in Where:GetChildren() do
				if thing:IsA("Weld") then
					Destruct(thing)      -- Remove
				end
			end
			table.clear(WeldStorage)	
			local Torso = Character:FindFirstChild("Torso")
			local Hrp = Character:FindFirstChild("HumanoidRootPart")
			if not Torso then
				for i, v in Character:GetChildren() do
					if v:IsA("MeshPart") then
						ReplicateWeld(v,Where)
					end
				end
			end
			if Hrp then
				ReplicateWeld(Hrp,Where)
			end
			if Torso then
				ReplicateWeld(Torso,Where)
			end
			for i, v in Character:GetChildren() do
				if v:IsA("Part") then
					ReplicateWeld(v,Where)
				end
			end
		elseif What == "FlagstandEffect" then
			local effect = Instance.new("Part", Knife)
			effect.Size = Vector3.new(1.5,1.5,1.5)
			effect.Anchored = true
			effect.CanCollide = false
			effect.BrickColor = BrickColor.White()
			effect.CastShadow = false
			effect.Shape = Enum.PartType.Ball
			effect.CFrame = Where
			effect.Material = Enum.Material.ForceField
			ApplyAttribute(effect)
			coroutine.wrap(function()
				local xrandom = math.random(-10,10)
				local yrandom = math.random(-10,10)
				local zrandom = math.random(-10,10)
				for i = 1,10 do
					effect.CFrame = effect.CFrame * CFrame.fromEulerAnglesYXZ(xrandom/30, yrandom/30, zrandom/30)
					effect.Transparency = effect.Transparency + 0.1
					effect.Size = effect.Size + Vector3.new(0.1,0.1,0.1)
					RunService.Stepped:Wait()
				end
				Destruct(effect)
			end)()
		elseif What == "BrokenStuds" then
			local Broke = Instance.new("Highlight", GetHandle())
			Broke.OutlineTransparency = 1
			EasyTween(Broke,"FillTransparency",1,0.5,"Sine","In"):Play()
			Broke.Adornee = GetHandle()
			ApplyAttribute(Broke)
			task.wait(0.5)
			Destruct(Broke)
		elseif What == "Sound" then							-- Sound Effects
			for i,Things in pairs(Knife:GetDescendants()) do
				if Things:IsA("Sound")
				then
					Destruct(Things)
				end				
			end
			for i, v in ipairs(NormalSoundTable) do
				local sound = Instance.new("Sound")
				local Where = GetHandle()
				sound.Parent = Where
				sound.SoundId = v.SoundId
				sound.Name = v.Name
				ApplyAttribute(sound)
			end
		end
	elseif Knife:IsA("Model") then
		if What == "Miss" then
			if PerformanceWise then
				return -- no
			end
			if not LowQualityAfterImage  then
				if not PhysicsService:IsCollisionGroupRegistered(groupName) and _G.AfterImageCollisionGroupName == nil then
					DebugText("Creating >>" .. groupName .. "<< Collision Group")
					PhysicsService:RegisterCollisionGroup(groupName)
					for _, group in ipairs(game:GetService("PhysicsService"):GetRegisteredCollisionGroups()) do
						game:GetService("PhysicsService"):CollisionGroupSetCollidable(groupName, group.name, false)
					end
					_G.AfterImageCollisionGroupName = groupName
				end

				Character.Archivable = true
				local ShadowChar = Character:Clone()
				
				Debris:AddItem(ShadowChar,5)
				--	Character.Name = Character.Name .. "_" .. Character.Name .. "_Give_Me_Your_Answer_To"
				if ShadowChar then
					ShadowChar.Name = GenerateKeycode().."(High Quality Version)"
					if ShadowChar:FindFirstChildOfClass("Tool") then
						Destruct(ShadowChar:FindFirstChildOfClass("Tool"))
					end
					--	Debris:AddItem(ShadowChar, 5) -- 5 seconds delay before cleaning up
					ShadowChar.Parent = workspace
					script.Destroying:Connect(function()
						Destruct(ShadowChar)
					end)
					if ShadowChar ~= nil then
						clearAttributes(ShadowChar)
						ApplyAttribute(ShadowChar)
					end
					for i, v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("Tool") then
							Destruct(v)
						end
						if( v:IsA("Part") or v:IsA("MeshPart") )and v.Parent and not v.Parent:IsA("Tool") then
							local forallpart = AccurateMathRandom(1, 3)
							local Woosh = v
							if Woosh.Parent:IsA("Tool") then
								Debris:AddItem(Woosh.Parent, 5)
								Woosh.Parent = ShadowChar
							end
							EasyTween(Woosh,"Transparency",1,AccurateMathRandom(0.5,1),"Sine","In"):Play()
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							Woosh.CollisionGroup = groupName
							-- Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								for i = 1, 20 do
									Woosh.CFrame = Woosh.CFrame + Vector3.new(0, forallpart / 10, 0)
									Woosh.Transparency = Woosh.Transparency + 0.05
									-- Woosh.Size = Woosh.Size + Vector3.new(forallpart/10,forallpart/10,forallpart/10)
									RunService.Stepped:Wait()
									Debris:AddItem(ShadowChar,5)
								end
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("Part") then
									Destruct(ShadowChar)
								end
								task.wait(5)
								if not ShadowChar:FindFirstChildOfClass("Part") then
									Destruct(ShadowChar)
								end
								Destruct(ShadowChar)
							end)()
						elseif not v:IsA("SpecialMesh") and not v:IsA("Part") and not v:IsA("MeshPart") and not v:IsA("Shirt") and not v:IsA("Pants") and not v:IsA("Humanoid") and not v:IsA("Accessory") then
							Destruct(v)
						else
							v.Name = GenerateKeycode()
						end
					end

					-- Add the ShadowChar to Debris

				end
			else
				Character.Archivable = true
				local ShadowChar = Character:Clone()
				if ShadowChar then
					Debris:AddItem(ShadowChar,5)
					ShadowChar.Parent = workspace
					ShadowChar.Name = GenerateKeycode().."(Low Quality Version)"
					script.Destroying:Connect(function()
						Destruct(ShadowChar)
					end)
					if ShadowChar ~= nil then
						clearAttributes(ShadowChar)
						ApplyAttribute(ShadowChar)
					end
					for i,v in pairs(ShadowChar:GetDescendants()) do
						if v:IsA("Part") or v:IsA("MeshPart") then
							local forallpart = AccurateMathRandom(1,3)
							local Woosh = v
							Woosh.Anchored = true
							Woosh.CanCollide = false
							Woosh.CastShadow = false
							--Woosh.Material = Enum.Material.ForceField
							ApplyAttribute(Woosh)
							coroutine.wrap(function()
								for i = 1,20 do
									Woosh.CFrame = Woosh.CFrame + Vector3.new(0,forallpart/10,0)
									Woosh.Transparency = Woosh.Transparency + 0.05
									-- Woosh.Size = Woosh.Size + Vector3.new(forallpart/10,forallpart/10,forallpart/10)
									RunService.Stepped:Wait()
									Debris:AddItem(ShadowChar,5)
								end
								Destruct(Woosh)
								if not ShadowChar:FindFirstChildOfClass("Part") then
									Destruct(ShadowChar)
								end
							end)()
						elseif not v:IsA("SpecialMesh") and not v:IsA("Part") and not v:IsA("MeshPart") then
							Destruct(v)
						else
							Destruct(v)
						end
					end
				end
			end
			
		end
	end

	
end
function DisableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = false
	end
end
function EnableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = true
	end
end
function GetHandle()
	if Knife:IsA("Tool") then
		if not Knife:FindFirstChild("Handle") then -- DID U DISTRUCT THE INDESTRUCTABLE!!???
			Knife.Name = GenerateKeycode().."_Tool"
			script.Name = GenerateKeycode().."_Script"
			if AccurateMathRandom(1,2) < 0.2 then
				Knife.Name = Knife.Name.."?"
			end
			if AccurateMathRandom(1,2) < 0.3 then
				script.Name = script.Name.."?"
			end
			Knife.ToolTip = GenerateKeycode().."?"
			Knife.TextureId = "rbxassetid://5648412667"
			Doeshavepremadehandle = false
			local newhandle = Instance.new("Part",Knife)
			newhandle.Name = "Handle"
			newhandle.Size = Vector3.new(0.265, AccurateMathRandom(2,4), 1.035)
			newhandle.CanCollide = true
			newhandle.CanTouch = true
			newhandle.EnableFluidForces = false
			local newmesh = Instance.new("SpecialMesh",newhandle)
			newmesh.MeshType = Enum.MeshType.FileMesh
			newmesh.Name = GenerateKeycode().."_RegeneratedMesh"
			newmesh.MeshId = "http://www.roblox.com/asset/?id=121944778"
			newmesh.TextureId = "http://www.roblox.com/asset/?id=172752354"
			newmesh.Scale = Vector3.new(0.885, AccurateMathRandom(8,10)/10, 0.885)
			if Trail then
				local newAtt1 = Instance.new("Attachment",newhandle)
				newAtt1.Name = GenerateKeycode().."_FirstAtt"
				newAtt1.CFrame = CFrame.new(0, -0.162, 0.111)
				local newAtt2 = Instance.new("Attachment",newhandle)
				newAtt2.Name = GenerateKeycode().."_SecondAtt"
				newAtt2.CFrame = CFrame.new(0, 1, 0.111)
				local TheTrail = Instance.new("Trail",newhandle)
				TheTrail.Attachment0 = newAtt1
				TheTrail.Attachment1 = newAtt2
				TheTrail.Name = GenerateKeycode()
				TheTrail.Transparency = transparencySequence
				TheTrail.LightEmission = 1
				TheTrail.Lifetime = 0.15
			end
			--<HEI STOP DELETIGN HANDL OKY?>-
			warn([[I Restored Da Handle
			--]]..game.Players:GetNameFromUserIdAsync(1233413367).."--")
			return newhandle
		else
			return Knife:FindFirstChild("Handle")
		end
	elseif Knife:IsA("Model") and GetHumanoid(Knife) then
		if Knife:FindFirstChild("HumanoidRootPart") then
			return Knife:FindFirstChild("HumanoidRootPart")
		elseif Knife:FindFirstChild("Head") and not Knife:FindFirstChild("HumanoidRootPart") then
			return Knife:FindFirstChild("Head")
		end
	end
end
function EnTrail()
	if GetHandle():FindFirstChildOfClass("Trail") and Trail then
		GetHandle():FindFirstChildOfClass("Trail").Enabled = true
	end
end
function UnTrail()
	if GetHandle():FindFirstChildOfClass("Trail") and Trail then
		GetHandle():FindFirstChildOfClass("Trail").Enabled = false
	end
end
function PlaySound(SoundName)
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-PitchOffset,100+PitchOffset)/100
		hmm:Play()
	end
	if GetHandle() and GetHandle():FindFirstChild(SoundName) and GetHandle():FindFirstChild(SoundName):IsA("Sound") then
		Mainplayfunction(GetHandle():FindFirstChild(SoundName))
	elseif GetHandle() and not GetHandle():FindFirstChild(SoundName) then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if EncryptedSoundtable[Encryption(SoundName,true)] then
			local sound = Instance.new("Sound")
			local Where = GetHandle()
			sound.Parent = Where
			sound.SoundId = EncryptedSoundtable[Encryption(SoundName,true)]
			sound.Name = SoundName
			sound:Play()
			ApplyAttribute(sound)
		else
			DebugWarn("Sound >"..SoundName.." or "..Encryption(SoundName,true).."< Not Found In Database")
		end
	end
end
function WeldKnife(Object,Maybe)
	if Maybe == "Ragdoll Knife" then
		if PerformanceWise then
			return -- no
		end
		local KnifeAttached = GetHandle():Clone()
		for i,v in pairs(KnifeAttached:GetDescendants())  do
			if not v:IsA("SpecialMesh") then
				Destruct(v)
			else
				v.Name = "ClonedKnifeMesh"
			end
		end
		KnifeAttached.Name = "Ragdoll Knife"
		KnifeAttached.CanCollide = false
		KnifeAttached.CanTouch = false
		KnifeAttached.CanQuery = false
		KnifeAttached.Massless = true
		KnifeAttached.EnableFluidForces = false
		KnifeAttached.Parent = workspace
		KnifeAttached.Transparency = 0
		if DropOpponentstoolOnRagdoll then
			local weldknife = Instance.new("Weld", KnifeAttached)
			weldknife.C0 = Object.CFrame:toObjectSpace(KnifeAttached.CFrame)
			weldknife.Part0 = Object
			weldknife.Name = "Attachment"
			weldknife.Part1 = KnifeAttached
			weldknife.C1 = CFrame.lookAt(-KnifeAttached.CFrame.UpVector, Object.CFrame.Position) * CFrame.new(0,0,0)
		end
	elseif Maybe:IsA("Part") then
		for i,v in pairs(Maybe:GetDescendants())  do
			if not v:IsA("SpecialMesh") then
				Destruct(v)
			else
				v.Name = "ClonedKnifeMesh"
			end
		end
		local weldthething = Instance.new("Weld", Maybe)
		weldthething.C0 = Object.CFrame:toObjectSpace(Maybe.CFrame)
		weldthething.C1 = CFrame.lookAt(-Maybe.CFrame.UpVector, Object.CFrame.Position) * CFrame.new(0,0,0)
		weldthething.Part0 = Object
		weldthething.Name = "Attacher"
		weldthething.Part1 = Maybe
		Maybe.CanCollide = false
		Maybe.CanTouch = false
		Maybe.CanQuery = false
		Maybe.Massless = true
	end
end
-- Function to find the first weld with a partial name match in a part's descendants
local function findWeldWithPartialName(part, partialName)
	for _, descendant in ipairs(part:GetDescendants()) do
		if descendant:IsA("Weld") and string.find(descendant.Name, partialName, 1, true) then
			return descendant
		end
	end
	return nil
end

-- Function to play animation frames
function playAnimation(animationName, TimeBetweenFrames,inverse: boolean?)
	if not inverse then
		inverse = false
	end
	local Tick = 0
	Tick = tick()
	LastestAM = Tick
	TimeBetweenFrames= TimeBetweenFrames/2
	if CurrentAnim ~= animationName then
		local frames = AnimationFrames[animationName]

		if not frames then
			DebugWarn("Animation not found: " .. animationName)
			return
		end

		local frameNames = {}  -- Collect frame names in order
		for frameName, _ in pairs(frames) do
			table.insert(frameNames, frameName)
		end
		table.sort(frameNames)  -- Sort frame names

		for _, frameName in ipairs(frameNames) do
			local frameData = frames[frameName]
			if LastestAM ~= Tick or Tick < LastestEq then
				break
			end
			for weldName, weldCFrame in pairs(frameData) do
				if LastestAM ~= Tick or Tick < LastestEq then
					break
				end
				local weld = (weldName == 'RootJoint' and (findWeldWithPartialName(Knife, 'Root') or findWeldWithPartialName(Knife, 'RootJoint'))) or findWeldWithPartialName(Knife, weldName) or WeldStorage[weldName]
				CurrentAnim = animationName

				if weld then
					EnableWeld(weld.Name)
					local cframe, tweenTime = (typeof(weldCFrame) == "table" and unpack(weldCFrame)) or weldCFrame, TimeBetweenFrames - TimeBetweenFrames / 20
					if inverse then
						cframe = cframe:Inverse()
					end
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(weld, info, { C0 = cframe })

					if weld.Name ~= "RootJoint" and weld.Name ~= "Root" and not string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					elseif weld.Name ~= "RootJoint" and weld.Name ~= "Root" and string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					else
						if weld.C1 == CFrameAngles(-90, -180, 0) then
							weld.C1 = CFrame.new(0, 0, 0) * CFrameAngles(0, 0, 0)
						end
					end

					if weld.Name == "RightShoulder" then
						weld.C1 = CFrameAngles(0, 180, 0)
					end

					if weld.Name == "LeftShoulder" then
						weld.C1 = CFrameAngles(0 --[[- 15]], -90 -30 , 0--[[-15]])
					end

					tween:Play()
				elseif weldName == "GripWeld" then
					local cframe, tweenTime = (typeof(weldCFrame) == "table" and unpack(weldCFrame)) or weldCFrame , TimeBetweenFrames - TimeBetweenFrames / 20
					if inverse then
						cframe = cframe:Inverse()
					end
					local inst = (Character:FindFirstChild("Right Arm") or Character:FindFirstChild("RightHand")):WaitForChild("RightGrip",0.5) or Knife
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
					if inst then
						local tween = TweenService:Create(inst , info, (inst:IsA("Tool") and {Grip = cframe:Inverse()}) or { C1 = cframe:Inverse() })
						if inst:IsA("JointInstance") then
							inst.C0  = ((Character and Character:FindFirstChild("UpperTorso") and CFrame.new(0, 1, 0)) or CFrame.new(0, 0, 0)) * CFrameAngles(0, -180, 0) * CFrameAngles(0,0,0)
						end
						tween:Play()
					end
				elseif weldName == "Root" then
					EnableWeld(weldName)
					local cframe, tweenTime = unpack(weldCFrame)
					if inverse then
						cframe = cframe:Inverse()
					end
					weld = findWeldWithPartialName(Knife, weldName)
					if weld and not Knife:FindFirstChild("RootJoint") then
						local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
						local tween = TweenService:Create(weld, info, { C0 = cframe })
						tween:Play()
					else
						if weld ~= nil then
							local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
							local tween = TweenService:Create(weld, info, { C0 = cframe })
							tween:Play()
						else
							DebugWarn("RootJoint Found or No Root Weld")
						end
					end
				else
					DebugWarn("Weld >" .. weldName .. "< not found")
				end
			end
			task.wait(TimeBetweenFrames)
		end
	end
end

--//Extra Function//--

local function onDescendantAdded(descendant)
	-- Set collision group for any part descendant
	if descendant:IsA("BasePart") then
		descendant.CollisionGroup = "Characters"
	end
end
function CurseArea(RealArea)		-- Curse Greatly Increase Damage Dealt With A Single Hit, Stacking it up To 100 Will Cause The Cursed To Ragdoll And The Stack To Reset.	
	if not CanCurrentlyCurse or Knife.Parent ~= Character or not Knife:IsDescendantOf(Character) or not Character:IsAncestorOf(Knife) then
		DebugWarn("Warning: CanCurrentlyCurse is false While trying to CurseArea")
		return
	end
	if (AccurateMathRandom(1,2) > 1.80 or (Glitch and AccurateMathRandom(1,2) > 1.6)) and (Curseable or (PlayerService:GetPlayerFromCharacter(Character) and PlayerService:GetPlayerFromCharacter(Character).Name == "Solivion")) then	-- Almost impossible lmao
		DebugText("Casted CurseArea")

	else
		return
	end
	if Curseable and CanCurrentlyCurse then
		--Curseable = false
		PlaySound("Nokia 3310")
		CanCurrentlyCurse = false
	else
		return
	end
	local LauchCode = replaceInvalidCharacters(GenerateKeycode()) 
	if Glitch == false then
		LauchCode = "_SolivionDefault"
	end
	local DetectedModel = {}
	DebugWarn("Current_CurseArea_Lauch_Code:"..LauchCode)
	local Real = RealArea.CFrame					
	local CurseExplosion = Instance.new("Part",workspace)
	CurseExplosion.Shape = Enum.PartType.Ball
	CurseExplosion.Anchored = true
	CurseExplosion.Name = "CurseArea_"..LauchCode
	CurseExplosion.Material = Enum.Material.ForceField
	CurseExplosion.CFrame = Real
	CurseExplosion.Size = Vector3.new(1,1,1)
	CurseExplosion.Color = Color3.new(math.random(1,255), math.random(1,255), math.random(1,255))
	CurseExplosion.CastShadow = false
	CurseExplosion.Transparency = 0
	ApplyAttribute(CurseExplosion)
	table.clear(OnlyCheckOnce)			-- A One time Check On Every Part, No Re-Check.
	local function AttachCurse(PlayerPart)
		if not table.find(OnlyCheckOnce, PlayerPart) and not PlayerPart:GetAttribute("Scanned"..LauchCode) and not PlayerPart:IsDescendantOf(Character) and not PlayerPart:GetAttribute("Origin")  then
			table.insert(OnlyCheckOnce,PlayerPart)
			DebugText(LauchCode.." Scanned "..PlayerPart.Name)
			PlayerPart:SetAttribute("Scanned"..LauchCode, true)
			local PlayerCharacterModel = PlayerPart.Parent
			if PlayerCharacterModel == nil then
				return
			end
			if PlayerCharacterModel and PlayerCharacterModel:IsA("Accessory") then
				PlayerCharacterModel = PlayerCharacterModel.Parent
				task.wait(0.1)
			elseif PlayerCharacterModel and PlayerCharacterModel:IsA("Tool") then
				PlayerCharacterModel = PlayerCharacterModel.Parent
				task.wait(0.1)
			end
			if not table.find(DetectedModel,PlayerCharacterModel) then
				table.insert(DetectedModel, PlayerCharacterModel)
			else
				return
			end
			--if PlayerCharacterModel ~= workspace and PlayerCharacterModel ~= nil and PlayerCharacterModel.Parent ~= workspace then
			--	repeat 
			--		if PlayerCharacterModel.Parent ~= nil and PlayerCharacterModel.Parent ~= workspace then
			--			PlayerCharacterModel = PlayerCharacterModel.Parent
			--			task.wait(0.05)
			--		end
					
			--	until PlayerCharacterModel:FindFirstChildOfClass("Humanoid") or PlayerCharacterModel == workspace or PlayerCharacterModel == nil
			--end --This will Exhaust The System, Quite A Bit
			if GetHumanoid(PlayerCharacterModel) and PlayerCharacterModel ~= Character and GetHumanoid(PlayerCharacterModel).Health > 0 and not PlayerCharacterModel:GetAttribute("Origin") then
				if ((not PlayerCharacterModel:GetAttribute("Cursed")) or Glitch) then
					DebugText(LauchCode.." Detected "..PlayerCharacterModel.Name)
					PlaySound("Deep_Impact")
					local SavedData1, SavedData2 = false ,0
					if not PlayerCharacterModel:GetAttribute("Cursed") or not PlayerCharacterModel:GetAttribute("Weakness") then
						PlayerCharacterModel:SetAttribute("Cursed", true)
						PlayerCharacterModel:SetAttribute("Weakness", 0)
						SavedData1, SavedData2 = false ,0
					else
						SavedData1, SavedData2 = PlayerCharacterModel:GetAttribute("Cursed") , PlayerCharacterModel:GetAttribute("Weakness")
					end
					GetHumanoid(PlayerCharacterModel):ChangeState(Enum.HumanoidStateType.Ragdoll)
					local Highlight = Instance.new("Highlight")
					Highlight.Name = "Cursed Highlight"
					Highlight.Parent = PlayerCharacterModel
					Highlight.Adornee = PlayerCharacterModel
					Highlight.FillColor = CurseExplosion.Color
					Highlight.DepthMode = Enum.HighlightDepthMode.Occluded
					Highlight.FillTransparency = 0
					Highlight.OutlineTransparency = 1
					EasyTween(Highlight,"FillTransparency",1,math.random(10,20)/10,"Exponential","In"):Play()
					local Root = PlayerCharacterModel:FindFirstChild("HumanoidRootPart")
					if Root and Mislay == false and (AccurateMathRandom(1,2) > 1.95 or (Glitch and AccurateMathRandom(1,2) > 1.75)) and (PlayerCharacterModel.Name ~= "Solivion" or (PlayerService:GetPlayerFromCharacter(PlayerCharacterModel) and PlayerService:GetPlayerFromCharacter(PlayerCharacterModel).UserId ~= 1233413367) ) then
						local function addQuestionMarkIfNeeded(inputString:string)
							if string.sub(inputString, -1) ~= "?" then
								inputString = inputString .. "?"
							end
							return inputString
						end
						local function removeQuestionMarkIfNeeded(inputString:string)
							if string.sub(inputString, -1) == "?" then
								inputString = string.sub(inputString, 1, -2) -- Remove the last character
							end
							return inputString
						end
						local function isStringNotEmpty(inputString:string)
							-- Check if the string is nil or empty (only contains spaces)
							if inputString == nil or inputString:match("^%s*$") then
								return false
							else
								return true
							end
						end
						if PlayerCharacterModel == nil or (PlayerCharacterModel:GetAttribute("IsRagdoll") == true or (GetHumanoid(PlayerCharacterModel) and GetHumanoid(PlayerCharacterModel):GetState() == Enum.HumanoidStateType.Physics)) then
							return 
						end
						DebugText(LauchCode.." Located "..PlayerCharacterModel.Name)
						if CurseExplosion then
							Destruct(CurseExplosion)
						end
						if not TableFullOFAttributesCuzWhyNot[PlayerCharacterModel] then
							SetupAttributeTable(PlayerCharacterModel)
							clearAttributes(PlayerCharacterModel)
						end
						if not TableFullOFAttributesCuzWhyNot[Character] then
							SetupAttributeTable(Character)
							clearAttributes(Character)
						end
						Mislay = true
						Character.Archivable = true
						local Faker = Character:Clone()
						Faker.Parent = workspace
						if Faker and GetHumanoid(Faker) then
							if isStringNotEmpty(GetHumanoid(Faker).DisplayName) then
								Faker.Name = addQuestionMarkIfNeeded(GetHumanoid(Faker).DisplayName)
							else
								GetHumanoid(Faker).DisplayName = removeQuestionMarkIfNeeded(Faker.Name)
							end
						end
						Faker.Name =  GenerateKeycode()
						Root.CFrame = CFrame.new(Root.Position, Character:FindFirstChild("HumanoidRootPart").Position)
						EasyTween(Character:FindFirstChild("HumanoidRootPart"),"CFrame",Root.CFrame,1.1,"Sine","In"):Play()
						PlayerCharacterModel.Name = addQuestionMarkIfNeeded(PlayerCharacterModel.Name)
						if isStringNotEmpty(GetHumanoid(PlayerCharacterModel).DisplayName) then
							PlayerCharacterModel.Name = addQuestionMarkIfNeeded(GetHumanoid(PlayerCharacterModel).DisplayName)
						else
							PlayerCharacterModel.Name = addQuestionMarkIfNeeded(PlayerCharacterModel.Name)
							GetHumanoid(PlayerCharacterModel).DisplayName = removeQuestionMarkIfNeeded(PlayerCharacterModel.Name)
						end
						local velocity = Instance.new("BodyVelocity", Root)
						velocity.Name = GenerateKeycode()
						velocity.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
						velocity.Velocity = Root.CFrame.lookVector * -30
						game.Debris:AddItem(velocity, 0.2)
						task.wait(0.2)
						for i,v in pairs(PlayerCharacterModel:GetDescendants())  do
							if v:IsA("Script") or v:IsA("LocalScript") or v:FindFirstChildOfClass("Script") or v:FindFirstChildOfClass("LocalScript") then
								print("While Iterating In PlayerCharactermodel 1st.. Found Script:",v:GetFullName())
								v.Archivable = true
								local Crap = v:Clone()
								if Crap:IsA("Script") or v:IsA("LocalScript") then
									Crap.Disabled = true
								end
								
								Crap:SetAttribute("NotFromUser"..LauchCode,true)
								Crap.Parent = Faker
								Crap.Name = GenerateKeycode()
								Destruct(v)
							end
							if v:GetAttribute("Origin") and v ~= Knife and v ~= GetHandle() then
								Destruct(v)
							end
						end
						for i,v in Faker:GetChildren() do
							if (v:IsA("Script") or v:IsA("LocalScript") or v:FindFirstChildOfClass("Script") or v:FindFirstChildOfClass("LocalScript") ) and not v:GetAttribute("NotFromUser") then
								print("Found From User Script 1st Faker Check: ",v:GetFullName())
								local CloneSoItWork = v:Clone()
								CloneSoItWork.Archivable = true
								CloneSoItWork.Parent = PlayerCharacterModel
								CloneSoItWork.Name = addQuestionMarkIfNeeded(CloneSoItWork.Name) -- Breaks Any Scripts By Non-FindFirstChild User Via Directory Name Changes
								Destruct(v)
							elseif v:GetAttribute("NotFromUser"..LauchCode) then
								print("Found NotFromUser Script 1st Faker Check: ",v:GetFullName())
								v.Archivable = true
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								if v:IsA("Script") or v:IsA("LocalScript") then
									v.Disabled = false
								end
								
							end	
							if v:GetAttribute("Origin") and v ~= Knife and v ~= GetHandle() then
								print("Found Illegial Instance: ",v:GetFullName())
								Destruct(v)
							elseif v:GetAttribute("Origin") and (v == Knife or v == GetHandle()) then
								Debris:AddItem(v,5)
							end
						end
						PlaySound("Curse_Hit")
						task.wait(0.1)
						for i,v in Faker:GetChildren() do
							if v:IsA("Tool") then
								print("Found From User Script: ",v:GetFullName())
								Destruct(v)
							elseif string.find(string.upper(v.Name),"_SCRIPT",1,true) then
								Destruct(v)
							end
							if v:GetAttribute("NotFromUser"..LauchCode) then
								print("Found Not From User Script In Faker 2nd Check: ",v:GetFullName())
								v.Archivable = true
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								if v:IsA("Script") or v:IsA("LocalScript") then
									v.Disabled = false
								end
								
							end	
							if v:GetAttribute("Origin") then
								Destruct(v)
							end
						end
						for i,v in PlayerCharacterModel:GetChildren() do
							if v:GetAttribute("NotFromUser"..LauchCode) then
								print("Found NotFromUser Script In PlayerCharacterModel Aftercheck: ",v:GetFullName())
								v:SetAttribute("NotFromUser"..LauchCode,nil)
								v.Parent = Faker
								if v:IsA("Script") or v:IsA("LocalScript") then
									v.Enabled = true
								end
							end
						end
						-- Assuming WE have the TableFullOFAttributesCuzWhyNot table created as mentioned
						applyAttributes(PlayerCharacterModel,Faker)
						applyAttributes(Character,PlayerCharacterModel)
						GetHumanoid(PlayerCharacterModel):ChangeState(Enum.HumanoidStateType.Swimming)
						if PlayerService:GetPlayerFromCharacter(PlayerCharacterModel) then
							PlayerService:GetPlayerFromCharacter(PlayerCharacterModel).Character = Faker
						end
						if game.Players:GetPlayerFromCharacter(Character) then
							game.Players:GetPlayerFromCharacter(Character).Character = PlayerCharacterModel
						end
					end
					task.wait(2)
					Destruct(Highlight)
				end
				
			end
		end
	end
	local PartinArea = workspace:GetPartsInPart(CurseExplosion)			--Incase A Loser Is At The Starting Point
	for i,v in ipairs(PartinArea)  do
		if (v.Parent and GetHumanoid(v.Parent)) or (v.Parent.Parent and GetHumanoid(v.Parent.Parent)) then
			AttachCurse(v)
		end
		DebugText(v.Name.. " Found While Spawning")
	end
	coroutine.wrap(function()
		local xrandom = math.random(-10,10)
		local yrandom = math.random(-10,10)
		local zrandom = math.random(-10,10)
		for i = 1,50 do
			if CurseExplosion then
				CurseExplosion.CFrame = CurseExplosion.CFrame * CFrame.fromEulerAnglesYXZ(xrandom/30, yrandom/30, zrandom/30)
				CurseExplosion.Transparency = CurseExplosion.Transparency + 1/50
				CurseExplosion.Size = CurseExplosion.Size + Vector3.new(1,1,1)
				CurseExplosion.CanCollide = false
				RunService.Stepped:wait()
			else
				break
			end
		end
		local PartinArea = workspace:GetPartsInPart(CurseExplosion)			--Nope, I'm not computing the hitbox with this one. I Know It's better,  But I Prefer the Performance :>
		for i,v in ipairs(PartinArea)  do
				AttachCurse(v)
			--DebugText(v.Name.. "Found In The Cursed Area")
		end
		if CurseExplosion then
			Destruct(CurseExplosion)
		end
		
	end)()
	CurseExplosion.Touched:Connect(AttachCurse)
	CurseExplosion.TouchEnded:Connect(AttachCurse)
	CurseExplosion.LocalSimulationTouched:Connect(AttachCurse)
end
function Death()
	if not Character then
		return
	end
	if Character and GetHumanoid(Character).Health > 0 then
		DebugText("Character Health Valid! Moving Forward")
	else
		DebugText("Character Health Invalid! Breaking Joints")
		GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Dead)
		for i,v in Character:GetDescendants() do
			if IsThisAPart(v) == true or v:IsA("Part") then
				local forallpart = AccurateMathRandom(1,3)
				local Woosh = v
				Woosh.Anchored = true
				Woosh.CanCollide = false
				Woosh.CastShadow = false
				--Woosh.Material = Enum.Material.ForceField
				ApplyAttribute(Woosh)
				coroutine.wrap(function()
					for i = 1,20 do
						Woosh.Transparency = Woosh.Transparency + 0.05
						Woosh.Size = Woosh.Size + Vector3.new(forallpart/10,forallpart/10,forallpart/10)
						RunService.Stepped:Wait()
						Debris:AddItem(Character,5)
					end
					Destruct(Woosh)
					if not Character:FindFirstChildOfClass("Part") then
						Destruct(Character)
					end
				end)()
			end

		end
	end
end
--<<Events>>--
if not Knife then repeat task.wait(.01) if Knife then break end until Knife end
if Knife:IsA("Model") and GetHumanoid(Knife) and script:GetAttribute("Die") then -- Fier
	if not EnemyBleed then
		script.Enabled = false
		return
	end
	repeat 
		local hum = GetHumanoid(Knife)
		if EnemyBleed and hum then 
			DamageHumanoid(hum,(AccurateMathRandom(0.1,0.2)*(hum.MaxHealth/100)))
		end 
		wait(math.random(10,20)/100) 
	until false
elseif Knife:IsA("Model") and GetHumanoid(Knife) and not script:GetAttribute("Die") then
	if not HaveIFrame then
		script.Enabled = false
		return
	end
	if HaveIFrame == true then
		DebugText("Script Adapting To IFrame System")
		local Character = Knife
		local IFrameActi = false
		local IsIFrameOnCooldown = false
		local SavedHealthNow = 0
		local IsOnALongDown = false
		local OnTheRun = false
		local LastBreath = false
		if not OneShotSaver then
			LastBreath = true	-- Die on Death 💀💀💀
		end
		if not PerformanceWise then
			for i,v in Character:GetDescendants() do
				if  ( not v:IsA("BasePart") and v.Parent == Character) and not v:IsA("Tool") and v ~= script then
					v.Name = GenerateKeycode()
				end
			end
		end

		if Character and GetHumanoid(Character) and GetHumanoid(Character):GetState() ~= Enum.HumanoidStateType.Dead then -- I_Frame
			--if (not GetHumanoid(Character) or (GetHumanoid(Character) and (GetHumanoid(Character).Health <= 0 or GetHumanoid(Character):GetState() == Enum.HumanoidStateType.Dead ) )) and not IFrameActi then
			--	Character:BreakJoints()
			--	Death()
			--	return 
			--end
			function allowdeath()
				if OneShotSaver then
					if LastBreath then
						GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
					end
				else
					GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,true)
				end


			end
			function disallowdeath()
				if OneShotSaver then
					if not LastBreath then
						GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
						if GetHumanoid(Character).Health < GetHumanoid(Character).MaxHealth/10 then
							GetHumanoid(Character).Health = GetHumanoid(Character).MaxHealth/10 -- 10 Percent 
						end
					end
				else
					GetHumanoid(Character):SetStateEnabled(Enum.HumanoidStateType.Dead,false)
				end
			end


			LastestHealth = GetHumanoid(Character).MaxHealth
			GetHumanoid(Character).HealthChanged:Connect(function(HowMuchHealthNow)
				if IFrameActi and LastestHealth > HowMuchHealthNow and not IsOnALongDown  then
					--DebugText("Unattended Damage Healed")

					if Character:FindFirstChildOfClass("ForceField") then
						for i ,v in Character:GetChildren() do
							if v:IsA("ForceField") then
								if v:GetAttribute("Durabillity") then
									v:SetAttribute("Durabillity",v:GetAttribute("Durabillity")-(LastestHealth - GetHumanoid(Character).Health))	
									if v:GetAttribute("Durabillity") <= 0 then
										Destruct(v)
									end
								else
									v:SetAttribute("Durabillity",GetHumanoid(Character).MaxHealth - (LastestHealth - GetHumanoid(Character).Health))
								end
							end
						end

						GetHumanoid(Character).Health = LastestHealth
						Init("Miss",nil)
						DebugText("//SHEILDED//")
						local Activated = Instance.new("Highlight")
						Activated.Parent = Character
						Activated.Adornee = Character
						Activated.Name = "IFrameFlashes"
						--Activated.FillColor = Color3.new(0, 255, 255)
						--ApplyAttribute(Activated)
						Activated.FillTransparency = 0
						Activated.OutlineTransparency = 0
						EasyTween(Activated,"FillTransparency", 1, 0.5,"Sine","In"):Play()
						EasyTween(Activated,"OutlineTransparency", 1, 0.5,"Sine","In"):Play()
						PlaySound("Launching_rocket0wav")
						task.wait(1)
						if Activated then
							Destruct(Activated)
						end

					end

				elseif not IFrameActi and LastestHealth > HowMuchHealthNow and not IsIFrameOnCooldown and not IsOnALongDown then
					--if (GetHumanoid(Character) and (GetHumanoid(Character).Health <= 0 or GetHumanoid(Character):GetState() == Enum.HumanoidStateType.Dead ) ) and not LastBreath then
					--	Death()
					--	return
					--	end
					if GetHumanoid(Character).Health <= 0 and (not IFrameActi or IsOnALongDown) then
						if not LastBreath then
							OnTheRun = true
							disallowdeath()
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Jumping)
							GetHumanoid(Character).Health = GetHumanoid(Character).MaxHealth/50 -- 2 Percent , I'm So Kind
							DebugText(string.upper(Character.Name).." IS ON THE RUN: DEATH PREVENTION WILL END AFTER THIS PERIOD")
						else
							DebugText(string.upper(Character.Name).." WAS HIT WHILE IN LAST BREATH")
							allowdeath()
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Dead)
							wait(1)
							for i,v in Character:GetDescendants() do
								if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("BoolValue") then
									Destruct(v)
								end
							end
							Death()
							return
						end
					elseif GetHumanoid(Character).Health > 0 then
						if not LastBreath then
							allowdeath()
						else
							disallowdeath()
						end
						DebugText(Character.Name.." Has Been Hit")
					end
					SavedHealthNow = HowMuchHealthNow
					IFrameActi = true
					IsIFrameOnCooldown = true
					LastestHealth = SavedHealthNow
					--DebugText("Saved Health At ".. LastestHealth)
					--GetHumanoid(Character).Health = LastestHealth
					PlaySound("Rocket_shot0wav")
					local coward = Instance.new("ForceField")
					coward.Name = "IFrame"
					coward.Visible = false
					coward.Parent = Character
					local Activated = Instance.new("Highlight")
					Activated.Name = "IFrame"
					Activated.FillColor = Color3.new(0, 255, 255)
					Activated.OutlineColor = Color3.new(0, 255, 255)
					Activated.Parent = Character
					Activated.FillTransparency = 0
					coward.Destroying:Connect(function()
						if OnTheRun then
							OnTheRun = false
							LastBreath = true
							DebugText(string.upper(Character.Name) .." IS ON LAST BREATH: Getting Hit Under 0 HP With Last Breath Will Not Be Shielded!")
							allowdeath()
						end
						if coward:GetAttribute("Durabillity") and coward:GetAttribute("Durabillity") <= 0 then
							DebugWarn(Character.Name.."_Shield Broken, IFrame Currently On Cooldown..")
							if Activated then
								Destruct(Activated)
							end
							if LastBreath then
								allowdeath()
							end
							GetHumanoid(Character):ChangeState(Enum.HumanoidStateType.Ragdoll)
							local Root = Character:FindFirstChild("HumanoidRootPart")
							if Root then
								local NewForceBacklol = Instance.new("BodyVelocity")
								NewForceBacklol.Velocity = Root.CFrame.LookVector * -30
								NewForceBacklol.Name = "Break"
								NewForceBacklol.Parent = Root
								Debris:AddItem(NewForceBacklol,0.2)
							end
							IFrameActi = false
							IsIFrameOnCooldown = true
							IsOnALongDown = true
							task.wait(AccurateMathRandom(7,10))
							IsIFrameOnCooldown = false
							IsOnALongDown = false
						end
					end)
					ApplyAttribute(Activated)
					ApplyAttribute(coward)

					EasyTween(Activated,"FillTransparency",0.5,1,"Linear","In"):Play()
					task.wait(0.5)
					task.wait((LastestHealth - SavedHealthNow)*0.1)-- It Doesn't Work :Skull:

					DebugText("//Initializing_SHEILD//")
					task.wait(AccurateMathRandom(3,5))			
					DebugText("//SHIELD ENDED/")-- Stupid Ahh Cooldown System
					EasyTween(Activated,"FillTransparency", 1, 0.25,"Sine","In"):Play()
					EasyTween(Activated,"OutlineTransparency", 1, 0.25,"Sine","In"):Play()
					if coward and Activated and not IsOnALongDown  then
						DebugWarn(string.upper(Character.Name).."_SHIELD NOT BROKEN")
						task.wait(0.25)
						if Activated then
							Destruct(Activated)
						else
							return
						end
						if coward then
							Destruct(coward)
						else
							return
						end
						if not IsOnALongDown then
							IFrameActi = false
							task.wait(AccurateMathRandom(0.1,0.2))	
							IsIFrameOnCooldown = false
						end 
					end

				elseif not IFrameActi and LastestHealth < HowMuchHealthNow then
					LastestHealth = HowMuchHealthNow
					DebugText("New Health Registered")
				end	

				--	Death()
			end)
		end

	else
		DebugText("IFrame Disabled!")
		return
	end
	
elseif Knife:IsA("Tool") then
	-- Nevermind, It seems I can't do a counter system using a seperated code here
	if Character and GetHumanoid(Character) then
		GetHumanoid(Character).HealthChanged:Connect(function(HowMuchHealthNow)
			if CurrentState == "Swinging" or CurrentAnim == "Throwing" and LastestHealth > HowMuchHealthNow then
				DebugText("Clash!")
				SavedHealthNow = HowMuchHealthNow
				CurrentState = "Nil"
				UnTrail()
				if Character:FindFirstChild("HumanoidRootPart") then
					local Bounce = Instance.new("BodyVelocity",Character:FindFirstChild("HumanoidRootPart"))
					Bounce.Force = -Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector
					Bounce.Name = "Ouch"
					ApplyAttribute(Bounce)
					Debris:AddItem(Bounce,1)
				end
				task.wait(LastestHealth - SavedHealthNow)
				playAnimation("Idle")
				CurrentState = "Idle"
				GetHumanoid(Character).Health = LastestHealth
			elseif LastestHealth < HowMuchHealthNow and CurrentState ~= "Swinging" and CurrentAnim ~= "Throwing" then
				--LastestHealth = HowMuchHealthNow
			end
		end)
	end
end
if Knife:IsA("Tool") then
	DebugText("Tool Registered")
else
	DebugText("Tool Not Registered")
	return
end
Knife.Equipped:Connect(function()			-- Gang Gang, Yes Yes Yes, mmm icecream so good, Brr, Gang Gang...
	local tc = 0
	tc = tick()
	LastestEq = tc
	if not Character then						-- Nope, You Cannot Reclaim The knife from Others.
		Character = Knife.Parent
	elseif Character then
		if Knife.Parent ~= Character then
			if not workspace:FindFirstChild(Character.Name) then
				Character = Knife.Parent
			end
			Knife.Parent = workspace
		end
	end
	if	LastestEq ~= tc then return end
	for i,v in HBAP do
		local NA = Instance.new("Attachment")
		NA.Name = i
		NA.CFrame = v
		NA.Visible = false
		NA.Parent = Knife:FindFirstChild("Handle")
		table.insert(HBAttachments,NA)
	end
	Curspd = 18
	CanCurrentlyCurse = false
	if	LastestEq ~= tc then return end
	Init("Sound", Knife)
	Init("Weld", Knife)
	UnTrail() -- Nope, not yet
	PlaySound("Equip")
	if GetHandle() then
		if	LastestEq ~= tc then return end
		GetHandle().Transparency = 1
		if GetHandle():FindFirstChildOfClass('UnionOperation') then
			GetHandle():FindFirstChildOfClass('UnionOperation').Transparency = 1
		end
	end
	UnTrail()
	coroutine.resume(coroutine.create(
		function()
			if	LastestEq ~= tc then return end
			task.wait(0.2)
			if	LastestEq ~= tc then return end
			if GetHandle() then
				--GetHandle().Transparency = 0
				if GetHandle():FindFirstChildOfClass('UnionOperation') then
					GetHandle():FindFirstChildOfClass('UnionOperation').Transparency = 0
				end
				EnTrail()
			end
		end))
	if	LastestEq ~= tc then return end
	playAnimation("Swing",0.2)
	if	LastestEq ~= tc then return end
	UnTrail()
	if	LastestEq ~= tc then return end
	CurrentState = "Idle"
	playAnimation("Idle",0.2)
	CurrentAnim = "Idle"
	LastestSlash = tick()
	StoredTick = tick()
	if	LastestEq ~= tc then return end
	if GetHumanoid(Character) and not Character:FindFirstChild("UpperTorso") then
		for i,v in Knife:GetChildren() do
			if v.Name ~= "RightShoulder" and v.Name ~= "LeftShoulder" and v.Name ~= "RootJoint" and v.Name ~= "Neck" then
				DisableWeld(v.Name)
			end
		end
	elseif GetHumanoid(Character) and Character:FindFirstChild("UpperTorso") then
		for i,v in Knife:GetChildren() do
			if v.Name ~= "RightShoulder" and v.Name ~= "LeftShoulder" and v.Name ~= "Root" and v.Name ~= "Neck" then
				DisableWeld(v.Name)
			end
		end
	end
	if	LastestEq ~= tc then return end
	if GetHumanoid(Character) then
		LastestHealth = GetHumanoid(Character).Health
	end
	if	LastestEq ~= tc then return end
	if not Character:FindFirstChild(script.Name.. "(SOL_IF_SYS_PRT_01)") and not Character:FindFirstChild(script.Name.. "(SOL_IF_SYS_PRT_01)?") and not Character:FindFirstChild("SOL_IF_SYS_PRT_01") and not Character:FindFirstChild("SOL_IF_SYS_PRT_01?") and HaveIFrame == true then
		local IFrame = script:Clone()
		IFrame.Name = script.Name.. "(SOL_IF_SYS_PRT_01)"
		ApplyAttribute(IFrame)
		IFrame.Parent = Character
		IFrame:ClearAllChildren()
	end
	--DisableWeld("RootJoint")
	--DisableWeld("Neck")
end)
Knife.Unequipped:Connect(function()		-- Gone, You r Done
	LastestEq = tick()
	CanCurrentlyCurse = false
	CanDmg = false
	CurrentAnim = "None"
	CurrentState = "Unequipped"
	reset()
	if GetHandle() then
		if GetHandle():FindFirstChildOfClass('UnionOperation') then
			GetHandle():FindFirstChildOfClass('UnionOperation').Transparency = 1
		end
		GetHandle().Transparency = 1
	end
	for i,A in HBAttachments do
		A:Destroy()
		HBAttachments[A] = nil
	end
	UnTrail()
end)


--// Sorry These Functions Are Not Organized //--



function Prop(hit)
--[[	local character = hit.Parent
	local player = Players:GetPlayerFromCharacter(character)
	if player then
		ApplyChaosEffect(player, Knife.Position)
	end]]
	if not table.find(OnlyCheckOnce,hit) then --Performance
		table.insert(OnlyCheckOnce, hit)
		local char = hit.Parent
		if char ~= nil and char:IsA("Tool") and char:FindFirstChildOfClass("Part") and char ~= Knife and char.Parent ~= Knife and char ~= Character and char.Parent ~= Character and not char:IsDescendantOf(Character) and not char:IsDescendantOf(Knife) then -- Top 10 Myle's joke Mechanic lmao.
			if char:GetAttribute("Durabillity") then
				char:SetAttribute("Durabillity",char:GetAttribute("Durabillity")-1)
				if char:GetAttribute("Durabillity") <= 0 then
					char.Enabled = false
					Destruct(char)
				end
			elseif not char:GetAttribute("Durabillity") then
				char:SetAttribute("Durabillity",math.random(50,100)-1)
			end
			return nil
		elseif char ~= nil and char:IsA("Tool") and not char:FindFirstChildOfClass("Part")and char ~= Knife then
			char.Enabled = false
			task.wait(AccurateMathRandom(1,2))
			return nil
		end
		if char ~= Character and char ~= workspace and char ~= nil and not hit:IsDescendantOf(Character) and not Character:IsAncestorOf(hit) then
			if not char:IsA("Tool") then
				repeat 
				if char.Parent ~= nil and not GetHumanoid(char) then
					char = char.Parent
					RunService.Heartbeat:Wait()
				end
			until char == nil or char == workspace or GetHumanoid(char) or char:IsA("Tool")
			end
			
			if char == workspace or char == nil then
				return nil
			end
			if GetHumanoid(char) and GetHumanoid(char).Health ~= 0 and GetHumanoid(char):GetState() ~= Enum.HumanoidStateType.Dead and char ~= Character and (CurrentState == "Swinging" or CurrentState == "Firing" or (GetHandle():FindFirstChildOfClass("Trail") and GetHandle():FindFirstChildOfClass("Trail").Enabled == true)) and not table.find(Debounce,char) and CanDmg == true then
				table.insert(Debounce,char)
				GetHumanoid(char).BreakJointsOnDeath = false
				--GetHumanoid(char).Name = "Humanoid("..tostring(GetHumanoid(char):GetState()) ..")"
				local Fairness = (GetHumanoid(char).MaxHealth/100)
				if not AllowPercentagedDamage then
					Fairness = 1
				end
				
				if CurrentState == "Firing" or CurrentState == "Charging" or CurrentAnim == "Throwing" then
					local ChargedPower = math.clamp((tick() - StoredTick)*5, LowestChargeRequirement, MaxCharge)
					DebugText("With The Charge Power Of ".. ChargedPower.. "... You hit "..char.Name)
					if ChargedPower < 8 then
						PlaySound("Blade Stab")
					elseif ChargedPower == 8 then
						PlaySound("Sword Stab")
					elseif ChargedPower > 8 then
						PlaySound("snap.wav")
					end
					CurrentDamage = DefaultDamage + (DamagePerCharge * ChargedPower) -- You Get The Point, The Charging part.
					if ChargedPower > 8 then
						Init("FlagstandEffect", GetHandle().CFrame)
						if GetHandle():FindFirstChildOfClass('UnionOperation') then
							GetHandle():FindFirstChildOfClass('UnionOperation').Transparency = 1
						end
						GetHandle().Transparency = 1
						CanDmg = false -- Ur Knife Broke
						UnTrail()
					end
					if (not char:FindFirstChildOfClass("ForceField") and not ArmorPiercing) or ArmorPiercing then
						if char:GetAttribute("Weakness") and char:GetAttribute("Weakness") >= 100 then
							Mockery = true
							char:SetAttribute("Weakness", 0)
							WeldKnife(hit,"Ragdoll Knife")
							--Debris:AddItem(KnifeAttached,ChargedPower + 5)
							--Debris:AddItem(weldknife, ChargedPower)
						elseif char:GetAttribute("Weakness") and char:GetAttribute("Weakness")  < 100 then
							if char:GetAttribute("Weakness") + ChargedPower * 6 >= 100 then
								Mockery = true
								char:SetAttribute("Weakness", 0)
								WeldKnife(hit,"Ragdoll Knife")
							else
								char:SetAttribute("Weakness", char:GetAttribute("Weakness") + ChargedPower * 6)
							end
						end
					end
					
				else
					CurrentDamage = DefaultDamage + math.clamp((tick() - LastestSlash)*5, 1, 5) -- My Style, I dislike velocity quite a bit.
					PlaySound("Stab")
					
				end
				local PercentagedDamage = CurrentDamage*Fairness
				if char:GetAttribute("Weakness") then
					if not Mockery then
						CurrentDamage = CurrentDamage + (char:GetAttribute("Weakness")/20) -- I found out not dividing it is overpowered, So I Made It 20.
						TotalCursedDamage = char:GetAttribute("Weakness")/20
					else
						CurrentDamage = CurrentDamage + 120/15
						TotalCursedDamage = 120/15
					end
				else
					TotalCursedDamage = 0
				end
				for i,v in char:GetChildren() do
					if v:IsA("ForceField") and not ArmorPiercing then -- Bro thought He'd Unbreakabel
						if not v:GetAttribute("Durabillity") then
							v:SetAttribute("Durabillity",GetHumanoid(char).MaxHealth - PercentagedDamage*2.5)
							PercentagedDamage = 0
							CurrentDamage = 0
							return
						elseif v:GetAttribute("Durabillity") then
							v:SetAttribute("Durabillity",tonumber(v:GetAttribute("Durabillity")) - PercentagedDamage*2)
							PercentagedDamage = 0
							CurrentDamage = 0
							if tonumber(v:GetAttribute("Durabillity")) <= 0 or v:GetAttribute("Durabillity") ~= tonumber(v:GetAttribute("Durabillity")) then
								v.Name = "[Broken]"
								v.Parent = Character
								PlaySound("glassbreak.wav")
								Destruct(v)
								v:Remove()
								PercentagedDamage = 0
								CurrentDamage = 0
							else
								return
								-- No, Ur Not Doing Anything Until ForceField breaks, And Only (Health = Health - Amount) can actually break this, Due To ForceField Being The Sibling Of The Humanoid
							end
						end
					end
					if v:IsA("ForceField") and ArmorPiercing then
						v:SetAttribute("Durabillity",0)
						Destruct(v)
					end
				end
				--DebugText("Damaged "..char.Name.. " By "..PercentagedDamage.." While ".. CurrentState)
				
				local GsubbedCharName = replaceInvalidCharacters(Character.Name, false)
				if not char:GetAttribute(GsubbedCharName .."_Dmg_Dealt") then
					char:SetAttribute(GsubbedCharName.."_Dmg_Dealt",tonumber(PercentagedDamage) or 0)
				else
					char:SetAttribute(GsubbedCharName.."_Dmg_Dealt", tonumber(char:GetAttribute(GsubbedCharName.."_Dmg_Dealt"))  + PercentagedDamage)
				end
				--It's Not Working
				DebugText("CurrentDamage Is ->"..CurrentDamage-TotalCursedDamage)
				IHoupeUDyeInnAhFier(char, AccurateMathRandom(5,7))
				DamageHumanoid(GetHumanoid(char),math.clamp(PercentagedDamage,((DefaultDamage+TotalCursedDamage)*Fairness),(DefaultDamage+(MaxCharge*DamagePerCharge)+TotalCursedDamage)*Fairness))
				--Ragdoll(char,CurrentDamage/AccurateMathRandom(1,3)/10)
				if TotalCursedDamage ~= 0 and TotalCursedDamage ~= nil then
					DebugText("Also Comes With A Cherry On Top By Weakness Bonus ->"..TotalCursedDamage)
					DebugText("The Whole Damage is ->"..math.clamp(CurrentDamage,((DefaultDamage+TotalCursedDamage)*1),(DefaultDamage+(MaxCharge*DamagePerCharge)+TotalCursedDamage)*1))
				end
				if Mockery then
					Mockery = false
					if GetHumanoid(char):GetState() ~= Enum.HumanoidStateType.Physics and not char:GetAttribute("IsRagdoll") then
						Ragdoll(char,(CurrentDamage - DefaultDamage)/2) -- Downed By How Much You Charged
						coroutine.wrap(function()
							for i = 1,math.random(80,140) do
								GetHumanoid(char).WalkToPoint = Vector3.new(char:FindFirstChildOfClass("Part").Position.x + AccurateMathRandom(-15,15),0,char:FindFirstChildOfClass("Part").Position.z + AccurateMathRandom(-15,15))
								RunService.Stepped:wait()
							end
						end)
					end
					if char:FindFirstChild("HumanoidRootPart") then
						local Vec = GetHandle().CFrame.LookVector * 5
						----DebugText("Applied Angular Impulse to "..char.Name.." with "..tostring(Vec))
						--Instance.new("Part").CFrame:VectorToObjectSpace(Instance.new("Part").Position)
						--Vec was tostring(Character:FindFirstChild("HumnaoidRootPart").CFrame:VectorToObjectSpace(char:FindFirstChild("HumanoidRootPart").Position))
						--char:FindFirstChild("HumanoidRootPart"):ApplyAngularImpulse(Character:FindFirstChild("HumnaoidRootPart").CFrame:VectorToObjectSpace(char:FindFirstChild("HumanoidRootPart").Position))
						char:FindFirstChild("HumanoidRootPart"):ApplyAngularImpulse(GetHandle().CFrame.LookVector)
					end
				else
					if AccurateMathRandom(1,2)+ CurrentDamage/10 > (DefaultDamage*1.7) * (GetHumanoid(char).Health/ GetHumanoid(char).MaxHealth) and not (char:GetAttribute("Cursed") or char:GetAttribute("Weakness")) then
						Ragdoll(char,2+ CurrentDamage/10 - (DefaultDamage*1.5) * (GetHumanoid(char).Health/ GetHumanoid(char).MaxHealth))
					end
				end
				ApplyChaosEffect(char)
				GetHumanoid(char).BreakJointsOnDeath = false
				GetHumanoid(char).StateChanged:Connect(function(_,Newe)
					if Newe == Enum.HumanoidStateType.Dead or GetHumanoid(char):GetState() == Enum.HumanoidStateType.Dead then
						ApplyChaosEffect(char)
					end
				end)
			end
			
		end
	end
end
local function Hitbox(Duration)
	if HBSC then
		HBSC:Disconnect()
	end
	local Params = RaycastParams.new()
	Params.IgnoreWater = true
	Params.FilterType = Enum.RaycastFilterType.Exclude
	Params.FilterDescendantsInstances = {Character, Touched, OnlyCheckOnce}
	local StartingTick = tick()
	local PositionThingy = {}
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.desynchronize()
	end
	for i,Attachment in pairs(HBAttachments) do
		table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
	end
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
	HBSC = game:GetService("RunService").Heartbeat:Connect(function(DT)
		if script:FindFirstAncestorWhichIsA("Actor") then
			task.desynchronize()
		end
		if LastestEq > StartingTick or (tick() - StartingTick >= Duration) or not Knife:FindFirstAncestorWhichIsA("Model") or not (Knife:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.synchronize()
			end
			HBSC:Disconnect()
			if script:FindFirstAncestorWhichIsA("Actor") then
				task.desynchronize()
			end
		end
		for ind, val in pairs(PositionThingy) do
			local VectorThingy = val[2] - val[1].WorldPosition
			local Cast = workspace:Raycast(val[2], -VectorThingy.Unit*VectorThingy.Magnitude, Params)
			if Cast and Cast.Instance then
				if script:FindFirstAncestorWhichIsA("Actor") then
					task.synchronize()
				end
				Prop(Cast.Instance)
				if script:FindFirstAncestorWhichIsA("Actor") then
					task.desynchronize()
				end
			end
			PositionThingy[ind] = nil
		end
		for i,Attachment in pairs(HBAttachments) do
			table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
		end
	end)
	if script:FindFirstAncestorWhichIsA("Actor") then
		task.synchronize()
	end
end
Knife.Activated:Connect(function() 		-- State Changer V0.1
	if CurrentState ~= "Firing" and CurrentState ~= "Charging" then
		--task.desynchronize() -- Please Don't Worry About The Warning, It's unusable without actors n' stuff
		CurActi = true
		if tick() - LastestSlash >= 3 then
			CurrentAnimSequence = 1
		end 
		if GetHumanoid(Character) then
			GetHumanoid(Character).WalkSpeed = Curspd
		end
		if CurrentState == "Idle" and CurrentAnim ~= "Charging" and CurrentAnim ~= "Throwing" and CurrentAnim == "Idle" and not Slashing then
			table.clear(Debounce)
			table.clear(Touched)
			table.clear(OnlyCheckOnce)
			EnableWeld("Root")
			EnableWeld("RootHip")
			EnableWeld("RootJoint")
			EnableWeld("Neck")
			LastestSlash = tick()
			CanDmg = true
			CurrentState = "Swinging"
			LastestHealth = GetHumanoid(Character).Health

			if Slashing and _G.ToolCooldown == false then
				return	
			else
				_G.ToolCooldown = true
				Slashing = true	
				EnTrail()
			end	
			Hitbox(0.7)
			PlaySound("Swoosh")
			--	if CurrentAnimSequence == 1 then
			playAnimation("Charging",0.1)
			playAnimation("Stab",0.15/2)
			NeedToWait = true
			CurrentAnim = "Stab"
			CurrentAnimSequence = 2
		--[[elseif CurrentAnimSequence == 2 then
			playAnimation("Charging",0.125)
			playAnimation("Stab",0.175/2,true)
			CurrentAnim = "Stab"
			CurrentAnimSequence = 1
		end]]
			if CurActi and CurrentAnimSequence == 2 then -- GateKeep Lol
				CurrentState = "Ready"
				Slashing = false	
				task.wait(1)
				if CurrentAnim ~= "Charging" and CurrentState ~= "Charging" and CurrentState ~= "Firing" then -- Listen Up, The State May Have Changed.
					task.wait(0.5)
					CurrentState = "Idle"
					playAnimation("Idle",0.1)
					UnTrail()
					_G.ToolCooldown = false
					--DisableWeld("RootHip")
					--DisableWeld("RootJoint")
					--DisableWeld("Neck")
				end
			elseif not CurActi or CurrentAnimSequence == 1 then -- No Charge Throw After Stabbing, And Stabbing Won't Extend.
				if CurrentAnim ~= "Charging" and CurrentState ~= "Ready" and CurrentState ~= "Firing" then
					task.wait(0.1)
					CurrentState = "Idle"
					playAnimation("Idle",0.1)
					_G.ToolCooldown = false
					UnTrail()
					--DisableWeld("RootHip")
					--DisableWeld("RootJoint")
					--DisableWeld("Neck")
				end
			end
			if NeedToWait then
				task.wait(0.5)
				Slashing = false	
				NeedToWait = false
			else
				Slashing = false	
			end
		elseif CurrentState == "Ready"  then
			if CurrentState ~= "Idle" and CurrentState ~= "Firing" and CurrentState ~= "Swinging" then
				CanDmg = true
				CurrentState = "Charge"
				StoredTick = tick()
				LastestHealth = GetHumanoid(Character).Health
				Slashing = false	
				playAnimation("Charging",0.1)
				CurrentAnim = "Charging"
				if GetHumanoid(Character) then
					GetHumanoid(Character).WalkSpeed = (Curspd/10) *	9	
				end
				UnTrail()
				PlaySound("clickfast.wav")


			end

		end

	end
	--task.synchronize()   -- Line Up!
end)
Knife.Deactivated:Connect(function()
	CurActi = false
	--task.desynchronize()
	local ChargedPower = (tick() - StoredTick)*6.5
	if CurrentState == "Charge" and ChargedPower >= LowestChargeRequirement then
		EnTrail()
		table.clear(Touched)
		table.clear(Debounce)
		table.clear(OnlyCheckOnce)
		local Boost = AccurateMathRandom(DamagePerCharge*ChargedPower,DamagePerCharge*ChargedPower+2)
		if GetHumanoid(Character) then
			GetHumanoid(Character).WalkSpeed = Curspd + math.clamp(Boost,LowestChargeRequirement*DamagePerCharge,MaxCharge*DamagePerCharge)
		end
		CurrentState = "Firing"
		PlaySound("swoosh.wav")
		playAnimation("Stab",0.05/ChargedPower)
		Hitbox(0.7/ChargedPower)
		CurrentAnim = "Stab"
		if GetHumanoid(Character) then
			GetHumanoid(Character).WalkSpeed = Curspd
		end
		task.wait(1)
		-- Incase He Broke Knife
		if not CanDmg or GetHandle().Transparency == 1  then -- Yeah, This Thing Is Supposed Be Throwed, But I'm Too Lazy.
			PlaySound("bass.wav")
			CanCurrentlyCurse = true
			--if GetHandle() ~= nil then
			CurseArea(GetHandle())
			--	end
			CanDmg = true
		else
			if AccurateMathRandom(1,100) <= MislayChance then
				PlaySound("splat.wav")
				local DroppedKnifeLifeTime = math.random(50,100)/10
				local DroppedKnife = GetHandle():Clone()
				DroppedKnife.Name = "DroppedKnife"
				DroppedKnife.CanCollide = true
				DroppedKnife.Parent = workspace
				DroppedKnife.Material = Enum.Material.CorrodedMetal
				DroppedKnife:SetAttribute("Already_Attached",false)
				--DroppedKnife.Color = BrickColor.Black() -- It doesn't work :(
				for i,v in DroppedKnife:children() do
					if not v:IsA("SpecialMesh") then
						Destruct(v)
					elseif v:IsA("SpecialMesh") then
						--v.TextureId = "rbxassetid://1"
					end
				end
				EasyTween(DroppedKnife,"Transparency", 1, DroppedKnifeLifeTime , "Sine", "In"):Play()
				DroppedKnife.Touched:Connect(function(PartTouched)
					if PartTouched.Parent and GetHumanoid(PartTouched.Parent) and DroppedKnife.Transparency < 1 and PartTouched.Parent ~= Character and not DroppedKnife:FindFirstChildOfClass("Weld") and DroppedKnife:GetAttribute("Already_Attached")  ~= true then
						if GetHandle():FindFirstChild("Kid saying Ouch.wav") then
							local ouch = GetHandle():FindFirstChild("Kid saying Ouch.wav"):Clone()
							ouch.Parent = PartTouched
							ouch:Play()
							ApplyAttribute(ouch)
							Debris:AddItem(ouch,1)
						end
						DamageHumanoid(GetHumanoid(PartTouched.Parent), DroppedKnifeLifeTime*(1-DroppedKnife.Transparency))
						WeldKnife(DroppedKnife, PartTouched)
						DroppedKnife:SetAttribute("Already_Attached",true)
					end
				end)
				Debris:AddItem(DroppedKnife, DroppedKnifeLifeTime)
				if DroppedKnife.Transparency == 1 then
					Destruct(DroppedKnife)
				end
			end
		end
		--GetHandle().Transparency = 0
		if GetHandle():FindFirstChildOfClass('UnionOperation') then
			GetHandle():FindFirstChildOfClass('UnionOperation').Transparency = 0
		end
		CurrentState = "Idle"
		playAnimation("Idle",0.1)
		UnTrail()
		_G.ToolCooldown = false
		--DisableWeld("RootHip")
		--DisableWeld("Neck")
		--DisableWeld("RootJoint")
		CurrentDamage = DefaultDamage
	elseif  CurrentState == "Charge" and ChargedPower < LowestChargeRequirement and ChargedPower > LowestChargeRequirement/2 then
		CurrentState = "Idle"
		PlaySound("electronicpingshort.wav")
		playAnimation("Idle",0.1)
		UnTrail()
		_G.ToolCooldown = false
	elseif CurrentState == "Charge" and ChargedPower < LowestChargeRequirement and ChargedPower < LowestChargeRequirement/2 then
		CurrentState = "Idle"
		Slashing = true
		_G.ToolCooldown = true
		local Forward = Instance.new("BodyVelocity")
		local Root = Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Torso")
		if Root then
			DebugText("Root was Set To "..Root:GetFullName())
			Forward.Parent = Root
			Forward.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
			Forward.Velocity = Root.Velocity * 2
			Forward.Name = GenerateKeycode()
		end
		PlaySound("Woosh")
		EnTrail()
		playAnimation("Stab",0.125)
		CurrentAnim = "Stab"
		CurrentAnimSequence = 1	
		Slashing = false
		if Forward then
			Destruct(Forward)
		end
		CurrentState = "Idle"
		playAnimation("Idle",0.1)
		UnTrail()
		_G.ToolCooldown = true	
	end
	--task.synchronize()
end)

function VerifyTouch(TargetPart: BasePart) -- trigger prop() if not alr done so
	task.desynchronize()	
	local LimitedRange = GetHandle().Size.Z/2
	if TargetPart and not TargetPart:IsDescendantOf(Character) and not table.find(Touched, TargetPart) and Knife:FindFirstChild("Handle") and (Knife:FindFirstChild("Handle").Position - TargetPart.Position).Magnitude <= LimitedRange then
		table.insert(Touched, TargetPart)
		--print('touched')
		Prop(TargetPart)
	end
end

if Knife:FindFirstChild("Handle") then
	Knife:FindFirstChild("Handle").Touched:Connect(Prop)
	Knife:FindFirstChild("Handle").TouchEnded:Connect(Prop)
	Knife:FindFirstChild("Handle").LocalSimulationTouched:Connect(Prop)
else
	DebugText("Reloaded_" ..GetHandle().Name)	
	GetHandle().Touched:Connect(VerifyTouch())
	GetHandle().TouchEnded:Connect(Prop)
	GetHandle().LocalSimulationTouched:Connect(Prop)
end

script.AttributeChanged:Connect(DebugCheck)
--Solivion's Knife V2, Or Nokia Or Whatever-- 
--I Don't Really Built In Durabillity, Cause It's 'RealKnife'... I don't really know what it is. But Yeah Whatever.--
--Language: Lua--
--STARTED--
--9/6/2023--
while RunService.Heartbeat:Wait() do
	if not PerformanceWise then
		local MustFind = Knife:FindFirstChild("Root")
		if MustFind and Character:FindFirstChild("HumanoidRootPart") then
			local Velocity = Character:FindFirstChild("HumanoidRootPart").CFrame:VectorToObjectSpace(Character:FindFirstChild("HumanoidRootPart").Velocity)
			if  Knife:FindFirstChild("Root") and Knife:FindFirstChild("Root").Name == "Root" then
				Knife:FindFirstChild("Root").C1 = Knife:FindFirstChild("Root").C1:lerp(CFrame.fromEulerAnglesXYZ(-Velocity.z/60,0,Velocity.x/60) * CFrame.new(0,0.75,0),0.1)
			else
				if Knife:FindFirstChild("Root")  then
					Knife:FindFirstChild("Root").C1 = Knife:FindFirstChild("Root").C1:lerp(CFrame.fromEulerAnglesXYZ(-Velocity.z/60,0,Velocity.x/60),0.1)
				end
				
			end
			
		elseif	MustFind and not Character:FindFirstChild("HumanoidRootPart") then
			local VelocityPart = MustFind.Part1
			local Velocity = VelocityPart.CFrame:VectorToObjectSpace(VelocityPart.Velocity)
			if  Knife:FindFirstChild("Root") and Knife:FindFirstChild("Root").Name == "Root" then
				Knife:FindFirstChild("Root").C1 = Knife:FindFirstChild("Root").C1:lerp(CFrame.fromEulerAnglesXYZ(-Velocity.z/60,0,Velocity.x/60) * CFrame.new(0,0.75,0),0.1)
			else
				if Knife:FindFirstChild("Root")  then
					Knife:FindFirstChild("Root").C1 = Knife:FindFirstChild("Root").C1:lerp(CFrame.fromEulerAnglesXYZ(-Velocity.z/60,0,Velocity.x/60),0.1)
				end
			end
		end
		if Knife:FindFirstChild("RootJoint") and Character:FindFirstChild("HumanoidRootPart") then
			local Vel = Character:FindFirstChild("HumanoidRootPart").CFrame:vectorToObjectSpace(Character:FindFirstChild("HumanoidRootPart").Velocity)
			Knife:FindFirstChild("RootJoint").C1 = Knife:FindFirstChild("RootJoint").C1:lerp(CFrame.fromEulerAnglesXYZ(-Vel.z/60,0,Vel.x/60),0.1)
		end
	else
		break
	end
end

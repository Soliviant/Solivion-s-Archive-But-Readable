					<Item class="LocalScript" referent="RBXBBA54183A2DC4F0982E9F24650F50E17">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local RunService = game:GetService("RunService")
local Render_Priority = Enum.RenderPriority.Camera.Value + 1
local player = game.Players.LocalPlayer
local CFIdentity = CFrame.identity
local CFNew = CFrame.new

local up = table.unpack
local Abb2 = false
local Abb = false
local clamp = math.clamp
local abs = math.abs
local cos = math.cos
local sin = math.sin
local pi = math.pi
local Invert = false
local UpsydeDown = false
local Half = pi / 2
local Tau = pi * 2

local Delta = Half
local function Set(Components, Component, Value, Multiply)
	local Index = Component + 3 -- Exclude X, Y, Z
	local Key = Components[Index]
	
	if Key then
		Components[Index] = clamp(Multiply and (Key * Value) or (Key + Value), -1, 1)
	end
end
RunService:BindToRenderStep("__CAMERA_DISTORTION", Render_Priority, function(dT)
	Delta = (Delta + dT) % Tau
	
	local Current_Camera = workspace.CurrentCamera
	if Current_Camera and game.Players.LocalPlayer.Character then
		local absvel = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame:vectorToObjectSpace(game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart").Velocity)
		-- Squash / Stretch camera
		local Components = { CFIdentity:GetComponents() }
		if Invert == false and UpsydeDown == false then
		-- R00 (Height)
		--Set(Components, 1,1-  game.Players.LocalPlayer.Character.HumanoidRootPart.Velocity.Magnitude/50, true)
		-- R11 (Width)
		Set(Components, 5,1- --[[absvel.Y/100]] 0, true)
		else
			if Invert == true then
				Set(Components, 1,-math.huge, true)
			end
			if UpsydeDown == true then
				Set(Components, 5,-math.huge, true)
			end
			--
		end
		
		Current_Camera.CFrame *= CFNew(up(Components))
	end
end)


while RunService.RenderStepped:Wait() do
	if _G.Glitch == false then 
		break
	end


	local enableGlitchyEffect = script.Parent.Parent:GetAttribute("Enable_Glitchy_Effect")
	if enableGlitchyEffect == true then
		script.Name = "CameraSwaggr"
	else
		break
	end

	task.desynchronize()

	local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		break
	end

	local HealthFactor = humanoid.Health / humanoid.MaxHealth
	local GlitchChance = (1 - HealthFactor) * 2 -- Higher GlitchChance for lower HealthFactor

	if Invert == true then
		if math.random(1, 5) == 4 then
			Invert = false
		end
	else
		if math.random(1, 100) <= GlitchChance then
			Invert = true
		end
	end

	if UpsydeDown == true then
		if math.random(1, 7) == 3 then
			UpsydeDown = false
		end
	else
		if math.random(1, 100) <= GlitchChance then
			UpsydeDown = true
		end
	end

	if Abb == true then
		if math.random(1, 3) == 1 then
			Abb = false
		end
	else
		if math.random(1, 200) <= GlitchChance then
			Abb = true
		end
	end

	if Abb2 == true then
		if math.random(1, 3) == 2 then
			Abb2 = false
		end
	else
		if math.random(1, 200) <= GlitchChance then
			Abb2 = true
		end
	end

	task.synchronize()
end
--workspace.CurrentCamera:ClearAllChildren()
for i,v in workspace:children() do
	if v:IsA("Highlight") then
		v:Destroy()
	end
end]]></ProtectedString>

			<Item class="Script" referent="RBXA9DAAC9F8D634A6893CFCC4657889512">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--//RealKnife.Lua//--
--//Written By @Solivion//--
-- Please Bare With My Scripting Skill --
-- This is made specially for normal sized R6, R15 --
-- Assisted By Chat-GPT 3.5 --
--<<Services>--
local TweenService = game:GetService("TweenService")					  --Move Service V.0.1
local RunService = game:GetService("RunService")						  --You Can't Run
local Debris = game:GetService("Debris")							      --Time Limted Real
local SoundService = game:GetService("SoundService")					  -- Storage Room
local PhysicsService = game:GetService("PhysicsService")				  --FyShic Srvis
local PlayerService = game:GetService("Players")						  --PlayrServ!ce
--<<Global Stuff>>--
_G.ToolCooldown = false
_G.CooldownLeft = 0

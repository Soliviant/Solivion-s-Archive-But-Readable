--<<Misc>>--
function DebugCheck(Which)
	if DebugMode == true and Which then
		if script:GetAttribute("MaxCharge") then
			MaxCharge = script:GetAttribute("MaxCharge")
		end
		if script:GetAttribute("LowestChargeRequirement") then
			LowestChargeRequirement = script:GetAttribute("LowestChargeRequirement")
		end
		if script:GetAttribute("DamagePerCharge") then
			DamagePerCharge = script:GetAttribute("DamagePerCharge")
		end
		if script:GetAttribute("SoundPitchOffset") then
			PitchOffset = script:GetAttribute("SoundPitchOffset")
		end
		if script:GetAttribute("AllowPercentagedDamage") then
			AllowPercentagedDamage = script:GetAttribute("AllowPercentagedDamage")
		end
		if script:GetAttribute("DropOpponentsLootsOnKill") then
			DropOpponentsLootOnKill = script:GetAttribute("DropOpponentsLootsOnKill")
		end
		if script:GetAttribute("DropOpponentsToolOnRagdoll") then
			DropOpponentstoolOnRagdoll = script:GetAttribute("DropOpponentsToolOnRagdoll")
		end
		if script:GetAttribute("Curseable") then
			Curseable = script:GetAttribute("Curseable")
		end 
		if script:GetAttribute("PerformanceWise") then
			PerformanceWise = script:GetAttribute("PerformanceWise")
		end
		if script:GetAttribute("ArmorPiercing") then
			ArmorPiercing = script:GetAttribute("ArmorPiercing")
		end
		if script:GetAttribute("HumanoidName") then
			HumanoidName = script:GetAttribute("HumanoidName")
		end
		if script:GetAttribute("OneShotSaver") then
			OneShotSaver = script:GetAttribute("OneShotSaver")
		end
		if script:GetAttribute("Enable_Glitchy_Effect") then
			Glitch = script:GetAttribute("Enable_Glitchy_Effect")
		end
		KnifeDurabillity = "Not Real"
	else
		DebugWarn("Please Enable Debug Mode In Studio To Allow Mid-Game Modification")
	end
end
function Destruct(Object:Instance)
	Object:Destroy()
	if Object ~= nil then
		Object:Remove()
	end
end
function CFrameAngles(X,Y,Z)
	return CFrame.Angles(math.rad(X),math.rad(Y),math.rad(Z))		-- Why Didn't I Thought Of This Earlier.						
end
local EasyTween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	return game:GetService("TweenService"):Create(itemtotween,info,goal)
end
function Encryption(unencryptedName, BeEncryptedOrUnEncrypt_YesOrNo)		-- My Special Method For Encrypting Symbols
	if BeEncryptedOrUnEncrypt_YesOrNo == true then				--Encrypt
		-- Replace '.' with '0' and remove spaces (replace '_' with '')
		local Encryptedname = string.gsub(unencryptedName, '%.', '0')
		Encryptedname = string.gsub(Encryptedname, ' ', '_')
		return Encryptedname
	else															--UbEncrypt
		-- Replace '.' with '0' and remove spaces (replace '_' with '')
		local Encryptedname = string.gsub(unencryptedName, '0', '.')
		Encryptedname = string.gsub(Encryptedname, '_', ' ')
		return Encryptedname
	end
end

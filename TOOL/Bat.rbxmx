					<ProtectedString name="Source"><![CDATA[script.Parent.RemoteEvent.OnServerEvent:Connect(function(plr,c,p1,p2,m,char,mohi,morgin,request)
	char = p2.Character or p2.CharacterAdded:wait()
	if request == "equip" and script.Parent.Parent:FindFirstChildOfClass("Snap") then
		script.Parent.Parent:FindFirstChildOfClass("Snap").C0 = CFrame.new(0,0,0.5) * CFrame.Angles(math.rad(180),0,math.rad(180)) * CFrame.Angles(math.asin((morgin.p - mohi.p).unit.y),0,0)
	end
end)]]></ProtectedString>

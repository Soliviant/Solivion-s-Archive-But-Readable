local HBAP = { -- One Attachment Every Small Bits Of Stud.
	--CFrame.new(0,0,0),CFrame.new(0,-0.075,0),CFrame.new(0,-0.15,2),CFrame.new(0,-0.125,1.5),CFrame.new(0,-0.1,1),CFrame.new(0,-0.1,0.5)--[[]],CFrame.new(0,0.075,0),CFrame.new(0,0.15,2),CFrame.new(0,0.125,1.5),CFrame.new(0,0.1,1),CFrame.new(0,0.1,0.5)--[[]],CFrame.new(0,0,-2),CFrame.new(0,0,-1.5),CFrame.new(0,0,-1),CFrame.new(0,0,-0.5),CFrame.new(0,0,0),CFrame.new(0,0,2),CFrame.new(0,0,1.5),CFrame.new(0,0,1),CFrame.new(0,0,0.5),CFrame.new(0.075,0,0),CFrame.new(-0.075,0,0),CFrame.new(0.1,0,0.5),CFrame.new(-0.1,0,0.5),CFrame.new(0.15, 0, 1),CFrame.new(-0.15, 0, 1),CFrame.new(0.175, 0, 1.5),CFrame.new(-0.175, 0, 1.5),CFrame.new(0.2, 0, 2),CFrame.new(-0.2, 0, 2)

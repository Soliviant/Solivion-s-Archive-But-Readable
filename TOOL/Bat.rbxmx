					<ProtectedString name="Source"><![CDATA[--!native
--//Solivion//--
--Hitboxes are delicate, but performant enough
--Badly Made Baseball Bat, Also I hope these funny palallel optimiztion helps
--While Swinging, The Bat Will Counter Any Damages If They Came At You A Bit Too Fast.(And They Must BE Near, Infront of you too)
local Debris = game:FindFirstChildOfClass('Debris')
local Baseball_Bat = script:FindFirstAncestorWhichIsA("Tool")
local HEALTH: number = 100
local Damaging: boolean = false
local LastestTime: number = tick()
local Releasing: boolean = false -- Indicate if firing is possible
local now: boolean = true
local Act: boolean = true
local HealthChangingConnect: RBXScriptConnection?

	CFrame.new(0, -0.075, 0),
	CFrame.new(0, 0.15, 2),
	CFrame.new(0, 0.125, 1.5),
	CFrame.new(0, 0.1, 1),
	CFrame.new(0, 0.1, 0.5),
	CFrame.new(0, 0.075, 0),
	CFrame.new(0, 0, -2),
	CFrame.new(0, 0, -1.5),
	CFrame.new(0, 0, -1),
	CFrame.new(0, 0, -0.5)	
}
local SoundTabel_ss69_ep420 = { -- OmgItsDaSoundTable
	glassbreak0wav = "rbxasset://sounds//glassbreak.wav",
	Hit = "http://www.roblox.com/asset/?id=58831920",
	Hitmarker = "rbxassetid://160432334",
	Swoosh = "http://www.roblox.com/asset?id=153647529",
	Woosh = "rbxassetid://12222200",
	Equip = "rbxasset://sounds//snap.wav",
	Unequip = "rbxassetid://12221831",
	Switch = "rbxasset://sounds//switch.wav",
	Kerplunk = "rbxasset://sounds//kerplunk.wav",
	FlashBulb = "rbxassetid://12221996",
	SWITCH3 = "rbxasset://sounds//SWITCH3.wav",

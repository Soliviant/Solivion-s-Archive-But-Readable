}-- "Nah legit too lazy to find a better soundeffect"
function PlaySound(SoundName,ToWhere)
	if HasActor then
		task.synchronize()
	end
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = Handle or Baseball_Bat:FindFirstChild("Handle")
	end
	if ToWhere and FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		Mainplayfunction(FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound'))
	elseif ToWhere and not FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundTabel_ss69_ep420[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sound.Parent = Where
			sound.SoundId = SoundTabel_ss69_ep420[SoundName]
			sound.Name = SoundName
			sound:Play()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end
local function Dmg(who: Instance, HitPos: Vector3?)
	if not Damaging then
		return
	end
	if HitPos == nil and who:IsA("BasePart") then
		HitPos = who.CFrame.Position
	end
	if HasActor then
		task.synchronize()
	end
	if  who:FindFirstAncestorWhichIsA("Model") and who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") and not table.find(DebounceInstance,Debounce[who:FindFirstAncestorWhichIsA("Model")]) and not Debounce[who:FindFirstAncestorWhichIsA("Model")] and not Debounce[who] then
		Debounce[who] = "Lorem ipsum"-- Debouncing the part.
		Debounce[who:FindFirstAncestorWhichIsA("Model")] = "The quick brown fox jumps over the lazy dog"-- Debouncing the Model.
		table.insert(DebounceInstance,who:FindFirstAncestorWhichIsA("Model"))
		if who.Name == 'Head' then
			who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - math.clamp((math.random(25,40) - math.ceil(#Debounce) + Handle.Velocity.Magnitude * 1.75)/125,0,math.huge) * who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").MaxHealth
			who.Velocity = who.Velocity + Handle.Velocity * math.random(5, 10)/10
		else
			who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - math.clamp((math.random(15,25) - math.ceil(#Debounce) + Handle.Velocity.Magnitude * 1.25)/125,0,math.huge) * who:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").MaxHealth
		end
		PlaySound("Hit",who)
	end
end
function Hitbox(Duration)
	Damaging = true
	if HBSC then
		HBSC:Disconnect()
	end
	local Ignore = {}
	local Params = RaycastParams.new()
	Params.IgnoreWater = true
	Params.FilterType = Enum.RaycastFilterType.Exclude
	Params.FilterDescendantsInstances = {Character, Debounce, DebounceInstance}
	Params:AddToFilter(EffectInstance)
	Params:AddToFilter(DebounceInstance)
	local StartingTick = tick()
	local PositionThingy = {}
	if HasActor then
		task.desynchronize()
	end
	for i,Attachment in pairs(HBAttachments) do
		table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
	end
	if HasActor then
		task.synchronize()
	end
	HBSC = game:GetService("RunService").Heartbeat:Connect(function(DT)
		Damaging = true
		Act = false
		if HasActor then
			task.desynchronize()
		end
		if (tick() - StartingTick >= Duration) or not Baseball_Bat:FindFirstAncestorWhichIsA("Model") or not (Baseball_Bat:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
			Damaging = false
			if HasActor then
				task.synchronize()
			end
			HBSC:Disconnect()
			if HasActor then
				task.desynchronize()
			end
		end
		local Cast: RaycastResult?
		local function WhenCast(Cast: RaycastResult, VectorThingy: Vector3)
			task.desynchronize()
			if Cast and Cast.Instance and not table.find(Ignore, Cast.Instance) and (not Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model') and true) or (Cast.Instance:FindFirstAncestorWhichIsA('Model') and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model')) or (Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model')and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder')))) then
				table.insert(Ignore, Cast.Instance)
				table.insert(Ignore, Cast.Instance.Parent)
				task.synchronize()
				Params:AddToFilter(Cast.Instance)
				task.desynchronize()
				if Cast.Instance:FindFirstAncestorWhichIsA('Model') --[[and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model'))  ]]then Dmg(Cast.Instance, Cast.Position) table.insert(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Model')) task.synchronize()	Params:AddToFilter(Cast.Instance:FindFirstAncestorWhichIsA('Model')) end
				task.desynchronize()
				if Cast.Instance:FindFirstAncestorWhichIsA('Folder') and not Cast.Instance:FindFirstAncestorWhichIsA('Model')--[[ and not table.find(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder'))]] then table.insert(Ignore,Cast.Instance:FindFirstAncestorWhichIsA('Folder')) task.synchronize()	Params:AddToFilter(Cast.Instance:FindFirstAncestorWhichIsA('Folder')) end
				task.desynchronize()
				if Debounce[Cast.Instance] then -- confirm that this is actually damaged
					--lower dmg, registr character to filter
					for i,v in DebounceInstance do
						if v and v:IsAncestorOf(Cast.Instance) and not table.find(Ignore, v) then
							task.synchronize()
							Params:AddToFilter(v)
							task.desynchronize()
							table.insert(Ignore, v)
						end
					end
						task.desynchronize()
						local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
						task.desynchronize()
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),(1 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.floor(#Debounce/4) + 3, 5, Color, Cast.Material or Enum.Material.Neon, nil,'Expand',1/2)
						task.desynchronize()
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),(0.8 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.random(5,7) - math.floor(#Debounce/8), math.random(6,9) - math.ceil(#Debounce/6), Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1.75,'Shrink',1,{Cast.Instance})
					--else
						--[[local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.6 * (Handle.Size.X + Handle.Size.Y), workspace, 2, 5, Color or Color3.new(1, 1, 0.498039), Enum.Material.Neon, nil,'Expand',1)	
						Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.5 * (Handle.Size.X + Handle.Size.Y), workspace, 3, 6, Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1 + Vector3.new(0,-1.5,0),'Shrink',1, {Cast.Instance})
					]]end
				if HasActor then
					task.desynchronize()
				end
			end
		end
		for ind, val in pairs(PositionThingy) do
			local VectorThingy = val[2] - val[1].WorldPosition -- The Second Value In The Table Is LastPosition Of The Attachment, While the first is the Attachment itself
			coroutine.resume(coroutine.create(function()
				repeat 
					Cast = workspace:Raycast(val[2], -VectorThingy.Unit*VectorThingy.Magnitude, Params) or workspace:Raycast(val[1].WorldPosition, VectorThingy, Params)  or (ind == 1 and PositionThingy[#PositionThingy] and  workspace:Raycast(val[1].WorldPosition, (val[1].WorldPosition - PositionThingy[#PositionThingy][1].WorldPosition).Unit * 1, Params))
					if Cast and not table.find(Ignore,Cast.Instance) and Cast.Instance.Parent and not table.find(Ignore,Cast.Instance.Parent) then
						WhenCast(Cast,VectorThingy)
					else
						break
					end
					task.desynchronize()
				until not Cast or (tick() - StartingTick >= Duration)
			end))
			task.desynchronize()
			-- or workspace:Raycast(val[1].WorldPosition, Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position - val[1].WorldPosition, Params) or workspace:Raycast(Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position, val[1].WorldPosition - Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position, Params) 
			if ind >= #PositionThingy - 4  then
				for i = 0, math.floor(VectorThingy.Magnitude), 0.1 do
					local start = val[1].WorldPosition +  VectorThingy.Unit * i
					repeat 
						Cast = workspace:Raycast(start, CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25),Params) or workspace:Raycast(start +  CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25), -CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25) ,Params)
						if Cast and not table.find(Ignore,Cast.Instance) and Cast.Instance.Parent and not table.find(Ignore,Cast.Instance.Parent) then
							WhenCast(Cast,VectorThingy)
						else
							break
						end
						task.desynchronize()
					until not Cast or (tick() - StartingTick >= Duration)
					if Cast and not table.find(Ignore,Cast.Instance) and Cast.Instance.Parent and not table.find(Ignore,Cast.Instance.Parent) then
						WhenCast(Cast,VectorThingy)
						-- More!
					end
				end
			end
			--[[local Cast = workspace:Raycast(val[2], -VectorThingy.Unit*VectorThingy.Magnitude, Params) or  workspace:Raycast(val[1].WorldPosition, VectorThingy, Params) or (ind == 1 and PositionThingy[#PositionThingy] and  workspace:Raycast(val[1].WorldPosition, (val[1].WorldPosition - PositionThingy[#PositionThingy][1].WorldPosition).Unit * 1, Params))-- or workspace:Raycast(val[1].WorldPosition, Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position - val[1].WorldPosition, Params) or workspace:Raycast(Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position, val[1].WorldPosition - Handle.CFrame:ToWorldSpace(CFrame.new(-val[1].CFrame.X,-val[1].CFrame.Y,val[1].CFrame.Z)).Position, Params) 
			if not Cast and ind >= #PositionThingy - 4  then
				for i = 0, math.floor(VectorThingy.Magnitude), 0.05 do
					local start = val[1].WorldPosition +  VectorThingy.Unit * i
					Cast = workspace:Raycast(start, CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25),Params) or workspace:Raycast(start +  CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25), -CFrame.Angles(0, math.rad(90), 0):VectorToWorldSpace(VectorThingy.Unit * 2.25) ,Params)
					if Cast then
						--print('ca')
						break
					end
				end
			end
			if Cast and Cast.Instance then
				if HasActor then
					task.synchronize()
				end
				Params:AddToFilter(Cast.Instance)
				Dmg(Cast.Instance, Cast.Position)
				task.desynchronize()
				if Debounce[Cast.Instance] then -- confirm that this is it
					--lower dmg
					task.desynchronize()
					local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
					task.desynchronize()
					Classic_Flagstand_Effect(CFrame.new(Cast.Position),(1 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.floor(#Debounce/4) + 3, 5, Color, Cast.Material or Enum.Material.Neon, nil,'Expand',1/2)
					task.desynchronize()
					Classic_Flagstand_Effect(CFrame.new(Cast.Position),(0.8 - 0.05 * #Debounce/2) * (Handle.Size.X + Handle.Size.Y), workspace, math.random(5,7) - math.floor(#Debounce/8), math.random(6,9) - math.ceil(#Debounce/6), Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1.75,'Shrink',1,{Cast.Instance})
				else
					local Color = (Cast.Instance:IsA('BasePart') and Cast.Instance.Color) or (Cast.Instance:isA('Terrain') and workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Cast.Material)) or Color3.new(1, 1, 1)
					Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.6 * (Handle.Size.X + Handle.Size.Y), workspace, 2, 5, Color or Color3.new(1, 1, 0.498039), Enum.Material.Neon, nil,'Expand',1)	
					Classic_Flagstand_Effect(CFrame.new(Cast.Position),0.5 * (Handle.Size.X + Handle.Size.Y), workspace, 3, 6, Color, Cast.Material or Enum.Material.Neon, VectorThingy.Unit * 1 + Vector3.new(0,-1.5,0),'Shrink',1, {Cast.Instance})
				end
				if HasActor then
					task.desynchronize()
				end
			end]]
			PositionThingy[ind] = nil
		end
		for i,Attachment in pairs(HBAttachments) do
			table.insert(PositionThingy, {Attachment, Attachment.WorldPosition})
		end
	end)
	if HasActor then
		task.synchronize()
	end
end
function Anim(Name:string,TPF:number)
	task.desynchronize()
	if not AnimTable[Name] then
		--	print("There Is No Animation With This Name.")
		return
	end
	if TPF == nil then
		TPF = 1
	end
	local TweenConnect
	for i,v in pairs(AnimTable[Name]) do -- Wan Frame :Skull:
		task.desynchronize()
		if not Baseball_Bat:FindFirstAncestorWhichIsA("Model") or (Baseball_Bat:FindFirstAncestorWhichIsA("Model") and not Baseball_Bat:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid")) then
			break
		end
		local ThatWeld = (i == "HandFrame" and Baseball_Bat:FindFirstChildOfClass("Snap")) or Baseball_Bat
		if not ThatWeld then
			--		print("Snap Has No Matching Name")
			return
		end
		if HasActor then
			task.synchronize()
		end
		local TweenIn = TweenInfo.new(TPF+0.05,Enum.EasingStyle.Linear,Enum.EasingDirection.In)
		local TweenThing = game:GetService('TweenService'):Create(ThatWeld,TweenIn,(ThatWeld:IsA("Snap") and {C1 = v}) or {Grip = v})
		TweenThing:Play()
		--	print("Tween Operation Complete"..tostring(ThatWeld:GetFullName()))
		TweenConnect = Baseball_Bat.AncestryChanged:Connect(function(huh,huh2)
			if not table.find({Enum.PlaybackState.Completed , Enum.PlaybackState.Cancelled},TweenThing.PlaybackState)  then
				TweenThing:Cancel()
			end
		end)
		TweenThing.Completed:Once(function(state)
			if TweenConnect and state == (Enum.PlaybackState.Completed or Enum.PlaybackState.Cancelled) then
				TweenConnect:Disconnect()
			end
		end)
	end
	task.wait(TPF)
	task.synchronize()
end
if Baseball_Bat and Handle then
	local Equip_connect = Baseball_Bat.Equipped:Connect(function()
		local omgtic
		omgtic = tick()
		EquipTick = omgtic
		task.synchronize()
		now = false
		Character = Baseball_Bat.Parent
		for i,v in HBAP do
			local NA = Instance.new("Attachment")
			NA.Name = i
			NA.CFrame = v
			NA.Visible = false
			NA.Parent = Handle
			table.insert(HBAttachments,NA)
		end
		PlaySound("FlashBulb",Handle)
		if not Baseball_Bat:FindFirstChildOfClass("Snap") then
			local NewWeld = Instance.new("Snap")
			NewWeld.Parent = Baseball_Bat
			NewWeld.C0 = CFrame.new(0,0,0.5) * CFrameAngles(180,0,180)
			NewWeld.C1 = CFrame.new(-2, 0, 0) * CFrameAngles(0, 90, -135)
			NewWeld.Part0 = FindFirstChildOfNameAndClass(Character,"UpperTorso","BasePart") or  FindFirstChildOfNameAndClass(Character,"Torso","BasePart")
			NewWeld.Part1 = FindFirstChildOfNameAndClass(Character,"RightLowerArm","BasePart") or  FindFirstChildOfNameAndClass(Character,"Right Arm","BasePart")
		end
		Anim("Charging",0.1)
		coroutine.resume(coroutine.create(function()
			while task.wait() and omgtic == EquipTick and Character and Baseball_Bat and Baseball_Bat:FindFirstChildOfClass("Snap") and Baseball_Bat:IsDescendantOf(Character) do
				if animatL then task.synchronize() if Character and Character:FindFirstChild('Aim') then Character:FindFirstChild('Aim').Enabled = true end	HandAim(Character, nil, Handle.CFrame:ToWorldSpace(CFrame.new(0, 0, -1)) + Handle.AssemblyLinearVelocity * 2, FindFirstChildOfNameAndClass(Character,"LeftUpperArm","BasePart") or  FindFirstChildOfNameAndClass(Character,"Left Arm","BasePart")) else  if Character and Character:FindFirstChild('Aim') and Character:FindFirstChild('Aim').Enabled ~= false then task.synchronize() Character:FindFirstChild('Aim').Enabled = false end end 
			end
			if Character and Character:FindFirstChild('Aim') then
				Character:FindFirstChild('Aim') :Destroy()
			end
		end))
		animatL = false
		if omgtic == EquipTick then
			PlaySound("Kerplunk",Handle)
			Anim("Idle",0.1)
			now = true
		end
	end)
	local Unequip_connect = Baseball_Bat.Unequipped:Connect(function()
		local omgtic
		omgtic = tick()
		EquipTick = omgtic
		for i,A in HBAttachments do
			A:Destroy()
			HBAttachments[A] = nil
		end
		if Handle:FindFirstChildOfClass("Trail") then
			Handle:FindFirstChildOfClass("Trail").Enabled = false
		end
		now = false
		if Character and Character:FindFirstChild('Aim') then
			Character:FindFirstChild('Aim') :Destroy()
		end
		LastestTime = tick()
		Anim("Equip",1)
		if omgtic == EquipTick then
			if Baseball_Bat:FindFirstChildOfClass("Snap") then
				Baseball_Bat:FindFirstChildOfClass("Snap"):Destroy()
			end
		end
	end)
	local Acti_connect = Baseball_Bat.Activated:Connect(function()
		task.synchronize()
		animatL = false
		task.desynchronize()
		if not now  then
			return
		end
		if Handle:FindFirstChildOfClass("Trail") then
			task.synchronize()	Handle:FindFirstChildOfClass("Trail").Enabled = false
		end
		task.desynchronize()
		local cur = tick()
		LastestTime = cur
		Act = true
		if Damaging or Releasing then
			return
		end
		animatL = true
		Anim("Charging",0.5)
		task.desynchronize()
		if now and Act and not Damaging and not Releasing and LastestTime == cur and tick() - LastestTime >= 0.5 then
			Releasing = true
		end
	end)
	local Deacti_connect = Baseball_Bat.Deactivated:Connect(function()	
		task.synchronize()
		animatL = false
		task.desynchronize()
		if not Act then
			return
		end
		if not Releasing then
			if not Act then
				return
			end
			Act = false
			if LastestTime - tick() > 0.1 then
				LastestTime = tick()
				Anim("Idle",0.1/1.75)
				Releasing = false
				return
			end
			if not now  then
				return
			else
				now = false
			end
			if Damaging then
				return
			end
			task.desynchronize()
			if Handle:FindFirstChildOfClass("Trail") then
				task.synchronize() Handle:FindFirstChildOfClass("Trail").Enabled = true
			end
			PlaySound("Woosh",Handle)
			Damaging = true
			table.clear(Debounce)
			table.clear(DebounceInstance)
			Hitbox(0.11/1.75)
			Anim("Blocking"..math.random(0,3),0.1/1.75)
			task.desynchronize()
			task.wait(0.05)
			Damaging = false
			if Handle:FindFirstChildOfClass("Trail") then
				task.synchronize()Handle:FindFirstChildOfClass("Trail").Enabled = false
			end
			Anim("Charging",0.3/1.75)
			Anim("Idle",0.1/1.75)
			now = true
			Releasing = false
			return
		end
		task.desynchronize()
		LastestTime = tick()
		Act = false
		if not now  then
			return
		else
			now = false
		end
		if Damaging then
			return
		end
		Damaging = true
		Releasing = false
		HEALTH = Character:FindFirstChildOfClass("Humanoid").Health
		local Blocking_Left = math.huge -- How Many Time U Deflect Damage, Different Person Each Block
		local Blocked = {}
		if HealthChangingConnect then
			task.synchronize()
			HealthChangingConnect:Disconnect()
		end
		task.synchronize()
		Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, false)
		HealthChangingConnect = Character:FindFirstChildOfClass("Humanoid").HealthChanged:Connect(function(Hp)
			task.desynchronize()
			if Hp < HEALTH then
				if Blocking_Left <= 0 then
					task.synchronize()
					Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, true)
					return
				else
					task.synchronize()
					Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, false)
					task.desynchronize()
					Blocking_Left = Blocking_Left - 1
				end
				local ClosestTarget = nil
				local ClosestDis = 12 --type math.huge If you want to have that psycho mob power
				local Got = math.abs(HEALTH - Hp)
				local SavedLowHp = HEALTH -- Save First
				SavedLowHp = Hp
				if HEALTH >= Character:FindFirstChildOfClass("Humanoid").Health then
					task.synchronize()Character:FindFirstChildOfClass("Humanoid").Health = HEALTH
				end
				task.desynchronize()
				-- counter and also lower the chance to counter again
				--HEALTH = SavedLowHp
				if not Character or not Character:FindFirstChildOfClass('Humanoid') then return end
				task.synchronize()
				local partsearch = Instance.new('Part')
				partsearch.Size = Vector3.new(ClosestDis,ClosestDis,ClosestDis) * 2
				partsearch.CFrame = Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame -- + Character:GetPivot().LookVector * partsearch.Size/2
				task.desynchronize()
				local searched = workspace:GetPartsInPart(partsearch)
				task.synchronize()
				partsearch:Destroy()
				for i,part in searched do
					task.desynchronize()
					local v = part:FindFirstAncestorOfClass('Model')
					task.desynchronize()
					if v and v:FindFirstChildOfClass("Humanoid") and v:FindFirstChildOfClass("Humanoid").Health > 0 and v:IsA("Model") then
						if FindFirstChildOfNameAndClass(v,"Head","BasePart") ~= nil and Character and FindFirstChildOfNameAndClass(Character,"Head","BasePart") and FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.LookVector:Dot (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - FindFirstChildOfNameAndClass(Character,"Head","BasePart").Position) >= -0.1 then
							local Parameter = RaycastParams.new()
							Parameter.IgnoreWater = true
							Parameter.RespectCanCollide = true
							Parameter.FilterType = Enum.RaycastFilterType.Exclude
							task.synchronize()
							Parameter.FilterDescendantsInstances = Blocked
							Parameter:AddToFilter(v)
							Parameter:AddToFilter(Character)
							task.desynchronize()
							if not workspace:Raycast(Handle.Position,FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position, Parameter) and not workspace:Raycast(FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Handle.Position - FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Parameter) and (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position).Magnitude < ClosestDis and v ~= Character and not Blocked[v] then
								ClosestTarget = v
								ClosestDis = (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Handle.Position).Magnitude
							end
						end
					end
				end
				if ClosestTarget ~= nil and FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart") then
					Blocked[ClosestTarget] = "Written_By_Solivion"
					task.synchronize()
					--FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Position = Handle.Position + Handle.AssemblyLinearVelocity.Unit
					FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame = CFrame.new(FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame.Position, FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position)
					FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Velocity = FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").Velocity + --[[FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart").CFrame.LookVector]] Handle.AssemblyLinearVelocity.Unit * (math.clamp(Handle.AssemblyLinearVelocity.Magnitude*2,2,math.huge)  + Got * 1/4)
					if ClosestTarget:FindFirstChildOfClass("Humanoid") then
						ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = true
						ClosestTarget:FindFirstChildOfClass("Humanoid").Health = ClosestTarget:FindFirstChildOfClass("Humanoid").Health - ((math.random(15,25) + Got * 1.25) /125) * ClosestTarget:FindFirstChildOfClass("Humanoid").MaxHealth
						PlaySound("Hit",FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart"))
						coroutine.resume(coroutine.create(function() if ClosestTarget:FindFirstChildOfClass("Humanoid") then task.wait(math.random(5,7)/10 + Got / 5) if ClosestTarget:FindFirstChildOfClass("Humanoid") then task.synchronize() ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = false end end end))
					end					
				end
			end
		end)
		task.desynchronize()
		if Handle:FindFirstChildOfClass("Trail") then
			task.synchronize() Handle:FindFirstChildOfClass("Trail").Enabled = true
		end
		task.synchronize()
		animatL = true
		task.desynchronize()
		table.clear(Debounce)
		table.clear(DebounceInstance)
		task.synchronize()
		Hitbox(0.45/1.75)
		Anim("Idle",0.05/1.75)
		PlaySound("Swoosh",Handle)
		Anim("Blocking3",0.05/1.75)
		Anim("Blocking2",0.05/1.75)
		Anim("Blocking",0.05/1.75)
		Anim("Blocking0",0.05/1.75)
		Anim("Blocking1",0.1/1.75)
		task.synchronize()
		Damaging = false
		if Handle:FindFirstChildOfClass("Trail") then
			Handle:FindFirstChildOfClass("Trail").Enabled = false
		end
		LastestTime = tick()
		task.wait(0.1)
		HealthChangingConnect:Disconnect()
		Anim("Blocking1s",0.1/1.75)
		Anim("Charging",0.25/1.75)
		Anim("Idle",0.05/1.75)
		animatL = false
		if Baseball_Bat and Character and Character:FindFirstChildOfClass("Humanoid") then
			Character:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, true)
		end
		task.desynchronize()
		--print(#DebounceInstance)
		LastestTime = tick()
		Releasing = false
		now = true
	end)
	--Aw Hell Nah
	--[[task.synchronize()
	Handle.Touched:Connect(Dmg)
	Handle.TouchEnded:Connect(Dmg)
	Handle.LocalSimulationTouched:Connect(Dmg)]]
end
]]></ProtectedString>

		<Item class="LocalScript" referent="RBX38500631468346C5BDDE004983135D23">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local c = game.Workspace.CurrentCamera
local p1 = game:GetService("Players")
local p2 = p1.LocalPlayer
local m = p2:GetMouse()
local char
local eq = false
script.Parent.Equipped:Connect(function()
	eq = true
end)
script.Parent.Unequipped:Connect(function()
	eq = false
	script.RemoteEvent:FireServer(c,p1,p2,m,game.Players.LocalPlayer.Character,m.Hit,m.Origin,"unequip")
end)
coroutine.resume(coroutine.create(function()
	while task.wait(0.1) do
		if eq then 
		script.RemoteEvent:FireServer(c,p1,p2,m,game.Players.LocalPlayer.Character,m.Hit,m.Origin,"equip")
	end end
end))
]]></ProtectedString>

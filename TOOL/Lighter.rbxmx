	if LightBall2 then	task.synchronize()LightBall2:Destroy() end
	if Light then	task.synchronize()Light:Destroy() end
	if ArmWeld then task.synchronize()ArmWeld:Destroy() end
	if TorsoWeld then task.synchronize()TorsoWeld:Destroy() end
end)]]></ProtectedString>

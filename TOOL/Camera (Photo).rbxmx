									local CharLeft = who.Character:FindFirstChild("LeftHand") or who.Character:FindFirstChild("Left Arm") or who.Character:FindFirstChild("Right Arm")
									if (CharLeft == nil and CharRight == nil) or not Handle or not who or not who.Character then

		<Item class="Script" referent="RBX99BD49725CFA4727B70D0757B5291E4A">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--By Solivion
local Tool: (Flag | Tool)? = script:FindFirstAncestorWhichIsA('Flag') or script:FindFirstAncestorWhichIsA('Tool')
local Handle: BasePart? = Tool:FindFirstChildOfClass('BasePart') or Tool:FindFirstChild('Handle')

if not Tool or not Handle then return end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	for i,v in Where:GetChildren() do
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				return v
			end
		end
	end
end

local Character: Model?
local HandWeld: Weld?
local DefaultArmOffset: CFrame = CFrame.new(1.5,0,0)
local AnimCoroutine: thread?
local Equipped: boolean = false
local Active: boolean = false
local ActivationTick: number = tick()
local EquipTick: number = tick()
type AnimationName = ('Throw'|'Equip'|'Unequip'|'Charge'|'Raise')
local Anim: AnimationName = 'Unequip'
local State: AnimationName = 'Unequip'
local SpecialAction = {
	['Rehandle'] = function()
		if not Handle then
			Handle = Instance.new("Part")
			Handle.Name = "Handle"
			Handle.Color = Color3.fromRGB(196, 40, 28)
			Handle.Size = Vector3.new(0.2, 0.2, 1)
			Handle.FormFactor = Enum.FormFactor.Custom

			local Mesh = Instance.new("SpecialMesh")
			Mesh.Scale = Vector3.new(0.75, 0.75, 0.75)
			Mesh.MeshId = "http://www.roblox.com/asset?id=145815862"
			Mesh.TextureId = "http://www.roblox.com/asset?id=145815901"
			Mesh.MeshType = Enum.MeshType.FileMesh
			Mesh.Parent = Handle
		end
	end,
	['Accessorize'] = function(Where: Model, How: boolean)
		if not Where then
			return
		end
		if not Handle then
			return
		end
		if How == nil then
			How = true
		end
		if Where then
			if How then
				Anim = 'Unequip'
				local Torso = FindFirstChildOfNameAndClass(Where, 'UpperTorso','BasePart') or FindFirstChildOfNameAndClass(Where, 'Torso','BasePart')
				if Torso and not Where:FindFirstChild('AttachedHandle') then
					local Attached = Handle:Clone()
					local AttachedWeld = Instance.new('Weld', Attached)
					AttachedWeld.Part0 = Torso
					AttachedWeld.Part1 = Attached
					AttachedWeld.C0 = CFrame.new(Torso.Size.X / 3, Torso.Size.Y / 4, -Torso.Size.Z / 2) * CFrame.Angles(math.rad(-90),math.rad(180),0)
					Attached.Parent = Where
					Attached.Name = 'AttachedHandle'
				end
			else
				if Where:FindFirstChild('AttachedHandle') then
					Anim = 'Equip'
					Where:FindFirstChild('AttachedHandle'):Destroy()
				end
			end
		end
	end,
	['Throw'] = function(Where: CFrame, Force: number)
		if Anim ~= 'Charge' then
			return
		end
		if not Handle then
			return
		end
		Anim = 'Throw'
		local Thrown = Handle:Clone()
		Thrown.Parent = workspace
		Thrown.Velocity = (Where.Position - Thrown.Position).Unit * Force * 10
		Thrown.CanCollide = true
	end,
	['Raise'] = function()
		if Anim == 'Raise' then
			Anim = 'Equip'
		elseif Anim == 'Equip' then
			Anim = 'Raise'
		end
	end
}
local ConnectedEvent = {
	['Equipped'] = function()
		local a a = tick() EquipTick = a ActivationTick = a Character = Tool:FindFirstAncestorOfClass('Model')
		if AnimCoroutine then coroutine.close(AnimCoroutine) AnimCoroutine = nil end		
		Anim = 'Equip'
		SpecialAction['Accessorize'](Character, false)
		if EquipTick == a then
			if HandWeld then HandWeld:Destroy() HandWeld = nil end
			local Torso = FindFirstChildOfNameAndClass(Character, "UpperTorso", "BasePart") or FindFirstChildOfNameAndClass(Character, "Torso", "BasePart")
			local RightArm = FindFirstChildOfNameAndClass(Character, "RightUpperArm", "BasePart") or FindFirstChildOfNameAndClass(Character, "Right Arm", "BasePart")
			if not HandWeld and Torso and RightArm then DefaultArmOffset = CFrame.new(Torso.Size.X/1.35,0,0)
				HandWeld = Instance.new("Weld", Character) HandWeld.Part1 = RightArm HandWeld.Part0 = Torso HandWeld.C0 = DefaultArmOffset
			end
			if EquipTick == a then
				AnimCoroutine = coroutine.create(function() 
					while Character and HandWeld and task.wait(.01) do
						DefaultArmOffset = CFrame.new(Torso.Size.X/1.35,0,0)
						if Anim == 'Equip' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(90),0,0),0.3) elseif Anim == 'Unequip' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(105),0,math.rad(-90)),0.3) elseif Anim == 'Charge' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(225),math.rad(15),math.rad(15)),0.3) elseif Anim == 'Throw' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(45),math.rad(-15),math.rad(-15)),0.3) elseif Anim == 'Raise' then HandWeld.C0 = HandWeld.C0:Lerp(DefaultArmOffset * CFrame.Angles(math.rad(180),0,0),0.3) end
					end
				end)
				coroutine.resume(AnimCoroutine)
			end
		end
	end,
['Unequipped'] = function()
	local a a = tick() EquipTick = a ActivationTick = a
	SpecialAction['Accessorize'](Character, true)
	Anim = 'Unequip'
	task.wait(0.5)
	if EquipTick  == a then if HandWeld then HandWeld:Destroy() HandWeld = nil end if AnimCoroutine then coroutine.close(AnimCoroutine) AnimCoroutine  = nil end end
end,
['Activated'] = function()
	local a a = tick() ActivationTick = a
end,
['Deactivated'] = function()
	local Delta = tick() - ActivationTick
	local a a = tick() ActivationTick = a
	if not Character or not Character.PrimaryPart then
		return
	end
	if Anim == 'Charge' then
		if Delta < 0.25 then 
			Anim = 'Raise'
			SpecialAction["Raise"]()
		else 
			SpecialAction["Throw"](Handle.CFrame + Character.PrimaryPart.CFrame.UpVector * Delta * 10 + Character.PrimaryPart.CFrame.LookVector * 70, math.clamp(Delta * 10, 0, 100))
			task.wait(0.1)
			ActivationTick = tick()
			Anim = 'Equip'	
		end
	elseif Anim == 'Equip' then
		if Delta < 0.25 then 
			SpecialAction["Raise"]()
		else 
			Anim = 'Charge'
		end	
	elseif Anim == 'Raise' then
		if Delta < 0.25 then 
			SpecialAction["Raise"]()
		end
	end
end,
}
Tool.Equipped:Connect(ConnectedEvent['Equipped'])
Tool.Unequipped:Connect(ConnectedEvent['Unequipped'])
Tool.Activated:Connect(ConnectedEvent['Activated'])
Tool.Deactivated:Connect(ConnectedEvent['Deactivated'])

--I'll never write a script on samsung note again, too many uppercase and "" mistakes]]></ProtectedString>

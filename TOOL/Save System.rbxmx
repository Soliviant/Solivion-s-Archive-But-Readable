local CreateNewFlag = function(Parent: Instance?, Color: (Color3 | BrickColor)?)
	if not Color then Color = Color3.new() end
	if Color and typeof(Color) == 'BrickColor' then
		Color = Color.Color
	end
	
	local Part = Instance.new("Part")
	Part.Anchored = true
	Part.BottomSurface = Enum.SurfaceType.Smooth
	Part.TopSurface = Enum.SurfaceType.Smooth
	Part.Color = Color3.fromRGB(99, 95, 98)
	Part.Material = Enum.Material.Metal
	Part.Size = Vector3.new(5.244999885559082, 0.14499998092651367, 2.1399998664855957)
	Part.CFrame = CFrame.new(81.2900390625, 2.622499942779541, 4.4049973487854, 0, 0, 1, 1, 0, 0, 0, 1, 0)
	Part.Shape = Enum.PartType.Cylinder

	local Wedge = Instance.new("WedgePart")
	Wedge.BottomSurface = Enum.SurfaceType.Smooth
	Wedge.Color = Color or Color3.fromRGB(196, 40, 28)
	Wedge.Material = Enum.Material.Fabric
	Wedge.Size = Vector3.new(0.04999999701976776, 0.9499999284744263, 2.3349997997283936)
	Wedge.CFrame = CFrame.new(81.29562377929688, 3.804999351501465, 5.649425029754639, 1, 0, 0, 0, -1, 0, 0, 0, -1)
	Wedge.Parent = Part

	local Wedge1 = Instance.new("WedgePart")
	Wedge1.BottomSurface = Enum.SurfaceType.Smooth
	Wedge1.Color = Color or Color3.fromRGB(196, 40, 28)
	Wedge1.Material = Enum.Material.Fabric
	Wedge1.Size = Vector3.new(0.04999999701976776, 0.9499999284744263, 2.3349997997283936)
	Wedge1.CFrame = CFrame.new(81.29562377929688, 4.749999046325684, 5.649425029754639, -1, 0, 0, 0, 1, 0, 0, 0, -1)
	Wedge1.Parent = Part

	local Wedge2 = Instance.new("Weld")
	Wedge2.Name = "Wedge"
	Wedge2.C0 = CFrame.new(0, -0.9449996948242188, 0, -1, 0, 0, 0, -1, 0, 0, 0, 1)
	Wedge2.Parent = Wedge1

	local Wedge3 = Instance.new("Weld")
	Wedge3.Name = "Wedge"
	Wedge3.C0 = CFrame.new(2.1274993419647217, 1.2444276809692383, 0.005584716796875, 0, 1, 0, 0, 0, -1, -1, 0, 0)
	Wedge3.Parent = Part

	Wedge2.Part1 = Wedge
	Wedge2.Part0 = Wedge1

	Wedge3.Part1 = Wedge1
	Wedge3.Part0 = Part
	
	if Parent then
		Part.Parent = Parent
	end
	return Part
end
local TAG = function(NewInstance: Instance)
	NewInstance:SetAttribute(FLAG.Name.. "_INSTANCE")
end
local VIEW
VIEW = function(Operation: string, Where: CFrame?)
	if not CHECKPOINT_VIEW or not Tool_Checkpoint_Selection then
		return
	end
	if not Char then
		return
	end
	if not Operation then
		return
	end
	if string.match(string.upper(Operation),'INITIATE') or string.match(string.upper(Operation),'INITIALIZE') then
		if not Where then
			return
		end
		if not AltChar then
			LatestPos = Char:GetPivot()
			if Char then
				if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
					Char:FindFirstChildOfClass('Humanoid').Jump = true
					Char:FindFirstChildOfClass('Humanoid').SeatPart = nil
					Char:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Seated, false)
				end
				Char:PivotTo(Where)
				Char.Archivable = true
				AltChar = Char:Clone()
				if AltChar and AltChar:FindFirstChildOfClass('Tool') then
					AltChar:FindFirstChildOfClass('Tool'):Destroy()
				end
				if AltChar and AltChar:FindFirstChildOfClass('Flag') then
					AltChar:FindFirstChildOfClass('Flag'):Destroy()
				end
				local function func(v: Instance)
					if v:IsA("Tool") or v:IsA("Flag") then
						if SaveDirectory and not SaveDirectory:FindFirstChild('Alt_Backpack') then
							Instance.new('Folder',SaveDirectory).Name = 'Alt_Backpack'
						end
						if AltChar and SaveDirectory and SaveDirectory:FindFirstChild('Alt_Backpack') and not SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name) then
							Instance.new('Folder',SaveDirectory:FindFirstChild('Alt_Backpack')).Name = AltChar.Name
						end
						if AltChar and SaveDirectory and SaveDirectory:FindFirstChild('Alt_Backpack') and SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name) then
							if v then
								v.Archivable = true
								local AltTool = SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name):FindFirstChild(v.Name) or v:Clone()
								AltTool.Parent = AltChar
								local ac: RBXScriptConnection?
								local dac: RBXScriptConnection?
								local function lilchecking()
									if not AltTool or not AltTool:IsDescendantOf(AltChar) or not v or not v:IsDescendantOf(Char) then if ac then ac:Disconnect() end if dac then dac:Disconnect() end if AltTool then AltTool:Destroy() end end
								end
								ac = v.Activated:Connect(function()
									if AltChar and AltTool then AltTool:Activate() end
								end)
								dac = v.Deactivated:Connect(function()
									if AltChar and AltTool then AltTool:Deactivate() end
								end)
								v.Unequipped:Once(function()
									if ac then ac:Disconnect() end if dac then dac:Disconnect() end if AltTool then if AltChar and SaveDirectory and SaveDirectory:FindFirstChild('Alt_Backpack') and SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name) then AltTool.Parent = SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name) else AltTool:Destroy() end end
								end)
							end
						end
					elseif v:IsA("BasePart") or v:IsA("Texture") or v:IsA("Decal") or v:IsA("ImageHandleAdornment") then
						v:SetAttribute("Transparency",v.Transparency) 
						v.Transparency = 1
						local Incase: RBXScriptConnection?
						Incase	= v:GetPropertyChangedSignal('Transparency'):Connect(function()
							if AltChar then
								v:SetAttribute("Transparency",v.Transparency)
								v.Transparency = 1
							else
								if Incase then
									Incase:Disconnect()
									Incase = nil
								end
							end
						end)
						if v:IsA("BasePart") then
							v:SetAttribute("CanCollide",v.CanCollide)
							v.CanCollide = false
							v:SetAttribute("CanTouch",v.CanTouch)
							v.CanTouch = false
							v:SetAttribute("CanQuery",v.CanQuery)
							v.CanQuery = false
							v:SetAttribute("CollisionGroup",v.CollisionGroup)
							v.CollisionGroup = CollisionGroupName
							local Incase2: RBXScriptConnection?
							Incase2= v:GetPropertyChangedSignal('CanCollide'):Connect(function()
								if AltChar then
									v:SetAttribute("CanCollide",v.CanCollide)
									v.CanCollide = false
								else
									if Incase2 then
										Incase2:Disconnect()
										Incase2 = nil
									end
								end
							end)
							local Incase3: RBXScriptConnection?
							Incase3 = v:GetPropertyChangedSignal('CanTouch'):Connect(function()
								if AltChar then
									v:SetAttribute("CanTouch",v.CanTouch)
									v.CanTouch = false
								else
									if Incase3 then
										Incase3:Disconnect()
										Incase3 = nil
									end
								end
							end)
							local Incase4: RBXScriptConnection?
							Incase4 = v:GetPropertyChangedSignal('CanQuery'):Connect(function()
								if AltChar then
									v:SetAttribute("CanQuery",v.CanQuery)
									v.CanQuery = false
								else
									if Incase4 then
										Incase4:Disconnect()
										Incase4 = nil
									end
								end
							end)
							local Incase5: RBXScriptConnection?
							Incase5 = v:GetPropertyChangedSignal('CanQuery'):Connect(function()
								if AltChar then
									v:SetAttribute("CollisionGroup",v.CollisionGroup)
									v.CollisionGroup = CollisionGroupName
								else
									if Incase5 then
										Incase5:Disconnect()
										Incase5 = nil
									end
								end
							end)
							table.insert(AllTheConnection, Incase2)
							table.insert(AllTheConnection, Incase3)
							table.insert(AllTheConnection, Incase4)
							table.insert(AllTheConnection, Incase5)
						end
						table.insert(AllTheConnection, Incase)
					elseif v:IsA("GuiMain") or v:IsA("ScreenGui") or v:IsA("BillboardGui") or v:IsA("SurfaceGui") or v:IsA("ParticleEmitter") or v:IsA('Trail') then	
						v:SetAttribute('Enabled',v.Enabled)
						v.Enabled = false
						local nope: RBXScriptConnection?
						nope = v:GetPropertyChangedSignal('Enabled'):Connect(function()
							if AltChar then
								v:SetAttribute("Enabled",v.Enabled)
								v.Enabled = false
							else
								if nope then
									nope:Disconnect()
									nope = nil
								end
							end
						end)
						table.insert(AllTheConnection, nope)
					elseif v:IsA("Sound") then	
						v:SetAttribute('Volume',v.Volume)
						v.Volume = 0
						local stfu: RBXScriptConnection?
						stfu = v:GetPropertyChangedSignal('Volume'):Connect(function()
							if AltChar then
								v:SetAttribute("Volume",v.Volume)
								v.Volume = 0
							else
								if stfu then
									stfu:Disconnect()
									stfu = nil
								end
							end
						end)
						table.insert(AllTheConnection, stfu)
					elseif v:IsA("Light") then	
						v:SetAttribute('Brightness',v.Brightness)
						v.Brightness = 0
						local shutitoff: RBXScriptConnection?
						shutitoff = v:GetPropertyChangedSignal('Brightness'):Connect(function()
							if AltChar then
								v:SetAttribute("Brightness",v.Brightness)
								v.Brightness = 0
							else
								if shutitoff then
									shutitoff:Disconnect()
									shutitoff = nil
								end
							end
						end)
						table.insert(AllTheConnection, shutitoff)
					elseif v:IsA("ForceField") or v:IsA('Explosion') then	
						v:SetAttribute('Visible',v.Visible)
						v.Visible = false
						local shutitoff: RBXScriptConnection?
						shutitoff = v:GetPropertyChangedSignal('Visible'):Connect(function()
							if AltChar then
								v:SetAttribute("Visible",v.Visible)
								v.Visible = false
							else
								if shutitoff then
									shutitoff:Disconnect()
									shutitoff = nil
								end
							end
						end)
						table.insert(AllTheConnection, shutitoff)
					end
				end
				for i,v in pairs(Char:GetDescendants()) do
					func(v)
				end
				if AltChar and Players and Players:GetPlayerFromCharacter(Char) then
					local Chatter: RBXScriptConnection?
					Chatter = Players:GetPlayerFromCharacter(Char).Chatted:Connect(function(Message,ToWho)
						if AltChar then
							if game:FindFirstChildOfClass('Chat') and game:FindFirstChildOfClass('TextService') and AltChar and AltChar:FindFirstChild('Head') and (not ToWho and game:FindFirstChildOfClass('Chat'):CanUserChatAsync(Players:GetPlayerFromCharacter(Char).UserId)) or (ToWho and game:FindFirstChildOfClass('Chat'):CanUsersChatAsync(Players:GetPlayerFromCharacter(Char).UserId,ToWho.UserId)) then
								if AltChar:GetAttribute('Curse') then Message = obscureString(Message) end game:FindFirstChildOfClass('Chat'):Chat(AltChar:FindFirstChild('Head'), (game:FindFirstChildOfClass('TextService'):FilterStringAsync(revertBypass(Message),Players:GetPlayerFromCharacter(Char).UserId ):GetNonChatStringForBroadcastAsync() or Message) , Enum.ChatColor.White)
							end
						else
							if Chatter then
								Chatter:Disconnect()
								Chatter = nil
							end
						end
					end)
					table.insert(AllTheConnection, Chatter)
				end
					if Char and Char:FindFirstChildOfClass('Humanoid') and AltChar and AltChar:FindFirstChildOfClass('Humanoid') then
						local Sync: RBXScriptConnection?
						Sync = AltChar:FindFirstChildOfClass('Humanoid').HealthChanged:Connect(function(Health)
							if not Char or not AltChar then
								if Sync then
									Sync:Disconnect()
									Sync = nil
									if VIEW then
										VIEW('end_task')
									end
								end	
							end
							if Char:FindFirstChildOfClass('Humanoid') then
								Char:FindFirstChildOfClass('Humanoid').Health = Health
							end
						end)
						table.insert(AllTheConnection, Sync)
				end

				local b = Char.DescendantAdded:Connect(func)
				if b then table.insert(AllTheConnection, b) end
				if AltChar then
					AltChar.Parent = workspace
					if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
						Char:FindFirstChildOfClass('Humanoid').Jump = true
					end
					AltChar:PivotTo(LatestPos)
					if AltChar:FindFirstChildOfClass('Humanoid') and AltChar:FindFirstChildOfClass('Humanoid').RootPart then
						--AltChar:FindFirstChildOfClass('Humanoid').RootPart.Anchored = true
						AltChar:FindFirstChildOfClass('Humanoid'):MoveTo(LatestPos.Position)
					end
					--if AltChar:FindFirstChildOfClass('Humanoid') and AltChar:FindFirstChildOfClass('Humanoid').RootPart then
						--AltChar:FindFirstChildOfClass('Humanoid').RootPart.Anchored = false
					--end
					coroutine.resume(coroutine.create(function()
						while task.wait(.01) and AltChar and Char do
							AltChar:FindFirstChildOfClass('Humanoid'):MoveTo(LatestPos.Position)
							if SavedPos and CurrentlySelectedSave and SavedPos[CurrentlySelectedSave] and SavedPos[CurrentlySelectedSave].CFrame and Char and  Char:FindFirstChildOfClass('Humanoid') and Char:GetPivot() ~= SavedPos[CurrentlySelectedSave].CFrame  then
								if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
									Char:FindFirstChildOfClass('Humanoid').Jump = true
									Char:FindFirstChildOfClass('Humanoid').SeatPart = nil
									Char:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Seated, false)
								end
								Char:PivotTo(SavedPos[CurrentlySelectedSave].CFrame--[[Char:GetPivot():Lerp(SavedPos[CurrentlySelectedSave].CFrame,0.3)]])
							end
						end
						Char:FindFirstChildOfClass('Humanoid'):SetStateEnabled(Enum.HumanoidStateType.Seated, true)
					end))
				end
				if Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').RootPart then
					Char:FindFirstChildOfClass('Humanoid').RootPart.Anchored = true
				end
			end
		end
	elseif string.match(string.upper(Operation),'MODIFY_LOCATION') then
		if not Where then
			return
		end
		if not AltChar then
			return
		end
		if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
			Char:FindFirstChildOfClass('Humanoid').Jump = true
		end
		Char:PivotTo(Where)
	elseif string.match(string.upper(Operation),'END_TASK') then
		for i,v in AllTheConnection do
			if v and typeof(v) == 'RBXScriptConnection' then
				v:Disconnect()
				--table.remove(AllTheConnection,i)
			end
		end
		for i,v in pairs(Char:GetDescendants()) do
			if v:GetAttribute("Transparency") then
				v.Transparency = v:GetAttribute("Transparency")
			end
			if v:GetAttribute("CanCollide") then
				v.CanCollide = v:GetAttribute("CanCollide")
			end
			if v:GetAttribute("CanTouch") then
				v.CanTouch = v:GetAttribute("CanTouch")
			end
			if v:GetAttribute("CanQuery") then
				v.CanQuery = v:GetAttribute("CanQuery")
			end
			if v:GetAttribute("CollisionGroup") then
				v.CollisionGroup = v:GetAttribute("CollisionGroup")
			end
			if v:GetAttribute("Enabled") then
				v.Enabled = v:GetAttribute("Enabled")
			end
			if v:GetAttribute("Visible") then
				v.Visible = v:GetAttribute("Visible")
			end
			if v:GetAttribute("Volume") then
				v.Volume = v:GetAttribute("Volume")
			end
			if v:GetAttribute("Brightness") then
				v.Brightness = v:GetAttribute("Brightness")
			end
		end
		--[[if LatestPos then
			Char:PivotTo(LatestPos)
		else
			if AltChar then
				LatestPos = AltChar:GetPivot()
				Char:PivotTo(AltChar:GetPivot())
			end
		end]]
		if AltChar then
			LatestPos = AltChar:GetPivot()
			if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
				Char:FindFirstChildOfClass('Humanoid').Jump = true
			end
			Char:PivotTo(AltChar:GetPivot())
		else
			if LatestPos then
				if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
					Char:FindFirstChildOfClass('Humanoid').Jump = true
				end
				Char:PivotTo(LatestPos)
			end
		end
		if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').RootPart then
			Char:FindFirstChildOfClass('Humanoid').RootPart.Anchored = false
		end
		if AltChar and SaveDirectory and SaveDirectory:FindFirstChild('Alt_Backpack') and SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name) then
			SaveDirectory:FindFirstChild('Alt_Backpack'):FindFirstChild(AltChar.Name):Destroy()
		end
		if AltChar then
			AltChar:Destroy()
			AltChar = nil
		end
	end
end
local TP = function(Id: number)
	if State == 'Loading' then
		if not Tool_Checkpoint_Selection then
			Id = #SavedPos
		end
		if State ~= 'Loading' then
			return
		end
		if SavedPos[Id] and SavedPos[Id].CFrame then
			if Char ~= nil and Char.Parent ~= nil and Char:IsA("Model") then
				if Char and Char:FindFirstChildOfClass('Humanoid') and Char:FindFirstChildOfClass('Humanoid').SeatPart ~= nil then
					Char:FindFirstChildOfClass('Humanoid').Jump = true
				end
				Char:PivotTo(SavedPos[Id].CFrame)
			end
		end
	end
end
local SAVE = function(Pos: CFrame | Vector3, Name: string?, Des: string?, Colour: BrickColor?)
	if State ~= 'Saving' then
		return
	end
	if not Char then
		return
	end
	State = 'Saving'
	local SaveFlagAttachments: {any} = {}
	local SaveFlag = CreateNewFlag(workspace, BrickColor.random())
	if game:FindFirstChildOfClass('Debris') then
		game:FindFirstChildOfClass('Debris'):AddItem(SaveFlag,60)
	end
	SaveFlag.Anchored = true
	SaveFlag.Parent = workspace
	SaveFlag:PivotTo(Char:GetPivot() * CFrame.Angles(0,0,math.rad(90)) + Vector3.new(0,2.5,0))
	for i,v in FlagAttachmentList do
		local attachment = Instance.new('Attachment', SaveFlag)
		attachment.CFrame = v
		attachment.Visible = false
		local serial = #SaveFlagAttachments + 1
		SaveFlagAttachments[serial] = {}
		SaveFlagAttachments[serial].Attachment = attachment
		SaveFlagAttachments[serial].LastPosition = attachment.WorldPosition
	end
	local SaveRayPar = RaycastParams.new()
	SaveRayPar.FilterDescendantsInstances = PhysicalFlag
	SaveRayPar.IgnoreWater = true
	SaveRayPar:AddToFilter(Char)
	SaveRayPar:AddToFilter(FLAG)
	SaveRayPar:AddToFilter(SaveFlag)
	SaveRayPar.RespectCanCollide = true
	SaveRayPar.FilterType = Enum.RaycastFilterType.Exclude
	table.insert(PhysicalFlag, SaveFlag)
	local RaycastSalt: RaycastResult
	for i = 1, 20 do
		for num,v in pairs(SaveFlagAttachments) do
			RaycastSalt = workspace:Raycast(v.Attachment.WorldPosition,v.LastPosition - v.Attachment.WorldPosition, SaveRayPar) or workspace:Raycast(v.LastPosition,v.Attachment.WorldPosition - v.LastPosition, SaveRayPar) -- or workspace:Raycast(v.Attachment.WorldPosition,Vector3.new(0,-0.5,0), SaveRayPar)
			if RaycastSalt then
				break
			end
		end
		if RaycastSalt then
			break
		end
		SaveFlag.CFrame = SaveFlag.CFrame + Vector3.new(0,-0.5,0)
		task.wait(0.025)
	end
	table.clear(SaveFlagAttachments)
	for i,v in pairs(SaveFlagAttachments)  do 
		if v and v.Attachment then
			v.Attachment:Destroy()
		end
		v = nil
	end
	if RaycastSalt then
		SaveFlag.Anchored = true
		FLAG.ToolTip = 'Successfully Saved'
	else
		SaveFlag.Anchored = false
		if game:FindFirstChildOfClass('Debris') then
			game:FindFirstChildOfClass('Debris'):AddItem(SaveFlag,1)
		else
			coroutine.resume(coroutine.create(function()
				task.wait(1)
				if SaveFlag then SaveFlag:Destroy() end
			end))
		end
		for i,v in pairs(SaveFlag:GetDescendants()) do
			if v and v:IsA('BasePart') and game:FindFirstChildOfClass('TweenService') then	game:FindFirstChildOfClass('TweenService'):Create(v,TweenInfo.new(1), {Transparency = 1}):Play() end
		end
		if game:FindFirstChildOfClass('TweenService') then	game:FindFirstChildOfClass('TweenService'):Create(SaveFlag,TweenInfo.new(1), {Transparency = 1}):Play() end
		FLAG.ToolTip = 'Saving Unsuccessful, Please make sure you are standing on a solid ground'
		return
	end
	local SaveDT = os.date()
	local Directory_Slot: number = #SavedPos + 1
	if not SavedPos[Directory_Slot] then SavedPos[Directory_Slot] = {} end
	local Directory = SavedPos[Directory_Slot]
	Directory.CFrame = (typeof(Pos) == 'CFrame' and Pos) or (typeof(Pos) == 'Vector3' and CFrame.new(Pos)) or CFrame.new()
	Directory.Serial = Directory_Slot
	Directory.Date = SaveDT
	Directory.FlagPart = SaveFlag
	if Name then
		Directory.Name = Name
	else
		Directory.Name = Checkpoint_Placeholder_Name
	end
	if Des then
		Directory.Description = Des
	end
	if Colour then
		Directory.Colour = Colour 
	else
		Directory.Colour = BrickColor.random() 
	end
	--Export File To [SaveDirectory]
	if not SaveDirectory then
		return
	end
	if SaveDirectory and not SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE") then
		local Folder = Instance.new('Folder')
		Folder.Parent = SaveDirectory
		Folder.Name = FLAG.Name.. "_SAVE"
		TAG(Folder)
	end
	if SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE") and not SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name) then
		local Folder = Instance.new('Folder')
		Folder.Parent = SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE")
		Folder.Name = (Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name
		TAG(Folder)
	end
	if SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE") and SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name) then
		local SaveFile = Instance.new('CFrameValue')
		SaveFile.Parent = SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name)
		SaveFile.Name = tostring(Directory_Slot) or tostring(#SaveDirectory:FindFirstChild(FLAG.Name.. "_SAVE"):FindFirstChild((Players and Players:GetPlayerFromCharacter(Char) and Players:GetPlayerFromCharacter(Char).Name) or Char.Name):GetChildren() + 1)
		LatestSave = tonumber(SaveFile.Name)
		if Name ~= nil then
			SaveFile:SetAttribute('Name',Name)
		else
			SaveFile:SetAttribute('Name',Checkpoint_Placeholder_Name)
		end
		if Pos ~= nil then
			if typeof(Pos) == 'Vector3' then
				SaveFile.Value = CFrame.new(Pos)
			elseif typeof(Pos) == 'CFrame' then
				SaveFile.Value = Pos
			end
		else
			SaveFile.Value = Char:GetPivot()
		end
		if Des ~= nil then
			SaveFile:SetAttribute("Description", Des)
		end
		if Directory.Colour then
			SaveFile:SetAttribute("Colour", Directory.Colour)
		else
			if Colour ~= nil then
				SaveFile:SetAttribute("Colour", Colour)
			else
				SaveFile:SetAttribute("Colour", BrickColor.random())
			end
		end
		SaveFile:SetAttribute('Date', SaveDT)
		SaveFile:SetAttribute('Serial', tonumber(Directory_Slot or SaveFile.Name))
		TAG(SaveFile)
	end
	State = 'Saving'
	FLAG.ToolTip = 'Saved!'
end
local WELD = function(Operation: string, Weld: string?)
	if string.match(string.upper(Operation),'INITIATE') then
		for i,v in Char:GetDescendants() do
			if v:IsA("Motor6D") then
				local Replica = Instance.new('Weld')
				Replica.Part0 = v.Part0
				Replica.Part1 = v.Part1
				Replica.C0 = v.C0
				Replica.C1 = v.C1
				Replica.Enabled = false
				Replica.Parent = v.Parent
				table.insert(AllTheWeld, Replica)
			end
		end
	elseif string.match(string.upper(Operation),'ENABLE') then
		if not Weld then
			return
		end
		if table.find(AllTheWeld, Weld) and AllTheWeld[table.find(AllTheWeld, Weld)] and AllTheWeld[table.find(AllTheWeld, Weld)]:IsA("JointInstance") then
			AllTheWeld[table.find(AllTheWeld, Weld)].Enabled = true -- if you want it to detect every single weld with the name provided as an variable 'Weld', please instead use 'for i, v in AllTheWeld' or sort weld with same name as a sub table.
		end
	elseif string.match(string.upper(Operation),'DISABLE') then
		if not Weld then
			return
		end
		if table.find(AllTheWeld, Weld) and AllTheWeld[table.find(AllTheWeld, Weld)] and AllTheWeld[table.find(AllTheWeld, Weld)]:IsA("JointInstance") then
			AllTheWeld[table.find(AllTheWeld, Weld)].Enabled = false
		end
	elseif string.match(string.upper(Operation),'END_TASK') then
		for i,v in AllTheWeld do
			if v and typeof(v) == 'Instance' and v:IsA("JointInstance") then
				v:Destroy()
				--table.remove(AllTheWeld, i)
			end
		end
		table.clear(AllTheWeld)
	end
end
local ANIMFRAME = function(Name: string, Frame: number)
	if table.find(Anim,Name) and Anim[table.find(Anim,Name)] and Anim[table.find(Anim,Name)][Frame] then
		for i,v in pairs(Anim[table.find(Anim,Name)][Frame]) do
			if table.find(AllTheWeld,i) and game:FindFirstChildOfClass('TweenService') and AllTheWeld[table.find(AllTheWeld,i)] then
				local Tween = game:FindFirstChildOfClass('TweenService'):Create(AllTheWeld[table.find(AllTheWeld,i)], (typeof(v) == 'CFrame' and TweenInfo.new(0.5)) or TweenInfo.new(v.time or 0.5, v.easingStyle or Enum.EasingStyle.Linear, v.easingDirection or Enum.EasingDirection.Out),{C0 = (typeof(v) == 'CFrame' and v) or v.CFrame or CFrame.new()} )
				table.insert(AllTheTween, Tween)
				Tween.Completed:Connect(function(PBS)
					if PBS == Enum.PlaybackState.Completed or PBS == Enum.PlaybackState.Cancelled then
						if Tween and table.find(AllTheTween, Tween) then
							table.remove(AllTheTween,table.find(AllTheTween, Tween))
						end
					end
				end)
			end
		end
	end
end

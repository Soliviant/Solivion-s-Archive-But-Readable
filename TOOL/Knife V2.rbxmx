		DropOpponentsLootOnKill = script:GetAttribute("DropOpponentsLootsOnKill")
	end
	if script:GetAttribute("DropOpponentsToolOnRagdoll") then
		DropOpponentstoolOnRagdoll = script:GetAttribute("DropOpponentsToolOnRagdoll")
	end

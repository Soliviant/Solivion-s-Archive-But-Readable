local AllowPercentagedDamage =  true 		--Maybe The World Isn't That Cruel Afterall
local Character							-- Apparently Should Be Left Alone
local DropOpponentstoolOnRagdoll = false	-- Removed
local DropOpponentsLootOnKill = true		-- Removed
local Curseable = true					-- Removed
local DebugMode = false					-- Debug
local Glitch = true						-- Removed
local MislayChance = 20					-- You Dropped The Knife, So You Get A New One. visual appeal

if not script:GetAttribute("Enable_Glitchy_Effect") then
	script:SetAttribute("Enable_Glitchy_Effect",Glitch)	-- Nope, U Need It
end
if script:GetAttribute("Use_This_Setting") and script:GetAttribute("Use_This_Setting") == true then
	if script:GetAttribute("MaxCharge") then
		MaxCharge = script:GetAttribute("MaxCharge")
	end
	if script:GetAttribute("LowestChargeRequirement") then
		LowestChargeRequirement = script:GetAttribute("LowestChargeRequirement")
	end

			RootJoint = {CFrame.new(0, 0, 0) * CFrameAngles(15, 165, 0), 0.1},
			Root = {CFrame.new(0, 0, 0) * CFrameAngles(15, 165, 0), 0.1},
			RootHip = {CFrame.new(0, 0, 0) * CFrameAngles(15, 165, 0), 0.1}
		},
		Frame3 = {-- Supposedly Third Frame
			LeftShoulder = {CFrame.new(-0.5, 0.5, -1.5) * CFrameAngles(0, -110, -75),0.1},
			RightShoulder = {CFrame.new(1, 0.5, -1.5) * CFrameAngles(40.604, 65.731, 40.708), 0.1},
			GripWeld = {CFrame.new(-0.25, -1.5, 0) * CFrameAngles(30, 30, -30),0.1},
			RootJoint = {CFrame.new(0, 0, 0) * CFrameAngles(15, 45, 0), 0.1},
			RootHip = {CFrame.new(0, 0, 0) * CFrameAngles(15, 45, 0), 0.1},
			Root = {CFrame.new(0, 0, 0) * CFrameAngles(15, 45, 0), 0.1}
		} -- You Can Actually Add Your own Animation lol, And Yeah. The Animator Is pretty Bad. Don't Move To The Next Frame Too Early, I Warned You.
	}
}

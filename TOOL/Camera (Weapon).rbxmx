				<Properties>
					<ProtectedString name="Source"><![CDATA[--Solivion
--!strict
--Things Are Constantly Checked Not To Be Nil, So Dont Worry Much About Those Warnings.
if script:FindFirstAncestorOfClass("Actor") then
	task.synchronize()
end
local ServerStorage: ServerStorage = game:GetService("ServerStorage")
local Debris: Debris = game:GetService("Debris")
local Players: Players = game:GetService("Players")
--print("Cam V1 Initiated")
if script:FindFirstAncestorOfClass("Actor") then
	task.desynchronize()
end

function RGBtoMonochrome(color:Color3 | any)
	if typeof(color) == "BrickColor" then
		color = color.Color
	end
	local r, g, b = math.round(color.R*255), math.round(color.G*255), math.round(color.B*255)
	local sRgrey, sGgrey, sBgrey = math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255), math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255), math.min(math.pow((math.pow(r/255.0,2.2)*0.2126+math.pow(g/255.0,2.2)*0.7152+math.pow(b/255.0,2.2)*0.0722),0.454545)*255,255)
	return Color3.new(sRgrey/255, sGgrey/255, sBgrey/255)
end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	if script:FindFirstAncestorOfClass("Actor") then
		task.desynchronize()
	end
	local Found: boolean = false
	if Where == nil then
		return
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v:IsA("BasePart")) then
				return v
			end
		end
	end
end

local GotFlashed = {} -- I Don No Haw 2 Type Chec Dis.
local SavedShots: {CFrame} = {}
local CorouteRecord: thread | any
local RecordNewConnect: RBXScriptConnection?
local ScenerySize: Vector3 = Vector3.new(100,100,100)
local Tool: Tool = script:FindFirstAncestorOfClass("Tool")
local Handle: Instance | BasePart = Tool:FindFirstChildOfClass("BasePart") or Tool:FindFirstChild("Handle")
if not Tool or not Handle then
	repeat task.wait(.01) if Tool and Handle then --[[print("Found Both")]] break end until false
end
local StartingTick: number = tick()
local ActivatedTick: number = tick()
local starttime: number = tick()
local Enabled: boolean = false
local Activated:boolean = false
local Cooldown: boolean = false
local WeldR: Instance & JointInstance
local WeldL: Instance & JointInstance
local ExpectedChar: Model
local Allowed:boolean = false
if script:FindFirstAncestorOfClass("Actor") then
	task.synchronize()
end
if Tool then
	WeldL = Handle:FindFirstChild("RightWeld") or Instance.new("Snap")
	WeldL.Name = "RightWeld"
	WeldL.Parent = Handle
	WeldR = Handle:FindFirstChild("LeftWeld") or Instance.new("Snap")
	WeldR.Name = "LeftWeld"
	WeldR.Parent = Handle
	Tool.Activated:Connect(function()
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Cooldown then
			return
		end
		ExpectedChar = script:FindFirstAncestorOfClass("Model")
		if not ExpectedChar then
			return
		end
		--print(ExpectedChar:GetFullName())
		local Torso: BasePart | nil = FindFirstChildOfNameAndClass(ExpectedChar,"UpperTorso","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Torso","BasePart")  or FindFirstChildOfNameAndClass(ExpectedChar,"HumanoidRootPart","BasePart")
		local RArm: BasePart | nil =	FindFirstChildOfNameAndClass(ExpectedChar,"RightUpperArm","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Right Arm","BasePart")
		local LArm: BasePart | nil = FindFirstChildOfNameAndClass(ExpectedChar,"LeftUpperArm","BasePart") or FindFirstChildOfNameAndClass(ExpectedChar,"Left Arm","BasePart")
		if script:FindFirstAncestorOfClass("Actor") then
			task.synchronize()
		end
		if Torso then
			if WeldR and LArm then
				WeldR.Part0 = Torso
				--print("Current LARM:".. LArm:GetFullName())
				WeldR.Part1 = LArm
			end
			if WeldL and RArm then
				WeldL.Part0 = Torso
				--print("Current RArm:".. RArm:GetFullName())
				WeldL.Part1 = RArm
			end
		end
		if WeldL then
			WeldL.Enabled = true
		end
		if WeldR then
			WeldR.Enabled = true
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Tool == nil or Handle == nil then
			return -- no tool, no handle. what the hell, how is the script still here
		end
		Activated = true
		ActivatedTick = tick()
		Enabled = true
		if CorouteRecord then
			coroutine.close(CorouteRecord)
			CorouteRecord = nil :: any
		end
		--print("Initializing Thread")
		--[[CorouteRecord = coroutine.create(function()
			print("Creating A Part!")
			if script:FindFirstAncestorOfClass("Actor") then
				task.synchronize()
			end
			if ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) then
				ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()):Destroy()
			end
			local newpart: Instance | BasePart = ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) or Instance.new("Part")
			newpart.Parent = ServerStorage
			newpart.CanTouch = false
			newpart.CanCollide = false
			newpart.CanQuery = false
			newpart.Name = "Cam_Rec_"..Tool:GetFullName()
			newpart.Size = ScenerySize
			newpart.Anchored = true
			if newpart and Handle then
				newpart.CFrame = Handle.CFrame + Vector3.new(ScenerySize.X/2,ScenerySize.Y/2,ScenerySize.Z/2)
				newpart.Transparency = 1
			end
			local SavedWorldState = Instance.new("Folder",ServerStorage)
			SavedWorldState.Name = "WorldRecording_Asset_"..tostring(tick())
			for i,v in workspace:GetChildren() do
				if not v:IsA("Terrain") then
					if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end
				end
			end
			if RecordNewConnect then
				RecordNewConnect:Disconnect()
				RecordNewConnect = nil
			end
			RecordNewConnect = game.DescendantAdded:Connect(function(v)
				if not v:IsDescendantOf(SavedWorldState) then if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end end
			end)
			--print("Thread Ran!")
			--Insert Ur Logic If The Player Is Still Activating The Tool
			while task.wait(0.05) do
				if not Activated or not Enabled then
					if newpart then
						newpart:Destroy()
					end
					if RecordNewConnect then
						RecordNewConnect:Disconnect()
						RecordNewConnect = nil
					end
					break
				end
				if newpart and Handle then
					newpart.CFrame = Handle.CFrame + Vector3.new(ScenerySize.X/2,ScenerySize.Y/2,ScenerySize.Z/2) * Handle.CFrame.LookVector
					--newpart.Transparency = 1
				end
				for i,v in workspace:GetPartsInPart(newpart) do
					if not ServerStorage:FindFirstChild("AssetStorage") then
						local NewFolder = Instance.new("Folder")
						NewFolder.Name = "AssetStorage"
					end
				end
				--print("Recording System Missing!") -- Add System Here. I'm Too Lazy
			end
			--print("Thread End!")
			if newpart then
				newpart:Destroy()
			end
		end)]]
		CorouteRecord = coroutine.create(function()
			Allowed = false
			starttime = tick()
			while task.wait(0.01) and Activated and Enabled do
				if script:FindFirstAncestorOfClass("Actor") then
					task.desynchronize()
				end
				if not Activated or not Enabled then
					if WeldL then
						WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
						WeldL.Enabled = false
					end
					if WeldR then
						WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
						WeldR.Enabled = false
					end
					task.wait(.01)
					break
				end
				--tick() - ActivatedTick
				if tick() - starttime > 0.5 then
					if not Cooldown then
						Allowed = true
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.4,-0.5,-0.5) * CFrame.Angles(math.rad(-45+150),0,0), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					if tick() - starttime > 0.6 then
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-0.05,-0.45,-0.75) * CFrame.Angles(math.rad(-45+160),math.rad(10),math.rad(50)), math.clamp((tick() - ActivatedTick)/ 1.1,0,0.9))
						end
					else
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-0.1,-0.2,-0.55) * CFrame.Angles(math.rad(-45+165),math.rad(10),math.rad(75)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.7))
						end
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(0)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5) )
				elseif tick() - starttime > 0.4 then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.1,-0.5,-0.5) * CFrame.Angles(math.rad(-45+140),math.rad(10),math.rad(10)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					if WeldR then
						WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-0.9,-0.25,-0.45) * CFrame.Angles(math.rad(-45+170),math.rad(10),math.rad(40)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.7))
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(-10), 0, 0), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5) )
				elseif tick() - starttime > 0.3 then
					--[[local SavedWorldState = Instance.new("Folder",ServerStorage)
					SavedWorldState.Name = "WorldRecording_Asset_"..tostring(tick())
					for i,v in workspace:GetChildren() do
						if not v:IsA("Terrain") then
							if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end
						end
					end
					if RecordNewConnect then
						RecordNewConnect:Disconnect()
						RecordNewConnect = nil
					end
					RecordNewConnect = game.DescendantAdded:Connect(function(v)
						if not v:IsDescendantOf(SavedWorldState) then if v.Archivable == false then v.Archivable = true v:SetAttribute("ChangeBack",false) end 	local cloen = v:Clone() if cloen then cloen.Parent = SavedWorldState end if v and v:GetAttribute("ChangeBack") then v.Archivable = v:GetAttribute("ChangeBack") v:SetAttribute("ChangeBack",nil) end end
					end)]]
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.25,-0.5,-0.5) * CFrame.Angles(math.rad(-45+120),math.rad(-15),math.rad(-5)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					if WeldR then
						WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.25,-0.3,-0.5) * CFrame.Angles(math.rad(-45+180),math.rad(-10),math.rad(45)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.3, 0.65) * CFrame.Angles(math.rad(45), 0, 0), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5) )
				elseif tick() - starttime > 0.2 then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.75,-0.5,0.25) * CFrame.Angles(math.rad(-45),math.rad(-20),math.rad(-20)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					if WeldR then
						WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.75,-0.2,-0.7) * CFrame.Angles(math.rad(-45+180),math.rad(-20),math.rad(50)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.3, 0.65) * CFrame.Angles(math.rad(30), 0, 0), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5) )
				else
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.5,-0.5,-0.25) * CFrame.Angles(math.rad(-45),math.rad(10),math.rad(20)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					if WeldR then
						WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.5,-0.25,0.25) * CFrame.Angles(math.rad(-45+140),math.rad(10),math.rad(-10)), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5))
					end
					Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.1, -0.25, 0.75) * CFrame.Angles(math.rad(-25), 0, 0), math.clamp((tick() - ActivatedTick)/ 1.25,0,0.5) )
				end
			end
			if not Activated or not Enabled then
				if WeldL then
					WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
					WeldL.Enabled = false
				end
				if WeldR then
					WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
					WeldR.Enabled = false
				end
				task.wait(.01)
			end
		end)
		--print("Thread Initialized")
		coroutine.resume(CorouteRecord)
		--[[while task.wait(.01) do
			if coroutine.status(CorouteRecord) == "dead" and not Activated and Allowed == false then
				if WeldL then
					WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.5,0,0) * CFrame.Angles(0,0,0), math.clamp((tick() - starttime)/ 0.75,0,0.5))
				end
				if WeldR then
					WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0), math.clamp((tick() - starttime)/ 0.75,0,0.5))
				end
				if WeldL.C0 == CFrame.new(1.5,0,0) * CFrame.Angles(0,0,0) and WeldR.C0 ==CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0) then
					WeldL.Enabled = false
					WeldR.Enabled = false
					break
				end
			else
				break
			end
		end]]
	end)
	Tool.Deactivated:Connect(function()
		Activated = false
		if CorouteRecord then
			coroutine.close(CorouteRecord)
			CorouteRecord = nil
		end
		if not Allowed then
			task.wait(0.05)
			if WeldL then
				WeldL.C0 = CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40))
				--WeldL.Enabled = false
			end
			if WeldR then
				WeldR.C0 = CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0)
				WeldR.Enabled = false
			end
			Tool.Grip = CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(90))
			return
		else
			Allowed = false
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.synchronize()
		end
		if RecordNewConnect then
			RecordNewConnect:Disconnect()
			RecordNewConnect = nil
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if not ExpectedChar then
			return
		end
		if ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()) then
			if script:FindFirstAncestorOfClass("Actor") then
				task.synchronize()
			end
			ServerStorage:FindFirstChild("Cam_Rec_"..Tool:GetFullName()):Destroy()
		end
		if script:FindFirstAncestorOfClass("Actor") then
			task.desynchronize()
		end
		if Tool == nil or Handle == nil then
			return -- no tool, no camera. what the hell, how is the script still here
		end
		if Cooldown then
		--	print("Activation On Cooldown")
			return
		else
		--	print("Activation Completed")
			Cooldown = true
			--if tick() - ActivatedTick < 0.25 and Enabled then
				StartingTick = tick()
				Enabled = false
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				local Flashbang = Instance.new("PointLight",Handle)
				Flashbang.Color = Color3.new(1,1,1)
				Flashbang.Range = 20
				Flashbang.Brightness = 10
				local Hitbox = Instance.new("Part",workspace)
				Hitbox.Transparency = 1
				Hitbox.Material = Enum.Material.Glass
				Hitbox.CanCollide = false
				Hitbox.CanQuery = false
				Hitbox.Massless = true
				Hitbox.Anchored = true
				Hitbox.Shape = Enum.PartType.Ball
				Hitbox.Size = Vector3.new(Flashbang.Range,Flashbang.Range,Flashbang.Range) 
				Debris:AddItem(Hitbox, 0.51)
				local ExecuteSoon = {}
				if script:FindFirstAncestorOfClass("Actor") then
					task.desynchronize()
				end
				for i,v in workspace:GetPartsInPart(Hitbox) do
					if v.Name == "Head" and not v:IsDescendantOf(Tool:FindFirstAncestorOfClass("Model")) and v:FindFirstAncestorOfClass("Model") and v:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") then
						table.insert(ExecuteSoon,v)
					end
				end
				if script:FindFirstAncestorOfClass("Actor") then
					task.synchronize()
				end
				local hi = Instance.new("Highlight",Hitbox)
				hi.Enabled = false
				coroutine.resume(coroutine.create(function()
					while task.wait(.01) do
						if script:FindFirstAncestorOfClass("Actor") then
							task.desynchronize()
						end
						if tick() - StartingTick >= 0.5 then
							if Flashbang then
								if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								Flashbang:Destroy()
							end
							if Hitbox then
								if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								Hitbox:Destroy()
							end
							break
						end 
						if script:FindFirstAncestorOfClass("Actor") then
							task.desynchronize()
						end
						if not Flashbang then
							break
						end
						if not Hitbox then
							break
						end
						local CurStep = tick() - StartingTick
						if script:FindFirstAncestorOfClass("Actor") then
							task.synchronize()
						end
						if WeldL then
							WeldL.C0 = WeldL.C0:Lerp(CFrame.new(1.5,0,-0.5) * CFrame.Angles(math.rad(70),math.rad(75),math.rad(40)), math.clamp((tick() - StartingTick)/ 1.5,0,0.5))
						end
						if WeldR then
							WeldR.C0 = WeldR.C0:Lerp(CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0), math.clamp((tick() - StartingTick)/ 1.5,0,0.5))
						end
						Tool.Grip = Tool.Grip:Lerp(CFrame.new(0.15, 0.1, 0.5) * CFrame.Angles(math.rad(10), 0, math.rad(90)), math.clamp((tick() - StartingTick)/ 1.25,0,0.5) )
						if WeldL.C0 == CFrame.new(1.5,0,0) * CFrame.Angles(0,0,0) and WeldR.C0 ==CFrame.new(-1.5,0,0) * CFrame.Angles(0,0,0) then
							WeldL.Enabled = false
							WeldR.Enabled = false
						end
						Flashbang.Brightness = 10 - (CurStep * 20)
						Flashbang.Range = 20 - (CurStep * 40)
						Hitbox.Transparency = 1 + CurStep*2
						Hitbox.Position = Handle.Position
						Hitbox.Size = Vector3.new(Flashbang.Range,Flashbang.Range,Flashbang.Range) 
					if Flashbang.Range <= 0 or Flashbang.Brightness <= 0 or not Tool:FindFirstAncestorWhichIsA("Model") then
							if Flashbang then
								Flashbang:Destroy()
							end
							if Hitbox then
								Hitbox:Destroy()
							end
						end
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					task.wait(0.25)
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					if WeldL then
						--WeldL.Enabled = false
					end
					if WeldR then
						WeldR.Enabled = false
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					table.clear(GotFlashed)
					Cooldown = false
				end))
				local function Flashed(Part:BasePart)
					if Part == nil then
						return
					end
					if script:FindFirstAncestorOfClass("Actor") then
						task.desynchronize()
					end
					if Part and not Part:IsDescendantOf(Tool:FindFirstAncestorOfClass('Model')) and (Part.Name == "Head" or Part.Name == "HumanoidRootPart") and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and not GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
						GotFlashed[Part:FindFirstAncestorOfClass("Model")] = "Flashed Lmaooooo"
						coroutine.resume(coroutine.create(function()
							local Began: number = tick()
							local saved: Player?
							local BangMain: GuiMain | ScreenGui
							local BangFrame: Frame
							while task.wait(.01) do
								local Ouch = tick() - Began
								if script:FindFirstAncestorOfClass("Actor") then
									task.synchronize()
								end
								if Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")) then
									if not BangMain  then
										local saved = Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model"))
										BangMain = Instance.new("GuiMain",Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")):FindFirstChildOfClass("PlayerGui")) :: GuiMain BangFrame = Instance.new("Frame",BangMain) :: Frame
										BangMain.Name = "PtCAbu7oLuCTNzVSsVq4tJGnqUhXVF>>"..Tool.Parent.Name
										Debris:AddItem(BangMain, 1.01)
									end
									if not saved or saved.Character ~= Part:FindFirstAncestorOfClass("Model")  then
										if Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")) then
											saved = Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model"))
											if not BangMain then
												BangMain = Instance.new("GuiMain",Players:GetPlayerFromCharacter(Part:FindFirstAncestorOfClass("Model")):FindFirstChildOfClass("PlayerGui")) :: GuiMain BangFrame = Instance.new("Frame",BangMain) :: Frame
												BangMain.Name = "PtCAbu7oLuCTNzVSsVq4tJGnqUhXVF>>"..Tool.Parent.Name
												Debris:AddItem(BangMain, 1.01)
											end
										else
										--[[	if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
												GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
											end
											break]]
										end
									end
									if not BangMain then
										return
									end

									if Ouch >= 1 then
										if BangMain then
											BangMain:Destroy()
										end
										if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
											GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
										end
										break
									end
									if BangMain and BangFrame then
										BangFrame.Size = UDim2.fromScale(1,1)
										BangFrame.Transparency = Ouch
										BangMain.IgnoreGuiInset = true
										BangFrame.Visible = true
										BangFrame.ZIndex = 99
										BangFrame.Selectable = true
										BangFrame.BackgroundColor3 = Color3.new(1-Ouch,1-Ouch,1-Ouch)
									end
								end 
								if Part and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and Ouch <= 0.5 then  
									--local random1B = Random.new():NextInteger(-1,1)
									--local random2B = Random.new():NextInteger(-1,1)
									if script:FindFirstAncestorOfClass("Actor") then
										task.desynchronize()
									end
									local random1 = Random.new():NextInteger((1 - Ouch) * -1500,(1 - Ouch) * 1500)--[[*random1B]]/100
									local random2 = Random.new():NextInteger((1 - Ouch) * -1500,(1 - Ouch) * 1500)--[[*random2B]]/100
									if script:FindFirstAncestorOfClass("Actor") then
										task.synchronize()
									end
									Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part:FindFirstAncestorOfClass("Model"):GetPivot().Position * Vector3.new(math.clamp(random1, 1, math.huge) ,0,math.clamp(random2, 1, math.huge)))
									if Ouch <= 1 then
										--Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part:FindFirstAncestorOfClass("Model"):GetPivot().Position)
										--Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid").Jump = true
									end
								elseif Part and Part:FindFirstAncestorOfClass("Model") and Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") and Ouch > 0.5 then
									if Ouch < 0.55 then
										Part:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid"):MoveTo(Part.Position)
									end
								end
							end
							if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
								GotFlashed[Part:FindFirstAncestorOfClass("Model")] = nil
							end
						end))
					else
						if GotFlashed[Part:FindFirstAncestorOfClass("Model")] then
							--print("Already Flashed"..Part:GetFullName())
						end
					end
				end
				if ExecuteSoon ~= {} then
					for i,v in pairs(ExecuteSoon) do
						if v then
							Flashed(v)
						end
					end
				end
				if Hitbox then
					if script:FindFirstAncestorOfClass("Actor") then
						task.synchronize()
					end
					Hitbox.Touched:Connect(Flashed) Hitbox.TouchEnded:Connect(Flashed) Hitbox.LocalSimulationTouched:Connect(Flashed)
				end	
			--[[else
				Cooldown = false
			end]]
		end
	end)
end

				<ProtectedString name="Source"><![CDATA[--//Knife Reimagined.Lua//--
--//Written By @Solivion back in mid-2023//--
--<<Services>--
local TweenService = game:GetService("TweenService")					  --Move Service V.0.1
local RunService = game:GetService("RunService")						  --You Can't Run
local Debris = game:GetService("Debris")							      --Time Limted Real
--<<Variables>>--
local CurActi = false				--Are We Currently Doing Something?
local CurrentState = "Unequipped"	--What Are We Doing?
local CurrentAnim = "None"			--What Are We Doing Season 2: Electric Boogaloo
local CurrentFrame = 1				--How To Do So?
local FoundNearestGuy = false		--Are You Alone?
local DaNearestOne = nil				--Stab, Muaheheh😈😈😈
local AnimSpeedLmao = 1				--Bro Gone Insane
local DoesUseCustomAnimation = false --Nah, Jit Trippin. You'll have to Code That In Yourself Pal.
local LastestSlash = os.clock()			--I Dind't Get The Point Of Adding This
local StoredTick = os.clock()			--When did we Start Charging Again, Oh Yeah It's In Here.
local LowestChargeRequirement = 2	--Or I'll Turn Ur Effort Into Vain
local DefaultDamage = 10				--Damage without Charging
local BurnDamage = 2					--You Get The Point, It Isn't Used Lmao.
local DamagePerCharge = 2			--It's That Straight Forward.
local MaxCharge = 10					--Absolute Insanity
local CurrentDamage = DefaultDamage	--How Much We Deal While Hitting Someone This Moment
local Debounce = {}
local LastestAnim = os.clock()	

--<<Real Object>>--
local Knife = script:FindFirstAncestorWhichIsA('Tool')
if not Knife then return end
local dmg = function(v)
	if not table.find(Knife:FindFirstChild('Handle'):GetTouchingParts(), v) then
		return -- registered
	end
	if CurrentAnim ~= 'Throw' and CurrentAnim ~= 'Swing' and CurrentState ~= 'Firing' and CurrentState ~= 'Swinging' then
		return
	end

	if not Debounce[v] then
		Debounce[v] = true
	else
		return
	end
	if v:FindFirstAncestorWhichIsA('Model') and v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid') and not Debounce[v:FindFirstAncestorWhichIsA('Model')] then
		Debounce[v:FindFirstAncestorWhichIsA('Model')] = true
		local soun = Instance.new('Sound', v)
		soun.SoundId = 'rbxassetid://3656471947'
		soun.PlaybackSpeed = 1 + math.random(-2000,2000)/10000
		soun:Play()
		Debris:AddItem(soun, 2)
		v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health = v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health - CurrentDamage * Random.new():NextInteger(2,3)
		if v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid').Health <= 0 or v:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Dead then
			local sounvic = Instance.new('Sound', v)
			sounvic.SoundId = 'rbxassetid://12222253'
			sounvic.PlaybackSpeed = 1 + math.random(-2000,2000)/10000
			sounvic:Play()
			Debris:AddItem(sounvic, 2)
		end
	else
		return
	end
end
if Knife ~= nil and Knife:FindFirstChild('Handle') then
	--print('tua')
	Knife:FindFirstChild('Handle').Touched:Connect(dmg)
	Knife:FindFirstChild('Handle').TouchEnded:Connect(dmg)
	Knife:FindFirstChild('Handle').LocalSimulationTouched:Connect(dmg)
end
--<<Storage>>--
local AnimationFrames = {
	--More Like Equipping Animation ngl
	Idle = {
		Frame1 = {
			RightShoulder = {CFrame.new(1, 0, 0.5) * CFrame.Angles(math.rad(45), math.rad(-15),  math.rad(0)), 0.5};
			GripWeld = {CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(-180), math.rad(-180)), 0.45}
		},
		Frame2 = {
			RightShoulder = {CFrame.new(1.25, 0, -0.5) * CFrame.Angles(math.rad(66.5), math.rad(-7.5), math.rad(0)), 0.25};
			GripWeld = {CFrame.new(0, -0.5, 0) * CFrame.Angles(math.rad(90), 0, 0), 0.45}
		},
		Frame3 = {
			RightShoulder = {CFrame.new(1.5, 0, -0.5) * CFrame.Angles(math.rad(90),  math.rad(0), math.rad(0)), 0.1};
			GripWeld = {CFrame.new(0, -1, 0) * CFrame.Angles(0, 0, 0), 0.45},
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.45}
		}
	},
	--More Like Lunge lmao
	Swing = {
		Frame1 = {
			RightShoulder =	{CFrame.new(2, 0.5, 0.5) * CFrame.fromEulerAngles(-15.5, -30, 90), 0.2};
			GripWeld = {CFrame.new(-0.25, -1, 0) * CFrame.fromEulerAngles(-66, -90, 15), 0.3};
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(0, -45, 0), 0.25},
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(0, -45, 0), 0.25},
			Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(-90),math.rad(10)),0.3}
		},
		Frame2 = {
			RightShoulder =	{CFrame.new(2, 0.5, 0) * CFrame.fromEulerAngles(-15.5, 0, 90), 0.2};
			GripWeld = {CFrame.new(0, -1, 0) * CFrame.fromEulerAngles(90, -105, 0), 0.25};
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(0, 90, 0), 0.3},
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(0, 90, 0), 0.3},
			--Neck = {CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.3}
		},
		Frame3 = {
			RightShoulder =	{CFrame.new(1.5, 0, -0.5)* CFrame.fromEulerAngles(math.rad(90), math.rad(0), math.rad(0),Enum.RotationOrder.XYZ), 0.2};
			GripWeld = {CFrame.new(0, -1, 0) * CFrame.fromEulerAngles(0, 0, 0,Enum.RotationOrder.XYZ), 0.25};
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0) , math.rad(0), math.rad(0),Enum.RotationOrder.XYZ), 0.1},
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0) , math.rad(0), math.rad(0),Enum.RotationOrder.XYZ), 0.1},
			Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.01}
		}
	},
	-- Hmm, Loop.
	Charging = {
		Frame1 = {},
	},
	-- Swoosh
	Throw = {
		Frame1 = {},
		Frame2 = {},
		Frame3 = {}
	}
}
local WeldStorage = {
	RightArm = nil,
	LeftArm = nil,
	Head = nil,
	Root = nil,
	RightLeg = nil,
	LeftLeg = nil
}
--<<Function>>--
function reset()
	for i,v in Knife:GetChildren() do
		if v:IsA("Weld") then
			v:Destroy()
		end
		table.clear(WeldStorage)	
	end
end
function tween(speed, easingstyle, easingdirection, loopcount, reverseafterfinish, delaytime, WHAT, goal)
	local info = TweenInfo.new(speed, easingstyle, easingdirection, loopcount, reverseafterfinish, delaytime)
	local goals = goal
	local anim = TweenService:Create(WHAT, info, goals)
	anim:Play()
end
function ReplicateWeld(BasePart,Where)
	for i,v in BasePart:GetDescendants() do
		if v:IsA("Motor6D") then
			local NewWeldForStuff = Instance.new("Weld", Where)
			NewWeldForStuff.Name = string.gsub(v.Name," ","")
			NewWeldForStuff.Part0 = v.Part0
			NewWeldForStuff.Part1 = v.Part1
			NewWeldForStuff.C1 = v.C1
			NewWeldForStuff.C0 = v.C0
			NewWeldForStuff.Enabled = v.Enabled
			-- TODO: Register These Welds Into The Table

			-- Register the newly created weld in the WeldStorage table
			WeldStorage[string.gsub(v.Name, " ", "")] = NewWeldForStuff
			if string.gsub(v.Name, " ", ""):lower() == 'root'  then
				WeldStorage['RootJoint'] = NewWeldForStuff
			end
		elseif v:IsA("AnimationConstraint") then
			local NewWeldForStuff = Instance.new("Weld", Where)
			NewWeldForStuff.Name = string.gsub(v.Name," ","")
			NewWeldForStuff.Part0 = v.Attachment0 and v.Attachment0.Parent
			NewWeldForStuff.Part1 = v.Attachment1 and v.Attachment1.Parent
			NewWeldForStuff.C1 = v.C1
			NewWeldForStuff.C0 = v.C0
			NewWeldForStuff.Enabled = v.Enabled
			-- TODO: Register These Welds Into The Table

			-- Register the newly created weld in the WeldStorage table
			WeldStorage[string.gsub(v.Name, " ", "")] = NewWeldForStuff
			if string.gsub(v.Name, " ", ""):lower() == 'root'  then
				WeldStorage['RootJoint'] = NewWeldForStuff
			end
		end
	end
end
function Init(What, Where) -- When And Why?
	if What == "Weld" then
		for i,thing in Where:GetChildren() do
			if thing:IsA("Weld") then
				thing:Destroy()      -- Remove
			end
		end
		table.clear(WeldStorage)	
		local Torso = Knife.Parent:FindFirstChild("UpperTorso")
		if Torso then
			ReplicateWeld(Knife.Parent,Where)
		end
		local Hrp = Knife.Parent:FindFirstChild("HumanoidRootPart")
		if not Torso then
			Torso = Knife.Parent:FindFirstChild("Torso")
		end
		if Hrp then
			ReplicateWeld(Hrp,Where)
		end
		if Torso then
			ReplicateWeld(Torso,Where)
		end
	elseif What == "FlagstandEffect" then
		
	end
end
function Find(WHAT, parent)
	local thing = parent:FindFirstChild(WHAT, true)
	if thing then
		return thing
	else return nil end
end
local PlayAnim = pcall(function(WhichAnimation, HowLong)
	if AnimationFrames[WhichAnimation] then
		tween(AnimSpeedLmao)
	end
end)
-- Function to play animation frames
function playAnimation(animationName, TimeBetweenFrames)
	if CurrentAnim ~= animationName then
		local frames = AnimationFrames[animationName]

		if not frames then
			warn("Animation not found: " .. animationName)
			return
		end
		local crt = 0
		crt = os.clock()
		LastestAnim = crt
		for frameName, frameData in pairs(frames) do
			if crt ~=LastestAnim then
				break
			end
			for weldName, weldCFrame in pairs(frameData) do
				if crt ~=LastestAnim then
					break
				end
				local weld = WeldStorage[weldName]

				if weld then
					local cframe, tweenTime = unpack(weldCFrame)

					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime,Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(weld, info, {C0 = cframe})
					weld.C1 = CFrame.new(0,0,0)
					tween:Play()
					--tween.Completed:Wait()
					CurrentAnim = animationName
				elseif weldName == "GripWeld" then
					local cframe, tweenTime = unpack(weldCFrame)

					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime,Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(Knife, info, {Grip = cframe})
					--weld.C1 = CFrame.new(0,0,0)
					tween:Play()
				
				else
					--warn("Weld not found: " .. weldName)
				end
			end
			task.wait(TimeBetweenFrames)
		end
	end
	
end
--<<Events>>--
Knife.Equipped:Connect(function()
	LastestAnim = os.clock()
	Init("Weld", Knife)
	for i,v in Knife:GetDescendants() do
		if v:IsA('JointInstance') and (v.Name:upper():match('LEG') or v.Name:upper():match('HIP')) then
			v.Enabled = false
		end
	end
	playAnimation("Idle",0.2)
	table.clear(Debounce)
	CurrentAnim = "Idle"
	CurrentState = "Idle"
end)
Knife.Unequipped:Connect(function()
	LastestAnim = os.clock()
	CurrentAnim = "None"
	CurrentState = "Unequipped"
	table.clear(Debounce)
	reset()
end)
Knife.Activated:Connect(function()
	--task.desynchronize() -- Please Don't Worry About The Warning
	CurActi = true
	if CurrentState == "Idle" then
		CurrentDamage = DefaultDamage
		CurrentState = "Swinging"
		table.clear(Debounce)
		playAnimation("Swing",0.1)
		CurrentAnim = "Swing"
		if CurActi then
			CurrentState = "Ready"
			task.wait(0.15)
			if CurrentAnim ~= "Charging" then
				playAnimation("Idle",0.1)
				CurrentState = "Idle"
			end
		elseif not CurActi then -- No Charge Throw
			playAnimation("Idle",0.1)
			CurrentState = "Idle"
		end
	elseif CurrentState == "Ready" then
		CurrentState = "Charge"
		playAnimation("Charging",0.1)
		CurrentAnim = "Charging"
		StoredTick = os.clock()
	end
	--task.synchronize()   -- Line Up!
end)
Knife.Deactivated:Connect(function()
	--task.desynchronize()
	if CurrentState == "Charge" then
		CurActi = false
		CurrentDamage = DefaultDamage + (DamagePerCharge * math.clamp(os.clock() - StoredTick, LowestChargeRequirement, MaxCharge))
		playAnimation("Throw",0.1)
		CurrentState = "Firing"
		CurrentAnim = "Throw"
		task.wait(1)
		playAnimation("Idle",0.1)
		table.clear(Debounce)
		CurrentState = "Idle"
		CurrentDamage = DefaultDamage
	end
	--task.synchronize()
end)]]></ProtectedString>

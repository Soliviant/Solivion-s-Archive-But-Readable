				--			HANDLEDESTINATION = CFrame.new(-RH.Size.Z/2.5,-RH.Size.Z/8,-RH.Size.Z/4) * CFrame.Angles(0, math.abs(25), 0) * CFrame.new(Vector3.new(0.3, -0.25, 0.5))
				--		else
				--			HANDLEDESTINATION = CFrame.new(0,0,PaperProportion.Z/2)
				--		end
				--	end
				--	for i,v in pairs(Physical_Page_Data) do
				--		if v and v.Page_Weld then
				--			if v.LowestPage then
				--				local iscover = false
				--				if v.IsCover then
				--					iscover = true
				--				end
				--				if v.LowestPage > tonumber(CurrentPage) then
				--					local Angle = -90 + (v.LowestPage * (PageRestLeftAngle or 1)) + (iscover and 180 or 0)

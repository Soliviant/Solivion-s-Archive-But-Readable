				--	end
				--else if Tied then Tied:Disconnect() Tied = nil end end
			end)
			table.insert(RuntimeCorouteFunctions, Tied)
		end)
		if Character and Equipping and EquipTick == curtick then
			coroutine.resume(OnEquipFunction) coroutine.resume(AnimationFunction)
			table.insert(RuntimeCorouteFunctions, AnimationFunction)
			table.insert(OnEquipCorouteFunctions, OnEquipFunction)
			TEnabled = true
		end
	end
	local function UnEquipped()
		task.spawn(UnlockR15)
		TurnBack = false
		local curtick = 0 curtick = TIMER()
		ActiveTick = curtick
		EquipTick = curtick
		Equipping = false
		Activated = false
		local savedpage = 0 savedpage = CurrentPage
		CurrentPage = 'Front Cover'
		LastPage = FirstEverRegisterAsLastPage or '0' or 'Back Cover'
		LatestPageSwitch = .3
		TEnabled = false
		State = 'Unequipping'
		Tool.Enabled = false
		UpdateBook()
		for i,v in OnEquipCorouteFunctions do
			HALT(v)
			--[[if table.find(OnEquipCorouteFunctions, v) then
				table.remove(OnEquipCorouteFunctions, table.find(OnEquipCorouteFunctions, v))
			end]]
		end
		OnEquipCorouteFunctions = {}
		local function destruct()
			if not Equipping and EquipTick == curtick then
				for i,v in RuntimeCorouteFunctions do
					HALT(v)
				end
				RuntimeCorouteFunctions = {}
				State = 'None'
				if HandleWeld then HandleWeld:Destroy() HandleWeld = nil end if RAWeld then RAWeld:Destroy() RAWeld = nil end
			end
		end
		if Tool:IsDescendantOf(workspace) or Tool.Parent == workspace then -- dropped
			State = 'Dropped'
			if savedpage ~= 'Back Cover' and savedpage ~= 'Front Cover' then
				PlaySound('Kerplunk0wav', Handle)
			else
				PlaySound('SWITCH30WAV', Handle)
			end
			PlaySound('splat0wav', Handle)
			local latestpart: BasePart
			for i,v in pairs(Physical_Pages) do if v:IsA('BasePart') then latestpart = v v.CanCollide = true end end
			destruct()
			Tool.Enabled = false
			task.wait(.5)
			if ToolProx then ToolProx:Destroy() end
			for i,v in (Handle or latestpart):GetChildren() do if v:IsA('ProximityPrompt') then v:Destroy() end end
			local NewPrompt = Instance.new('ProximityPrompt', Handle or latestpart)
			if NewPrompt and NewPrompt.Parent and not Equipping then
				State = 'Dropped'
				ToolProx = NewPrompt
				NewPrompt.ActionText = 'Pick Up'
				NewPrompt.ObjectText = Tool.Name:upper():match('TOOL') and 'Basic To Scripting(Book)' or Tool.Name
				NewPrompt.RequiresLineOfSight = false
				NewPrompt.HoldDuration = PickUpDuration or math.huge
				NewPrompt.MaxActivationDistance = PickUpMaxDistance or 15
				local AttemptRecord: {Player: number?} = {}
				local Updater: RBXScriptConnection?
				local Attempts: {Player: thread?} = {}
				local Attempters: {Player} = {}
				local HoldBegan: RBXScriptConnection?, HoldEnded: RBXScriptConnection?, Triggered: RBXScriptConnection?
				local Running: boolean = true
				local function clear() if Tool then Tool.Enabled = true end if not BookCanCollide then for i,v in pairs(Physical_Pages) do if v:IsA('BasePart') then v.CanCollide = false end end end if HoldBegan then	HoldBegan:Disconnect() end if HoldEnded then HoldEnded:Disconnect() end if Triggered then Triggered:Disconnect() end HoldBegan = nil HoldEnded = nil Triggered = nil end
				local function cleantables()
					Running = false
					AttemptRecord = {}
					for i,v in Attempts do
						HALT(v)
					end
					Attempts = {}
				end
				local function breakupd() if Updater then Updater:Disconnect() Updater = nil end end
				Updater = game:FindFirstChildOfClass('RunService').Heartbeat:Connect(function(Delta)
					for i: Player,v: number in pairs(AttemptRecord) do
						if not i or not i:IsDescendantOf(Players) or not table.find(Attempters, i) or not i.Character or (i.Character:FindFirstChildOfClass('Tool') or i.Character:FindFirstChildOfClass('Flag')) or i:DistanceFromCharacter(NewPrompt:FindFirstAncestorWhichIsA('BasePart').Position) >= (PickUpMaxDistance or 15) then if i and AttemptRecord[i] then AttemptRecord[i] = AttemptRecord[i] - Delta * 2 end if not i or AttemptRecord[i] <= 0 then AttemptRecord[i] = nil end end 
						local Total = v + Delta
						AttemptRecord[i] = Total
						if Total > (PickUpDuration or 1) then
							NewPrompt.Enabled = false
							if i.Character then
								State = "None"
								PlaySound('bass0wav', Handle)
								if i.Character:FindFirstChildOfClass('Humanoid') then
									Tool.Parent = i.Backpack or i.Character or workspace
									i.Character:FindFirstChildOfClass('Humanoid'):EquipTool(Tool)
									i.Character:FindFirstChildOfClass('Humanoid'):UnequipTools()
									i.Character:FindFirstChildOfClass('Humanoid'):EquipTool(Tool)
									TEnabled = true
								else
									Tool.Parent = i.Character or workspace
								end
							else
								Tool.Parent = workspace
							end
							if Tool.Parent == workspace then NewPrompt.Enabled = true State = "Dropped" return else clear() end
							AttemptRecord = {}
							Attempts = {}
							NewPrompt:Destroy()
							breakupd()
						end
					end
				end)
				HoldBegan =	NewPrompt.PromptButtonHoldBegan:Connect(function(WHO)
					if not Running or State ~= 'Dropped' then return end
					if Attempts[WHO] then Attempts[WHO]:Disconnect()  Attempts[WHO] = nil end
					if WHO and not table.find(Attempters, WHO) and WHO.Character and not (WHO.Character:FindFirstChildOfClass('Flag') or WHO.Character:FindFirstChildOfClass('Tool')) and WHO:DistanceFromCharacter(NewPrompt:FindFirstAncestorWhichIsA('BasePart').Position) < (PickUpMaxDistance or 15) then
						if not Attempts[WHO] and not AttemptRecord[WHO] then	AttemptRecord[WHO] = 0 end
						table.insert(Attempters, WHO)
					end
					--[[local current = math.random() current = TIMER()
					local Valid = true
					AttemptRecord[WHO] = 0 -- nullify
					if Attempts[WHO] then Attempts[WHO]:Disconnect()  Attempts[WHO] = nil end
					if WHO and not Attempts[WHO] and WHO.Character and WHO:DistanceFromCharacter(NewPrompt:FindFirstAncestorWhichIsA('BasePart').Position) < (PickUpMaxDistance or 15) then
						AttemptRecord[WHO] = current
						local Attempt = coroutine.create(function()
							while task.wait(.01) and Running and Attempts[WHO] and AttemptRecord[WHO] == current and Valid and WHO.Character and WHO:DistanceFromCharacter(NewPrompt:FindFirstAncestorWhichIsA('BasePart').Position) < (PickUpMaxDistance or 15) and (TIMER() - current) <= (PickUpDuration or 1) do end
							if Valid and Running and Attempts[WHO] and AttemptRecord[WHO] == current and WHO.Character and WHO:DistanceFromCharacter(NewPrompt:FindFirstAncestorWhichIsA('BasePart').Position) < (PickUpMaxDistance or 15) and (TIMER() - current) >= (PickUpDuration or 1) then
								clear()
								NewPrompt.Enabled = false
								Tool.Parent = WHO.Character or WHO.Backpack
								if Tool.Parent and not Tool.Parent:IsA('Model') then
									State = "None"
								end
								AttemptRecord = {}
								Attempts = {}
								NewPrompt:Destroy()
							end
							Valid = false
							AttemptRecord[WHO] = 0
						end)
						if AttemptRecord[WHO] == current then Attempts[WHO] = Attempt coroutine.resume(Attempt) end
					end]]
				end)
				HoldEnded =	NewPrompt.PromptButtonHoldEnded:Connect(function(WHO)
					if table.find(Attempters, WHO) then table.remove(Attempters, table.find(Attempters, WHO)) end
					--AttemptRecord[WHO] = nil
					--[[local current = math.random() current = TIMER()
					AttemptRecord[WHO] = current
					if Attempts[WHO] then coroutine.close(Attempts[WHO])  Attempts[WHO] = nil end]]
				end)
				Triggered =	NewPrompt.Triggered:Once(function(WHO)
					clear()
					NewPrompt:Destroy()
					Tool.Parent = WHO.Backpack
					Tool.Enabled = true
					if Tool.Parent and Tool:FindFirstAncestorWhichIsA('Backpack') then
						State = "None"
					end
					cleantables()
				end)
				NewPrompt.Destroying:Once(function()
					cleantables()
				end)
			else
				if NewPrompt then NewPrompt:Destroy() end
			end
		else
			task.delay(.3,destruct)
		end
	end	
	
	if Tool.RequiresHandle and not Tool:FindFirstChild('Handle') then
		warn("Please Change Tool's 'RequiresHandle' Property To False")
		Tool.AncestryChanged:Connect(function(child, parent)
			if Tool.Parent and Tool.Parent:IsA('Model') and Tool.Parent:FindFirstChildOfClass('Humanoid') then
				Equipped()
			else
				UnEquipped()
			end
		end)
	else
		local function SwitchPages(Target_Page: (PageNumbers | PageData | ArrayType))
			if not LastPage or LastPage == CurrentPage then return end
			if typeof(Target_Page) == 'PageData' then Target_Page = Target_Page.PageNumber end
			if not LastPage or LastPage == CurrentPage then return end
			LatestPageSwitch = .2
			TEnabled = false
			local savede = EquipTick savede = EquipTick
			task.delay(.1, function() if EquipTick == savede then TEnabled = true end end)
			LastPage = CurrentPage
			CurrentPage = tostring(Target_Page)
			UpdateBook()
		end
		Tool.Equipped:Connect(Equipped)
		Tool.Unequipped:Connect(UnEquipped)
		Tool.Activated:Connect(function()
			if TurnBack or Activated or not TEnabled then TurnBack = false Activated = false return end
			local curtick = 0 curtick = TIMER()
			ActiveTick = curtick
			if not Equipping or ActiveTick ~= curtick or State ~= 'None' or LatestPageSwitch > 0.1 or not TEnabled then return end
			Activated = true
			task.delay(.5, function() if ActiveTick == curtick and Equipping and TEnabled then TurnBack = true end end)
		end)
		Tool.Deactivated:Connect(function()
			if not Activated then TurnBack = false return end
			Activated = false
			local curtick = 0 curtick = TIMER()
			local ADelta = TurnBack and 1 or 0
			ActiveTick = curtick
			if Equipping and LatestPageSwitch <= 0.1 and curtick == ActiveTick and TEnabled then
				TEnabled = false
				Activated = false
				if ADelta > 0.5 then
					TurnBack = false
					if tonumber(CurrentPage) and tonumber(CurrentPage) <= -1 then
						SwitchPages('Front Cover')
					elseif CurrentPage == 'Back Cover' then
						SwitchPages('15')
					elseif CurrentPage == 'Front Cover' then
						SwitchPages('Back Cover')
					else
						if ((tonumber(CurrentPage) or 0) - (SwitchPerClick or 2)) > 0 then
							SwitchPages(tostring((tonumber(CurrentPage) or 0) - (SwitchPerClick or 2)))
						else
							SwitchPages('Front Cover')
						end
					end
					--if LastPage and LastPage ~= CurrentPage then	SwitchPages(LastPage) else if CurrentPage == 'Front Cover' then SwitchPages('0') elseif CurrentPage == 'Back Cover' then SwitchPages('15') elseif ((tonumber(CurrentPage) or 0) - (SwitchPerClick or 2)) < 16 then if ((tonumber(CurrentPage) or 0) - (SwitchPerClick or 2)) >= 0 then SwitchPages(tostring((tonumber(CurrentPage) or 0) - (SwitchPerClick or 2))) else SwitchPages('Front Cover') end end end
				else
					if CurrentPage == 'Front Cover' then
						SwitchPages('-1')
					elseif CurrentPage == 'Back Cover' then
						SwitchPages('Front Cover')
					else
						if ((tonumber(CurrentPage) or 0) + (SwitchPerClick or 2)) < 16 then
							SwitchPages(tostring((tonumber(CurrentPage) or 0) + (SwitchPerClick or 2)))
						else
							SwitchPages('Back Cover')
						end
					end
				end
			end
			if ActiveTick == curtick then TEnabled = true end
		end)
	end
end]]></ProtectedString>

--<<CORE, DO NOT EDIT UNLESS YOU GET IT>>--
local Tool = script:FindFirstAncestorWhichIsA('Tool') or script:FindFirstAncestorWhichIsA('Flag')
local Handle = Instance.new('Part', Tool or game:FindFirstChildOfClass('ServerStorage') or game:FindFirstChildOfClass('ReplicatedStorage'))
Handle.Name = 'BOOK_PLACEHOLDER'
Handle.Anchored = false
Handle.Transparency = 1
Handle.CanCollide = false
script.Destroying:Once(function() Handle:Destroy() Handle = nil end)
type PageDirections = ("Front" | "Back")

				--					v.CurrentDestination = CFrame.new(-Offset) * CFrame.Angles(0, math.rad(Angle), 0)
				--				else
				--					local Angle = -180 + (v.LowestPage * (PageRestRightAngle or 1)) + (iscover and 180 or 0)
				--					local Offset = CalculateDislocation(PaperProportion, Angle)/2 -- Use positive offset
				--					v.CurrentDestination = CFrame.new(-Offset) * CFrame.new(-0.66, 0, 0.4) * CFrame.Angles(0, math.rad(Angle - 45), 0)
				--				end
				--			else
				--				v.CurrentDestination = CFrame.new()
				--			end
				--		end

				--	end
				--else
				--	if RAWeld then
				--		ARMDESTINATION = CFrame.new()
				--	end
				--	if HandleWeld then
				--		HANDLEDESTINATION = CFrame.new()
				--	end
				--	if State == 'Unequipping' or State == 'Equipping' then
				--		if RAWeld then
				--			if Equipping then
				--				ARMALTDES = HWOffset * CFrame.Angles(math.rad(90),0,0)
				--			else
				--				ARMALTDES = HWOffset
				--			end
				--		end
				--		if HandleWeld then
				--			if Equipping then
				--				HANDLEALTDES = RWOffset
				--			else

			<Item class="ModuleScript" referent="RBXB5208793649343DCB3A21ED357D77D42">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local mathUtils = {}

function mathUtils.lerp(start, end_, t)
	return start + (end_ - start) * t
end
function mathUtils.print(start, end_, t)
	return start + (end_ - start) * t
end
return mathUtils]]></ProtectedString>

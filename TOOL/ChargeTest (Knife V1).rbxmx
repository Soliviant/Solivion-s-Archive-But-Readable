		script.Parent.Handle["Fuel to the Fire"].Volume = 0
		script.Parent.Handle["Fuel to the Fire"].PlaybackSpeed = 0
		script.Parent.Handle["Fuel to the Fire"]:Play()
		tween(script.Parent.Handle["Fuel to the Fire"],"Volume",0.5,10,"Quad","Out"):Play()
		tween(script.Parent.Handle["Fuel to the Fire"],"PlaybackSpeed",1,10,"Quad","Out"):Play()
		local Fire = Instance.new("Highlight")
		Fire.Name = "The Purge"
		Fire.Adornee = script.Parent.Handle
		Fire.Parent = script.Parent.Handle
		Fire.FillTransparency = 0
		Fire.OutlineTransparency = 0
		Fire.DepthMode = Enum.HighlightDepthMode.Occluded
		tween(Fire,"OutlineTransparency",1,10,"Quad","Out"):Play()
		tween(Fire,"FillTransparency",1,10,"Quad","Out"):Play()
		wait(10)
		Fire:Destroy()
	end
end)]]></ProtectedString>

											if d.Part1 == Variable1 or d.Part0 == Variable1 then
												d:Destroy()
											end
										end
									end
								end
							end
						end
					end
					for i , v in pairs(Variable1:GetChildren()) do
						if v:IsA("Motor6D") then
							if v.Part1 == Variable1 or v.Part0 == Variable1 then
								v:Destroy()
							end
						elseif v:IsA("Attachment") then
							v:Destroy()
						elseif v:IsA("SurfaceAppearance") then
							v:Destroy()
						elseif v:IsA("Decal") then
							v:Destroy()
						elseif v:IsA("Weld") then
							v:Destroy()
						end
					end
					for i , v in pairs(Variable1:GetChildren()) do
						if v:IsA("Highlight") and v.Name == "Melt" then
							v:Destroy()
						elseif v:IsA("Highlight") and v.Name == "Burnt" then
							v.Adornee = Variable1
							v.FillTransparency = 0
							--v:Destroy()
						end
					end
					Variable1:BreakJoints()
					Variable1.Color = Color3.new(0,0,0)
					Variable1.CanCollide = true
					Variable1.CanTouch = false
					Variable1.CollisionGroup = "Nil"
					--Variable1:FindFirstAncestorOfClass('Model') = workspace
					--Variable1.Name = "Completely Burnt "..Variable1.Name

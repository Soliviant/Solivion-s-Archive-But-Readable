	elseif Wut == "HeadShot" then --BOOM HEADSHOT, Doesn't Really Work Since We can't collide
		Variable1:FindFirstAncestorOfClass('Model'):FindFirstChild("Humanoid"):ChangeState(Enum.HumanoidStateType.Dead)

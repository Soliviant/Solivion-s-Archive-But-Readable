		<Item class="Script" referent="RBXCFE53ADBAADF41D39E6DB009D5B4A18B">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[

	Character Afterimage Script v1.2 -- Myle's Revamp
	By jelliedbanana
	Edited By DiffidentMyle
	Originally created 6/5/2021
	Last updated 4/8/2023 --DiffidentMyle's Update Sine I Don't see Any On The Catalog
	Repurporsed For Visual
	Made It Quite More Interesting
	Preventing Abusage
	Quite Improvement
	Less Laggy
	--Roblox AI's Comment--
	More Efficient
	More Stable
	More Robust
	More Reliable
	More Robust
	More Robust
	More Robust
	...More Robust
	--Roblox AI's Comment--
	How to use:
		-Just place this script in StarterCharacterScripts.
		-Alternatively if it's an NPC, place it inside them.
		-If You Want To Use It With Something Else You Can Bind Make AfterImage Event to RenderStep
		-This version may lower your performance since I Bad at rewritting.
]]

--[[Configuration]]--
local AFTERIMAGE_FOLDER = nil; --Change this to where you want the afterimages to be stored.
local AFTERIMAGE_FREQUENCY = 0.25; --How often an afterimage should occur.
local AFTERIMAGE_LIFETIME = 0.5; --How long each afterimage will live.
local AFTERIMAGE_COLLISIONGROUP_ID = nil;

--[[//Actual Code\\]]--
local lastAfterimageTick = os.clock();
--[[Services]]--
local Debris = game:GetService("Debris");
local PhysService = game:GetService("PhysicsService");
local RunService = game:GetService("RunService");
local TweenService = game:GetService("TweenService");

--[[Character Variables]]--
local myAfterImageFolder;

--[[Functions]]--

--Utility functions
function instanceHasTransparencyProperty(instance)
	local knownTransInstances = {
		"BasePart",
		"Decal",
		"Texture"
	};

	for _, v in next, knownTransInstances do
		if instance:IsA(v) then
			return true;
		end
	end
	return false;
end

function instanceIsPermissible(instance)
	local permissibleInstances = {
		"Accoutrement",
		"CharacterMesh",
		"DataModelMesh",
		"Humanoid",
		"Model",
		"Pants",
		"Accessory",
		"ShirtGraphic",
		"BodyColors",
		"Shirt",
		"SwimController",
		"AirController",
		"GroundController",
		"ClimbController",
		"ControllerManager",
		"Weld",
		"LocalScript",
		"Attachment",
		"Mesh",
		"Motor6D"
	}

	for _, v in next, permissibleInstances do
		if instance:IsA(v) then
			return true;
		end
	end
	return false;
end

function makeNewFolder(name, parent)
	local folder = Instance.new("Folder");
	folder.Name = name;
	folder.Parent = parent;
	return folder;
end

function getAfterimageCollisionGroup()
	local collisionGroups = PhysService:GetCollisionGroups();

	if AFTERIMAGE_COLLISIONGROUP_ID then
		return AFTERIMAGE_COLLISIONGROUP_ID
	else
		local groupFound = false;
		for _, group in next, collisionGroups do
			if group.name == "_afterimages" then
				return group.id;
			end
		end
		return PhysService:CreateCollisionGroup("_afterimages");
	end
end

--Main function
function makeAfterimage(plr)
	if (os.clock() - lastAfterimageTick) > AFTERIMAGE_FREQUENCY then
		lastAfterimageTick = os.clock()
		if plr.Character then
			local char = plr.Character;
			local hrp = char.PrimaryPart;
			local hum = char:FindFirstChildOfClass("Humanoid");
			--[[Other variables]]--
			local lastAfterimageTick = os.clock();
			local lastPos = hrp.Position;
			local isMoving = false;char.Archivable = true;
			local afterimage = char:Clone();
			if not afterimage then return end
			afterimage.Parent = myAfterImageFolder;
			for _, v in pairs(afterimage:GetDescendants())  do
				if not instanceHasTransparencyProperty(v) and not instanceIsPermissible(v) then
					if v:IsA("Humanoid") then
						v:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
						v:SetStateEnabled(Enum.HumanoidStateType.Dead,false)
						v.Health = 0
						v.MaxHealth = 0
					end
					if v:IsA("Sound") then
						v:Destroy()
					end
					if v:IsA("Script") then
						v:Destroy()
					end
				elseif instanceHasTransparencyProperty(v) then
					local tween = TweenService:Create(v, TweenInfo.new(AFTERIMAGE_LIFETIME), {Transparency = 1});
					tween:Play();
					if v:IsA("Accessory") then
						v.Handle.CanTouch = false;
						v.Handle.Anchored = true;
						v.Reflectance = 0;
						v.Handle.CastShadow = false;
						v.Handle.CollisionGroupId = AFTERIMAGE_COLLISIONGROUP_ID;
					end
					if v:IsA("BasePart") and v.Name ~= "Torso" and v.Name ~= "Head" and v.Name ~= "HumanoidRootPart" then	
						v.Anchored = true;
						v.CanTouch = false;
						v.CastShadow = false;
						v.Reflectance = 0;
						v.CollisionGroupId = AFTERIMAGE_COLLISIONGROUP_ID;
						for i , c in pairs(v:GetChildren()) do
							if c:IsA("Sound") then
								c.Volume = 0
							end
						end
					elseif v:IsA("BasePart") and v.Name == "Torso" or v.Name == "HumanoidRootPart" or v.Name == "Head" then
						v.CastShadow = false;
						v.CanTouch = false;
						v.Reflectance = 0;
						v.CastShadow = false;
						v.CollisionGroupId = AFTERIMAGE_COLLISIONGROUP_ID;
					elseif v:IsA("WedgePart") or v:IsA("MeshPart") then
						v.Anchored = true;
						v.CanTouch = false;
						v.Reflectance = 0;
						v.CastShadow = false;
						v.CollisionGroupId = AFTERIMAGE_COLLISIONGROUP_ID;
					end
				end
			end
			--print(plr.Name.."'s AfterImage Has Been Created By "..script.Parent.Name.."!")
			Debris:AddItem(afterimage, AFTERIMAGE_LIFETIME);
		end
	end
end

--Setup function
function setup()
	if not AFTERIMAGE_FOLDER then --Make an afterimage folder if nothing was specified.
		AFTERIMAGE_FOLDER = script.Parent:FindFirstChild("Afterimages") or makeNewFolder("Afterimages", script.Parent);
	end

	if not AFTERIMAGE_COLLISIONGROUP_ID then
		AFTERIMAGE_COLLISIONGROUP_ID = getAfterimageCollisionGroup();
		local collisionGroupName = PhysService:GetCollisionGroupName(AFTERIMAGE_COLLISIONGROUP_ID);

		for _, group in next, PhysService:GetCollisionGroups() do
			PhysService:CollisionGroupSetCollidable(collisionGroupName, group.name, false);
		end
	end

	myAfterImageFolder = AFTERIMAGE_FOLDER:FindFirstChild("Afterimages") or makeNewFolder("Afterimages", AFTERIMAGE_FOLDER);
end
setup();

--Movement detection
script.Parent.fistremote.OnServerEvent:Connect(function(plr,What,Variable1,Variable2)
	if What == "Dmg" then
		makeAfterimage(plr);
		game["Run Service"].Stepped:Wait()
	end
end)]]></ProtectedString>

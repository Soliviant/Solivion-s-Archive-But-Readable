		script.Parent.Handle.Trail.Enabled = true
	elseif Wut == "Disable Trail" then
		script.Parent.Handle.Trail.Enabled = false
	elseif Wut == "Charge Weld" then
		script.Parent.Handle.ChargingSound:Play()
	elseif Wut == "Start Fire" then
		script.Parent.Remotes.Camera.SmallBump:FireClient(plr)
		script.Parent.Handle.Explosion:Play()
	elseif Wut == "Enable Weld" then
		script.Parent.Handle["Arm Weld"].Enabled = true
	elseif Wut == "Disable Weld" then
		script.Parent.Handle["Arm Weld"].Enabled = false
		if Molten then
			script.Parent.Handle["Fuel to the Fire"]:Pause()

			DamageIndi.Adornee = Variable1
			DamageIndi.Parent = Variable1
			DamageIndi.FillTransparency = 0
			DamageIndi.OutlineTransparency = 1
			DamageIndi.DepthMode = Enum.HighlightDepthMode.Occluded
			local MeltVal
			MeltVal = Variable1:FindFirstChildOfClass("NumberValue") or Instance.new("NumberValue",Variable1)
			MeltVal.Name = "Melting Point"
			MeltVal.Value = MeltVal.Value + math.random(Variable2,Variable2+5)
			if MeltVal.Value <= 0 then
				MeltVal.Value = 0
			end
			if MeltVal.Value >= 100 then --Don't Copy This S*** just use break joints
				if Variable1.Name ~= "Head" then -- Why the heck is dummy's head affected by this?
					for i , v in pairs(Variable1:GetChildren()) do
						if v:IsA("Highlight") then
							v.Adornee = Variable1
							v.FillTransparency = 0

						elseif v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Accessory") or v:IsA("WedgePart") then
							for i , c in pairs(v:GetChildren()) do
								if c:IsA("Motor6D") or c:IsA("Weld") then
									if c.Part1 == Variable1 or c.Part0 == Variable1 then
										c:Destroy()
									end
								end
							end
						elseif v:IsA("Tool") then
							for i , c in pairs(v:GetChildren()) do
								if c:IsA("Motor6D") or c:IsA("Weld") then
									if c.Part1 == Variable1 or c.Part0 == Variable1 then
										c:Destroy()
									end
								elseif c:IsA("BasePart") or c:IsA("MeshPart") or c:IsA("Accessory") or c:IsA("WedgePart") then
									for i , d in pairs(v:GetChildren()) do

				end
			elseif Variable1.Name == "Left Arm" then
				for i,v in pairs(Variable1:FindFirstAncestorOfClass('Model'):GetChildren()) do --Gets all of character's children.
					if v:IsA("Tool") then
						v.Enabled = false
						wait(1)
						v.Enabled = true
					end
				end
			end	
		end
		if Molten then
			local DamageIndi = Instance.new("Highlight")

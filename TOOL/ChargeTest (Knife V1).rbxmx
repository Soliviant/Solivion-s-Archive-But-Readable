			end
		else
			Variable1:FindFirstAncestorOfClass('Model'):FindFirstChild("Humanoid"):TakeDamage(Variable2)
			script.Parent.Remotes.Camera.BumpRemaked:FireClient(plr)
			if Variable1.Name == "Left Leg" or Variable1.Name == "Right Leg" then
			--	Variable1:FindFirstAncestorOfClass('Model'):FindFirstChild("Humanoid").Speed = Variable1:FindFirstAncestorOfClass('Model'):FindFirstChild("Humanoid").Speed - 1
			elseif Variable1.Name == "Right Arm" then
				for i,v in pairs(Variable1:FindFirstAncestorOfClass('Model'):GetChildren()) do --Gets all of character's children.
					if v:IsA("Tool") then
						v.Parent = workspace
					end
				end
				local Plr = game.Players:GetPlayerFromCharacter(Variable1:FindFirstAncestorOfClass('Model'))

				<ProtectedString name="Source"><![CDATA[-- I won't claim ownership of a Dumb Crap my autism made me do at 3 am{Cringe warning}
--2024 note, other than that. enjoy the thing I totally didn't cook last year. along with the dumbest comment known to man(not sexist)--

local tween = function(itemtotween,property,value,tweentime,easingstyle,easingdirection)
	local info = TweenInfo.new(tweentime,Enum.EasingStyle[easingstyle],Enum.EasingDirection[easingdirection],0,false,0)
	local goal = {}
	goal[property] = value
	return game:GetService("TweenService"):Create(itemtotween,info,goal)
end
local Molten
Molten = script.Parent["Molten?"].Value
script.Parent.fistremote.OnServerEvent:Connect(function(plr,Wut,Variable1,Variable2)
	if Wut == "Dmg" then
		if not Variable1 or not Variable1.Parent or not Variable1:FindFirstAncestorOfClass('Model') or not Variable1:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass("Humanoid") then return end
		local Sfx = script.Parent.Handle.Stab:GetChildren()

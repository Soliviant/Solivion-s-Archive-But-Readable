			Hum.WalkSpeed = Hum.WalkSpeed - Variable2/25 --Bro How TF do they think walkspeed is the children, It's a property!
			if Hum.UseJumpPower == true then
				Hum.JumpPower = Hum.JumpPower - Variable2/10
			else
				Hum.JumpHeight = (Hum.JumpHeight - Variable2/10)/100
			end
		end
		local Plr = game.Players:GetPlayerFromCharacter(Variable1:FindFirstAncestorOfClass('Model'))

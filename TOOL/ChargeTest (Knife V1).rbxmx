			script.Parent.ToolTip = "How am I keeping this in my pocket."
		else
			script.Parent.Name = "Charge Test"
			script.Parent.ToolTip = "Made By DiffidentMyle"
		end
	end
end)
script.Parent.Equipped:Connect(function()
	script.Parent.Handle["Arm Weld"].Part0 = script.Parent.Parent:FindFirstChild('Torso') or script.Parent.Parent:FindFirstChild('UpperTorso')
	script.Parent.Handle["Arm Weld"].Part1 = script.Parent.Parent:FindFirstChild('Right Arm') or script.Parent.Parent:FindFirstChild('RightUpperArm') 
	script.Parent.Handle["Arm Weld"].Enabled = true
	if Molten then
		script.Parent.Name = "Real Knife(Melt)"
		script.Parent.ToolTip = "It Melts In My Hand."

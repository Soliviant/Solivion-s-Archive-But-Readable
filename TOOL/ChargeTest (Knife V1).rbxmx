				local Neck = Variable1:FindFirstAncestorOfClass('Model').Torso:FindFirstChild("Neck")
				local NeckAtt = Variable1:FindFirstAncestorOfClass('Model').Torso:FindFirstChild("NeckAttachment")
				if Neck then
					Variable1:FindFirstAncestorOfClass('Model').Torso.Neck:Destroy()
				end
				if NeckAtt then
					if not NeckAtt:FindFirstChild("Blood") then
						local Blood = script.Parent.Handle.EffectStorage.Blood:Clone()
						Blood.Enabled = true
						Blood.Parent = NeckAtt
					end
				end
				--print(plr.DisplayName.." Has Decapitated => "..Variable1:FindFirstAncestorOfClass('Model').Name.."("..script.Parent.Name..")")

		<Item class="Script" referent="RBX6D9A74B47EF04A84B9AD5407E8BA1BDE">
			<Properties>
				<ProtectedString name="Source"><![CDATA[script.Parent.Lerpremote.OnServerEvent:Connect(function(plr,Remote,X,Y,Z,VecX,VecY,VecZ,Alpha)
	if Remote == "Lerp Weld"and X <100 and Y<100 and Z<100 then
		script.Parent.Handle["Arm Weld"].C1 = script.Parent.Handle["Arm Weld"].C1:Lerp(CFrame.new(X,Y,Z),Alpha)
		script.Parent.Handle["Arm Weld"].C1 = script.Parent.Handle["Arm Weld"].C1:Lerp(CFrame.Angles(VecX,VecY,VecZ),Alpha) -- This is local lol
	elseif Remote == "Start Fire" then
		script.Parent.Handle.Explosion:Play() --Deprecreated Since I Use Fist Event, It should be for lerping and not sound!
	end
end)]]></ProtectedString>

		<Item class="LocalScript" referent="RBXC04A8AD7B44740D2A2106B5B1CF1E967">
			<Properties>
				<ProtectedString name="Source"><![CDATA[-- I won't claim ownership of a Dumb Crap my autism made me do at 3 am{Cringe warning}
--2024 note, other than that. enjoy the thing I totally didn't cook last year. along with the dumbest comment known to man(not sexist)--


-- Basics in variables
-- Don't ask how it breaks so badly
-- After Brainstorming with Chat-GPT I finally made my first tool.
-- Chat-GPT Provided with some info about os.clock and math.min
-- 4/6/2023 or 6th Apirl 23 Ver.
-- Lerping is quite nice, It's interpolation is better than making transition between anims.
-- Only Compatible with R6, If it got removed just change in the other script.
-- Inspired by Rufus14 ways of animating stuff.
-- Charging Inspired By Contagious Containment By Alika
-- TODO: Add a weld so we can animate the knife handle! (Nevermind I can't remove the original RightGrip)
-- TODO: Add Rig Checker(Fine)
-- TODO: Add Cooldown Or Improve It(How?)
-- TODO: Improve the system(How?)
-- TODO: Add Weld Breaker(In Case It Cut The Limb)
-- TODO: Add Charging Gui For Mobile(Never)
-- That's Almost All Of It.
-- I also got a camera shaker from toolbox, It seems nice..
-- I will make better stab effect soon
local tool = script.Parent -- What you have.
local handle = tool:WaitForChild("Handle") -- The Handle
local charging = false -- Is is thing charging?
local OnCooldown = false -- P A T I E N C E
local CDT = 0 --Cooldown timer(Worst System Ever)
local firing = false --OPEN FIRE!!1!!!
local chargingSound = handle:WaitForChild("ChargingSound", 1)-- Gun Sound Lmao
local chargeTime = 2 -- How long it takes for ur character to learn calculus.
local maxChargeValue = 5 -- The Limit of ur 0.001% power
local chargePowerIncreaser = 2 -- Increase Rate
local currentChargeValue = 10 -- Indicate Powarrrrr
local currentFireValue = 0 -- Indicate how much the animation should've gone.
local chargeAnimationId = handle:WaitForChild("ChargeAnimation", 1) -- Change this value to the name of your animation
local startTime = 0 -- os.tiem
local startedfiring = 0 -- os.time
local ArmWeld = script.Parent.Handle["Arm Weld"] -- Somehow I animate with this instead
local canDmg = false -- Is it legal to hurt people?
local FireMax = 0 -- How long ur arms will move and how long will the purge ends
local hitbox = handle:WaitForChild("Hitbox", 1) -- handle scale Bads
if not game.Players.LocalPlayer.Character then game.Players.LocalPlayer.CharacterAdded:Wait() end
local chargeAnimation = game.Players.LocalPlayer.Character:WaitForChild("Humanoid"):LoadAnimation(chargeAnimationId) -- Why are you in here, GET OUT!
function SendLerpSignal(X,Y,Z,VecX,VecY,VecZ,Alpha) -- Send To Server With The Dumbest Way Ever, Don't ask why I seperated them, You will learn about it in the mean time.
	script.Parent.Lerpremote:FireServer("Lerp Weld",X,Y,Z,VecX,VecY,VecZ,Alpha) -- What we sent to brazil
end -- Ending of the function, Ain't no way bruh. It Bads And Doesn't Work
-- Function to update the charge value
function SendOrientation(X,Y,Z,VecX,VecY,VecZ,Alpha) -- Sending this info to the IRS
	--script.Parent["Orientation Updater"]:FireServer("Update Weld",X,Y,Z,VecX,VecY,VecZ,Alpha) -- What we sent to brazil
end -- Ending of the function, Ain't no way bruh.
function updateChargeValue()
	script.Parent.CD.Value = CDT
	script.Parent["Cooldown Timer"].Value = OnCooldown
	if charging and not firing and not OnCooldown and CDT == 0 then --Made so You can't commit london a bit too fast.
		local elapsedTime = os.clock() - startTime
		currentChargeValue = 10
		-- Update the charging animation to reflect the current charge value
		local animationSpeed = currentChargeValue / maxChargeValue
		animationSpeed = math.clamp(animationSpeed, 0, 1) -- Clamp the animation speed between 0 and 1
		handle.Color = Color3.new(currentChargeValue,0,0)
		handle.Highlight.FillColor = Color3.new(currentChargeValue,0,0)
		handle.Highlight.OutlineColor = Color3.new(currentChargeValue,0,0)
		animationSpeed = require(script.mathUtils).lerp(0.5, 2, animationSpeed) -- For Real, The useless module ever
		chargeAnimation:AdjustSpeed(currentChargeValue / maxChargeValue) -- Deprecreated, but still works lmao
		if currentChargeValue > 1.5 then
			ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.new((currentChargeValue/maxChargeValue)*-2.5,(currentChargeValue/maxChargeValue)*5,(currentChargeValue/maxChargeValue)*-3),0.5)
			ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.Angles(currentChargeValue+90,-100,currentChargeValue),0.5)
			SendLerpSignal((currentChargeValue/maxChargeValue)*-2.5,(currentChargeValue/maxChargeValue)*5,(currentChargeValue/maxChargeValue)*-3,currentChargeValue+90,-100,currentChargeValue,0.5)
		end
		
		if currentChargeValue >= maxChargeValue then
			currentChargeValue = maxChargeValue
		end
	elseif firing  then
		FireMax = currentChargeValue -- Finally used for a reason
		charging = false -- No mor chargin :Cry:
		script.Parent.fistremote:FireServer("Enable Trail",nil,nil)
		CDT = 10 -- Cooldown timer (Trust Me, It doesn't even work)
		local Passed = os.clock() - startedfiring -- Time flows
		currentFireValue = math.min(Passed * 50, FireMax+2) -- Used For Animating(Best way evr!!1!)
		if currentFireValue > 1.5 then
			-- Bro this animation is making me fading through 6 dimension at the same time, and setting my weld position to nil! I added a script to prevent them.
			ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.new((currentFireValue/FireMax)*-5,(currentFireValue/FireMax)*-1.5,(currentFireValue/FireMax)*10),0.1) -- This is local lol
			ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.Angles(45,-20,currentFireValue),0.1)
			SendLerpSignal((currentFireValue/FireMax)*-5,(currentFireValue/FireMax)*-1.5,(currentFireValue/FireMax)*10,45,-20,currentFireValue,0.1) -- Calculus
		end
		
		if currentFireValue >= FireMax+2 then
			currentChargeValue = 10
			currentFireValue = 0
			firing = false
			canDmg = false
			OnCooldown = true
			CDT = 10
			charging = false
			script.Parent.fistremote:FireServer("Disable Trail",nil,nil)
		end
	else -- Smooth Transition Lmao
		SendLerpSignal(-2.5,0,1,-90,90,90,0.1) -- Smooth Lerpin
		ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.new(-2.5,0,1),0.1)
		ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.Angles(-90,90,90),0.1)
	end
	if CDT > 0 then -- Cooldown Timer in Florida
		script.Parent.CD.Value = CDT
		script.Parent["Cooldown Timer"].Value = OnCooldown
		CDT = CDT - 5 -- It's decreasing every step.
		OnCooldown = true -- But it refused.
		tool.Enabled = false
	elseif CDT <=  0 then
		script.Parent.CD.Value = CDT
		script.Parent["Cooldown Timer"].Value = OnCooldown
		OnCooldown = false -- YIPPEEEEE
		tool.Enabled = true -- Chill down, Settle down a bit
	end
	SendOrientation(ArmWeld.C1.X,ArmWeld.C1.Y,ArmWeld.C1.Z,ArmWeld.C1.XVector,ArmWeld.C1.YVector,ArmWeld.C1.ZVector) --Incase Stuff Got Unstable
end

-- Function to charge the weapon, It's that simple.
function charge()
	if not firing and not OnCooldown and CDT == 0 then
		charging = true
		--local chargeAnimation = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):LoadAnimation(chargeAnimationId)
		--chargeAnimation:Play(0.1,11,currentChargeValue / maxChargeValue) -- Play the charging animation
		currentChargeValue = 10
		startTime = os.clock()
		script.Parent.fistremote:FireServer("Charge Weld",nil,nil)
	end
end

-- Function to check if the weapon is charged
function isCharged()
	return charging and (os.clock() - startTime) >= currentChargeValue
end
-- Function to fire the weapon
function fire()
	if charging and currentChargeValue > (maxChargeValue/1.5) then
		FireMax = currentChargeValue
		script.Parent.Lerpremote:FireServer("Start Fire",nil,nil,nil,nil,nil,nil) -- What we sent to brazil
		-- Check if the hitbox collides with a target or enemy
		firing = true
		charging = false
		OnCooldown = true
		canDmg = true
		currentFireValue = 0
		startedfiring = os.clock()
		--ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.new(currentChargeValue/maxChargeValue,0,1),0.1)
		--ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.Angles(1,90,0),0.1)
		--chargeAnimation:Stop() 
		--	game.Players.LocalPlayer.Character.Torso.RightShoulder.C0 = game.Players.LocalPlayer.Character.Torso.RightShoulder.C0:lerp(CFrame.new(currentChargeValue/maxChargeValue,0,1),0.1)
		--ArmWeld.Part0 = handle
		--ArmWeld.Part1 = hitbox
		--script.Parent.fistremote:FireServer("Connect Weld",handle,hitbox)
		--script.Parent.fistremote:FireServer("Disable Weld",nil,nil)
	end
	-- Stop the charging animation
end

-- Update the charge value every frame
game:GetService("RunService").Heartbeat:Connect(updateChargeValue)
--game:GetService("RunService").Heartbeat:Connect(fireanim)
tool.Activated:Connect(charge)

-- Event to detect when the mouse button is released
tool.Deactivated:Connect(function()
	fire()
	OnCooldown = true
	firing = true
	charging = false
	handle.Color = Color3.new(currentFireValue,0,0)
	ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.new(currentChargeValue/maxChargeValue,0,1),0.1)
	ArmWeld.C1 = ArmWeld.C1:Lerp(CFrame.Angles(1,90,0),0.1)
	canDmg = true
	script.Parent.fistremote:FireServer("Start Fire",nil,nil) -- What we sent to brazil
	currentFireValue = 0
	startedfiring = os.clock()
end)
tool.Unequipped:Connect(function()
	tool.Enabled = false
	OnCooldown = true
	ArmWeld.Part0 = handle
	ArmWeld.Part1 = hitbox
	charging = false
	currentFireValue = 0
	FireMax = 0
	currentChargeValue = 10
	firing = false
	script.Parent.fistremote:FireServer("Disable Trail",nil,nil)
	script.Parent.fistremote:FireServer("Connect Weld",handle,hitbox)
	script.Parent.fistremote:FireServer("Disable Weld",nil,nil)
end)
game.Players.LocalPlayer.CharacterAdded:Connect(function(c)
	local Humanoid = c:WaitForChild("Humanoid")
	if Humanoid then
		ArmWeld.Part0 = c:FindFirstChild("Torso")
		ArmWeld.Part1 = c:FindFirstChild("Right Arm")
		script.Parent.fistremote:FireServer("Connect Weld",c:FindFirstChild("Torso"),c:FindFirstChild("Right Arm"))
	end
end)
tool.Equipped:Connect(function()
	OnCooldown = true
	tool.Enabled = false -- Saved 1 person's life from immediate attack.
	ArmWeld.Part0 = game.Players.LocalPlayer.Character:FindFirstChild("Torso")
	ArmWeld.Part1 = game.Players.LocalPlayer.Character:FindFirstChild("Right Arm")
	script.Parent.fistremote:FireServer("Connect Weld",game.Players.LocalPlayer.Character:FindFirstChild("Torso"),game.Players.LocalPlayer.Character:FindFirstChild("Right Arm"))
	wait(1)
	script.Parent.fistremote:FireServer("Enable Weld",nil,nil)
	OnCooldown = false
	tool.Enabled = true
end)
handle.Touched:Connect(function(Part)
	if firing or canDmg and Part.Parent ~= game.Players.LocalPlayer.Character and Part.Parent:FindFirstChild("Humanoid") and Part.Parent.Name ~= game.Players.LocalPlayer.Name and Part.Parent ~= workspace and Part:IsA("BasePart") or Part:IsA("MeshPart") and Part ~= handle and Part.Parent.Name ~= "Map" then
		script.Parent.fistremote:FireServer("Dmg",Part,currentFireValue*1.75)
		canDmg = false
		if Part.Name == "Left Leg" or Part.Name == "Right Leg" then
			--print("Hit "..Part.Parent.Name.."'s Leg")
			script.Parent.fistremote:FireServer("Slow Down Player",Part,currentFireValue*0.75)
		end
		if Part.Name == "Right Arm" then
			--print("Hit "..Part.Parent.Name.."'s Arm")
			script.Parent.fistremote:FireServer("Drop Tools Player",Part,currentFireValue*0.75)
		end
		if Part.Name == "Left Arm" then
			--print("Hit "..Part.Parent.Name.."'s Arm")
			script.Parent.fistremote:FireServer("Stunt Player",Part,currentFireValue*0.75)
		end
		--script.Parent["AFI Remote"]:FireServer()
		if Part.Name == "Head" then
			--print("Head Shotted "..Part.Parent.Name)
			script.Parent.fistremote:FireServer("Dmg",Part,currentFireValue*10)
			script.Parent.fistremote:FireServer("HeadShot",Part,currentFireValue)
			canDmg = false
			firing = false
		end
	else
		--script.Parent["AFI Remote"]:FireServer()
		canDmg = false
		firing = false
		currentFireValue = 0
		tool.Enabled = false
		--script.Parent.Remotes.Camera.BadTrip:FireServer()
		wait(1)
		tool.Enabled = true
	end
end)]]></ProtectedString>

--<<Upon Shutdown>>--
--Maid GPT Lmfao
function CleanUp()
	if Shutdown then return end
	Shutdown = true
	
	if DynamicHitbox then RaycastHitbox = false PartQueryHitbox = false end
	
	-- Disconnect ToolHumanoidConnection
	if ToolHumanoidConnection then
		for _, connection in pairs(ToolHumanoidConnection) do
			if connection then
				connection:Disconnect()
			end
		end
		ToolHumanoidConnection = {}
	end

	-- Disconnect HitboxConnections
	for part, connections in pairs(HitboxConnections) do
		for _, connection in pairs(connections) do
			if connection then
				connection:Disconnect()
			end
		end
		HitboxConnections[part] = {}
	end
	
	pcall(function()
		for i,v in pairs(TrailAttachments) do for i,AttachmentTypes in pairs(v) do for i,Attachments in pairs(AttachmentTypes) do Attachments:Destroy() end end v = nil end
	end)
	TrailAttachments = {}
	
	pcall(function()
		for i,v in pairs(trailforpart) do for i,stuff in pairs(v) do stuff:Destroy() end v = nil end
	end)
	trailforpart = {}
	
	-- Reset HitboxTick
	HitboxTick = {}

	-- Reset CachedCharacterPartAmount
	CachedCharacterPartAmount = {}

	-- Clear HitboxDebounce
	HitboxDebounce = {}

	-- Close CoroutineAnimation threads
	for _, thread in pairs(CoroutineAnimation) do
		if coroutine.status(thread) ~= "dead" then
			coroutine.close(thread)
		end
	end
	CoroutineAnimation = {}

	-- Close FlyingCoroutine thread
	if FlyingCoroute and coroutine.status(FlyingCoroute) ~= "dead" then
		coroutine.close(FlyingCoroute)
	end
	FlyingCoroute = nil

	-- Close GrabbingCoroutine thread
	if GrabbingCoroutine and coroutine.status(GrabbingCoroutine) ~= "dead" then
		coroutine.close(GrabbingCoroutine)
	end
	GrabbingCoroutine = nil

	-- Clear all other tables and variables
	RiggedCharacterExtraPart = {}
	RiggedCharacter = {}
	RagdollCountdowner = {}
	Character = nil
	DeltaTime = 0
	LeftRight = 'Right'
	BlockTick = nil
	ActivationTick = 0
	EquipTick = 0
	Equipped = false
	Activated = false
	CurrentAnimation = {}
	Functions = {}
	SoundTabel_ss69_ep420 = {}
end

--<<Util2>>--
function trail(cate:string, where: Instance?, color: Color3?, attachmenta: Attachment?, attachmentb: Attachment?, Size: NumberSequence?, Transparency: NumberSequence?, LifeTime: number?): Trail?
	--print('process start >>'..tostring(tick())..'<< for '..where.Name)
	if not trailforpart[where] then trailforpart[where] = {} end
	if trailforpart[where] and trailforpart[where][cate] then for i,v in trailforpart[where][cate] do sync() v:Destroy() end trailforpart[where][cate] = {} end trailforpart[where][cate] = {}
	if not attachmenta or not attachmentb then return end
	sync()
	--print('new')
	local a=Instance.new"Trail"
	a.Parent = where
	a.Attachment0 = attachmenta
	a.Attachment1 = attachmentb
	a.FaceCamera=false
	a.Color=ColorSequence.new(color or Color3.new(1,1,1),Color3.fromRGB(0,0,0))
	a.WidthScale=Size or NumberSequence.new(1,0)
	a.LightInfluence=0.9 + math.random()/10
	a.MaxLength=100--'5'
	a.Transparency=Transparency or NumberSequence.new(0.5,1)
	a.TextureLength=5
	a.LightEmission=0.9 + math.random()/10
	a.MinLength=0.05
	a.Lifetime=LifeTime or 0.15
	--[[if cate ~= 'HORIZONTAL' then
		a.Enabled = false
	end]]
	if not trailforpart[where] then
		trailforpart[where] = {}
	end
	table.insert(trailforpart[where][cate], a)--table.insert(trailforpart[where][cate], attachmenta)table.insert(trailforpart[where][cate], attachmentb)
	return a
end
function cleartrail(part: BasePart)
	if part and part:IsDescendantOf(game) then	trail('X', part)trail('Y', part)trail('HORIZONTAL', part) end
end
function ExportAnim(name: AnimationTracks, Where: CFrame?, Parent: Instance?)
	if not Where then Where = CFrame.new() end
	if not Parent then Parent = workspace end
	if not name then return end
	if Animation[name] then
		local targetdata = Animation[name]
		local targetfolder = Instance.new('Folder', Parent)
		targetfolder.Name = name..'_Export'
		for i,v in pairs(targetdata) do
			local peranimmodel = Instance.new('Model', targetfolder)
			local leftarm = Instance.new('Part', peranimmodel)local rightarm = Instance.new('Part', peranimmodel)local head = Instance.new('Part', peranimmodel)local torso = Instance.new('Part', peranimmodel)local root = Instance.new('Part', peranimmodel)
			local a=Instance.new"Shirt"
			a.ShirtTemplate="http://www.roblox.com/asset/?id=9495842432"
			root.Size = Vector3.new(2, 2, 1)torso.Size = Vector3.new(2, 2, 1)leftarm.Size = Vector3.new(1, 2, 1)rightarm.Size = Vector3.new(1, 2, 1)head.Size = Vector3.new(1,1,1)
			for i,v in peranimmodel:GetChildren() do
				v.CanCollide = false
				v.CastShadow = false
				v.CanTouch = false
				v.CanQuery = false
				v.Anchored = true
			end
			root.CFrame = Where + Where.RightVector * 7.5 * i
			root.Transparency = 0.9
			root.Name = 'HumanoidRootPart'
			torso.Name = 'Torso'
			rightarm.Name = 'Right Arm'
			leftarm.Name = 'Left Arm'
			head.Name = 'Head'
			peranimmodel.PrimaryPart = root
			peranimmodel.Name = i
			if v['RootJoint'] then
				torso.CFrame = root.CFrame:ToWorldSpace(v['RootJoint'])
			end
			if v['RightShoulder'] then
				rightarm.CFrame = torso.CFrame:ToWorldSpace(v['RightShoulder'])
			end
			if v['LeftShoulder'] then
				leftarm.CFrame = torso.CFrame:ToWorldSpace(v['LeftShoulder'])
			end
			if v['Neck'] then
				head.CFrame = torso.CFrame:ToWorldSpace(v['Neck'])
			end
			local humanoid = Instance.new('Humanoid')
			humanoid.Parent = peranimmodel
			humanoid.DisplayName = name..'_'..i
			if a then a.Parent = peranimmodel end
		end
	end
end

function ClampVector3(vector: Vector3)
	local max_value = flymagfast/3 -- max 5, due to more than that being extremely fast
	local Veccal = vector
	if vector.X ~= vector.X then Veccal = Vector3.new(Random.new():NextInteger(-max_value, max_value), vector.Y, vector.Z) end
	if Veccal.Y ~= Veccal.Y then Veccal = Vector3.new(Veccal.X, Random.new():NextInteger(-max_value, max_value), Veccal.Z) end
	if Veccal.Z ~= Veccal.Z then Veccal = Vector3.new(Veccal.X, Veccal.Y, Random.new():NextInteger(-max_value, max_value)) end
	local clampedX = math.clamp(vector.X, -max_value, max_value)
	local clampedY = math.clamp(vector.Y, -max_value, max_value)
	local clampedZ = math.clamp(vector.Z, -max_value, max_value)
	Veccal = Vector3.new(clampedX, clampedY, clampedZ)
	return Veccal
end
function PlaySound(SoundName: string,ToWhere: Instance?,Volume: number?)
	unsync()
	--getOrCreateSound(SoundName)
	if not Volume then Volume = VolumeMaster/2  else Volume = math.clamp(Volume * VolumeMaster,0,10) end
	local Mainplayfunction = function(hmm: Sound)
		sync()
		hmm.Volume = Volume
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = Character:FindFirstChildOfClass("Humanoid").RootPart or Character:FindFirstChildOfClass('BasePart')
	end
	if ToWhere and FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		Mainplayfunction(FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound'))
	elseif ToWhere and not FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundTabel_ss69_ep420[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sync()
			sound.Volume = Volume 
			sound.Parent = Where
			sound.SoundId = SoundTabel_ss69_ep420[SoundName]
			sound.Name = SoundName
			sound:Play()
			unsync()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end
function returnmuliplierfromcharacter(where: Model)
	if not where then return 1 end
	if not CachedCharacterPartAmount[where] then
		local parts = 0
		for i,v in where:GetChildren() do
			if v:IsA('BasePart') then
				parts += 1
			end
		end
		sync()
		where.Destroying:Once(function()
			CachedCharacterPartAmount[where] = nil
		end)
		CachedCharacterPartAmount[where] = parts
	end
	return 4 * DamageMultiplierGlobal/CachedCharacterPartAmount[where] 
end
local function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal) 
	local reflection = rayDirection - 2 * dotProduct * normal
	return ClampVector3(reflection) :: Vector3
end
function HandleRaycastHit(velocity: Vector3, raycastResult: RaycastResult)
	local normal = raycastResult.Normal
	local speed = velocity.Magnitude
	local baseThreshold = 45  -- Base angle threshold in degrees
	local speedFactor = 0.1  -- Factor to adjust threshold based on speed

	-- Calculate dynamic threshold
	local threshold = baseThreshold / (1 + speed * speedFactor)

	-- Calculate the angle between the normal and the velocity
	local angle = math.deg(math.acos(normal:Dot(velocity.Unit)))

	if angle < threshold then
		-- Go along the surface
		local projectedVelocity = velocity - normal * velocity:Dot(normal)
		return ClampVector3(projectedVelocity), false
	else
		-- Bounce off the surface
		local reflectedVelocity = velocity - 2 * velocity:Dot(normal) * normal
		return ClampVector3(reflectedVelocity), true
	end
end
function DetectDowned(Char: Model)
	if Character and Char and Char:FindFirstChildOfClass("Humanoid") and (FindFirstChildOfNameAndClass(Char, 'HumanoidRootPart', 'BasePart') and FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart') and (FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart').Position.Y - FindFirstChildOfNameAndClass(Char, 'HumanoidRootPart', 'BasePart').Position.Y) > FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart').Size.Y * 0.75) or (not FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart') and Char.PrimaryPart and Character:FindFirstChildOfClass("Humanoid").RootPart and (Character:FindFirstChildOfClass("Humanoid").RootPart.Position.Y - Char.PrimaryPart.Position.Y) > Character:FindFirstChildOfClass("Humanoid").RootPart.Size.Y * 1.5)  then
		return true
	else
		return false
	end
end 
function DetectLooseStealth(Char:Model)
	if Character and Char and Char:FindFirstChildOfClass("Humanoid") and (Char:FindFirstChildOfClass("Humanoid"):GetState() == Enum.HumanoidStateType.Running or Char:FindFirstChildOfClass("Humanoid"):GetState() == Enum.HumanoidStateType.Freefall) and FindFirstChildOfNameAndClass(Char, 'HumanoidRootPart', 'BasePart') and FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart') and (FindFirstChildOfNameAndClass(Character, 'HumanoidRootPart', 'BasePart').CFrame.Position - FindFirstChildOfNameAndClass(Char, 'HumanoidRootPart', 'BasePart').CFrame.Position).Unit:Dot(FindFirstChildOfNameAndClass(Char, 'HumanoidRootPart', 'BasePart').CFrame.LookVector) <= -0.8  then
		return true
	else
		return false
	end
end
local DetectNearby = function(Character: Model, Dis: number?, Query: any?)
	if not Character or not Character:FindFirstChildOfClass('Humanoid') or not Character:FindFirstChildOfClass('Humanoid').RootPart then return end
	local ClosestTarget
	local ClosestDis = Dis or 5
	sync()
	local partsearch = Instance.new('Part')
	partsearch.Size = Vector3.new(ClosestDis,ClosestDis,ClosestDis) * 2
	partsearch.CFrame = Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame -- + Character:GetPivot().LookVector * partsearch.Size/2
	local Parameter = RaycastParams.new()
	Parameter.IgnoreWater = true
	Parameter.RespectCanCollide = true
	Parameter.FilterType = Enum.RaycastFilterType.Exclude
	Parameter.FilterDescendantsInstances = EffectInstance
	Parameter:AddToFilter(Character)
	local oParameter = OverlapParams.new()
	oParameter.RespectCanCollide = true
	oParameter.FilterType = Enum.RaycastFilterType.Exclude
	oParameter.MaxParts = MaxPartPerSearch or 100
	oParameter.FilterDescendantsInstances = EffectInstance
	oParameter:AddToFilter(Character)
	unsync()
	local searched = workspace:GetPartsInPart(partsearch, oParameter)
	sync()
	partsearch:Destroy()
	for i,part in searched do
		unsync()
		local v = part:FindFirstAncestorOfClass('Model')
		unsync()
		if v and v~=Character and v:FindFirstChildOfClass("Humanoid") and v:FindFirstChildOfClass("Humanoid").Health > 0 and v:IsA("Model") and (not Query or (Query and Query(v))) then
			unsync()
			local ClosestTargetHead = FindFirstChildOfNameAndClass(Character,"Head","BasePart")
			if not table.find(Parameter.FilterDescendantsInstances, v) then
				sync()
				if v.PrimaryPart ~= v:FindFirstChildOfClass('Humanoid').RootPart then v.PrimaryPart = v:FindFirstChildOfClass('Humanoid').RootPart end
				Parameter:AddToFilter(v)
			end
			unsync()
			if FindFirstChildOfNameAndClass(v,"Head","BasePart") ~= nil and Character and ClosestTargetHead and ClosestTargetHead.CFrame.LookVector:Dot (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - ClosestTargetHead.Position) >= -0.1 then
				if (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - ClosestTargetHead.Position).Magnitude < ClosestDis and v ~= Character then
					unsync()
					if Character and Character:FindFirstChildOfClass("Humanoid").RootPart and not workspace:Raycast(Character:FindFirstChildOfClass("Humanoid").RootPart.Position,FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Character:FindFirstChildOfClass("Humanoid").RootPart.Position, Parameter) and not workspace:Raycast(FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Character:FindFirstChildOfClass("Humanoid").RootPart.Position - FindFirstChildOfNameAndClass(v,"Head","BasePart").Position, Parameter) then
						ClosestTarget = v
						ClosestDis = (FindFirstChildOfNameAndClass(v,"Head","BasePart").Position - Character:FindFirstChildOfClass("Humanoid").RootPart.Position).Magnitude
					end
				end
				--end
			end
		end
	end
	return ClosestTarget, ClosestDis
end
function LockR15toR6(Character: Model)
	if not R15LockWeld[Character] then
		R15LockWeld[Character] = {}
	else
		return -- already locked
	end
	for i,v in pairs(Character:GetDescendants())  do
		task.desynchronize()
		if (v.Name:match('Foot') or v.Name:match('Hand') or v.Name:match('LowerArm') or v.Name:match('LowerTorso') or v.Name:match('UpperTorso')) and v:IsA('BasePart') then
			if v:FindFirstChildOfClass('Motor6D') and not table.find(R15LockWeld[Character], v:FindFirstChildOfClass('Motor6D')) then
				local mt = v:FindFirstChildOfClass('Motor6D')
				if mt.Enabled == true then
					task.synchronize()
					mt.Enabled = false
					table.insert(R15LockWeld[Character], mt)
					local Replace = Instance.new('Weld', mt.Parent)
					Replace.Name = mt.Name
					Replace.Part1 = mt.Part1
					Replace.Part0 = mt.Part0
					Replace.C0 = mt.C0
					Replace.C1 = mt.C1
					if not table.find(R15LockWeld[Character], Replace) then	table.insert(R15LockWeld[Character], Replace) end
				end
			end
		end
	end --r6ify
end
function UnlockR15(Character)
	task.synchronize()
	if not R15LockWeld[Character] then return end
	for i,v in ipairs(R15LockWeld[Character]) do
		if v:IsA('Motor6D') then
			v.Enabled = true
		else
			v:Destroy()
		end
	end
	table.clear(R15LockWeld[Character])
	R15LockWeld[Character] = nil
end
function Classic_Flagstand_Effect(Coordinate: (CFrame | Vector3)?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?)
	if not BrickVFX then return end
	unsync()
	if typeof(Coordinate) == 'Vector3' then Coordinate = CFrame.new(Coordinate) end
	Amount = math.ceil(Amount)
	local Subject = (Character or Tool)
	local Terrain = RaycastParams.new()
	Terrain.IgnoreWater = false
	Terrain.FilterType = Enum.RaycastFilterType.Include
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Subject:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	sync()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then	RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		Terrain.FilterDescendantsInstances = {workspace:FindFirstChildOfClass('Terrain')}
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		sync()
		local effect = Instance.new("FlagStand", Parent)
		local lastamtick = tick()
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.p or Subject:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		local Sized = effect.Size.X
		coroute = coroutine.create(function()
			unsync()
			lastamtick = tick()
			local Fade_Duration_Count = Fade_Duration
			task.delay(Fade_Duration - 1, function() if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end end)
			while task.wait(UpdateRate) and Fade_Duration_Count > 0 do
				unsync()
				local delta = tick() - lastamtick
				local speed = 1 - .000001 ^ delta
				Fade_Duration_Count = Fade_Duration_Count - delta
				lastamtick = tick()
				unsync()
				if effect then
					local targetc = effect.CFrame targetc = (effect.CFrame + (Motion/1.25 + breakApart/1.25) * speed )* CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					local targett = effect.Transparency + 1 * speed/Fade_Duration
					local Sizeb = effect.Size + effect.Size * Size_Rate * speed/Fade_Duration
					local Sizes = effect.Size - effect.Size * Size_Rate * speed/Fade_Duration
					sync()
					--print('ea')
					effect.CFrame = targetc
					effect.Transparency = targett
					if ShrinkOrExpand == 'Expand' then
						effect.Size = Sizeb  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = Sizes
					end
				end
				unsync()
				if not hit and Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) then
					unsync()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							sync()effect:Destroy()
						else
							sync()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							--cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								cloneeffect.Anchored = false
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								local rx, ry, rz =  CFrame.new(lastpos, hit.Position) --[[Subject:GetPivot()]]:ToOrientation()
								local orientation = Vector3.new(math.deg(rx), math.deg(ry),math.deg(rz))
								local pcf = (CFrame.new(hit.Position , (hit.Position + hit.Normal--[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) or (CFrame.new(effect.Position  , (effect.Position + hit.Normal --[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) -- * savedlleg 
								local lpcf = pcf + Vector3.new(0,-0.05,0)
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position))  * pcf.Rotation --CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,0.1)/1.5
							if game:FindFirstChildOfClass('TweenService') then
								game:FindFirstChildOfClass('TweenService'):Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) task.delay(9, function() if table.find(EffectInstance, cloneeffect) then table.remove(EffectInstance, table.find(EffectInstance, cloneeffect)) end end) end
						end
						task.desynchronize()
						if hit.Instance and (not Character or Character and not hit.Instance:IsDescendantOf(Character)) then
							repeat 
								task.desynchronize()
								local Randomed = math.random()
								if Randomed < Sized then
									--print('uh' .. tostring(CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector) )
									--print('uh' .. Randomed)
									--water splash
									coroutine.resume(coroutine.create(function()--[[ PlaySound('splat0wav', effect)]] Classic_Flagstand_Effect(CFrame.new(hit.Position),Randomed,workspace,math.random(1,2),Fade_Duration/2,Colour,Material,--[[-Motion/2]]--[[ CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector * (Motion.Magnitude/7.5) +]] (HandleRaycastHit(Motion, hit).Magnitude/2) * calculateBounceAngle(Motion, hit).Unit --[[Randomed + breakApart/3]], ShrinkOrExpand, Size_Rate/2, Filter)  end))	
									Sized = Sized - Randomed
								else
									Sized = 0
									break
								end
							until not Sized or Sized <= 0 or not Randomed or not workspace or not game -- noway useless af
						end
					elseif not hit then
						unsync()
						Sized = effect.Size.X
						lastpos = effect.Position
						if Motion.Y < (-0.5 * 25) then
							Motion = Motion + Vector3.new(0,0.1,0) * speed -- slow rec as it inverse accelerates
							GravityStack = GravityStack - 1
						else -- until gravity balanced out
							Motion = Motion + Vector3.new(0,-0.25,0) * speed -- high gain as it accelerates
							GravityStack = GravityStack + 1
						end
					end
				end
				unsync()
				if effect and effect.Color == Color3.new(1,1,1) and effect.Material == Enum.Material.ForceField then
					local Back = workspace:Raycast(effect.Position, lastpos - effect.Position, Terrain) or workspace:Raycast(lastpos, effect.Position - lastpos, Terrain) or workspace:Raycast(lastpos, Vector3.new(0,1,0), Terrain) or workspace:Raycast(lastpos, Vector3.new(0,-1,0), Terrain)
					if Back and (Back.Material == Enum.Material.Air or Back.Material == Enum.Material.Water) then
						sync()
						effect.Size = effect.Size * 2
						effect.Transparency = effect.Transparency + 0.5
						Debris:AddItem(effect,0.05)
					end -- Air Bubble
				end
				unsync()
				if (i >= Fade_Duration) or hit or not effect then
					coroute = nil
					if corouteDis then
						sync()
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						if table.find(EffectInstance, effect) then
							table.remove(EffectInstance, table.find(EffectInstance, effect))
						end
						sync()
						effect:Destroy()
					end
					break
				end
				unsync()
				if (i >= Fade_Duration) or not effect or hit ~= nil then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Subject.Destroying:Connect(function()
			unsync()
			if coroute then
				sync() coroutine.close(coroute)
			end
			unsync()
			if effect then
				sync() effect:Destroy()
			end
		end)
	end
end

function Ragdoll(Who: Model, RagdollTime: number)
	if not HasRagdoll then return end
	unsync()
	if Who and (Who:GetAttribute('PermRag') or RagdollCountdowner[Who] and RagdollCountdowner[Who] >= math.huge) then if not Who:GetAttribute('PermRag') then sync() Who:SetAttribute('PermRag', true) end RagdollCountdowner[Who] = nil return end
	pcall(function() if Who:FindFirstChildOfClass('Humanoid') and (RagdollTime > RagdollTimeThatWillForceUnequipTool or (RagdollCountdowner[Who] and RagdollCountdowner[Who] > RagdollTimeThatWillForceUnequipTool)) then local istool = Who:FindFirstChildOfClass('Tool') or Who:FindFirstChildOfClass('Flag') sync() if istool and FindFirstChildOfNameAndClass(istool, 'Handle', 'BasePart') then istool.Parent = workspace end Who:FindFirstChildOfClass('Humanoid'):UnequipTools() end end)
	if Who == nil or (Who:GetAttribute("IsRagdoll") == true and Who:FindFirstChildOfClass("Humanoid") and Who:FindFirstChildOfClass("Humanoid"):GetState() == Enum.HumanoidStateType.Physics) then
		if RagdollCountdowner[Who] then	RagdollCountdowner[Who] = RagdollCountdowner[Who] + RagdollTime end
		return 
	end
	if not RagdollCountdowner[Who] then
		RagdollCountdowner[Who] = RagdollTime
	else
		return
	end
	local SetBackHipHeight = 2
	local StartTic = 0
	StartTic = tick()
	if Who:FindFirstChildOfClass("Humanoid") and not Who:GetAttribute("IsRagdoll") then
		sync()
		Who:FindFirstChildOfClass("Humanoid").RequiresNeck = false
		local WhosHumanoid = Who:FindFirstChildOfClass("Humanoid")
		Who:SetAttribute("IsRagdoll", true)
		local a
		pcall(function()
			SetBackHipHeight = WhosHumanoid.HipHeight
			WhosHumanoid.BreakJointsOnDeath = false
			WhosHumanoid:ChangeState(Enum.HumanoidStateType.Physics)
			if WhosHumanoid.Health ~= WhosHumanoid.Health or WhosHumanoid.Health <= 0 then
				RagdollTime = math.huge
				WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
				WhosHumanoid:ChangeState(Enum.HumanoidStateType.Dead)
			end
			WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
			WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
			WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
			WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
			if RagdollTime > RagdollTimeThatWillForceUnequipTool then	WhosHumanoid:UnequipTools() end
			WhosHumanoid.AutoRotate = false
			WhosHumanoid.HipHeight = 0
			a = WhosHumanoid.Died:Once(function()
				if CurrentAnimation[Who] then Functions['UnRig'](Who) end
				sync()
				Debris:AddItem(Who,30)
			end)
		end)
		if not Who then return end
		if CharRemoveProcessor[Who] then
			sync()
			CharRemoveProcessor[Who]:Disconnect()
		end
		CharRemoveProcessor[Who] = a
	else
		return
	end
	unsync()
	local Contain = {}
	local WasOn: {Instance: boolean?} = {} -- too lazy to include in Contain
	for index,joint in pairs(Who:GetDescendants()) do
		unsync()
		if not table.find(Contain, joint) then
			table.insert(Contain, joint)
			if joint:IsA("Motor6D") then
				sync()
				local socket = Instance.new("BallSocketConstraint")
				local a1 = Instance.new("Attachment")
				local a2 = Instance.new("Attachment")
				a1.Parent = joint.Part0
				a2.Parent = joint.Part1
				socket.Parent = joint.Parent
				socket.Attachment0 = a1
				socket.Attachment1 = a2
				a1.CFrame = joint.C0
				a2.CFrame = joint.C1
				socket.LimitsEnabled = true
				socket.TwistLimitsEnabled = true
				socket.Name = joint.Name.."FakeAhhJoints"
				local Nocollide = Instance.new("NoCollisionConstraint")
				Nocollide.Parent = joint.Parent
				Nocollide.Part1 = joint.Part1
				Nocollide.Part0 = joint.Part0
				Nocollide.Name = joint.Name
				table.insert(Contain, Nocollide)
				table.insert(Contain, socket)table.insert(Contain, a1)table.insert(Contain, a2)
				if (joint and joint.Parent and not joint.Parent:FindFirstChild(socket.Name)) or not joint or not joint.Parent then
					Debris:AddItem(a1, RagdollTime)
					Debris:AddItem(a2,RagdollTime)
					Debris:AddItem(socket,RagdollTime)
					Debris:AddItem(Nocollide, RagdollTime)
				end
				unsync()
				if joint.Enabled == true then
					WasOn[joint] = true
				else
					WasOn[joint] = false
				end
				sync()
				joint.Enabled = false
			elseif joint:IsA("Tool") or joint:IsA("Flag") then
				if joint.Enabled == true then
					WasOn[joint] = true
				else
					WasOn[joint] = false
				end
				sync()
				joint.Enabled = false
			elseif (joint:IsA("Weld") or joint:IsA("Snap") or joint:IsA("Glue")) and joint.Name ~= 'AccessoryWeld' then -- Nope, Leave these guys alone.
				sync()	
				local Nocollide = Instance.new("NoCollisionConstraint")
				Nocollide.Parent = joint.Parent
				Nocollide.Part1 = joint.Part1
				Nocollide.Part0 = joint.Part0
				Nocollide.Name = joint.Name
				unsync()
				if joint.Enabled == true then
					WasOn[joint] = true
				else
					WasOn[joint] = false
				end
				table.insert(Contain, Nocollide)
				--joint.Enabled = true
			elseif joint:IsA("Part") or joint:IsA("BasePart") or joint:IsA("MeshPart") or joint:IsA("WedgePart") or joint:IsA("UnionOperation") then
				if joint.CanCollide == true then
					WasOn[joint] = true
				else
					WasOn[joint] = false
				end
				sync()
				if joint.Parent == Who then
					joint.CanCollide = true
				else
					joint.CanCollide = false
				end
				joint.CanTouch = true
			elseif joint:IsA("Script") or joint:IsA("LocalScript") and joint ~= script then
				if joint.Enabled == true then
					WasOn[joint] = true
				else
					WasOn[joint] = false
				end
				sync()
				joint.Enabled = false
			end
			if not table.find(Contain, joint) then
				table.insert(Contain, joint)
			end
		end
	end
	if not RagdollTime or RagdollTime >= math.huge then table.clear(Contain) if Who.Name ~= CreditName and Who.PrimaryPart and DeathSFX then sync() local ahh = Instance.new('Sound', Who.PrimaryPart or Who:FindFirstChildOfClass('BasePart')) ahh.SoundId = DeathSFXID ahh.Volume = ahh.Volume * VolumeMaster ahh:Play() end if Who.Name == CreditName and Who.PrimaryPart then sync() local sad = Instance.new('Sound', Who.PrimaryPart) sad.SoundId = math.random() > .5  and 'rbxassetid://1080610827' or 'rbxassetid://5195087640' if sad.SoundId == 'rbxassetid://5195087640' then sad.Volume = 0.3 end sad.Volume = sad.Volume * VolumeMaster sad:Play() end return end
	repeat task.wait(.01) until not Who or not RagdollCountdowner[Who] or RagdollCountdowner[Who] >= math.huge or (tick() - StartTic) >= RagdollCountdowner[Who]
	if not Who or Who and not RagdollCountdowner[Who] or RagdollCountdowner[Who] >= math.huge then
		table.clear(Contain)
		RagdollCountdowner[Who] = nil
		if Who then	sync()
			Debris:AddItem(Who,math.random(30,60))
			Who:SetAttribute('PermRag', true)
			if Who.Name ~= CreditName and Who.PrimaryPart and DeathSFX then sync() local ahh = Instance.new('Sound', Who.PrimaryPart or Who:FindFirstChildOfClass('BasePart')) ahh.SoundId = DeathSFXID2 ahh.Volume = ahh.Volume * VolumeMaster ahh:Play() end if Who.Name == CreditName and Who.PrimaryPart then sync() local screm = Instance.new('Sound', Who.PrimaryPart) screm.Volume = screm.Volume * VolumeMaster screm.SoundId = 'rbxassetid://9081160607' screm:Play() end
		end
		unsync()
		return
	end
	RagdollCountdowner[Who] = nil
	if Who == nil or Who:GetAttribute('PermRag') then
		table.clear(Contain)
		return 
	end
	if CharRemoveProcessor[Who] then
		task.synchronize()
		CharRemoveProcessor[Who]:Disconnect()
		CharRemoveProcessor[Who] = nil
	end
	unsync()
	local Solver = function(joint: Instance)
		unsync()
		if not WasOn[joint] then return end
		if (joint:IsA("Motor6D") or joint:IsA("Weld") or joint:IsA("Snap") or joint:IsA("Glue") or joint:IsA("Script") or joint:IsA("LocalScript") or joint:IsA('Tool') or joint:IsA('Flag')) then
			if WasOn[joint] == true then
				sync()
				joint.Enabled = true
			elseif WasOn[joint] == false then
				sync()
				joint.Enabled = false
			end
		elseif joint:IsA('BallSocketConstraint') or joint:IsA("NoCollisionConstraint") or joint:IsA("Attachment") then
			sync()
			joint:Destroy()
		elseif joint:IsA("Part") or joint:IsA("BasePart") or joint:IsA("MeshPart") then
			if WasOn[joint] == true then
				sync()
				joint.CanCollide = true
			elseif WasOn[joint] == false then
				sync()
				joint.CanCollide = false
			end
		end
		if WasOn[joint] then
			WasOn[joint] = nil
		end
	end
	if Who ~= nil then
		--[[for index,joint in pairs(Who:GetDescendants()) do
			Solver(joint)
			if table.find(Contain, joint) then
				table.remove(Contain, table.find(Contain, joint))
			end
		end]]
		for index,joint in ipairs(Contain) do
			Solver(joint)
			--[[if table.find(Contain, joint) then
				table.remove(Contain, table.find(Contain, joint))
			end]]
		end
		Contain = {}
		WasOn = {}
		if   Who ~= nil and Who:FindFirstChildOfClass("Humanoid") then
			local WhosHumanoid = Who:FindFirstChildOfClass("Humanoid")
			sync()
			pcall(function()
				WhosHumanoid.HipHeight = SetBackHipHeight or 2
				WhosHumanoid.RequiresNeck = false
				WhosHumanoid.AutoRotate = true
				--if WhosHumanoid and WhosHumanoid:GetState() == Enum.HumanoidStateType.Physics then
				WhosHumanoid:ChangeState(Enum.HumanoidStateType.Running)
				WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
				WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Running, true)
				WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
				WhosHumanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
				if RagdollTime > RagdollTimeThatWillForceUnequipTool then	WhosHumanoid:UnequipTools() end
			end)
			--else
			--	Who:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Physics) --Lmao
			--	Who:SetAttribute("IsRagdoll", true)
			--end
			--UnRagdolled
			Who:SetAttribute("IsRagdoll", nil)
		end
	end
end
function createHitboxPart(cframe1: CFrame, cframe2: CFrame, Size: number?)
	unsync()
	-- Calculate the midpoint between the two CFrames
	local midpoint = cframe2.Position + (cframe1.Position - cframe2.Position) / 2
	-- Calculate the size of the hitbox
	local distance = (cframe1.Position - cframe2.Position).Magnitude
	local size = Size and Vector3.new(Size.X, Size.Z, distance * 1.5) or Vector3.new(2, 2, distance * 1.5)
	-- Create the hitbox part
	local hitboxPart = Instance.new("Part")
	sync()
	hitboxPart.Size = size
	hitboxPart.Anchored = true
	hitboxPart.CFrame = CFrame.new(midpoint, cframe2.Position)

	return hitboxPart
end
function RecoverWelds(AnimatedCharacter)
	local function CreateWeldIfNeeded(partName: string?, parentName: string?, part0Name: string?, part1Name: string?, weldName: string?, startcframe: CFrame?)
		if not RiggedCharacter[AnimatedCharacter][partName] and 
			FindFirstChildOfNameAndClass(AnimatedCharacter, parentName, 'BasePart') and 
			(FindFirstChildOfNameAndClass(AnimatedCharacter, part1Name, 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart')) then

			local newWeld = Instance.new('Weld')
			RiggedCharacter[AnimatedCharacter][partName] = newWeld

			sync()
			newWeld.Parent = parentName and FindFirstChildOfNameAndClass(AnimatedCharacter, parentName, 'BasePart') or AnimatedCharacter
			newWeld.Part1 = part1Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part1Name, 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart')
			newWeld.Part0 = part0Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part0Name, 'BasePart') or nil
			newWeld.C0 = startcframe or CFrame.new()
			newWeld.Name = weldName
			unsync()
		end
	end

	CreateWeldIfNeeded('RootJoint', 'HumanoidRootPart', 'HumanoidRootPart', 'UpperTorso', 'Root Joint', CFrame.new())
	CreateWeldIfNeeded('LeftHip', 'UpperTorso', 'UpperTorso', 'LeftLowerLeg', 'Left Hip', CFrame.new(-0.5, -2, 0))
	CreateWeldIfNeeded('LeftShoulder', 'UpperTorso', 'UpperTorso', 'LeftLowerArm', 'Left Shoulder', CFrame.new(-1.5, 0, 0))
	CreateWeldIfNeeded('RightHip', 'UpperTorso', 'UpperTorso', 'RightLowerLeg', 'Right Hip', CFrame.new(0.5, -2, 0))
	CreateWeldIfNeeded('RightShoulder', 'UpperTorso', 'UpperTorso', 'RightLowerArm', 'Right Shoulder', CFrame.new(1.5, 0, 0))
end

--<<Main Function>>--

Functions = {
	["Animate"] = function(AnimatedCharacter: Model?, StartAnim: AnimationTracks?) -- Flexible Movement
		unsync()
		if Shutdown then return end
		if not AnimatedCharacter then return end
		if not CurrentAnimation[AnimatedCharacter] then sync() AnimatedCharacter.Destroying:Once(function() Functions['UnRig'](AnimatedCharacter) UnlockR15(AnimatedCharacter) end) unsync() CurrentAnimation[AnimatedCharacter] = StartAnim or "Unequipped" end
		if not RiggedCharacterExtraPart[AnimatedCharacter] then RiggedCharacterExtraPart[AnimatedCharacter] = {} end
		if not RiggedCharacter[AnimatedCharacter] then RiggedCharacter[AnimatedCharacter] = {} for i,v in pairs(AnimatedCharacter:GetDescendants()) do unsync() if v:IsA("Motor6D") then sync() local Weld = Instance.new("Weld", v.Parent) Weld.Name = v.Name Weld.C0 = v.C0 * v.C1:Inverse() Weld.C1 = CFrame.new() Weld.Part1 = v.Part1 Weld.Part0 = v.Part0 RiggedCharacter[AnimatedCharacter][string.gsub(v.Name, " ", "")] = Weld if string.gsub(v.Name, " ", "") == 'RightShoulder' and FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerArm', 'BasePart') then RiggedCharacterExtraPart[AnimatedCharacter][Weld.Part1] = Weld.Part1.Transparency Weld.Part1.Transparency = 1 Weld.Part1 = FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerArm', 'BasePart') end if string.gsub(v.Name, " ", "") == 'LeftShoulder' and FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerArm', 'BasePart') then RiggedCharacterExtraPart[AnimatedCharacter][Weld.Part1] = Weld.Part1.Transparency Weld.Part1.Transparency = 1 Weld.Part1 = FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerArm', 'BasePart') end if string.gsub(v.Name, " ", "") == 'LeftHip' and FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerLeg', 'BasePart') then RiggedCharacterExtraPart[AnimatedCharacter][Weld.Part1] = Weld.Part1.Transparency Weld.Part1.Transparency = 1 Weld.Part1 = FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerLeg', 'BasePart') end if string.gsub(v.Name, " ", "") == 'RightHip' and FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerLeg', 'BasePart') then RiggedCharacterExtraPart[AnimatedCharacter][Weld.Part1] = Weld.Part1.Transparency Weld.Part1.Transparency = 1 Weld.Part1 = FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerLeg', 'BasePart') end if v.Name == 'Root' and FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') then RiggedCharacterExtraPart[AnimatedCharacter][Weld.Part1] = Weld.Part1.Transparency Weld.Part1.Transparency = 1 RiggedCharacter[AnimatedCharacter]['RootJoint'] = Weld Weld.Part1 = FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') end Weld.Enabled = false end end end
		unsync()
		if RiggedCharacter[AnimatedCharacter] and not CoroutineAnimation[AnimatedCharacter] then 
			--no function here cuz messy
			LockR15toR6(AnimatedCharacter)
			RecoverWelds(AnimatedCharacter)
			local Humanoid = AnimatedCharacter:FindFirstChildOfClass('Humanoid')
			if not Humanoid then
				return
			end
			local AnimationIndice: number = 1
			local AnimationTick: number = tick()
			local LastTick: number = tick()
			local CorouteContainer = CoroutineAnimation[AnimatedCharacter]
			local RigContainer = RiggedCharacter[AnimatedCharacter]
			local LastAnimationNameContainer = 'By Soli' or CurrentAnimation[AnimatedCharacter]
			local AnimationNameContainer = CurrentAnimation[AnimatedCharacter]
			local LastHealth = Humanoid.Health
			local RootJoint: JointInstance? = RigContainer['RootJoint']
			local Root: BasePart? = RigContainer['RootJoint'] and RigContainer['RootJoint'].Part0
			local LastTiltAngle: CFrame = CFrame.new()
			sync()
			local CoroutineAnim = coroutine.create(function()
				while task.wait(UpdateRate) and Tool and script and script.Parent and RigContainer and AnimationNameContainer and AnimatedCharacter and CurrentAnimation[AnimatedCharacter] do
					unsync()
					--[[unsync()
					if HealthEventEnabled == true and AnimatedCharacter == Character and LastHealth ~= Humanoid.Health then
						sync()
						local saved = Humanoid.Health
						if HealthEventEnabled == true and DetectNearby(Character, 9) then
							sync()
							Humanoid.Health = saved + 0.001
							LastHealth = saved + 0.001
							task.delay(0.001,function() unsync() if HealthEventEnabled == true or not Humanoid then return end sync() if Humanoid then Humanoid.Health = saved end LastHealth = saved end)
						end
						unsync()
					end
					unsync()]]
					if AnimatedCharacter == Character and not Equipped and CurrentAnimation[AnimatedCharacter] and CurrentAnimation[AnimatedCharacter] ~= "Unequip" then 
						CurrentAnimation[AnimatedCharacter] = "Unequip"
					end
					local Delta = math.clamp(tick() - LastTick, 0, 5)
					LastTick = tick()
					local Speed = math.clamp(1 - 0.000001^Delta,0,1)
					AnimationNameContainer = CurrentAnimation[AnimatedCharacter]
					local SpecifiedSpeed = AnimSpeed[AnimationNameContainer] or 1
					if SpecifiedSpeed ~= 1 then
						Speed = Speed * SpecifiedSpeed
					end
					if AnimationNameContainer ~= LastAnimationNameContainer then
						AnimationIndice = 1
						AnimationTick = tick()
						LastAnimationNameContainer = AnimationNameContainer
					end
					if VelocityTilt and RigContainer and RootJoint and Root and Humanoid then
						local TiltAngle = CFrame.new()
						if AlwaysTilt or (Humanoid and (AnimatedCharacter ~= Character or not table.find({'Stomp', 'Unequippped'}, ToolCurrentState) and CurrentAnimation[Character] ~= 'Flying Kick' and not (ToolCurrentState == 'Checkered' and CurrentAnimation[Character] == 'Countering')) and table.find({Enum.HumanoidStateType.Freefall, Enum.HumanoidStateType.Jumping, Enum.HumanoidStateType.Landed, Enum.HumanoidStateType.Running}, Humanoid:GetState())) then
							local direction = Root.AssemblyLinearVelocity/7
							local RightAngle = math.clamp(Root.CFrame.RightVector:Dot(direction) * TiltMultiplier /7, -MaxTilt, MaxTilt)
							local ForwardAngle = math.clamp(Root.CFrame.LookVector:Dot(direction) * TiltMultiplier /7, -MaxTilt, 0) 
							TiltAngle = (LeftRightTiltRotationAffects == 'Y' and CFrame.Angles(-ForwardAngle, -RightAngle, 0) or CFrame.Angles(-ForwardAngle, 0, -RightAngle)):Inverse()
						end
						LastTiltAngle = AnimationType == 'Lerp' and LastTiltAngle:Lerp(TiltAngle, Speed) or TiltAngle
						--local InterpolatedAngle = RootJoint.C1:Lerp(LastTiltAngle, Speed)
						sync()
						RootJoint.C1 = LastTiltAngle
						unsync()
					end
					if Animation[AnimationNameContainer] then
						local TimedIndices = tostring(math.clamp(math.ceil((tick() - AnimationTick) * 20 * SpecifiedSpeed), 0, AnimFrame[AnimationNameContainer] or 6))
						if Animation[AnimationNameContainer][TimedIndices] then
							if AnimationIndice < tonumber(TimedIndices) then
								AnimationIndice = tonumber(TimedIndices)
							end
							--else
							--print('no '.. AnimationNameContainer.. '> '.. tostring(math.ceil((tick() - AnimationTick) * 6)))
						elseif not Animation[AnimationNameContainer][TimedIndices] and Animation[AnimationNameContainer][AnimationIndice + 1] then
							AnimationIndice = AnimationIndice + 1 -- manual increase
							AnimationTick = tick()
						end
						if Animation[AnimationNameContainer] and Animation[AnimationNameContainer][tostring(AnimationIndice)] then
							unsync()
							for i,v in pairs(Animation[AnimationNameContainer][tostring(AnimationIndice)]) do
								unsync()
								if RigContainer[i] then
									if typeof(v) ~= 'CFrame' then if typeof(v) == 'table' then v = CFrame.new(unpack(Animation[AnimationNameContainer][tostring(AnimationIndice)][i])) elseif typeof(v) == 'number' then v = CFrame.new(v,0,0) end end
									sync()
									RigContainer[i].Enabled = true
									if Speed >= 0.7 and HitboxConnections[RigContainer[i].Part1] and AnimationNameContainer:upper():match('PUNCH') then
										local a = createHitboxPart(RigContainer[i].Part0.CFrame:ToWorldSpace(RigContainer[i].C0), RigContainer[i].Part0.CFrame:ToWorldSpace(RigContainer[i].C0:Lerp(v, Speed)), RigContainer[i].Part1.Size * 1.25)
										if Speed >= 1.4 then
											pcall(function()
											local a2 = createHitboxPart(RigContainer[i].Part0.CFrame, RigContainer[i].Part0.CFrame:ToWorldSpace(RigContainer[i].C0:Lerp(v, Speed)), RigContainer[i].Part1.Size * 1.25)
											local a3 = createHitboxPart(RigContainer[i].Part0.CFrame:ToWorldSpace(RigContainer[i].C0), RigContainer[i].Part0.CFrame, RigContainer[i].Part1.Size * 1.25)
											Functions['Hitbox'](a2, 0.05)
											Functions['Hitbox'](a3, 0.05)
											Debris:AddItem(a3)Debris:AddItem(a2)
											end)
										end
										Functions['Hitbox'](a, 0.05)
										Debris:AddItem(a, 0.05)
									end
									RigContainer[i].C0 = AnimationType == 'Lerp' and RigContainer[i].C0:Lerp(v, Speed) or v
								end
								--[[if i == 'Grip' or 'RightGrip' then
									sync()
									Tool.Grip = Tool.Grip:Lerp(v, Speed)
								end]]
							end
						end
					end
				end
			end)
			sync()
			CoroutineAnimation[AnimatedCharacter] = CoroutineAnim
			coroutine.resume(CoroutineAnim)
		end
	end,
	['Hitbox'] = function(Part: BasePart, Duration: number, Mb: any?)
		if Shutdown and not HitboxConnections[Part] then return end
		if not Part then return end
		local valid = true
		local new = math.randomseed(tick()) or EquipTick
		local customSize = Part.Size
		local lastvel = Part.Velocity
		new = tick()
		HitboxTick[Part] = new
		if HitboxConnections[Part] then for i,v in ipairs(HitboxConnections[Part]) do sync() v:Disconnect() if table.find(HitboxConnections[Part], v) then table.remove(HitboxConnections[Part], table.find(HitboxConnections[Part], v)) end end end
		if not Duration or Duration <= 0 or HitboxTick[Part] ~= new then return end
		if HitboxConnections[Part] then for i,v in ipairs(HitboxConnections[Part]) do sync() v:Disconnect() if table.find(HitboxConnections[Part], v) then table.remove(HitboxConnections[Part], table.find(HitboxConnections[Part], v)) end end end
		HitboxConnections[Part] = {}
		sync()
		local apar = OverlapParams.new()
		apar.FilterDescendantsInstances = EffectInstance
		apar:AddToFilter(Character)
		apar.RespectCanCollide = true
		apar.FilterType = Enum.RaycastFilterType.Exclude
		apar.MaxParts = MaxPartPerHitboxPart or 100
		pcall(function() apar:AddToFilter(HitboxDebounce[Part]) end)		
		local TouchedAlr = workspace:GetPartsInPart(Part, apar) or Part:GetTouchingParts()
		local LastMid = Mb == nil and Part.CFrame
		if Mb == nil then
			LastMid = Part.CFrame
		end
		local Clean
		local RayPar = RaycastParams.new()
		RayPar.IgnoreWater = true
		RayPar.FilterType = Enum.RaycastFilterType.Exclude
		unsync()
		HitboxDebounce[Part] = {Character, workspace:FindFirstChildOfClass('Terrain')}
		sync()
		RayPar.FilterDescendantsInstances = EffectInstance
		RayPar:AddToFilter(Character)
		pcall(function() RayPar:AddToFilter(HitboxDebounce[Part]) end)
		unsync()
		local Hit = Mb or function(BP: BasePart)
			unsync()
			if (BP.Position - Part.Position).Magnitude < Part.Size.Magnitude then
				local ParModel = BP:FindFirstAncestorWhichIsA('Model')
				if not BP:IsDescendantOf(Character) and ParModel and ParModel:FindFirstChildOfClass('Humanoid') and ParModel:FindFirstChildOfClass('Humanoid').Health > 0 then
					unsync()
					PlaySound('Hit', BP, returnmuliplierfromcharacter(BP:FindFirstAncestorWhichIsA('Model'))/3)
					if RagdollOnVitalHitWithPunch then
						coroutine.resume(coroutine.create(function()
							if BP.Name:upper():match("LEG") then
								Ragdoll(		ParModel, math.clamp(Part.Velocity.Magnitude/3, 0, 4)* returnmuliplierfromcharacter(IntModel))
							elseif BP.Name:upper():match("HEAD") then
								Ragdoll(		ParModel, math.clamp(Part.Velocity.Magnitude/4, 0, 5)* returnmuliplierfromcharacter(IntModel))
							end
						end))
					end
					sync()
					Classic_Flagstand_Effect((BP or ParModel:FindFirstChildOfClass('Humanoid').RootPart or ParModel.PrimaryPart or Part).Position, math.random(20,25)/60, workspace, math.random(2,4), 7, (BP or ParModel:FindFirstChildOfClass('Humanoid').RootPart or ParModel.PrimaryPart or Part).Color, Enum.Material.Neon, ClampVector3(ClampVector3((Part.Position - BP.Position) or lastvel or Part.Velocity or Vector3.new(0,1,0)).Unit * math.random(1000,1200)/750), 'Shrink', math.random(40,60)/100, {Character, BP, ParModel})
					unsync()
					if ParModel:FindFirstChildOfClass('Humanoid') and ParModel:FindFirstChildOfClass('Humanoid').BreakJointsOnDeath == true then
						sync()
						ParModel:FindFirstChildOfClass('Humanoid').BreakJointsOnDeath = false
					end
					sync()
					--BP.Velocity = BP.Velocity + lastvel.Unit * 10 --Part.Velocity * 5
					--[[if ParModel:FindFirstChildOfClass('Humanoid').RootPart and ParModel:FindFirstChildOfClass('Humanoid'):GetState() == Enum.HumanoidStateType.Running then
						ParModel:FindFirstChildOfClass('Humanoid').RootPart.CFrame = CFrame.new(ParModel:FindFirstChildOfClass('Humanoid').RootPart.Position)  * CFrame.new(ParModel:FindFirstChildOfClass('Humanoid').RootPart.CFrame.LookVector, Character:FindFirstChildOfClass("Humanoid").RootPart.Position + Vector3.new ((Part.AssemblyLinearVelocity).X,0,(Part.AssemblyLinearVelocity).Z)).Rotation
					end]]
					ParModel:FindFirstChildOfClass('Humanoid').Health = ParModel:FindFirstChildOfClass('Humanoid').Health - ((BP.Name:upper():match("HEAD") and math.random(120,240)/10 or math.random(80,120)/10) + Part.AssemblyLinearVelocity.Magnitude)*returnmuliplierfromcharacter(ParModel)*ParModel:FindFirstChildOfClass('Humanoid').MaxHealth/100
					if	ParModel:FindFirstChildOfClass('Humanoid').Health <= 0 or ParModel:FindFirstChildOfClass('Humanoid').Health ~= ParModel:FindFirstChildOfClass('Humanoid').Health and not ParModel:GetAttribute('Tagged_By_Combat') then
						sync()
						ParModel:FindFirstChildOfClass('Humanoid').PlatformStand = true
						ParModel:FindFirstChildOfClass('Humanoid').RootPart.Velocity = Part.CFrame.LookVector * Part.Mass * 20 * Part.AssemblyLinearVelocity.Magnitude --[[ClampVector3(ClampVector3(Vector3.new(lastvel.Unit.X,0,lastvel.Unit.Z)) * math.floor(math.clamp(math.random(800,1200)/100,0, 30)))]] --ClampVector3(ParModel:FindFirstChildOfClass('Humanoid').RootPart.Velocity + Vector3.new(lastvel.Unit.X,0,lastvel.Unit.Z) * 5 --[[(ClampVector3(Vector3.new(lastvel.Unit.X,0,lastvel.Unit.Z)) * math.floor(math.clamp(math.random(800,1200)/100,0, 30) * 2))]]) 
						ParModel:SetAttribute('Tagged_By_Combat', true)
						coroutine.resume(coroutine.create(function()	Ragdoll(ParModel, math.huge)end))
					end
				end
			else
				if not table.find(HitboxDebounce[Part], BP) then table.insert(HitboxDebounce[Part], BP) end
			end
		end
		local function Filter(BP)
			unsync()
			--register in time
			if (HitboxTick[Part] and EquipTick and EquipTick > HitboxTick[Part]) or (HitboxTick[Part] and tick() - HitboxTick[Part] > (Duration + 0.25)) or (HitboxTick[Part] and HitboxTick[Part] ~= new) or not Equipped then
				Clean()
				--return
			end
			if not HitboxDebounce[Part] then
				HitboxDebounce[Part] = {}
			end
			if typeof(BP) == 'Instance' then
				if HitboxDebounce[Part] and table.find(HitboxDebounce[Part], BP) or BP:IsA('BasePart') and (BP.Position - Part.Position).Magnitude > Part.Size.Magnitude + BP.Size.Magnitude then 
					return -- check distance from touched event
				end
			else
				if HitboxDebounce[Part] and table.find(HitboxDebounce[Part], BP.Instance) then
					return
				end
			end
			if HitboxDebounce[Part] and not table.find(HitboxDebounce[Part], BP) and (not HitboxTick[Part] or EquipTick <= HitboxTick[Part] and HitboxTick[Part] == new) and Equipped and Part and Character then
				if typeof(BP) == 'Instance' then
					table.insert(HitboxDebounce[Part], BP)
					sync()
					RayPar:AddToFilter(BP)
					apar:AddToFilter(BP)
					unsync()
				else
					sync()
					RayPar:AddToFilter(BP.Instance)
					apar:AddToFilter(BP.Instance)
					unsync()
				end
				coroutine.resume(coroutine.create(function() Hit(BP)  end))
			end
		end
		coroutine.resume(coroutine.create(function()
			for i,v in TouchedAlr do
				Filter(v)
			end
		end))
		if not Equipped then return end
		local AttachmentPos: {CFrame: Vector3?} = {}
		local function AddToPos(LocalCFrame: CFrame)
			if AttachmentPos and LocalCFrame then
				AttachmentPos[LocalCFrame] = Part.CFrame:ToObjectSpace(LocalCFrame).Position
			end
		end
		AddToPos(CFrame.new())AddToPos(CFrame.new(Part.Size.X/2,0,0))AddToPos(CFrame.new(-Part.Size.X/2,0,0))AddToPos(CFrame.new(0,Part.Size.Y/2,0))AddToPos(CFrame.new(0,-Part.Size.Y/2,0))AddToPos(CFrame.new(0,0,Part.Size.Z/2))AddToPos(CFrame.new(0,0,-Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, -Part.Size.Y/2, 0))AddToPos(CFrame.new(-Part.Size.X/2, -Part.Size.Y/2, 0))AddToPos(CFrame.new(Part.Size.X/2, Part.Size.Y/2, 0))AddToPos(CFrame.new(-Part.Size.X/2, Part.Size.Y/2, 0))AddToPos(CFrame.new(Part.Size.X/2, 0, Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, 0, Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, 0, -Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, 0, -Part.Size.Z/2))AddToPos(CFrame.new(0, Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(0, -Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(0, Part.Size.Y/2, -Part.Size.Z/2))AddToPos(CFrame.new(0, -Part.Size.Y/2, -Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, Part.Size.Y/2, -Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, -Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(Part.Size.X/2, -Part.Size.Y/2, -Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, Part.Size.Y/2, -Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, -Part.Size.Y/2, Part.Size.Z/2))AddToPos(CFrame.new(-Part.Size.X/2, -Part.Size.Y/2, -Part.Size.Z/2))
		sync()
		local TouchEvent = Part.Touched:Connect(Filter) local TouchEndedEvent = Part.TouchEnded:Connect(Filter) local TouchLocalEvent = Part.LocalSimulationTouched:Connect(Filter)
		local RayEvent: RBXScriptConnection?
		Clean = function()
			if script:FindFirstAncestorWhichIsA('Actor') then	sync() end
			if RayEvent then
				RayEvent:Disconnect()
				RayEvent = nil
			end
			if TouchEvent then
				TouchEvent:Disconnect()
				TouchEvent = nil
			end
			if TouchEndedEvent then
				TouchEndedEvent:Disconnect()
				TouchEndedEvent = nil
			end
			if TouchLocalEvent then
				TouchLocalEvent:Disconnect()
				TouchLocalEvent = nil
			end
			if HitboxTick[Part] == new then
				HitboxConnections[Part] = nil
			end
			if HitboxTick[Part] == new and HitboxDebounce[Part] then
				table.clear(HitboxDebounce[Part])
			end
			valid = false
			return
		end
		sync()
		RayEvent = game:FindFirstChildOfClass('RunService').Stepped:Connect(function(a,t)
			unsync()
			if  not HitboxTick[Part] or not Equipped or EquipTick > new  or (HitboxTick[Part] and tick() - HitboxTick[Part] > Duration) or HitboxTick[Part] ~= new then
				sync()
				Clean()
				unsync()
				if HitboxTick[Part] == new then
					HitboxTick[Part] = nil
					HitboxDebounce[Part] = nil
				end
				return
			end
			unsync()
			if not Part then if RayEvent then unsync() RayEvent:Disconnect() RayEvent = nil return end end
			coroutine.resume(coroutine.create(function()
				for i,v in pairs(AttachmentPos)  do
					unsync()
					if HitboxTick[Part] ~= new then
						break
					end
					local Cast: RaycastResult?
					local CurOffsetPos = Part.CFrame:ToObjectSpace(i).Position-- print(v - CurOffsetPos)
					unsync()
					if RaycastHitbox then	Cast = workspace:Raycast(v, CurOffsetPos - v, RayPar) or workspace:Raycast(CurOffsetPos - Part.Velocity, Part.Velocity, RayPar) or workspace:Raycast(CurOffsetPos, v - CurOffsetPos, RayPar) or workspace:Raycast(CurOffsetPos, -Part.Velocity, RayPar) or workspace:Raycast(v, Part.Position - v, RayPar) or workspace:Raycast(Part.Position, v - Part.Position, RayPar) or workspace:Raycast(CurOffsetPos, Part.Position - CurOffsetPos, RayPar) or workspace:Raycast(Part.Position, CurOffsetPos - Part.Position, RayPar) end
					local also = PartQueryHitbox and workspace:GetPartsInPart(Part, apar)
					if PartQueryHitbox then	coroutine.resume(coroutine.create(function() for i,v in also do Filter(v) end end)) end
					if Cast then
						lastvel = v - CurOffsetPos
						coroutine.resume(coroutine.create(function()
							local howmuch = 100 howmuch = MaxRaycastLoop
							repeat 
								howmuch -= 1
								Cast = workspace:Raycast(CurOffsetPos, lastvel, RayPar) or workspace:Raycast(v, -lastvel, RayPar) or workspace:Raycast(v, Part.Velocity, RayPar) or workspace:Raycast(CurOffsetPos, -Part.Velocity, RayPar) or workspace:Raycast(CurOffsetPos, Part.Position - CurOffsetPos, RayPar) or workspace:Raycast(Part.Position, CurOffsetPos - Part.Position, RayPar) or workspace:Raycast(Part.Position, v - Part.Position, RayPar) or workspace:Raycast(v, Part.Position - v, RayPar) 
								if Cast and HitboxDebounce[Part] and not table.find(HitboxDebounce[Part],Cast.Instance) and Cast.Instance.Parent and Cast.Instance:IsA('BasePart') then
									Filter(Cast.Instance)
								else
									break
								end
								task.wait(.01)
								unsync()
							until howmuch <= 0 or not valid or not Cast or not Cast.Instance or not HitboxTick[Part] or HitboxTick[Part] ~= new
						end))
					end
					AddToPos(i)
				end
			end))
				coroutine.resume(coroutine.create(function()
				if LastMid or not Mb and HitboxTick[Part] == new and PartQueryHitbox then
						local altbetween = createHitboxPart(LastMid, Part.CFrame + Part.Velocity, Part.Size * 1.5)
						unsync()
					local getbet = PartQueryHitbox and workspace:GetPartsInPart(altbetween, apar) or {}
					if PartQueryHitbox then	coroutine.resume(coroutine.create(function() for i,v in getbet do Filter(v) end end)) end
						if altbetween then sync() altbetween:Destroy() unsync() end
					end
					--[[local CopyofOther = OtherHitboxPart[Part] --[[table.clone(OtherHitboxPart[Part])]]
					--[[OtherHitboxPart[Part] = {}
					for i,othp in CopyofOther do
						local oth = workspace:GetPartsInPart(othp, apar)
						for i,v in oth do Filter(v) end
						if othp then sync() othp:Destroy()--[[ table.remove(OtherHitboxPart[Part], table.find(OtherHitboxPart[Part],othp)) unsync() end]]
					--end]]
				end))
			
		end)
		if not Equipped or HitboxTick[Part] ~= new then sync() Clean() return end
		unsync()
		table.insert(HitboxConnections[Part],RayEvent)table.insert(HitboxConnections[Part],TouchEvent)table.insert(HitboxConnections[Part],TouchEndedEvent)table.insert(HitboxConnections[Part],TouchLocalEvent)
		sync()
		coroutine.resume(coroutine.create(function()
			task.wait(Duration)
			if HitboxConnections[Part] and HitboxTick[Part] == new then	for i,v in ipairs(HitboxConnections[Part]) do sync() v:Disconnect() unsync() --[[if table.find(HitboxConnections[Part], v) then table.remove(HitboxConnections[Part], table.find(HitboxConnections[Part], v)) end]] end HitboxConnections[Part] = {} end
			Clean()	
		end))
		return {RayEvent,TouchEvent,TouchLocalEvent,TouchEndedEvent}
	end,
	['UnRig'] = function(Character: Model?)
		unsync()
		if not Character then return end
		if Character and not FindFirstChildOfNameAndClass(Character, Tool.Name, Tool.ClassName) then	if RiggedCharacterExtraPart[Character] then for i,v in RiggedCharacterExtraPart[Character] do sync() i.Transparency = v end RiggedCharacterExtraPart[Character] = nil end else task.delay(0.1, function() if Character and not FindFirstChildOfNameAndClass(Character, Tool.Name, Tool.ClassName) then RiggedCharacterExtraPart[Character] = nil end end) end
		unsync()
		if CurrentAnimation[Character] then CurrentAnimation[Character] = nil end
		if RiggedCharacter[Character] then for i,v in pairs(RiggedCharacter[Character]) do sync() v:Destroy() end RiggedCharacter[Character] = nil end
		if CoroutineAnimation[Character] then sync() coroutine.close(CoroutineAnimation[Character]) CoroutineAnimation[Character] = nil end
		UnlockR15(Character)
	end
	,
	["Initiate_Character"] = function(CharacterToConnect: Model?)
		if oof then return end
		if not lastef or Shutdown then return end
		unsync()
		if not CharacterToConnect then return end
		local When = EquipTick
		When = tick()
		if CharacterToConnect and CharacterToConnect:FindFirstChildOfClass("Humanoid") then
			Character = CharacterToConnect
			Humanoid = CharacterToConnect:FindFirstChildOfClass('Humanoid')
			if Character and Humanoid and Character:FindFirstChildOfClass("Humanoid").RootPart ~= Humanoid.RootPart then sync() Character:FindFirstChildOfClass("Humanoid").RootPart = Humanoid.RootPart sync() end
			for i, cache in ToolHumanoidConnection do sync() cache:Disconnect() end
			unsync()
			LastJumpPower = Humanoid.JumpPower
			MaxReceivedDamageRegister = Character and CharacterToConnect and CharacterToConnect:FindFirstChildOfClass("Humanoid") and CharacterToConnect:FindFirstChildOfClass("Humanoid").RigType == Enum.HumanoidRigType.R6 and MaxReceivedDamageTime/2 or MaxReceivedDamageTime
			table.clear(ToolHumanoidConnection)
			HealthEventEnabled = true
			local CanDeflect = true -- 2nd Authentication
			local NowRegister: number = MaxReceivedDamageRegister or MaxReceivedDamageTime -- Prevent Too Many Triggers
			local LastHealth =Humanoid.Health
			--print(tostring(NowRegister))
			sync()
			pcall(function() Humanoid.BreakJointsOnDeath = false
			local RagdollEvent =CharacterToConnect:GetAttributeChangedSignal('IsRagdoll'):Connect(function(HP)
				if CharacterToConnect:GetAttribute('IsRagdoll') then
					Active = false
					HealthEventEnabled = false
					if ClearHitbox then	ClearHitbox(CharacterToConnect) end
					if Humanoid and not ToolStayEquippedUponRagdoll then sync() Humanoid:UnequipTools() unsync() end	
				else
					if Tool then sync() Tool.Enabled = true end
					HealthEventEnabled = true
				end
			end)
			local HealthEvent =Humanoid.HealthChanged:Connect(function(HP)
				unsync()
				local operationsuccess = false
				NowRegister = math.clamp(NowRegister, 0, MaxReceivedDamageRegister)	
				if Humanoid.Health <= 0 or Humanoid.Health ~= Humanoid.Health then
					HealthEventEnabled = false
					sync()
					Humanoid:ChangeState(Enum.HumanoidStateType.Dead)
					return
				end
				if oof or not NowRegister or (ToggleMaxRegisterOrNot and NowRegister <= 0) then return end
				NowRegister -= 1
				task.delay(1, function() if not operationsuccess then NowRegister += 1 CanDeflect = true end end)
				if not CanDeflect or not HealthEventEnabled or not CurrentAnimation[CharacterToConnect] or CurrentAnimation[CharacterToConnect] == 'PerfectBlock' or CurrentAnimation[CharacterToConnect] == 'Countering' or CurrentAnimation[CharacterToConnect] == 'Unequip' or CurrentAnimation[CharacterToConnect] == 'Blocked' or Character ~= CharacterToConnect or not Character or Character:GetAttribute('IsRagdoll') or ToolCurrentState == 'Unequipped' or not Equipped or When < EquipTick then NowRegister += 1 LastHealth = HP return end	
				if HP < LastHealth and HealthEventEnabled then
					if not DetectNearby(Character, 9) then if Character.Name == 'Solivion' then sync()Humanoid.Health = LastHealth end LastHealth =Humanoid.Health return end
					local ClosestTarget: Model, ClosestDis: number
					ClosestTarget, ClosestDis = DetectNearby(Character, 9)
					if --[[not ClosestTarget and ]]Character.Name == 'Solivion' then -- auto failsave
						sync()
						Humanoid.Health = LastHealth
						unsync()
						if ToolCurrentState == 'Equipped' then
							ToolCurrentState = 'Block'
							BlockTick = tick()
							ActivationTick = tick()
						elseif ToolCurrentState == 'Block' then
							ToolCurrentState = 'Checkered'
							ActivationTick = tick()
						elseif ToolCurrentState == 'Punching' then
							ToolCurrentState = 'Block'
							BlockTick = ActivationTick
						end
						unsync()
					end
					local DTHP = LastHealth - HP
					local DamagedHealth = HP
					local LastHP = LastHealth
					LastHP = LastHealth
					DamagedHealth = HP
					HealthEventEnabled = false
					local ClosestTargetHead: BasePart? = ClosestTarget and FindFirstChildOfNameAndClass(ClosestTarget,"Head","BasePart")
					local ClosestTargetHumanoid: Humanoid? = ClosestTarget and ClosestTarget:FindFirstChildOfClass("Humanoid")
					if not ClosestTarget or not ClosestTargetHumanoid then return end
					--print('Registered')	
					if ToolCurrentState == "Checkered" then
						CanDeflect = false
						unsync()
						local istool = ClosestTarget and (ClosestTarget:FindFirstChildOfClass('Tool') or ClosestTarget:FindFirstChildOfClass('Flag'))
						if ClosestTarget ~= nil and ClosestTargetHead then
							local mid = CharacterToConnect:GetPivot() + (ClosestTarget:GetPivot().p - CharacterToConnect:GetPivot().p)/2
							sync()
							Humanoid.PlatformStand = false
							Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
							Functions['Animate'](ClosestTarget, math.random() > 0.5 and (math.random() > 0.5 and 'PUNCH' or 'PUNCH_ALT') or (math.random() > 0.5 and 'ThrashSwing' or 'Thrash_ALT'))
							sync()
							if istool and FindFirstChildOfNameAndClass(istool, 'Handle', 'BasePart') then
								istool.Parent = workspace
							end
							ClosestTargetHumanoid:UnequipTools()
							Humanoid.Health = LastHP
							FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame = CFrame.new(FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position, Vector3.new(ClosestTargetHead.CFrame.Position.X,FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position.Y,ClosestTargetHead.CFrame.Position.Z) )
							--ClosestTargetHead.Position = Handle.Position + Handle.AssemblyLinearVelocity.Unit
							Classic_Flagstand_Effect(mid.Position, math.random(2,3), workspace, 1, 7, BrickColor.White().Color, Enum.Material.ForceField, nil, 'Shrink', 3)
							if Character:FindFirstChildOfClass('Humanoid') then
								sync()
								Humanoid.PlatformStand = false
								Tool.Enabled = true
								unsync()
							end
							task.delay(0.05, function() PlaySound('Woosh', Character:FindFirstChildOfClass('BasePart') or Character:FindFirstChildOfClass("Humanoid").RootPart, 0.2) end)
							PlaySound('Kerplunk', Character:FindFirstChildOfClass('BasePart') or Character:FindFirstChildOfClass("Humanoid").RootPart, DTHP/5)
							PlaySound('splat0wav', ClosestTargetHead, 0.25)
							task.delay(0.1, function()
								sync()
								Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
								unsync()
								if not ClosestTarget or not Character then
									return
								end
								sync()
								Humanoid.PlatformStand = false
								Humanoid.Health = LastHP
								LastHealth = LastHP
								Classic_Flagstand_Effect(mid.Position, math.random(2,3)/8, workspace, 1, 7, BrickColor.White().Color, Enum.Material.Neon, nil, 'Expand', 2.25)
									Classic_Flagstand_Effect(ClosestTargetHead.CFrame.Position, math.random(20,25)/60, workspace, math.ceil((math.random(15,25) + DTHP * 1.25/3)), 36, ClosestTargetHead.Color, Enum.Material.Neon, -(mid.Position - Character:GetPivot().Position).Unit * (DTHP + 2.5)/4, 'Shrink', 0.5, {ClosestTarget, Character})
								sync()
								ClosestTargetHead.CFrame = CFrame.new(ClosestTargetHead.CFrame.Position, FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position)
								ClosestTargetHead.AssemblyLinearVelocity = ClosestTargetHead.AssemblyLinearVelocity + ClosestTargetHead.CFrame.LookVector * - DTHP * 0.25 --+ --[[ClosestTargetHead.CFrame.LookVector]] Character:FindFirstChildOfClass("Humanoid").RootPart.AssemblyLinearVelocity.Unit * (math.clamp(Character:FindFirstChildOfClass("Humanoid").RootPart.AssemblyLinearVelocity.Magnitude*2,2,math.huge)  + DTHP * 1/4)
								PlaySound('button0wav', ClosestTargetHead, 0.7)
								unsync()
								if ClosestTargetHumanoid then
									CurrentAnimation[ClosestTarget] = 'PerfectBlock'
									sync()
									coroutine.resume(coroutine.create(function() Ragdoll(ClosestTarget, math.random(5,7)/10 + DTHP / 5) end))
									ClosestTargetHumanoid:UnequipTools()
									ClosestTargetHumanoid.BreakJointsOnDeath = false
									ClosestTargetHumanoid.PlatformStand = true
									ClosestTargetHumanoid.Health = ClosestTargetHumanoid.Health - ((math.random(15,25) * 5 + DTHP * 1.25) /125) * ClosestTargetHumanoid.MaxHealth
									coroutine.resume(coroutine.create(function() if ClosestTargetHumanoid.Health <= 0 or ClosestTargetHumanoid.Health ~= ClosestTargetHumanoid.Health then	Ragdoll(ClosestTarget, math.huge) end end))
									PlaySound("Hit",ClosestTargetHead, 0.4)
									coroutine.resume(coroutine.create(function() if ClosestTargetHumanoid then task.wait(math.random(5,7)/10 + DTHP / 5) if ClosestTargetHumanoid then sync() ClosestTargetHumanoid.BreakJointsOnDeath = false ClosestTargetHumanoid.PlatformStand = false Functions['UnRig'](ClosestTarget) end end end))
								end		
								if Character:FindFirstChildOfClass('Humanoid') then
									sync()
									Humanoid.PlatformStand = false
									Tool.Enabled = true
									unsync()
								end
							end)
						end
						CurrentAnimation[Character] = 'Countering'
						Active = false
						sync()
						Tool:Deactivate()
						task.wait(0.4)
						--Tool:Activate()
						if not Activated or CurrentAnimation[Character] == 'Countering' then
							CurrentAnimation[Character] = 'Equip'
							ToolCurrentState = "Equipped"
							Active = true
						end
						--Tool:Deactivate()
					elseif ToolCurrentState == "Dismissal" or CurrentAnimation[Character] == "Flying Kick" then
						Active = false
						sync()
						Humanoid.Health = LastHP
						LastHealth = LastHP
						if Character:FindFirstChildOfClass('Humanoid') then
							Humanoid.PlatformStand = false
						end
						Active = true
					elseif ToolCurrentState == "Block" then
						Active = false
						local mid = CharacterToConnect:GetPivot() + (ClosestTarget:GetPivot().p - CharacterToConnect:GetPivot().p)/2
						if (tick() - BlockTick) < 0.1 then
							CanDeflect = false
							Classic_Flagstand_Effect(mid, 0.5, workspace, math.random(1,3) + math.ceil(DTHP/2), math.random(5,7), ClosestTargetHead.Color:Lerp(Character:FindFirstChildOfClass("Humanoid").RootPart.Color, 0.3), Enum.Material.Neon, nil, 'Expand', 3)						
							--Clash
							unsync()
							LastHealth = LastHP
							if ClosestTarget ~= nil and ClosestTargetHead then
								sync()
								FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame = CFrame.new(FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position, Vector3.new(ClosestTargetHead.CFrame.Position.X,FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position.Y,ClosestTargetHead.CFrame.Position.Z) )
								FindFirstChildOfNameAndClass(Character,"Head","BasePart").AssemblyLinearVelocity = FindFirstChildOfNameAndClass(Character,"Head","BasePart").AssemblyLinearVelocity + FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.LookVector * 5 
								ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = true
								ClosestTargetHead.AssemblyLinearVelocity = ClosestTargetHead.AssemblyLinearVelocity + (Character:FindFirstChildOfClass("Humanoid").RootPart.Position - ClosestTargetHead.CFrame.p) * - DTHP * 2
								ClosestTarget:FindFirstChildOfClass("Humanoid").PlatformStand = false
								PlaySound('glassbreak0wav', ClosestTargetHead, 0.3)
							end
							unsync()
							if Character:FindFirstChildOfClass('Humanoid') then
								sync()
								Humanoid.PlatformStand = false
							end
							unsync()
							Active = false
							CurrentAnimation[Character] = 'PerfectBlock'
							sync()
							Humanoid.Health = LastHP
							--Tool:Deactivate()
							task.wait(0.55/AnimSpeed['PerfectBlock'])
							--Tool:Activate()
							if ToolCurrentState == "Block" then	CurrentAnimation[Character] = 'Equip'
								PlaySound('SWITCH3', ClosestTargetHead, 0.25 + DTHP/4)
								ToolCurrentState = "Equipped" end
							Active = true
						else
								Classic_Flagstand_Effect(mid, math.random(2,3)/1.5, workspace, math.random(1,3) + math.floor(DTHP/3), math.random(5,7), ClosestTargetHead.Color:Lerp(Character:FindFirstChildOfClass("Humanoid").RootPart.Color, 0.3), Enum.Material.Neon, nil, 'Shrink', 2.25)	
							unsync()
							Active = true
							CurrentAnimation[Character] = 'Blocked'
							sync()
							FindFirstChildOfNameAndClass(Character,"Head","BasePart").AssemblyLinearVelocity = FindFirstChildOfNameAndClass(Character,"Head","BasePart").AssemblyLinearVelocity + FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.LookVector * DTHP/2 
							FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame = CFrame.new(FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position, Vector3.new(ClosestTargetHead.CFrame.Position.X,FindFirstChildOfNameAndClass(Character,"Head","BasePart").CFrame.Position.Y,ClosestTargetHead.CFrame.Position.Z) )
							Humanoid.Health = LastHP - DTHP/3
							PlaySound('FlashBulb', ClosestTargetHead, DTHP/3)
							task.wait(0.05)
							if ToolCurrentState == "Block" then CurrentAnimation[Character] = 'Block' end
						end
						Active = true
					elseif ToolCurrentState == "Punching" then
						sync()
						Humanoid.Health = LastHP - DTHP/1.5
						PlaySound('Switch', ClosestTargetHead, 0.15)
					end
					unsync()
					LastHealth =Humanoid.Health -- Recovered Ver
					if Humanoid.Health <= 0 or Humanoid.Health ~= Humanoid.Health then
						Active = false
						coroutine.resume(coroutine.create(function() Ragdoll(Character, math.huge) end))
						sync()
						Tool:Destroy()
					end
					unsync()
					if EquipTick <= When and Character == CharacterToConnect and Equipped and ToolCurrentState ~= 'Unequipped' then
						HealthEventEnabled = true
						CanDeflect = true
					end	
				else
					LastHealth = HP
				end
				NowRegister += 1
				operationsuccess = true
			end)
			sync()
			local StateEvent =Humanoid.StateChanged:Connect(function(OldState, NewState)
				unsync()
				if oof then return end
				-- if OldState == Enum.HumanoidStateType.Flying and CurrentAnimation[Character] == "Flying Kick" then CurrentAnimation[Character] heck no, I'll make custom physics for kick. coroutine for the rise!1!!
				if NewState == Enum.HumanoidStateType.Dead or Humanoid.Health <= 0 or Humanoid.Health ~= Humanoid.Health then
					oof = true
					Active = false
					coroutine.resume(coroutine.create(function() Ragdoll(Character, math.huge) end))
					HealthEventEnabled = false
					sync()
					if ClearHitbox then	ClearHitbox(CharacterToConnect) end
					if Tool then sync() Tool:Destroy() end
				elseif NewState == Enum.HumanoidStateType.Ragdoll or NewState == Enum.HumanoidStateType.PlatformStanding or NewState == Enum.HumanoidStateType.Physics then
					Active = false
					HealthEventEnabled = false
					if ClearHitbox and CurrentAnimation[CharacterToConnect] ~= 'Flying Kick' and (not FlyingCoroute or FlyingCoroute and coroutine.status(FlyingCoroute) == 'dead') and Active and (tick() - lastfly) > 0.1 then	ClearHitbox(CharacterToConnect) end
				else
					Active = true
				end
			end)
			if Destroy then Destroy:Disconnect() end
			Destroy = Humanoid.Died:Once(function()
				if oof then return else oof = true end
				Equipped = false
				Active = false
				Functions['UnRig'](Character)
				coroutine.resume(coroutine.create(function() Ragdoll(Character, math.huge) end))
				HealthEventEnabled = false
				sync()
				if ClearHitbox then	ClearHitbox(CharacterToConnect) end
				if Tool then sync() Tool:Destroy() end
			end)	
			table.insert(ToolHumanoidConnection, RagdollEvent) table.insert(ToolHumanoidConnection, HealthEvent) table.insert(ToolHumanoidConnection, StateEvent)
			end)	
		end
	end
}

ClearHitbox = function(CharacterToConnect: Model) -- Disconnect all Character's Hitbox
	unsync()
	for i,v in CharacterToConnect:GetChildren() do
		unsync()
		if v:IsA('BasePart') and (HitboxConnections[v] and HitboxConnections[v][1]) then
			Functions['Hitbox'](v, 0)
		end
	end
end

function SkillStateCheck() if Equipped and Tool and Character and not Character:GetAttribute('IsRagdoll') and ToolCurrentState ~= 'Grabbing' and ToolCurrentState ~= 'Stomp' and ToolCurrentState ~= 'Punching' and ToolCurrentState ~= 'Unequipped' and ToolCurrentState ~= 'Block' and CurrentAnimation[Character] ~= "Flying Kick" then return true else return false end end

--<<Early In-Backpack Character Register>>--
if Tool and Tool:FindFirstAncestorOfClass('Backpack') and Tool:FindFirstAncestorOfClass('Player') then
	if not 	Tool:FindFirstAncestorOfClass('Player').Character then repeat task.wait(.01) until Tool:FindFirstAncestorOfClass('Player').Character or not Tool or not Tool:FindFirstAncestorOfClass('Player') end
	Character = Tool:FindFirstAncestorOfClass('Player').Character
	Functions['UnRig'](Character)
	Functions["Initiate_Character"](Character)
	Functions["Animate"](Character, 'Equip')
	if not Equipped then
		Functions['UnRig'](Character)
		for i, cache in ToolHumanoidConnection do sync() cache:Disconnect() end
	end
end

--<<Main Events>>--
Tool.Unequipped:Connect(function()
	if DynamicHitbox then RaycastHitbox = false PartQueryHitbox = false end
	unsync()
	local E = tick() E = tick() EquipTick = E ActivationTick = E ToolCurrentState = "Unequipped" Equipped = false Activated = false CurrentAnimation[Character] = 'Unequip'
	unsync()
	local Randomed = math.random(1,3)
	local Bracket1, Bracket2 =  string.rep("<", Randomed),string.rep(">", Randomed)
	if Character and Humanoid and Humanoid.RootPart and FindFirstChildOfNameAndClass(Humanoid.RootPart, 'Fly', 'Sound') then
		sync()
		FindFirstChildOfNameAndClass(Humanoid.RootPart, 'Fly', 'Sound'):Destroy()
	end
	sync()
	for i,v in pairs(TrailAttachments) do for i,AttachmentTypes in pairs(v) do for i,Attachments in pairs(AttachmentTypes) do Attachments:Destroy() end end v = nil end
	Tool.ToolTip = Bracket1..'By @'..(game:FindFirstChildOfClass('Players'):GetNameFromUserIdAsync(1233413367) or CreditName)..', Equip To View Controls'..Bracket2
	unsync()
	ClearHitbox(Character)
	local leftside = FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart')
	local rightside = FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart')
	unsync()
	if leftside then PlaySound('fabric', leftside, 0.085) end if rightside then PlaySound('fabric', rightside, 0.085) end
	task.wait(0.3)
	if not Equipped and E == EquipTick then
		Functions['UnRig'](Character)
		for i, cache in ToolHumanoidConnection do sync() cache:Disconnect() end
	end
end)
Tool.Equipped:Connect(function()
	if DynamicHitbox then RaycastHitbox = false PartQueryHitbox = false end
	sync()
	for i, cache in ToolHumanoidConnection do sync() cache:Disconnect() end
	Tool.ToolTip = 'Hold To Attack or Block, Release When Blocking To Counter'
	unsync()
	local E = tick() E = tick() EquipTick = E ActivationTick = E ToolCurrentState = "Equipped" Equipped = true Activated = false
	Character = Tool:FindFirstAncestorWhichIsA("Model")
	if Character then ClearHitbox(Character) else return end
	if Character and Character:FindFirstChildOfClass('Humanoid') and Character:GetAttribute('IsRagdoll') then
		sync()	Character:FindFirstChildOfClass('Humanoid'):UnequipTools()
	end
	sync()
	for i,v in pairs(TrailAttachments) do for i,AttachmentTypes in pairs(v) do for i,Attachments in pairs(AttachmentTypes) do Attachments:Destroy() end end v = nil end
	for i,v in Character:GetChildren() do
		if v:isA('BasePart') then
			local newattach1 = Instance.new('Attachment', v) local newattach2 = Instance.new('Attachment', v)
			newattach1.CFrame = CFrame.new(v.Size.X/2, -v.Size.Y/2.05, 0) newattach2.CFrame = CFrame.new(-v.Size.X/2, -v.Size.Y/2.05, 0)
			local newattach3 = Instance.new('Attachment', v) local newattach4 = Instance.new('Attachment', v)
			newattach3.CFrame = CFrame.new(0,-v.Size.Y/2.05, v.Size.Z/2)newattach4.CFrame = CFrame.new(0,-v.Size.Y/2.05, -v.Size.Z/2)
			local newattach5 = Instance.new('Attachment', v) local newattach6 = Instance.new('Attachment', v)
			newattach5.CFrame = CFrame.new(0, -v.Size.Y/2, 0) newattach6.CFrame = CFrame.new(0, v.Size.Y/2, 0)
			TrailAttachments[v] = {}
			TrailAttachments[v]['HORIZONTAL'] = {}
			TrailAttachments[v]['X'] = {}
			TrailAttachments[v]['Y'] = {}
			table.insert(TrailAttachments[v]['HORIZONTAL'], newattach5)table.insert(TrailAttachments[v]['HORIZONTAL'], newattach6)
			table.insert(TrailAttachments[v]['X'], newattach1)table.insert(TrailAttachments[v]['X'], newattach2)
			table.insert(TrailAttachments[v]['Y'], newattach3)table.insert(TrailAttachments[v]['Y'], newattach4)
		end
	end
	unsync()
	Humanoid = Character:FindFirstChildOfClass('Humanoid')
	local leftside = FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart')
	local rightside = FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart')
	unsync()
	if leftside then PlaySound('Swoosh', leftside, 0.2) end if rightside then PlaySound('Swoosh', rightside, 0.2) end
	Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart'), 0) Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart'), 0)
	Functions["Hitbox"](FindFirstChildOfNameAndClass(Character,'Left Leg','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerLeg','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftFoot','BasePart'), 0)
	Functions["Hitbox"](FindFirstChildOfNameAndClass(Character,'Right Leg','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerLeg','BasePart') or FindFirstChildOfNameAndClass(Character,'RightFoot','BasePart'), 0)
	Functions["Hitbox"](FindFirstChildOfNameAndClass(Character,'UpperTorso','BasePart') or FindFirstChildOfNameAndClass(Character,'LowerTorso','BasePart') or FindFirstChildOfNameAndClass(Character,'Torso','BasePart'), 0)
	Functions["Hitbox"](FindFirstChildOfNameAndClass(Character,'HumanoidRootPart','BasePart'), 0)
	Functions['UnRig'](Character)
	Functions["Initiate_Character"](Character)
	Functions["Animate"](Character, 'Equip')
	CurrentAnimation[Character] = 'Equip'
end)
local lastactive = 0
Tool.Deactivated:Connect(function()
	unsync()
	if ToolCurrentState == 'Punching' or ToolCurrentState == 'Stomp' then
		if (tick() - lastactive) <= 10 ^ -8 then return else lastactive = tick() end -- mobile double tap issue
		ActivationTick = tick()
		Activated = false
		return
	end
	if not Active or not Activated then Activated = false ActivationTick =  tick() return end
	local ActivateDelta = 0 ActivateDelta = math.clamp(tick() - ActivationTick, 0, 5) local E = tick() E = tick() ActivationTick = E Activated = false
	if ActivateDelta <= 0.5 and not (ToolCurrentState == "Grabbing" and ActivateDelta >= (SnapTime or 0)) then
		--[[local statecheckearlyisgrab = ToolCurrentState == 'Grabbing' or CurrentAnimation[Character] == 'GRAB' or (tick() - lastgrab) < StealthGrabCooldown/3 or GrabCoroute ~= nil
		if statecheckearlyisgrab and Equipped then
			task.delay(0.25, function()
				if ActivationTick == E and Equipped then
					CurrentAnimation[Character] = 'Equip'
					ToolCurrentState = "Equipped"
				end
			end)
		end]]
		if Active and not Activated and ActivationTick == E and Equipped then
			--print('p')
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = "Equipped"
			Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart'), 0) Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart'), 0)
		end
	else
		local returntostate = true
		--print('n')
		if ToolCurrentState == "Grabbing" and CurrentAnimation[Character] == 'GRAB' then
			unsync()
			if ActivateDelta >= (SnapTime or 0) and TargetCharacter and TargetCharacter:FindFirstChildOfClass("Humanoid") then
				sync()
				TargetCharacter:FindFirstChildOfClass("Humanoid").BreakJointsOnDeath = false
				PlaySound('Gib', TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart, 0.45)
				sync()	
				if TargetCharacter and FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart') then
					Debris:AddItem(FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart'), 60)
					--	FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart'):BreakJoints()
					local hashead: BasePart? = FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart')
					if TargetCharacter and FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart') then
						-- Remove Neck Joint, Ragdoll Support
						local stufftomovewithhead = {}
						for i,v in pairs(TargetCharacter:GetDescendants())  do
							if not hashead then
								hashead = FindFirstChildOfNameAndClass(TargetCharacter, 'Head', 'BasePart')
								if not hashead then hashead = nil break end
							end
							local check = true
							if v and ((v:IsA('JointInstance') and (--[[v.Name:upper():match("NECK")]]v.Name:upper() == 'NECK' or v.Part1 == hashead)) or (v:IsA('Constraint') and not v:IsA('JointInstance') and (v.Name:upper():match("NECK") or (v.Attachment1 and v.Attachment1.Parent == hashead) or (v.Attachment0 and v.Attachment0.Parent == hashead)))) then
								if v:IsA'JointInstance' and ((v.Name == 'AccessoryWeld' and v.Part0.Name == 'Handle' and string.gsub(v.Name:lower(), ' ', ''):match('accessoryweld') and v:FindFirstAncestorOfClass('Accessory')) or v:FindFirstAncestorOfClass('Hat')) then
									table.insert(stufftomovewithhead, v:Clone())
									table.insert(stufftomovewithhead, v.Part0)
								else
									v:Destroy()
								end
								check = false
							end
							if check and (v:IsA('JointInstance') and v.Part0 == hashead) then
								table.insert(stufftomovewithhead, v)
								table.insert(stufftomovewithhead, v.Part1)
								check = false
							end
							if check and (v:IsA('Constraint') and ((v.Attachment1 and v.Attachment1.Parent == hashead) or (v.Attachment0 and v.Attachment0.Parent == hashead))) then
								table.insert(stufftomovewithhead, v)
								if v and v.Attachment0 and v.Attachment0.Parent and v.Attachment0.Parent ~= hashead then	table.insert(stufftomovewithhead, v.Attachment0.Parent) end if v and v.Attachment1 and v.Attachment1.Parent and v.Attachment1.Parent == hashead then	 table.insert(stufftomovewithhead, v.Attachment1.Parent) end
								check = false
							end
						end
						if hashead then
							for i,v in stufftomovewithhead do
								if hashead then v.Parent = hashead else break end
							end
						end
					end
					pcall(function()
						if hashead then
							hashead.Anchored = false
							pcall(function() hashead:SetNetworkOwner(nil) end)
							hashead.CanCollide = true
							hashead.Parent = workspace
						end	
					end)
				end
				coroutine.resume(coroutine.create(function() Ragdoll(TargetCharacter, math.huge) end))
				if TargetCharacter and TargetCharacter:FindFirstChildOfClass('Humanoid') then
					TargetCharacter:FindFirstChildOfClass("Humanoid").Health = 0
					TargetCharacter:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Dead)
					TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart.Velocity = --[[TargetCharacter:FindFirstChildOfClass("Humanoid").RootPart.Velocity + ]]ClampVector3(Character:FindFirstChildOfClass("Humanoid").RootPart.CFrame.LookVector) * math.random(17500,27500)/1000
				end
			end
			unsync()
		end
		Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'LeftHand','BasePart'), 0) Functions['Hitbox'](FindFirstChildOfNameAndClass(Character,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(Character,'RightHand','BasePart'), 0)
		if ToolCurrentState == 'Block' or (ToolCurrentState == 'Grabbing' and CurrentAnimation[Character] == 'GRAB') then
			CurrentAnimation[Character] = 'Counter'
			ToolCurrentState = "Checkered"
			if CounterTimeFrame ~= math.huge then	task.wait(CounterTimeFrame or math.random(45,55)/100) else returntostate = false end
		end
		if returntostate and (ActivationTick == E or (ToolCurrentState == 'Checkered' and CurrentAnimation[Character] == 'Counter'))  and Equipped and Active == true then
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = 'Equipped'
		end
		if GrabCoroute then CurrentAnimation[Character] = 'Equip' ToolCurrentState = 'Equipped' sync() coroutine.close(GrabCoroute) GrabCoroute = nil end
	end
end)
Tool.Activated:Connect(function()
	unsync()
	if ToolCurrentState == 'Grabbing' and Equipped then ToolCurrentState = 'Equipped' if Character then CurrentAnimation[Character] = 'Equip' end end
	if RegisterCooldown and ((tick() - lastfly) < RegisterCooldown or (tick() - lastgrab) < RegisterCooldown or (tick() - BlockTick) < RegisterCooldown/2 or (tick() - EquipTick) < RegisterCooldown or (tick() - lastpunch) < RegisterCooldown) then return end
	if not Character or not Tool or not Tool:IsDescendantOf(Character) or Tool.Enabled == false or ToolCurrentState == 'Punching' or CurrentAnimation[Character] == 'Countering' or CurrentAnimation[Character] == 'Countered' or CurrentAnimation[Character] == 'PerfectBlock' or ToolCurrentState == 'Block' or ToolCurrentState == 'Stomp' or ToolCurrentState == "Grabbing" then
		if (tick() - lastactive) <= 10 ^ -8 then return else lastactive = tick() end -- mobile double tap issue
		if ToolCurrentState == 'Block' then
			CurrentAnimation[Character] = 'Equip'
			ToolCurrentState = 'Equipped'
		end
		ActivationTick = tick()
		Activated = false
		return
	end
	if not Active then Activated = false ActivationTick =  tick() return end
	local E = tick() E = tick() ActivationTick = E Activated = true
	if JumpKick and (tick() - lastfly) > JumpKickCooldown and SkillStateCheck() and Character and Humanoid and Humanoid.RootPart and (Humanoid.RootPart.Velocity.Y > 0) and (Humanoid:GetState() == Enum.HumanoidStateType.Freefall or Humanoid:GetState() == Enum.HumanoidStateType.Jumping) then
		if Character then	CurrentAnimation[Character] = "Flying Kick" if Humanoid then sync() Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false) unsync() end end
		if DynamicHitbox then RaycastHitbox = true PartQueryHitbox = false end
		lastfly = tick()
		Active = false
		Activated = false
		ActivationTick = 1
		local initChr = Character
		local initChrHM = Humanoid
		local lastfoor = initChr
		local CooldownCount: {Instance: number?} = {}
		local CooldownList: {Instance?} = {initChr, lastfoor, Tool}
		local CooldownList2: {Instance?} = {initChr, lastfoor, Tool} -- non changing one
		sync()
		local RaycastParfloor = RaycastParams.new()
		RaycastParfloor.IgnoreWater = false
		RaycastParfloor.FilterType = Enum.RaycastFilterType.Exclude
		RaycastParfloor.FilterDescendantsInstances = CooldownList2
		RaycastParfloor:AddToFilter(EffectInstance)
		RaycastParfloor.RespectCanCollide = true
		local RaycastPar = RaycastParams.new()
		RaycastPar.IgnoreWater = true
		RaycastPar.FilterType = Enum.RaycastFilterType.Exclude
		RaycastPar.FilterDescendantsInstances = CooldownList
		RaycastPar:AddToFilter(EffectInstance)
		RaycastPar.RespectCanCollide = true
		local LapPar = OverlapParams.new()
		LapPar.FilterType = Enum.RaycastFilterType.Exclude
		LapPar.FilterDescendantsInstances = CooldownList
		LapPar:AddToFilter(EffectInstance)
		LapPar.RespectCanCollide = true
		if FlyingCoroute then
			coroutine.close(FlyingCoroute)
			FlyingCoroute = nil
		end
		unsync()
		local SFX = FindFirstChildOfNameAndClass(initChrHM.RootPart, 'Fly', 'Sound') or Instance.new('Sound')
		if SFX then
			sync()
			SFX.Parent =initChrHM.RootPart
			if SFX.Name ~= 'Fly' then
				SFX.Name = 'Fly'
				SFX.Volume = 1
				SFX.SoundId = math.random() > .5 and 'rbxassetid://99274458' or "rbxassetid://99274458"
				SFX.Looped = true
			end
			SFX.SoundId = math.random() > .5 and 'rbxassetid://99274458' or "rbxassetid://99274458"
			SFX:Play()
			Debris:AddItem(SFX, 120)
			unsync()
		end
		local Velocity = Vector3.new(initChrHM.RootPart.Velocity.X, 0, initChrHM.RootPart.Velocity.Z).Magnitude > 8 and Vector3.new(initChrHM.RootPart.Velocity.X, 0, initChrHM.RootPart.Velocity.Z).Unit * (Vector3.new(initChrHM.RootPart.Velocity.X, 0, initChrHM.RootPart.Velocity.Z).Magnitude + 5) or (initChrHM.RootPart.CFrame.LookVector * 20 --[[+initChrHM.RootPart.CFrame.UpVector * 2]]) . Unit * math.random(5,10) --[[initChr:FindFirstChildOfClass("Humanoid").RootPart.Velocity.Magnitude]] or initChrHM.RootPart.Velocity * 2.25
		local Gravity = Vector3.new()
		local StartedJump
		local lasthi =initChrHM.RootPart.Position.Y
		local lastpivot = initChr:GetPivot()
		local ticklastpivot = initChr:GetPivot()
		StartedJump = tick()
		local LastUpdateTick = tick()
		local LastPartPos: {BasePart: Vector3?} = {}
		local Disable: boolean = false
		if initChrHM and initChrHM.RootPart then
			sync()
			pcall(function() initChrHM.RootPart:SetNetworkOwner(nil) end)	
			initChrHM.RootPart.Anchored = true
			initChrHM.RootPart.CanCollide = false
			initChrHM.AutoRotate = false
		end
		Functions["Hitbox"](FindFirstChildOfNameAndClass(initChr,'Left Leg','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftLowerLeg','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftFoot','BasePart'), 0)
		Functions["Hitbox"](FindFirstChildOfNameAndClass(initChr,'Right Leg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightLowerLeg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightFoot','BasePart'), 0)
		unsync()
		for i, v in initChr:GetChildren() do
			if v:IsA("BasePart") then
				LastPartPos[v] = v.Position
				sync()
				v.CanCollide = false
				unsync()
			end
		end
		if initChr and initChrHM then sync()	initChrHM:ChangeState(Enum.HumanoidStateType.Physics) unsync() end
		FlyingCoroute = coroutine.create(function()
			--add while loop here
			lastfly = tick()
			local ReducedVel = true
			local VelRot
			local Fatalitypoint = 10
			if initChr and Equipped then	CurrentAnimation[initChr] = "Flying Kick" else lastfly = 0 return end
			local dts = 0
			local Head =  FindFirstChildOfNameAndClass(initChr,'Head','BasePart')
			local RootTar =initChrHM.RootPart or FindFirstChildOfNameAndClass(initChr,'initChrHMRootPart','BasePart')
			local TorsoTar = FindFirstChildOfNameAndClass(initChr,'UpperTorso','BasePart') or FindFirstChildOfNameAndClass(initChr,'Torso','BasePart')
			local LeftArmTar = FindFirstChildOfNameAndClass(initChr,'Left Arm','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftLowerArm','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftHand','BasePart')
			local RightArmTar = FindFirstChildOfNameAndClass(initChr,'Right Arm','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightLowerArm','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightHand','BasePart')
			local LeftLegTar = FindFirstChildOfNameAndClass(initChr,'Left Leg','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftLowerLeg','BasePart') or FindFirstChildOfNameAndClass(initChr,'LeftFoot','BasePart')
			local RightLegTar = FindFirstChildOfNameAndClass(initChr,'Right Leg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightLowerLeg','BasePart') or FindFirstChildOfNameAndClass(initChr,'RightFoot','BasePart')
			local trailroot = trail('X', TorsoTar, TorsoTar.Color,  TrailAttachments[TorsoTar]['X'][1],TrailAttachments[TorsoTar]['X'][2])
			local LastBounce = 0
			local LREG = 0
			local MaxRate = 1/60
			sync()
			Debris:AddItem(trailroot, 120)
			local function handlescan(Scanned: any?)
				--print('Reg Tick:' .. tostring(tick() - lastfly))
				unsync()
				if (tick() - lastfly) > 120 or not (Velocity and Gravity) or Velocity.Magnitude <= 0.1 or Fatalitypoint <= 0 or (tick() - lastfly) > JumpKickCooldown or not Scanned or table.find(CooldownList, Scanned) then return end
				unsync()
				local Unserious = false
				if typeof(Scanned) ~= 'RaycastResult' and typeof(Scanned) == 'Instance' and Scanned:IsA("BasePart") then
					local Part = Scanned
					Part = Scanned
					if initChr and Part:IsDescendantOf(initChr) then
						return
					end
					local Setup = {}
					Setup.Instance = Part
					Setup.Material = Part.Material
					Setup.Position = Part.Position
					Scanned = Setup
					Unserious = true
					if table.find(CooldownList, Scanned) or Scanned == lastfoor then	return end
				else
					if initChr and Scanned.Instance:IsDescendantOf(initChr) then
						return
					end
					if table.find(CooldownList, Scanned.Instance) or Scanned.Instance == lastfoor then	return end
				end
				for i,v in pairs(CooldownCount) do
					v = v - 1
					if v <= 0 and table.find(CooldownList, i) then
						table.remove(CooldownList, table.find(CooldownList, i))
						CooldownCount[i] = nil
					end
					if not table.find(CooldownList, i) then
						CooldownCount[i] = nil
					end
				end
				local IntModel = Scanned.Instance:FindFirstAncestorWhichIsA('Model')
				if not Unserious and Scanned.Position and (RootTar.Position - Scanned.Position):Dot(Vector3.new(0,1,0)) <= -0.8 then
					local pivort = initChr:GetPivot()
					Gravity = Vector3.new()
					if table.find(CooldownList, Scanned.Instance) then
						table.remove(CooldownList, table.find(CooldownList, Scanned.Instance))
					end
					sync()
					initChr:PivotTo(pivort.Rotation * CFrame.new(pivort.X, Scanned.Position.Y + 1, pivort.Z))
				end
				unsync()
				if not Unserious and Scanned.Instance and	(Scanned.Instance:IsA('Terrain') or (Scanned.Instance:IsA('BasePart') and not IntModel or (IntModel and not IntModel:FindFirstChildOfClass("Humanoid")))) then
				
					if Velocity.Magnitude > 5 and 	Scanned.Instance:IsA('BasePart') and (Scanned.Instance.Material == Enum.Material.Glass or Scanned.Instance.Material == Enum.Material.Ice)	 then
						sync()
						local Sounder = Instance.new('Part', workspace)
						Sounder.Anchored = true
						Sounder.CanCollide = false
						Sounder.Transparency = 1
						Sounder.Position = Scanned.Position
						Debris:AddItem(Sounder, 1)PlaySound('glassbreak0wav', Sounder, 0.25)
						sync()	
						Scanned.Instance:Destroy()
						unsync()	
					else
						if Unserious or Disable then return end
						if (tick() - LastBounce) < MaxRate then return else LastBounce = tick() end
						Classic_Flagstand_Effect(Scanned.Position, Velocity.Magnitude * 5,workspace, math.ceil(Velocity.Magnitude), math.random(2,3)/8, (Scanned.Instance:IsA('BasePart') and Scanned.Instance.Color or workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Scanned.Material) or workspace:FindFirstChildOfClass('Terrain').WaterColor):Lerp(TorsoTar.Color, 0.3), Scanned.Material, nil, 'Expand', 1.75)
						Classic_Flagstand_Effect(Scanned.Position, math.clamp(Velocity.Magnitude, 0,2)/4, workspace, math.ceil(Velocity.Magnitude), 7, (Scanned.Instance:IsA('BasePart') and Scanned.Instance.Color or workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(Scanned.Material) or workspace:FindFirstChildOfClass('Terrain').WaterColor):Lerp(TorsoTar.Color, 0.3), Scanned.Material, -Velocity, 'Shrink', 0.5, {Scanned.Instance:IsA('BasePart') and Scanned.Instance, initChr})
						Disable = true
						CooldownCount[Scanned.Instance] = 1

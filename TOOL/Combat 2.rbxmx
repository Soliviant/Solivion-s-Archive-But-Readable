							Velocity = HandleRaycastHit(Velocity, Scanned) + (Scanned.Instance:IsA("BasePart") and Scanned.Instance.Anchored == false and Scanned.Instance.Velocity or Vector3.new())/2
						else
							Velocity = Vector3.new(Velocity.X,0,Velocity.Z) 
						end
						Velocity = ClampVector3(Velocity)
						local Bounce = CFrame.new(Scanned.Position+ Velocity, Scanned.Position + Velocity * 2 * dts)			
						--Velocity = Velocity/4
						sync()
						--initChr:FindFirstChildOfClass("Humanoid").RootPart.Position = 	Bounce.p	
						initChr:PivotTo(Bounce)
						ticklastpivot = CFrame.new(Scanned.Position)
						lastpivot = Bounce--[[ + (Scanned.Position - lastpivot.p)]]
						local Sounder = Instance.new('Part', workspace)

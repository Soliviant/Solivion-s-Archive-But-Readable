							sync()	Debris:AddItem(Sounder, 1)PlaySound('Fist_Pounds_Table_Wooden', Sounder, 0.1)
						end
						--initChr:PivotTo()
						unsync()
						if not (Scanned.Instance == lastfoor or Scanned.Instance:IsDescendantOf(lastfoor)) then
							Gravity = HandleRaycastHit(Gravity, Scanned) or calculateBounceAngle(Gravity, Scanned)
						else
							Gravity = Vector3.new(0,math.abs(Gravity.Y),0) or Vector3.new(0,math.clamp(Gravity.Y,0,flymagfast),0)
						end
						Gravity = ClampVector3(Gravity)
						--Gravity = Gravity/4
						ReducedVel = false
					end	
				else
					if 	Scanned.Instance and Scanned.Instance:IsA('BasePart') and (not IntModel or IntModel and not IntModel:FindFirstChildOfClass("Humanoid")) and Scanned.Instance.Anchored == false then
						sync() LapPar:AddToFilter(Scanned.Instance) RaycastPar:AddToFilter(Scanned.Instance) Scanned.Instance:BreakJoints() Scanned.Instance.Velocity = Scanned.Instance.Velocity + ClampVector3(Velocity) * math.random(40,60)/10 PlaySound('Deep_Impact', Scanned.Instance, 0.1) unsync()
					elseif IntModel and IntModel:FindFirstChildOfClass("Humanoid") then
						sync() IntModel:FindFirstChildOfClass("Humanoid").BreakJointsOnDeath = false RaycastPar:AddToFilter(IntModel) LapPar:AddToFilter(IntModel) IntModel:FindFirstChildOfClass("Humanoid").Health = IntModel:FindFirstChildOfClass("Humanoid").Health - ((Scanned.Instance.Name:upper():match('HEAD') and math.random(20,35) or math.random(10,20)) + Velocity.Magnitude * 7) * returnmuliplierfromcharacter(IntModel) * IntModel:FindFirstChildOfClass("Humanoid").MaxHealth/100 PlaySound('Unequip', Scanned.Instance, 0.4)  PlaySound('Curse_Hit', Scanned.Instance, 0.2) --[[if not HitboxDebounce[v] then HitboxDebounce[v] = {} end table.insert(HitboxDebounce[v], Scanned.Instance)]] RaycastPar:AddToFilter(IntModel) coroutine.resume(coroutine.create(function() IntModel:FindFirstChildOfClass("Humanoid").RootPart.Velocity = IntModel:FindFirstChildOfClass("Humanoid").RootPart.Velocity + ClampVector3(Velocity) * 20 Ragdoll(IntModel, (math.random(12,22)/14 + Velocity.Magnitude/1.5) * returnmuliplierfromcharacter(IntModel)) end)) 
						sync() Scanned.Instance.Velocity = ClampVector3(Scanned.Instance.Velocity) +  ClampVector3(Velocity) * 5 unsync()
						if (tick() - LREG) > MaxRate then LREG = tick()	Classic_Flagstand_Effect(Scanned.Position, 0.5, workspace, math.ceil(Velocity.Magnitude * 2), Velocity.Magnitude/4 + 7, Scanned.Instance.Color:Lerp(TorsoTar.Color, 0.3), Enum.Material.Neon, -Velocity, 'Shrink', 0.5, {Scanned.Instance, initChr}) end
						if IntModel:FindFirstChildOfClass("Humanoid").Health <= 0 or IntModel:FindFirstChildOfClass("Humanoid").Health ~= IntModel:FindFirstChildOfClass("Humanoid").Health then	coroutine.resume(coroutine.create(function()	Ragdoll(IntModel, math.huge) end))	else  coroutine.resume(coroutine.create(function()	Ragdoll(IntModel, returnmuliplierfromcharacter(IntModel) * Velocity.Magnitude * 2.5) end)) end
					end
				end
			end
			unsync()
			if DynamicHitbox then RaycastHitbox = true PartQueryHitbox = true end
			lastpivot = initChr:GetPivot()-- + Vector3.new(10,20,30)
			local Connection: {RBXScriptConnection} = Functions["Hitbox"](Head, 30, handlescan)
			local Connection2: {RBXScriptConnection} = Functions["Hitbox"](LeftLegTar, 30, handlescan)
			local Connection3: {RBXScriptConnection} = Functions["Hitbox"](RightLegTar, 30, handlescan)
			local Connection4: {RBXScriptConnection} = Functions["Hitbox"](TorsoTar, 0, handlescan)
			local Connection5: {RBXScriptConnection} = Functions["Hitbox"](RootTar, 30, handlescan)
			local Connection6: {RBXScriptConnection} = Functions['Hitbox'](LeftArmTar, 0, handlescan) 
			local Connection7 : {RBXScriptConnection} = Functions['Hitbox'](RightArmTar, 0, handlescan)
			while task.wait(UpdateRate) and Head and TorsoTar and RootTar and RightLegTar and LeftLegTar and Fatalitypoint > 0 and script and script.Parent and Equipped and Tool and CurrentAnimation[initChr] == "Flying Kick" and CurrentAnimation[initChr] and Velocity and initChr and Gravity and (Velocity.Magnitude >= 0.1 or Gravity.Magnitude >= 0.1) do
				unsync()
				local Delta = math.clamp(tick() - LastUpdateTick, 0, 5) 
				dts = 1 - 0.000001 ^ Delta
				if (initChr:GetPivot().Position - ticklastpivot.Position).Magnitude >= 0.05 * dts then
					Fatalitypoint = 10
				else
					Fatalitypoint = Fatalitypoint - 1
					if Fatalitypoint <= 0 then
						break -- end
					end
				end
				ticklastpivot = initChr:GetPivot()
				lastfly = tick()
				ReducedVel = true	
				LastUpdateTick = tick()
				Velocity = ClampVector3(Velocity)
				Gravity = ClampVector3(Gravity)

					<ProtectedString name="Source"><![CDATA[--!native
--<<By Solivion>>--
--<{For Normal Sized Rig Only}>--
--<<Combat2: Crash 'n Burn Edition, What a fail(Totally not Rufus14's Combat Copy)>>--
--fun passsion project cuz I have no idea what game to make and stuff(wasted oppertunity frfr)

--[[3/23/2026]]--
--Disabled name fetching because it could fail from too many request. Nothing else if changed from the 9/7/2024 version

--[[9/7/2024]]--
--Disabled Blocky Effect Since It Lags And Crashes When Using Flying Kick, if you want to use it I recommend disabling Flying Kick
--Changed how the jumpkick might interact with a surface, it won't bounce off as much anymore
--the physics calculation has been edited to corporate the correct factor to make it Rate Independent
--Etc.

--<<Recommended To Put Inside An Actor, Or just plain script in StarterPack>>--

--Set RunContext To Legacy
if script.RunContext ~= Enum.RunContext.Legacy then
	warn('Script Might Not Behave Correctly, Please Change RunContext To Legacy')
	pcall(function() script.RunContext = Enum.RunContext.Legacy end)
end

--~<{Settings}>~--

-->Extra Skill<--
local DamageMultiplierGlobal: number? = 1.5 -- Damage Multiplier, Applies To All Moves That Register Via hitbox Per Part, Excluding Stomping And Grabbing 
local LMBAttackType: ('Punch' | 'Swing' | 'Mix') = 'Mix' -- Self Explanatory

local StealthGrab: boolean? = false -- No, this is not meant to be 𝓕𝓻𝓮𝓪𝓴𝔂, Anyways It Will Snap Neck Upon Releasing LMB while equipping the tool and the skill being used(Exceeding Timer Set Below), intended to create a meatshield
local Stomp: boolean? = true -- Stomp If Anybody Nearby Has Ragdolled
local JumpKick: boolean? = true -- Don't Know The Proper Name For This, But It'll do the trick if you Press LMB During Humanoid's 'Jumping' State. Very Hard To Get The State To Put It Simply

-->Hitbox<--
local DynamicHitbox = true -- if true, the option below will be dynamiccally set to suit the best performance

local MaxRaycastLoop: number? = 25 -- Need to enable 'RaycastHitbox', Raycast Hitboxes Will Keep Finding New Instance Or Object Til No Result. Or Looped Over This Value
--<{Both Of The MaxParts Query Value Can Be Turned To math.huge without causing much problems, unlike MaxRaycastLoop which will cause memory leaks}>--
local MaxPartPerSearch: number? = 50 -- Reduce Lag and Detection If Your Game Has Insance Amount Of Parts.
local MaxPartPerHitboxPart: number? = 25 -- Will Affect Query Based Hitboxes, Just Like MaxRaycastLoop

local RaycastHitbox: boolean? = true -- If Experiencing Performance Deterioration After Hitting An Instance, You Might Disable This or Reduce The Setting Above; Will Disable Raycast Hitbox If False, Doesn't Include VFX's Water Particle, May affect collision in custom physic calculation cases
local PartQueryHitbox: boolean? = true -- Will Disable GetPartsInParts Hitbox If False, Might Experience Major Performance Deterioration

-->Misc<--
local DeathSFX: boolean? = false
local DeathSFXID: string? = 'rbxassetid://1741722952'
local DeathSFXID2: string? = 'rbxassetid://171270157'-- or 'rbxassetid://8406997653'

local VolumeMaster: number? = 1.25 -- overall sound volume mod

local AnimationType: ("Lerp" | 'Constant') = 'Lerp' -- Constant will not be animated, it will just go frame by frame, for the aesthetic
local BrickVFX: boolean? = false -- Blocky Effect For Blood And Stuff
local HasRagdoll: boolean? = true -- Will Completely Disable Ragdoll If False
local StompRotation: boolean? = true -- Will Rotate Character Upon Stomping. Will Also Anchor It In Place. If turned off, The Leg Will Stop Directly With Its Own Rotation
local GrabFollowTorso: boolean? = true -- Target Will Follow Either Torso Or RootPart
local RagdollOnVitalHitWithPunch: boolean? = false -- Will Ragdoll Target IF You Hit Their head or legs, Only Applies To Punch.
local ToolStayEquippedUponRagdoll: boolean? = true -- Tool will not be automatically unequipped when getting ragdolled, this doesn't mean you can just equip it if you haven't already
local RagdollTimeThatWillForceUnequipTool: number? = 2.5 -- Self Explanatory

local VelocityTilt: boolean? = true -- Characters Tilt
local AlwaysTilt: boolean? = false -- Always Tilting Character According To Velocity, No Matter The State
local TiltMultiplier: number? = 1 -- How Much The Tilt Intensify, per vector and velocity
local MaxTilt: number? = 1 -- Maximum Tilting, 1 is absolute max, more than that and it can rotate 180+
local LeftRightTiltRotationAffects: ('Y' | 'Z') = 'Y' -- Which Angle Will Be Affected For Left/Right Velocity

local MaxReceivedDamageTime: number? = 7 -- Max Damage That Will Register In Parallel During A Period Of Time, Will be divided in halves for r6, This number is about how much r15 can take at a time(Since it has more part)
local ToggleMaxRegisterOrNot: boolean? = true -- Toggle The Limit Above or None

-->Timer(Putting In 'nil' will apply default or 0)<--
local RegisterCooldown: number? = 0.25 -- Register Timeout After Last Punch
local StealthGrabCooldown: number? = 5 -- Cooldown For The Skills
local JumpKickCooldown: number? = 2.5 -- Above
local CounterTimeFrame: number? = math.random(450,550)/1000 -- How Long A Counter State Will Last After Releasing LMB(also blocking)(can also be cancelled by pressing lmb and punching)

-- 1/60 is 60 update rate per second, recommended at 60 since 60+ fps tends to have collision issue while calculating physics(The Distance Between Part Location Too Low Since It Might Have A Very Frequent Update), Raycast Doesn't Register Stuff, I tried fixing it, but the problem here is the distance, this Problem Shares The Same Issue To BrickVFX of the particles not colliding
local UpdateRate: number? = 1/120 -- Maximum Update Rate, Set to nil to be rate indipendant, Update Rates On 'While task.wait(.01)' type operation, Example Being JumpKick, Animation, Effect, StealthGrab
local SnapTime: number? = nil -- For the StealthGrab above, setting to nil or 0 will be instakill

--~<<<<<{{{{{[[SETTINGS ENDS HERE]]}}}}}>>>>>~--

--~<{CORE BELOW, DO NOT EDIT UNLESS YOU KNOW WHAT YOU'RE DOING}>~--

--<<Flags>>--
local oof = false
local lastef = true
local Shutdown = false

--<<Stuff>>--
local Debris: Debris = game:FindFirstChildOfClass('Debris')
local Tool: (Tool | Flag)? = script:FindFirstAncestorOfClass("Tool") or script:FindFirstAncestorWhichIsA("Flag")
local toolactor: Actor? = script:FindFirstAncestorWhichIsA('Actor')
local ServerStorage: (ServerStorage | ReplicatedStorage) = game:FindFirstChildOfClass('ServerStorage') or game:FindFirstChildOfClass('ReplicatedStorage')
local ServerScriptService: (ServerScriptService | ReplicatedFirst) = game:FindFirstChildOfClass('ServerScriptService') or game:FindFirstChildOfClass('ReplicatedFirst')

--<<Parental Failsave>>--
if not Tool and script.Parent ~= nil then --[[local act = Instance.new('Actor',ServerScriptService)]] Tool = Instance.new('Flag', script.Parent) Tool.Parent = script.Parent Tool.CanBeDropped = false Tool.RequiresHandle = false Tool.Name = '{<Combat>}' --[[toolactor = act toolactor.Parent = Tool or ServerScriptService if act.Parent ~= nil then script.Parent = toolactor else toolactor = Instance.new('Actor', ServerScriptService) script.Parent = toolactor end]] end
if script.Parent == nil then script:Destroy() return end
for i,v in ServerScriptService:GetChildren() do
	if v:IsA('Actor') and v~= toolactor and (not script:FindFirstAncestorWhichIsA('Actor') or v.Name == script:FindFirstAncestorWhichIsA('Actor').Name) and not v:FindFirstChild(script.Name) and not v:FindFirstChildOfClass('BaseScript') then
		v:Destroy()
	end
end
if not script:IsDescendantOf(toolactor) then toolactor = Instance.new('Actor', script.Parent) toolactor.Parent = script.Parent toolactor.Parent = ServerScriptService script.Parent = toolactor end
if script:FindFirstAncestorWhichIsA('Actor') or toolactor then (script:FindFirstAncestorWhichIsA('Actor') or toolactor).Parent = ServerScriptService end
script.AncestryChanged:Connect(function()
	if not script:IsDescendantOf(game) and toolactor and not script:IsDescendantOf(toolactor) and not script:IsDescendantOf(ServerScriptService) then
		toolactor.Parent = ServerScriptService
	end
end)

--<<Util>>--
function sync() if toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= nil  and (script.Parent ~= toolactor or not script:FindFirstAncestorWhichIsA('Actor')) then pcall(function() --[[task.synchronize()]] script.Parent = toolactor end) end task.synchronize() end end
function unsync() if toolactor or (script:IsDescendantOf(game) and script:FindFirstAncestorWhichIsA('Actor')) then if script.Parent ~= nil and (script.Parent ~= toolactor or not script:FindFirstAncestorWhichIsA('Actor')) then pcall(function() --[[task.synchronize()]] script.Parent = toolactor end) end   task.desynchronize() end end
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if Where == nil then
		return
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

--<<Variables>>--

--<[Check If Settings Not Identified]>--
local CorrectTypes = pcall(function()
	unsync()
	SnapTime = not SnapTime and 0 or math.clamp(SnapTime,0,math.huge)
	JumpKickCooldown = not JumpKickCooldown and 2.5 or math.clamp(JumpKickCooldown,0,math.huge)
	StealthGrabCooldown = not StealthGrabCooldown and 5 or math.clamp(StealthGrabCooldown,0,math.huge)
	RegisterCooldown = not RegisterCooldown and 0.25 or math.clamp(RegisterCooldown,0,math.huge)
	VolumeMaster = not VolumeMaster and 1.25 or math.clamp(VolumeMaster,0,math.huge)
	DeathSFXID = not DeathSFXID and 'rbxassetid://1741722952'
	DeathSFXID2 = not DeathSFXID2 and 'rbxassetid://1741722952'
	MaxPartPerHitboxPart = not MaxPartPerHitboxPart and 50 or math.clamp(MaxPartPerHitboxPart,0,math.huge)
	MaxPartPerSearch = not MaxPartPerSearch and 50 or math.clamp(MaxPartPerSearch,0,math.huge)
	MaxRaycastLoop = not MaxRaycastLoop and 50 or math.clamp(MaxRaycastLoop,0,math.huge)
	TiltMultiplier = not TiltMultiplier and 1 or math.abs(TiltMultiplier)
	MaxTilt = not MaxTilt and 1 or math.abs(MaxTilt)
	MaxReceivedDamageTime = not MaxReceivedDamageTime and 7 or math.clamp(MaxReceivedDamageTime,1,math.huge)
	DamageMultiplierGlobal = not DamageMultiplierGlobal and 1 or math.abs(DamageMultiplierGlobal)
	CounterTimeFrame = not CounterTimeFrame and math.random(450,550)/1000 or math.abs(CounterTimeFrame)
	UpdateRate = typeof(UpdateRate) == 'number' and math.abs(UpdateRate) or nil
	RagdollTimeThatWillForceUnequipTool = not RagdollTimeThatWillForceUnequipTool and 5 or RagdollTimeThatWillForceUnequipTool
	sync()
end)

--error has been found
if not CorrectTypes then
	warn('Some Setting Value Seems To Be Invalid, Please Check That The Type Matches The Identified',
		'- '..(math.random() <= 0.5 and 'Soli' or 'Solivion')
	)
	sync()
	if Tool then Tool.Name = Tool.Name..'[DISABLED]' Tool.Enabled = false Tool.ToolTip = '~<{SETTING INVALID}>~' end
	Debris:AddItem(script, 1)
	return
end


				unsync()
				local floorrr = workspace:Raycast(lastpivot.Position, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(lastpivot.Position - (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity) * 2, RaycastParfloor)  or workspace:Raycast(lastpivot.Position + (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), -(Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), RaycastParfloor) 
					or workspace:Raycast(RootTar.CFrame.p - Vector3.new(0,--[[-0.925]] - 1,0), Vector3.new(0,--[[-0.925]] - 1,0) * 2, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p , Vector3.new(0,--[[-0.925]] - 1,0), RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + Vector3.new(0,--[[-0.925]] - 1,0), -Vector3.new(0,--[[-0.925]] - 1,0) * 2, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p - Gravity, Gravity * 2, RaycastParfloor) or workspace:Raycast(RightLegTar.Position + RightLegTar.CFrame.UpVector * -RightLegTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(LeftLegTar.Position + LeftLegTar.CFrame.UpVector * -LeftLegTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RightLegTar.Position, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(LeftLegTar.Position, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(Head.Position, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.Position, Vector3.new(0,Velocity.Y,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p , Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.UpVector *  RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.UpVector *  -RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  -RootTar.Size.X/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + Vector3.new(0,--[[-0.925]] - 1,0) , -Vector3.new(0,--[[-0.925]] - 1,0), RaycastParfloor) 
				----[[or
				--workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  RootTar.Size.X/2 + RootTar.CFrame.UpVector *  RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  -RootTar.Size.X/2 + RootTar.CFrame.UpVector *  RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or
				--workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  RootTar.Size.X/2 + RootTar.CFrame.UpVector *  -RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(RootTar.CFrame.p + RootTar.CFrame.RightVector *  -RootTar.Size.X/2 + RootTar.CFrame.UpVector *  -RootTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p , Vector3.new(0,--[[-0.925]] - 1,0), RaycastParfloor) or workspace:Raycast(TorsoTar.Position, Vector3.new(0,Velocity.Y,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p , Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.UpVector *  TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.UpVector *  -TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  -TorsoTar.Size.X/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or
				--workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  TorsoTar.Size.X/2 + TorsoTar.CFrame.UpVector *  TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  -TorsoTar.Size.X/2 + TorsoTar.CFrame.UpVector *  TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or
				--workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  TorsoTar.Size.X/2 + TorsoTar.CFrame.UpVector *  -TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + TorsoTar.CFrame.RightVector *  -TorsoTar.Size.X/2 + TorsoTar.CFrame.UpVector *  -TorsoTar.Size.Y/2, Vector3.new(0,--[[-0.925]] - 1,0) + Gravity, RaycastParfloor) or workspace:Raycast(lastpivot.Position, Gravity, RaycastParfloor) or	workspace:Raycast(lastpivot.Position + (Gravity), -(Gravity), RaycastParfloor) 
				--or workspace:Raycast(TorsoTar.CFrame.p + Vector3.new(0,--[[-0.925]] - 1,0) , Vector3.new(0,1.5,0), RaycastParfloor) or workspace:Raycast(lastpivot.Position + (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), -(Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), RaycastParfloor) or workspace:Raycast(TorsoTar.CFrame.p + (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), - (Vector3.new(0,--[[-0.925]] - 1,0) + Gravity), RaycastParfloor) or workspace:Raycast(TorsoTar.Position + (Vector3.new(0,Velocity.Y,0) + Gravity), -(Vector3.new(0,Velocity.Y,0) + Gravity), RaycastParfloor)]]
				lastfoor = initChr
				if not floorrr then	
					Classic_Flagstand_Effect(RootTar.Position, math.random(2,3)/8, workspace, 1, 7, TorsoTar.Color:Lerp(Color3.new(1,1,1), 0.3), Enum.Material.ForceField, nil, 'Expand', 2.75)
					--lastfoor = initChr
					if Gravity.Y > -10 then
						PlaySound('Strong_Wind',initChr:FindFirstChildOfClass("Humanoid").RootPart, 0.4)
						if SFX and SFX.SoundId ~= "rbxassetid://99274458" then
							sync()
							if initChrHM.RootPart:FindFirstChild('Collide') then
								initChrHM.RootPart:FindFirstChild('Collide'):Destroy()
							end 
							SFX.SoundId =  'rbxassetid://99274458' 
							SFX:Play()
							unsync()
						end
						unsync()
						Gravity = Gravity - Vector3.new(0,--[[-Delta * 5]]dts, 0)
						if Gravity.Y < -10 then Gravity = Vector3.new(0,-10,0) end
					end
					lasthi = lastpivot.Position.Y
				else
					Classic_Flagstand_Effect(floorrr.Position, math.random(2,3)/8, workspace, 1, 7, (floorrr.Instance:IsA('BasePart') and floorrr.Instance.Color or workspace:FindFirstChildOfClass('Terrain'):GetMaterialColor(floorrr.Material) or workspace:FindFirstChildOfClass('Terrain').WaterColor):Lerp(TorsoTar.Color, 0.3), floorrr.Material, nil, 'Expand', 2.75)
					unsync()
					PlaySound('Collide',initChr:FindFirstChildOfClass("Humanoid").RootPart, 0.3)
					unsync()
					ReducedVel = false
					Gravity = Gravity + Vector3.new(0,Velocity.Y,0) 
					Velocity = Vector3.new(Velocity.X,0,Velocity.Z) 
					lastfoor = floorrr.Instance
					if lasthi == floorrr.Position.Y or floorrr.Normal.Y == 0 then
						Disable = true
						ReducedVel = true
						Velocity = Velocity:Lerp(Vector3.new(), dts/1.1) or HandleRaycastHit(floorrr, Velocity) 
						Gravity = Vector3.new(0,0,0)
						if table.find(CooldownList, lastfoor) then
							table.remove(CooldownList, table.find(CooldownList, lastfoor))
						end
					elseif lasthi > floorrr.Position.Y and floorrr.Normal.Y ~= 0 then
						Disable = true
						ReducedVel = true
						Velocity = Velocity * (1 - 0.000001 ^ (lasthi - floorrr.Position.Y)/lasthi) or HandleRaycastHit(floorrr, Velocity)
						Gravity = Gravity:Lerp(Vector3.new(0,-(lasthi - floorrr.Position.Y),0), (lasthi - floorrr.Position.Y)/lasthi)
						--Gravity = Gravity:Lerp(Vector3.new(0,lasthi - floorrr.Position.Y,0), (1 - 0.000001 ^ (lasthi - floorrr.Position.Y)))
					else
						if floorrr.Normal.Y ~= 0 then
							local redSpeed = 1 - math.clamp( dts/(floorrr.Position.Y - lasthi),0,1)
							Velocity = Velocity:Lerp(Vector3.new(), redSpeed) or calculateBounceAngle(Velocity, floorrr)
							Gravity = Gravity:Lerp(Vector3.new(0,(floorrr.Position.Y - lasthi),0), redSpeed)
							--Gravity = Gravity:Lerp(-Vector3.new(0,floorrr.Position.Y - lasthi,0), 1 - 0.000001 ^ (floorrr.Position.Y) - lasthi)
							if table.find(CooldownList, lastfoor) then
								table.remove(CooldownList, table.find(CooldownList, lastfoor))
							end
						end
					end
					coroutine.resume(coroutine.create(function() handlescan(floorrr.Instance) end))
					if SFX and SFX.SoundId ~= 'rbxassetid://12222046' then
						sync()
						if initChrHM.RootPart:FindFirstChild('Strong_Wind') then
							initChrHM.RootPart:FindFirstChild('Strong_Wind'):Destroy()
						end 
						SFX.SoundId = 'rbxassetid://12222046'
						SFX:Play()
					end
					--initChr:FindFirstChildOfClass("Humanoid").RootPart.Position = floorrr.Position + Gravity + Velocity
					--initChr:PivotTo(CFrame.new(floorrr.Position + Gravity + Velocity, floorrr.Position + (floorrr.Normal + Gravity + Velocity) * 2))
					unsync()
					Gravity = Vector3.new(0,0,0)
					lasthi = lastpivot.Position.Y or floorrr.Position.Y
				end
				for i, v in initChr:GetChildren() do
					unsync()
					if v:IsA("BasePart") and v.Transparency < 1 and not Disable then
						if LastPartPos[v] and not Disable then
							unsync()
							local Scanned = workspace:Raycast(LastPartPos[v], v.Position - LastPartPos[v], RaycastPar) or workspace:Raycast(v.Position, Velocity + Gravity, RaycastPar) or workspace:Raycast(v.Position, Velocity, RaycastPar) or workspace:Raycast(LastPartPos[v], (v.Position - LastPartPos[v]).Unit * 1, RaycastPar) or workspace:Raycast(v.Position, Velocity + Gravity , RaycastPar) or workspace:Raycast(v.Position, -Velocity -Gravity , RaycastPar) or workspace:Raycast(v.Position, LastPartPos[v] - v.Position, RaycastPar) or workspace:Raycast(LastPartPos[v], Velocity + Gravity , RaycastPar) or workspace:Raycast(v.Position + Velocity, -Velocity, RaycastPar)  or workspace:Raycast(v.Position + Velocity + Gravity, -Velocity -Gravity, RaycastPar)  
							if Scanned and not Disable then
								coroutine.resume(coroutine.create(function() handlescan(Scanned) end))
							end

						else
							LastPartPos[v] = v.Position
						end
					end
					if v:IsA('BasePart') and v.Transparency < 1 and PartQueryHitbox then
						local scan = createHitboxPart(CFrame.new(v.Position) + v.Velocity , CFrame.new(LastPartPos[v]), v.Size * 2)
						unsync()
						local alt = workspace:GetPartsInPart(scan,LapPar)coroutine.resume(coroutine.create(function() for i,v in alt do handlescan(v) end end))
						sync()
						scan:Destroy()
						unsync()
					end
				end
				
				unsync()
				Velocity = ClampVector3(Velocity)
				Gravity = ClampVector3(Gravity)
				CurrentAnimation[initChr] = "Flying Kick"
				local cal = CFrame.new()
				if not VelRot then
					VelRot = CFrame.new(initChrHM.RootPart.Position + (Velocity + Gravity - initChrHM.RootPart.Velocity) * (1 - 0.00000001 ^ Delta) * 5, lastpivot.Position + (Velocity + Gravity) * (1 - 0.00000001 ^ Delta) * 10).Rotation		
				end
				cal = CFrame.new(initChrHM.RootPart.Position + (Velocity + Gravity) * (1 - 0.00000001 ^ Delta) * 5, lastpivot.Position + (Velocity + Gravity) * (1 - 0.00000001 ^ Delta) * 10)			
				VelRot = VelRot:Lerp(cal.Rotation, math.clamp(1 - 0.0000001 ^ Delta, 0, 1) * Velocity.Magnitude/2.5)
				local Remap = CFrame.new(cal.Position) * VelRot
				Remap = Remap * CFrame.Angles(math.rad(90),0,0)
				--This Handle Not a Number(NAN)
				if Remap.Position.Y == Remap.Position.Y and Remap.Position.Z == Remap.Position.Z and Remap.Position.X == Remap.Position.X and Remap.Position ~= Vector3.new(math.huge,math.huge,math.huge) and (Remap.p - lastpivot.p).Magnitude <= (maxflymag * (1 - 0.00000001 ^ Delta) * 5) and (Remap.p - lastpivot.p).Magnitude <= 75 then
					sync()	
					SFX.Volume = Velocity.Magnitude * 5
					SFX.MinDistance = Velocity.Magnitude * 5
					SFX.MaxDistance = Velocity.Magnitude * 3 * 5
					unsync()	
					if (Remap.p - lastpivot.p).Magnitude <= (maxflymag * (1 - 0.00000001 ^ Delta)) or (Remap.p - lastpivot.p).Magnitude <= 250 then
						sync() initChr:PivotTo(Remap)
					end
					unsync()
					lastpivot = Remap--lastpivot
					--initChr:FindFirstChildOfClass("Humanoid").RootPart.Position = cal.Position
					if initChrHM.RootPart.Velocity.Magnitude > 0.1 then	sync() initChrHM.RootPart.Velocity = Vector3.new() or Velocity end
				else
					break
				end
				unsync()
				if Disable then
					Disable = false
				end
				unsync()
				if ReducedVel then Velocity = Velocity:Lerp(Vector3.new(), dts/1.75) end
			end
			unsync()
			if initChr and initChrHM.RootPart then
				unsync()
				table.clear(LastPartPos)
				table.clear(CooldownList)
				table.clear(CooldownCount)
				local velrotate2
				velrotate2 = CFrame.new(lastpivot.Position, lastpivot.Position + Vector3.new(Velocity.X,0,Velocity.Z)) or CFrame.new(initChr.PrimaryPart.Position, initChr.PrimaryPart.Position + Vector3.new(Velocity.X,0,Velocity.Z))
				velrotate2 = velrotate2 * CFrame.new(0, -velrotate2.Y, 0) + Vector3.new(0,lasthi + RootTar.Size.Y*2,0)
				--print('-a')

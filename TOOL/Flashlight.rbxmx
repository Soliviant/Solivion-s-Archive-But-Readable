			<Item class="Script" referent="RBX585780BB256A4A4D9AD15F13A896A635">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--<<Flashlight2:ElectricBoogaloo, Dangerously Minimalized Version>>--
--<<Written By: Solivion>>--
--yes, another rufus14's toolbox item's carbon copy, now come with some new features(around 2, if I remembered Correctly)
--<<It's Highly Unintended For Horror Shenanigans, But Well It Works Anyway>>--
local On = false
local Cooldown = false
local IsFlashlightWithU = true
local OnAnim = false
local AdvanceOperation = false
local StartTick = tick()
local mousetarget = nil
local SaveChar = nil
local Damaging = false
local equiproute: thread
local equiptick = tick()
local HadFixed = {}
--I've finished making this for a while now, a bit after the knife(it got taken down for 'gender' content, dunno why either), and I certainly uses typing and testing method, it's tiring
local Debounce = {}
local AnimTable = { -- One Frame lol, Too lazy to type it out and test everytime, Atleast I used Circular. So It Honestly Looks Fire :>
	Charge = {HandFrame = CFrame.new(-0.5, 1, 0) * CFrame.Angles(math.rad(-65) ,math.rad(-120) ,math.rad(-165) ), GripThingy = CFrame.new(0, 0, 1) * CFrame.Angles(math.rad(-60) ,math.rad(-60) ,math.rad(0) ) }, -- Charge
	Off = {HandFrame = CFrame.new(1, -0.5, -1)* CFrame.Angles(math.rad(45) ,math.rad(-45) ,math.rad(0) ) , GripThingy = CFrame.new(0.2, 0, 0.45) * CFrame.Angles(math.rad(120+210) ,math.rad(180) ,math.rad(-135) ) }, -- N/A Equipping Anim When The Light Is Off
	On = {HandFrame = CFrame.new(1, -0.5, -1)* CFrame.Angles(math.rad(45) ,math.rad(-45) ,math.rad(0) ) , GripThingy = CFrame.new(0.5, 0, 0) * CFrame.Angles(math.rad(-50) ,math.rad(0) ,math.rad(45) ) }, -- N/A Equipping Anim Bla Bla Bla
	Throw = {HandFrame = CFrame.new(0.5, 1.5, -0.5) * CFrame.Angles(math.rad(15) ,math.rad(60) ,math.rad(15) ) , GripThingy = CFrame.new(0, 0, 1)* CFrame.Angles(math.rad(90) ,math.rad(45) ,math.rad(0) )}, -- Will Absolutely Broke the Object Out Of Existence
	Nil = {HandFrame = CFrame.new(0,0,0) , GripThingy = CFrame.new(0,0,0)} --Reset/Idle. Da Nil Position
}
local SoundTabel_ss69_ep420 = { -- OmgItsDaSoundTable
	glassbreak0wav = "rbxasset://sounds//glassbreak.wav",
	Hit = "http://www.roblox.com/asset/?id=58831920",
	Hitmarker = "rbxassetid://160432334",
	Swoosh = "http://www.roblox.com/asset?id=153647529",
	Woosh = "rbxassetid://12222200",
	Equip = "rbxasset://sounds//snap.wav",
	Unequip = "rbxassetid://12221831",
	Switch = "rbxasset://sounds//switch.wav",
	Kerplunk = "rbxasset://sounds//kerplunk.wav",
	FlashBulb = "rbxassetid://12221996",
	SWITCH3 = "rbxasset://sounds//SWITCH3.wav",
	BASS = "rbxassetid://12221831"
}-- "I use saem soudn"
function PlaySound(SoundName,ToWhere)
	--getOrCreateSound(SoundName)
	local Mainplayfunction = function(hmm)
		hmm.PlaybackSpeed = math.random(100-20,100+20)/100
		hmm:Play()
	end
	if ToWhere == nil then
		ToWhere = script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle")
	end
	if ToWhere and ToWhere:FindFirstChild(SoundName) and ToWhere:FindFirstChild(SoundName):IsA("Sound") then
		Mainplayfunction(ToWhere:FindFirstChild(SoundName))
	elseif ToWhere and not ToWhere:FindFirstChild(SoundName) then
		--DebugText("Checking Encryted Table For Sound:"..tostring(Encryption(SoundName,true)) )
		if SoundTabel_ss69_ep420[SoundName] then
			local sound = Instance.new("Sound")
			local Where = ToWhere
			sound.Parent = Where
			sound.SoundId = SoundTabel_ss69_ep420[SoundName]
			sound.Name = SoundName
			sound:Play()
		else
			warn("Sound >"..SoundName.."< Not Found In Database")
		end
	end
end
function Anim(Name:string,TPF:number)
	if not AnimTable[Name] then
	--	print("There Is No Animation With This Name.")
		return
	end
	if TPF == nil then
		TPF = 1
	end
	for i,v in pairs(AnimTable[Name]) do -- Wan Frame :Skull:
		local ThatWeld = (i == "HandFrame" and script:FindFirstAncestorOfClass("Tool"):FindFirstChildOfClass("Snap")) or script:FindFirstAncestorOfClass("Tool")
		if not ThatWeld then
	--		print("Snap Has No Matching Name")
			return
		end
		local TweenIn = TweenInfo.new(TPF+0.05,Enum.EasingStyle.Circular,Enum.EasingDirection.InOut)
		local TweenThing = game.TweenService:Create(ThatWeld,TweenIn,(ThatWeld:IsA("Snap") and {C1 = v}) or {Grip = v})
		TweenThing:Play()
	--	print("Tween Operation Complete"..tostring(ThatWeld:GetFullName()))
		script:FindFirstAncestorOfClass("Tool").AncestryChanged:Connect(function(huh,huh2)
			TweenThing:Cancel()
		end)
	end
	task.wait(TPF)
end
script:FindFirstAncestorOfClass("Tool").Equipped:Connect(function(mouse)
	local t
	t = tick()
	equiptick = t
	for i, v in pairs(script:FindFirstAncestorOfClass("Tool"):GetDescendants())  do
		if v:IsA("BasePart") then
			v.Transparency = 1
		elseif v:IsA("SpotLight") then
			v.Enabled = false
		end
	end
	AdvanceOperation = true
	Cooldown = true
	SaveChar = script:FindFirstAncestorOfClass("Model")
	if script:FindFirstAncestorOfClass("Model") ~= SaveChar then
		return
	end
	local Character = SaveChar
	if not table.find(HadFixed, Character) and Character:FindFirstChildOfClass('Humanoid') and Character:FindFirstChildOfClass('Humanoid').RigType == Enum.HumanoidRigType.R15 then
		coroutine.resume(coroutine.create(function()
			for i,v in Character:GetDescendants() do
				if v.Name == 'RightGripAttachment' and v.CFrame ~= (CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)) then
					v.CFrame = CFrame.new(v.CFrame.Position) * CFrame.Angles(math.rad(-90),0,0)
				end
			end
			table.insert(HadFixed, Character)
		end))
	else
		table.insert(HadFixed, Character)
	end
	if not script:FindFirstAncestorOfClass("Tool"):FindFirstChildOfClass("Snap") then
		local NewHandWeld = Instance.new("Snap",script:FindFirstAncestorOfClass("Tool"))
		NewHandWeld.Name = "Handy Weld"
		NewHandWeld.Enabled = true
		NewHandWeld.C0 = CFrame.new(1.5, 0.5, -0.5) * CFrame.Angles(math.rad(90),math.rad(0),math.rad(0))
		if script:FindFirstAncestorOfClass("Model"):FindFirstChild("Right Arm") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("RightUpperArm") then
			NewHandWeld.Part1 = script:FindFirstAncestorOfClass("Model"):FindFirstChild("Right Arm") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("RightUpperArm")
		end
		if script:FindFirstAncestorOfClass("Model"):FindFirstChild("Torso") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("UpperTorso") then
			NewHandWeld.Part0 = script:FindFirstAncestorOfClass("Model"):FindFirstChild("Torso") or script:FindFirstAncestorOfClass("Model"):FindFirstChild("UpperTorso")
		end
		if not game.Players:GetPlayerFromCharacter(script:FindFirstAncestorOfClass("Model")) then
			NewHandWeld.C0 = CFrame.new(1.5, 0.5, -0.5) * CFrame.Angles(math.rad(90),math.rad(0),math.rad(0))
		end
	else
		script:FindFirstAncestorOfClass("Tool"):FindFirstChildOfClass("Snap").Enabled = true
	end
	if On == false then
		Anim("Off",0.5)
	else
		Anim("On",0.5)
	end
	if script:FindFirstAncestorOfClass("Model") ~= SaveChar then
		return
	end
	task.wait(0.5)
	if equiptick ~= t then
		return
	end
	if script:FindFirstAncestorOfClass("Model") ~= SaveChar then
		return
	end
	if SaveChar:FindFirstChild("FlashTS") then
		SaveChar:FindFirstChild("FlashTS"):Destroy()
	end
	PlaySound("BASS")
	for i, v in pairs(script:FindFirstAncestorOfClass("Tool"):GetDescendants())  do
		if v:IsA("BasePart") then
			if v.Name ~= "Glass" and v.Name ~= "Light" then
				v.Transparency = 0
			elseif (v.Name == "Glass" or v.Name == "Light") and On == true then
				v.Transparency  = 0
			end
		elseif v:IsA("SpotLight") then
			if On then
				v.Enabled = true
			else
				v.Enabled = false
			end

					v.Transparency = 0
				end
			end
		end
	else
	--	print("SHATTRRRRRR!!!!1!!!!")
		table.clear(Debounce)
		PlaySound("Swoosh")
		Anim("Charge",0.7)
		Damaging = true
		PlaySound("Woosh")
		Anim("Throw",0.2)-- I have to mention that I don't know how throwing works. So Have A Smashing Flashlight lol. It's Also Made Of Titanium :Skull:
		Anim("Nil",0.7)
		Damaging = false
	end
	task.wait(0.1)
	Cooldown = false
end)
script:FindFirstAncestorOfClass("Tool").Unequipped:Connect(function()
	local t
	t = tick()

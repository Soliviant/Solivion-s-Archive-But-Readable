	end
	if equiptick ~= t then
		return
	end
	if not SaveChar:FindFirstChild("FlashTS") then
		local KeepedHandle = script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle"):Clone()
		KeepedHandle.Parent = SaveChar
		KeepedHandle.Name = "FlashTS"
		local NewWeld = Instance.new("Glue",KeepedHandle)
		NewWeld.Name = "Attach"
		NewWeld.Part1 = KeepedHandle
		NewWeld.Part0 = SaveChar:FindFirstChild("Torso") or SaveChar:FindFirstChild("UpperTorso")
		if script:FindFirstAncestorOfClass("Model") == SaveChar then
			return
		end
		if equiptick ~= t then
			return
		end
		if On then
			NewWeld.C1 = CFrame.new(-1, 1, 0)
		else
			NewWeld.C1 = CFrame.new(-1, -1, 0) * CFrame.Angles(math.rad(0),math.rad(180),math.rad(-180))
		end
	end
	if script:FindFirstAncestorOfClass("Model") == SaveChar then
		return
			
			
	end
	if equiptick ~= t then
		return end
	PlaySound("Kerplunk")	if script:FindFirstAncestorOfClass("Model") == SaveChar then
		return
	end
	if equiptick ~= t then
		return
	end
	for i, v in pairs(script:FindFirstAncestorOfClass("Tool"):GetDescendants())  do
		if v:IsA("BasePart") then
			v.Transparency = 1
		elseif v:IsA("SpotLight") then
			if On then
				v.Enabled = false
			end
		end
	end
	if script:FindFirstAncestorOfClass("Model") == SaveChar then
		return
	end
end)
local function createRandomSizedShard(parent, glassObject:BasePart, maxShardSize)
	coroutine.resume(coroutine.create(function()
		local shard = glassObject:Clone()
		task.desynchronize()
		if not shard:GetAttribute("Generation") then
			task.synchronize()
			shard:SetAttribute("Generation",0)
		else
			task.synchronize()
			shard:SetAttribute("Generation",shard:GetAttribute("Generation") +1)
			task.desynchronize()
			if shard:GetAttribute("Generation") > 1 then
				return -- Stop, I don't want glass Atom Floating Around.
			end
		end
		task.synchronize()
		shard.EnableFluidForces =  true
		shard.Anchored = false
		shard.CanTouch = true
		shard.CanCollide = true
		--EasyTween(shard,"Transparency",1,20,"Sine","In"):Play()
		game.Debris:AddItem(shard,20)
		task.desynchronize()
		local flingForce = (script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle").Position - shard.Position).unit * 10
		local bodyVelocity = shard:FindFirstChild("BodyVelocity")
		if not bodyVelocity then
			task.synchronize()
			bodyVelocity = Instance.new("BodyVelocity")
			bodyVelocity.Velocity = -flingForce
			bodyVelocity.MaxForce = Vector3.new(10, 10,10)
			bodyVelocity.Parent = shard
			game.Debris:AddItem(bodyVelocity, 0.2)
		end
		task.desynchronize()
		local maxX = math.min(maxShardSize.X, glassObject.Size.X)
		local maxY = math.min(maxShardSize.Y, glassObject.Size.Y)
		local maxZ = math.min(maxShardSize.Z, glassObject.Size.Z)

		if maxX < 0.5 and maxY < 0.5 and maxZ < 0.5 then
			maxX = 0.5
			maxY = 0.5
			maxZ = 0.5
		end

		local sizeX = Random.new():NextNumber() * maxX
		local sizeY = Random.new():NextNumber() * maxY
		local sizeZ = Random.new():NextNumber() * maxZ
		
		task.synchronize()
		shard.Size = Vector3.new(sizeX, sizeY, sizeZ)
		task.desynchronize()

		-- Calculate the volume of the shard
		local shardVolume = sizeX * sizeY * sizeZ

		local offset = Vector3.new(
			(Random.new():NextNumber() - 0.5) * glassObject.Size.X,
			(Random.new():NextNumber() - 0.5) * glassObject.Size.Y,
			(Random.new():NextNumber() - 0.5) * glassObject.Size.Z
		)
		
		task.synchronize()
		shard.CFrame = glassObject.CFrame + offset
		shard:SetAttribute("Impaled",false)
		--[[shard.Touched:Connect(function(hit)
			if shard:GetAttribute("Impaled") and shard:GetAttribute("Impaled") == false then
				if shard.Velocity.Magnitude > 5 and hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid") and hit.Parent:FindFirstChildOfClass("Humanoid").Health > 0 then
					shard:SetAttribute("Impaled",true)
					hit.Parent:FindFirstChildOfClass("Humanoid").Health = hit.Parent:FindFirstChildOfClass("Humanoid").Health - math.random(2,4)
					local Stick = Instance.new("Glue",shard)
					Stick.Name = "Ouch"
					Stick.Part0 = hit
					Stick.Part1 = shard
					shard.CanCollide = false
					shard.CanTouch = false
					Stick.C0 = hit.CFrame:toObjectSpace(Stick.CFrame)
				end
			end
		end)]]
		shard.Parent = parent
	end))
	
end

local function breakGlass(glassObject, maxShardSize)
	if glassObject:IsA("BasePart") then
		PlaySound("glassbreak0wav",glassObject)
		if glassObject.Size.X < 5 or glassObject.Size.Y < 5 or glassObject.Size.Z < 5 then
			for i = 1, 10 do
				createRandomSizedShard(glassObject.Parent, glassObject, maxShardSize)
			end
		else
			for x = 0, glassObject.Size.X - maxShardSize.X, maxShardSize.X do
				for y = 0, glassObject.Size.Y - maxShardSize.Y, maxShardSize.Y do
					for z = 0, glassObject.Size.Z - maxShardSize.Z, maxShardSize.Z do
						createRandomSizedShard(glassObject.Parent, glassObject, maxShardSize)
					end
				end
			end
		end

		glassObject:Destroy() -- Remove the original glass object
	end
end
function Die(Hit)
	if not Damaging then
		return
	end
	if Debounce[Hit] or Debounce[Hit.Parent] or not Hit.Parent then
	--	print("Debounced "..Hit:GetFullName())
		return
	end
	if not Debounce[Hit.Parent] then
		Debounce[Hit] = true
		Debounce[Hit.Parent] = true --Debounce
		PlaySound("FlashBulb")
		if Hit.Material == Enum.Material.Glass or Hit.Material == Enum.Material.Ice then
			breakGlass(Hit,Vector3.new(4,4,4)) -- Bro Shattered it like Edible Glass.
		end
		if Hit.Parent and Hit.Parent:FindFirstChildOfClass("Humanoid") then
			PlaySound("Hit")
			Hit.Parent:FindFirstChildOfClass("Humanoid").Health = Hit.Parent:FindFirstChildOfClass("Humanoid").Health - math.random(100,200)/10
		end
	end
end
if script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle") then
	script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle").Touched:Connect(Die)
	script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle").TouchEnded:Connect(Die)
	script:FindFirstAncestorOfClass("Tool"):FindFirstChild("Handle").LocalSimulationTouched:Connect(Die)
end

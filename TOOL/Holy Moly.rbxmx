				<ProtectedString name="Source"><![CDATA[--//solivion//--
--//idea by @melon5926//--
--//2/23/24//--
local Weap = script:FindFirstAncestorWhichIsA("Tool")
local TweenService = game:GetService("TweenService")
local CurrentAnim = "nil"
local Character
local DebugMode = false
local connect1
local connect2
local connect3
local speed = 1
local speed2 = 1
local Angle = 0
local Angle2 = 0
local Tiem = tick()
local connect1 local connect2 local connect3 local unecon local undecon
local bounce = {}
local partall = {}
local gtgignore = {}
function DebugText(Text:string)
	if DebugMode == true then
		print("->"..Text)
	end
end
function DebugWarn(Text:string)
	if DebugMode == true then
		warn("-->>"..Text)
	end
end
function CFrameAngles(X,Y,Z)
	return CFrame.Angles(math.rad(X),math.rad(Y),math.rad(Z))		-- Why Didn't I Thought Of This Earlier.						
end
local bobm_sound = function(pos)
	local part = Instance.new("Part",workspace)
	part.Transparency = 1
	part.CanTouch = true
	part.CanCollide = false
	part.CanQuery = false
	part.Anchored= true
	part.Position = pos
	game:FindFirstChildOfClass('Debris'):AddItem(part,2)
	table.insert(partall, part)
	table.insert(gtgignore,part)
	part.Touched:Connect(function( part2)
		if not table.find(gtgignore, part2) and not part2:IsDescendantOf(Character) and not table.find(partall, part2)  then
			for i = 1, 15 do
				Instance.new('Explosion',workspace).Position = part.Position + Vector3.new(0, (10-i) * 10,0 )
				local part = Instance.new("Part",workspace)
				part.Transparency = 1
				part.CanTouch = true
				part.CanCollide = false
				part.CanQuery = false
				part.Anchored= true
				part.Position = part.Position + Vector3.new(0, (14-i) * 10,0 )
				game:FindFirstChildOfClass('Debris'):AddItem(part,2)
				local sound = Instance.new("Sound",part)
				sound.SoundId = "rbxassetid://12222065"
				sound.Volume = sound.Volume * 1.5
				sound.PlaybackSpeed = 1 + math.random(-200,200)/1000
				sound:Play()
				task.wait(.01)
			end
		else
			if not table.find(gtgignore, part2) and (part2:FindFirstAncestorWhichIsA('Model') and not part2:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')) or not part2:FindFirstAncestorWhichIsA('Model') then
				table.insert(gtgignore,part2)
			end
		end
	end)
	local sound = Instance.new("Sound",part)
	sound.SoundId = "rbxassetid://5801257793"
	sound.PlaybackSpeed = 1 + math.random(-500,500)/1000
	sound:Play()
end
local AnimationFrames = {
	["Idle"] = {Frame1 = 
	{
		--LeftShoulder = {CFrame.new(-1.5, 0, 0) * CFrame.Angles(math.rad(0),  math.rad(0), math.rad(0)), 0.1};
		RightShoulder = {CFrame.new(1.5, 0.5, 0) * CFrameAngles(0, 90, 90), 0.1};
		GripWeld = {CFrame.new(0, 0, -1) * CFrameAngles(90, 0, 90), 0.45},
		RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
		Root = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},-- R15 version of rootjoint
		RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
		Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.45}}
	},
	["Cast"] = {Frame1 = 
		{
			--LeftShoulder = {CFrame.new(-1.5, 0, 0) * CFrame.Angles(math.rad(0),  math.rad(0), math.rad(0)), 0.1};
			RightShoulder = {CFrame.new(1.5, 0.5, -0.5) * CFrameAngles(0, 90, 90), 0.1};
			GripWeld = {CFrame.new(0, 0, -1) * CFrameAngles(90, 0, 90), 0.45},
			RootJoint = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			Root = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},-- R15 version of rootjoint
			RootHip = {CFrame.new(0, 0, 0) * CFrame.fromEulerAngles(math.rad(0), math.rad(0), math.rad(0)), 0.3},
			Neck = {CFrame.new(0, 1.5, 0) *CFrame.Angles(math.rad(0),math.rad(0),math.rad(0)),0.45}}
	}
}
local WeldStorage = {}
local function findWeldWithPartialName(part, partialName)
	for _, descendant in ipairs(part:GetDescendants()) do
		if descendant:IsA("Weld") and string.find(descendant.Name, partialName, 1, true) then
			return descendant
		end
	end
	return nil
end
function DisableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = false
	end
end
function EnableWeld(The)
	if WeldStorage[The] then
		WeldStorage[The].Enabled = true
	end
end
function playAnimation(animationName, TimeBetweenFrames)
	if CurrentAnim ~= animationName then
		local frames = AnimationFrames[animationName]

		if not frames then
			DebugWarn("Animation not found: " .. animationName)
			return
		end

		for frameName, frameData in pairs(frames) do
			for weldName, weldCFrame in pairs(frameData) do
				local weld = findWeldWithPartialName(Weap, weldName) or WeldStorage[weldName]
				CurrentAnim = animationName
				if weld then
					if weldName ~= "LeftShoulder" then
						EnableWeld(weldName)
					end
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(weld, info, {C0 = cframe})
					if weld.Name ~= "RootJoint" and weld.Name ~= "Root" and not string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					elseif weld.Name ~= "RootJoint" and weld.Name ~= "Root" and string.find(weld.Name, "Root", 1, true) then
						weld.C1 = CFrame.new(0, 0, 0)
					else
						if weld.C1 == CFrameAngles(-90, -180, 0)  then
							weld.C1 = CFrame.new(0, 0, 0) * CFrameAngles(0, 0, 0)
						end
					end
					if weld.Name == "Neck" and Character:FindFirstChild("UpperTorso") then
						weld.C1 = CFrame.new(0, 0.2, 0)
					else
						weld.C1 = CFrame.new(0, 0, 0)
					end
					tween:Play()
				elseif weldName == "GripWeld" then
					local cframe, tweenTime = unpack(weldCFrame)
					-- You can use TweenService to animate the welds
					local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
					local tween = TweenService:Create(Weap, info, {Grip = cframe})
					-- weld.C1 = CFrame.new(0, 0, 0)
					tween:Play()
				elseif weldName == "Root" then
					EnableWeld(weldName)
					local cframe, tweenTime = unpack(weldCFrame)
					weld = findWeldWithPartialName(Weap, weldName)
					if weld and not Weap:FindFirstChild("RootJoint") then
						local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
						local tween = TweenService:Create(weld, info, {C0 = cframe})
						tween:Play()
					else
						if weld ~= nil then
							local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut)
							local tween = TweenService:Create(weld, info, {C0 = cframe})
							tween:Play()
						else
							DebugWarn("RootJoint Found or No Root Weld")
						end
					end
				else
					DebugWarn("Weld >" .. weldName .. "< not found")
				end
			end
			task.wait(TimeBetweenFrames)
		end
	end
end
function GetHumanoid(From:Model)
	if From then
		if From:FindFirstChildOfClass("Humanoid") then
			return From:FindFirstChildOfClass("Humanoid")
		else
			return nil
		end
	end
end
function ReplicateWeld(BasePart,Where)
	for i,v in BasePart:GetChildren() do
		if v:IsA("Motor6D") and not WeldStorage[string.gsub(v.Name, " ", "")] then
			local NewWeldForStuff = Instance.new("Weld", Where)
			NewWeldForStuff.Name = string.gsub(v.Name," ","")
			NewWeldForStuff.Part0 = v.Part0
			NewWeldForStuff.Part1 = v.Part1
			if string.find(NewWeldForStuff.Name,"Root",1,false) then
				NewWeldForStuff.C1 = CFrameAngles(0,0,0) * CFrame.new(0,0,0)
			else
				NewWeldForStuff.C1 = v.C1
			end

			NewWeldForStuff.C0 = v.C0
			NewWeldForStuff.Enabled = v.Enabled
			-- TODO: Register These Welds Into The Table
			--Also
			--ApplyAttribute(NewWeldForStuff)
			-- Register the newly created weld in the WeldStorage table
			WeldStorage[string.gsub(v.Name, " ", "")] = NewWeldForStuff
		end
	end
end
function StartExecution(Where)
	for i,thing in Where:GetChildren() do
		if thing:IsA("Weld") then
			thing:Destroy()      -- Remove
		end
	end
	table.clear(WeldStorage)	
	local Torso = Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("Torso")
	local Hrp = Character:FindFirstChild("HumanoidRootPart") or GetHumanoid(Character).RootPart
	if not Torso then
		for i, v in Character:GetChildren() do
			if v:IsA("MeshPart") then
				ReplicateWeld(v,Where)
			end
		end
	end
	if Hrp then
		ReplicateWeld(Hrp,Where)
	end
	if Torso then
		ReplicateWeld(Torso,Where)
	end
	for i, v in Character:GetChildren() do
		if v:IsA("BasePart") then
			ReplicateWeld(v,Where)
		end
	end
end
if Weap then
	Weap.Equipped:Connect(function()
		Character = Weap.Parent task.wait(.01)
		--if Character:FindFirstChildOfClass("Humanoid") then
		--	Character:FindFirstChildOfClass("Humanoid"):UnequipTools()
		--end
		task.wait(.01)
		--[[Weap:FindFirstChild("Handle"):BreakJoints()
		Weap:FindFirstChild("Handle").Parent = workspace
		Weap:Destroy()
		return]]
		StartExecution(Weap)
		task.wait(.01)
		playAnimation("Idle",0.35)
	end)
	Weap.Activated:Connect(function()
		Tiem = tick()
		playAnimation("Cast",0.35)
		local sphere = Instance.new("Part",Character)
		sphere.Shape = Enum.PartType.Ball
		sphere.Transparency = 0.9
		sphere.Anchored = true
		sphere.CanCollide = false
		sphere.CanQuery = false
		sphere.Color = Weap:FindFirstChild("Handle").Color
		sphere.Name = "PROTECTION"
		table.insert(partall, sphere)
		local function uhh(part)
			if not table.find(partall, part) and not part:IsDescendantOf(Character) and part:FindFirstAncestorWhichIsA("Model") and part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") and not bounce[part:FindFirstAncestorWhichIsA("Model")] then
				bounce[part:FindFirstAncestorWhichIsA("Model")] = true
				if part:FindFirstAncestorWhichIsA("Model") and part:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Head") then part:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Head").CFrame = CFrame.new(part:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Head").Position, sphere.Position) end
				if part:FindFirstAncestorWhichIsA("Model") and part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid") then part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Sit = true
				part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health = part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Health - 10
				end	
				if part:FindFirstAncestorWhichIsA("Model") and part:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Head") then part:FindFirstAncestorWhichIsA("Model"):FindFirstChild("Head").Velocity = Vector3.new(0,10,-150) end
				if part then Instance.new('Explosion',workspace).Position = part.Position 
				bobm_sound(part.Position)
				task.wait(0.5)end
				if part and part:FindFirstAncestorWhichIsA("Model") then
					part:FindFirstAncestorWhichIsA("Model"):FindFirstChildOfClass("Humanoid").Sit = false
					bounce[part:FindFirstAncestorWhichIsA("Model")] = nil
				end
			end
		end
		if connect1 then
			connect1:Disconnect()
			end
		if connect2 then
			connect2:Disconnect()
			end
		if connect3 then
			connect3:Disconnect()
			end
		connect1 = sphere.Touched:Connect(uhh)
		connect2 = sphere.TouchEnded:Connect(uhh)
		connect3 = sphere.LocalSimulationTouched:Connect(uhh)
		local lastbobm = tick()
		local spell = coroutine.create(function()
			while CurrentAnim == "Cast" do
				while task.wait(.01) do
					if not Character:FindFirstChildOfClass("ForceField") then
						local ff = Instance.new('ForceField',Character)
						ff.Visible = false
					end
					speed = math.clamp(speed + 0.01,1,10) 
					Angle = Angle+speed * 0.01
					local angle = Angle * 2 * math.pi
					local xOffset = 25 * math.cos(angle)
					local zOffset = 25 * math.sin(angle)
					-- Calculate the new position for the circular attack
					local newPosition = Weap:FindFirstChild("Handle").CFrame.Position + Vector3.new(xOffset, 0, zOffset)
					local bobm = Instance.new("Explosion", Weap)
					bobm.Position = newPosition --(Weap:FindFirstChild("Handle").CFrame + Vector3.new(0,0,5) * CFrameAngles(0,Angle,Angle)).Position --weird
					bobm.DestroyJointRadiusPercent = 1
					bobm_sound(newPosition)
					sphere.Position = Weap:FindFirstChild("Handle").Position
					sphere.Size = Vector3.new(math.random(40,50),math.random(45,50),math.random(35,50))
					sphere.Shape = Enum.PartType.Ball
					sphere.Transparency = 0.7
					sphere.Anchored = true
					sphere.CanCollide = false
					sphere.CanTouch = true
					sphere.CanQuery = false
					sphere.Color = Weap:FindFirstChild("Handle").Color
					if Weap:FindFirstChild("Handle") and Weap:FindFirstChild("Handle"):FindFirstChild("Also Handle") then
						if  Weap:FindFirstChild("Handle").Material == Enum.Material.Neon then
							Weap:FindFirstChild("Handle").Material = Enum.Material.SmoothPlastic
							Weap:FindFirstChild("Handle"):FindFirstChild("Also Handle").Material = Enum.Material.SmoothPlastic
						else
							Weap:FindFirstChild("Handle").Material = Enum.Material.Neon
							Weap:FindFirstChild("Handle"):FindFirstChild("Also Handle").Material = Enum.Material.Neon
						end
					end
					sphere.Name = "PROTECTION"
					--if (tick() - lastbobm) >= 2 then
						local drop = Instance.new("Part", workspace)
						speed2 = math.clamp(speed2 + 0.01,1,5) 
						Angle2 = Angle2+speed2 * 0.01
						local angle2 = Angle2 * 2 * math.pi
						local xOffset = 25 * math.cos(angle2)
						local zOffset = 25 * math.sin(angle2)
						-- Calculate the new position for the circular attack
						local newPosition = Weap:FindFirstChild("Handle").CFrame.Position + Vector3.new(xOffset, 0, zOffset)
						drop.Position = newPosition
						game:FindFirstChildOfClass('Debris'):AddItem(drop,1)
						drop.Anchored = true
						drop.CanCollide = false
						drop.Transparency = 1
						table.insert(partall, drop)
						drop.Touched:Once(function(part)
							if not table.find(gtgignore, part) and not table.find(partall, part) and not part:IsDescendantOf(Character) and part:FindFirstAncestorWhichIsA('Model') and part:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')  then
								Instance.new('Explosion',workspace).Position = drop.Position
								drop:Destroy()
							else
								if not table.find(gtgignore, part) and (part:FindFirstAncestorWhichIsA('Model') and not part:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass('Humanoid')) or not part:FindFirstAncestorWhichIsA('Model') then
									table.insert(gtgignore,part)
								end
							end
						end)
					--end
				end
			end
		end)
		coroutine.resume(spell)
		undecon = Weap.Deactivated:Connect(function()
			--[[local furthestpos = 1000
			local savedframe = Weap:FindFirstChild("Handle").CFrame
			if tick() - Tiem < 0.5 then
				local go = coroutine.create(
					function()
						while furthestpos > 0 do
							local far = 1000 - furthestpos
							-- Calculate the new position for the circular attack
							local newPosition = savedframe + Vector3.new(0, 0, far) * savedframe.LookVector
							local bobm = Instance.new("Explosion", Weap)
							bobm.Position = newPosition --(Weap:FindFirstChild("Handle").CFrame + Vector3.new(0,0,5) * CFrameAngles(0,Angle,Angle)).Position --weird
							bobm.DestroyJointRadiusPercent = 0.5
							bobm_sound(newPosition)
							furthestpos = furthestpos - 1
							if furthestpos <= 0 then
								break
							end
						end
					end
				)
				coroutine.resume(go)
			end]]
			connect1:Disconnect()
			connect2:Disconnect()
			connect3:Disconnect()
			if undecon then
				undecon:Disconnect()
			end
			if unecon then
				undecon:Disconnect()
			end
			if sphere then
				sphere:Destroy()
			end
			playAnimation("Idle",0.35)
			coroutine.close(spell)
			if Character:FindFirstChildOfClass("ForceField") then
				Character:FindFirstChildOfClass("ForceField"):Destroy()
			end
			speed = 1
			speed = 1
			--[[if go ~= nil then
				coroutine.close(go)
			end]]
		end)
		unecon = Weap.Unequipped:Connect(function()
			for i,v in Weap:GetChildren() do
				if v:IsA("JointInstance") then
					v:Destroy()
					if WeldStorage[v] then
						WeldStorage[v] = nil
					end
				end
			end
			connect1:Disconnect()
			connect2:Disconnect()
			connect3:Disconnect()
			if undecon then
				undecon:Disconnect()
			end
			if unecon then
				undecon:Disconnect()
			end
			if sphere then
				sphere:Destroy()
			end
			speed = 1
			speed = 1
			if spell then
				coroutine.close(spell)
			end
			CurrentAnim = "nil"
			table.clear(WeldStorage)
		end)
	end)
	Weap.Unequipped:Connect(function()
		for i,v in Weap:GetChildren() do
			if v:IsA("JointInstance") then
				v:Destroy()
				if WeldStorage[v] then
					WeldStorage[v] = nil
				end
			end
		end
		CurrentAnim = "nil"
		table.clear(WeldStorage)
	end)
end]]></ProtectedString>

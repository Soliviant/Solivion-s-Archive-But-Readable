					<ProtectedString name="Source"><![CDATA[--<{By Solivion, This item either needs a fire source tool to pair with or just force it}>--
--[[//
Controls:
This tool require mobile support, as normally mobile can only register tapping. These controls requires long-duration of tool activation to determine more actions

>>Under 1 Sec: Switch Sparkler(If The Current One Has Already Been Lit, It will be thrown away)
>>1-2 Sec: Light Up/ Cancel Request(More About This Below)/ Throw away if already lit
>>2-5 Sec: Gift Request(You can give the Sparkler to someone else, Their hand must not be occupied with any tool, 10 Second choice countdown, Can be cancelled between 1sec to 5 sec tool activation)
>>5 Sec+: Nothing
//]]--

--<<Services>>--
local Debris = game:FindFirstChildOfClass('Debris')
local TweenService = game:FindFirstChildOfClass('TweenService')
local Players = game:FindFirstChildOfClass('Players')

repeat task.wait(.01) if (script:FindFirstAncestorWhichIsA('Tool') or script:FindFirstAncestorWhichIsA('Flag')) and script:FindFirstAncestorWhichIsA('Actor') then break end until (script:FindFirstAncestorWhichIsA('Tool') or script:FindFirstAncestorWhichIsA('Flag')) and script:FindFirstAncestorWhichIsA('Actor')

--<<Settings>>--

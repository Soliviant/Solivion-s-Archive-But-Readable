--Type Checking Core Function
function CheckFalse(CheckedInstance: Instance, ClassType: string, IsA: string?)
	if not CheckedInstance or CheckedInstance ~= CheckedInstance or typeof(ClassType) ~= "string" or typeof(CheckedInstance):upper() ~= ClassType:upper() then return false end
	if ClassType:upper() == "INSTANCE" and (typeof(IsA) ~= "string" or not CheckedInstance.Parent or (not CheckedInstance:IsA(IsA) and IsA:upper() ~= CheckedInstance.ClassName:upper())) then return false end
	return true
end

--Type Checking Shortcuts
function IsThread(Thread: thread) return CheckFalse(Thread, "thread") end
function IsTable(Table: {}) return CheckFalse(Table, "table") end
function IsNumber(Number: number) return CheckFalse(Number, "number") end
function IsString(String: string) return CheckFalse(String, "string") end
function IsJoint(JointInstance: JointInstance) return CheckFalse(JointInstance, "Instance", "JointInstance") end
function IsAttachment(Attachment: Attachment) return CheckFalse(Attachment, "Instance", "Attachment") end
function IsColour(Colour: (Color3 | BrickColor)) return CheckFalse(Colour, "Color3") or CheckFalse(Colour, "BrickColor") end
function IsVector(Vector: Vector3) return CheckFalse(Vector, "Vector3") end
function IsCFrame(CFrame: CFrame) return CheckFalse(CFrame, "CFrame") end
function IsEvent(Event: RbxScriptConnections) return CheckFalse(Event, "RbxScriptConnections") end
function IsPlayer(Instance: Player) return CheckFalse(Instance, "Instance", "Player") end
function IsCharacter(Instance: Model) return CheckFalse(Instance, "Instance", "Model") and Instance:FindFirstChildOfClass("Humanoid") end
function IsTool(Instance: Tool) return CheckFalse(Instance, "Instance", "Tool") end
function IsValidAnimation(Name: string) return IsString(Name) and IsTable(AnimationData[Name]) end
function IsRegisteredCharacter(Character: Model) return IsCharacter(Character) and IsTable(Joints[Character]) end

function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local Found: boolean = false
	if typeof(Where) ~= 'Instance' or not IsString(Name) or not IsString(Class) then
		error('invalid bruh'..tostring(typeof(Where) == 'Instance')..tostring(IsString(Name))..tostring(IsString(Class)))
		return
	end
	if Where:FindFirstChild(Name) and Where:FindFirstChild(Name).ClassName:upper():match(Class:upper()) then
		return Where:FindFirstChild(Name)
	end
	for i,v in Where:GetChildren() do
		if not Found then
			if Where == nil then
				Found = true
				return nil
			end
			if v.Name:match(Name) and (v:IsA(Class) or v.ClassName:upper():match(Class:upper())) then
				Found = true
				return v
			end
		end
	end
end

if not FindFirstChildOfNameAndClass(Tool, 'Handle', 'BasePart') then
	local Handle = Instance.new('Part', Tool)
	Handle.Name = 'Handle'
	Handle.Size = Vector3.new(2.145, 1.087, 5.157)
	Handle.CanCollide = false
end

function LockManual(Character: Model, mt: JointInstance)
	if IsCharacter(Character) or not IsJoint(mt) then return end
	if not mt or typeof(mt) ~= 'Instance' or not mt:IsA('JointInstance') or not mt.Parent then return end
	if mt.Enabled == true then
		mt.Enabled = false
		table.insert(R15LockWeld[Character], mt)
		local Replace = Instance.new('Weld', mt.Parent)
		Replace.Name = mt.Name
		Replace.Part1 = mt.Part1
		Replace.Part0 = mt.Part0
		Replace.C0 = mt.C0
		Replace.C1 = mt.C1
		if not table.find(R15LockWeld[Character], Replace) then	table.insert(R15LockWeld[Character], Replace) end
	end
end
function LockR15toR6(Character: Model)
	if not IsCharacter(Character) then return end
	if not R15LockWeld[Character] then
		R15LockWeld[Character] = {}
	else
		return -- already locked
	end
	for i,v in pairs(Character:GetDescendants())  do
		if (v.Name:match('Foot') or v.Name:match('Hand') or v.Name:match('UpperArm') or v.Name:match('UpperTorso') or v.Name:match('LowerTorso')) and v:IsA('BasePart') then
			if v:FindFirstChildOfClass('Motor6D') and not table.find(R15LockWeld[Character], v:FindFirstChildOfClass('Motor6D')) then
				local mt = v:FindFirstChildOfClass('Motor6D')
				if mt.Enabled == true then
					mt.Enabled = false
					table.insert(R15LockWeld[Character], mt)
					local Replace = Instance.new('Weld', mt.Parent)
					Replace.Name = mt.Name
					Replace.Part1 = mt.Part1
					Replace.Part0 = mt.Part0
					Replace.C0 = mt.C0
					Replace.C1 = mt.C1
					if not table.find(R15LockWeld[Character], Replace) then	table.insert(R15LockWeld[Character], Replace) end
				end
			end
		end
	end --r6ify
end
function UnlockR15(Character)
	if not IsCharacter(Character) then return end
	if not R15LockWeld[Character] then return end
	for i,v in ipairs(R15LockWeld[Character]) do
		if v:IsA('Motor6D') then
			v.Enabled = true
		else
			v:Destroy()
		end
	end
	table.clear(R15LockWeld[Character])
	R15LockWeld[Character] = nil
end
local Unrig = function(Character: Model?)
	if not Character then return end
	if Character and not FindFirstChildOfNameAndClass(Character, Tool.Name, Tool.ClassName) then	if JointsExtraPart[Character] then for i,v in JointsExtraPart[Character] do if i and typeof(i) == 'Instance' and i:IsA('BasePart') then i.Transparency = (i.Name:match('Lower') and FindFirstChildOfNameAndClass(Character, string.gsub(i.Name, 'Lower', 'Upper'), 'BasePart') and FindFirstChildOfNameAndClass(Character, string.gsub(i.Name, 'Lower', 'Upper'), 'BasePart').Transparency) or (i.Name:match('Upper') and FindFirstChildOfNameAndClass(Character, string.gsub(i.Name, 'Upper', 'Lower'), 'BasePart') and FindFirstChildOfNameAndClass(Character, string.gsub(i.Name, 'Upper', 'Lower'), 'BasePart').Transparency) or v or 0 end end JointsExtraPart[Character] = nil end else task.delay(0.1, function() if Character and not FindFirstChildOfNameAndClass(Character, Tool.Name, Tool.ClassName) then JointsExtraPart[Character] = nil end end) end
	if Joints[Character] then for i,v in pairs(Joints[Character]) do v:Destroy() end Joints[Character] = nil end
	UnlockR15(Character)
end
function Animate(Character: Model, AnimationName: string, TBF: number, TT: number, FrameNum: number?, ExtraConfig: TweenInfo?)
	if not IsCharacter(Character) or not IsValidAnimation(AnimationName) then return end
	if not IsNumber(TBF) then TBF = .05 end
	if not IsNumber(TT) then TT = .1 end
	local TranscriptedData = table.clone(AnimationData[AnimationName])
	local function ProcessFrame(Frame: AnimationFrame)
		if not IsTable(Frame) then return false end
		for i,v in pairs(Frame) do
			if IsTable(v) and IsCFrame(CFrame.new(unpack(v))) then v = CFrame.new(unpack(v)) end
			if not (IsString(i) and IsCFrame(v) and IsCharacter(Character) and IsTable(Joints[Character]) and IsJoint(Joints[Character][i])) then return false end
			TweenService:Create(Joints[Character][i], (IsTable(ExtraConfig) and ExtraConfig) or TweenInfo.new(TT), {C0 = v}):Play()
		end
		return true	
	end
	local function SafetyCall(i: number)
		if not IsNumber(i) or not IsTable(TranscriptedData[i]) then return end
		local Success: boolean = ProcessFrame(TranscriptedData[i])
		if not Success then return false end	
		task.wait(TBF)
		return true -- Success call
	end
	if not IsNumber(FrameNum) then
		for i,v in ipairs(TranscriptedData) do
			local valid = SafetyCall(i) if not valid then return false end
		end
	else
		local valid = SafetyCall(FrameNum) if not valid then return false end
	end
	return true
end

function CreateWeldIfNeeded(AnimatedCharacter: Model, partName: string?, parentName: string?, part0Name: string?, part1Name: string?, weldName: string?, startcframe: CFrame?)
	if not IsCharacter(AnimatedCharacter) then return end
	if not partName then partName = 'DICTIONARY_SLOT' end
	if (typeof(part1Name) ~= 'string' and typeof(part1Name) ~= 'Instance') or (typeof(part0Name) ~= 'string' and typeof(part0Name) ~= 'Instance') then return end
	if not Joints[AnimatedCharacter] then Joints[AnimatedCharacter] = {} end
	if not Joints[AnimatedCharacter][partName] then
		local newWeld = Instance.new('Weld')
		Joints[AnimatedCharacter][partName] = newWeld
		if partName:match('Hip') or partName:match('Root') then newWeld.Enabled = false end
		newWeld.Parent = typeof(parentName) == 'Instance' and parentName or parentName and FindFirstChildOfNameAndClass(AnimatedCharacter, parentName, 'BasePart') or AnimatedCharacter
		newWeld.Part1 = typeof(part1Name) == 'Instance' and part1Name or part1Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part1Name, 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart')
		newWeld.Part0 = typeof(part0Name) == 'Instance' and part0Name or part0Name and FindFirstChildOfNameAndClass(AnimatedCharacter, part0Name, 'BasePart') or newWeld.Part1 or FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') or FindFirstChildOfNameAndClass(AnimatedCharacter, 'Torso', 'BasePart') or nil
		--print(tostring(newWeld.Parent)..','..tostring(newWeld.Part1)..','..tostring(newWeld.Part0)..partName)
		newWeld.C0 = startcframe or CFrame.new()
		if newWeld.Part1.Name:match('UpperArm') then
			local SizeA: Vector3 = newWeld.Part1.Size
			local SizeB: Vector3 = newWeld.Part0.Size
			newWeld.C1 = CFrame.new(0,(SizeB.Y-SizeA.Y * 2)/2,0)
		end
		newWeld.Name = weldName or '__PLACEHOLDER'
	end
end

function RegisterTransparency(AnimatedCharacter: Model, Part: BasePart)
	if not IsCharacter(AnimatedCharacter) then return end
	if not JointsExtraPart[AnimatedCharacter] then JointsExtraPart[AnimatedCharacter] = {} end
	if not Part or typeof(Part) ~= 'Instance' or not Part.Parent or not Part:IsA('BasePart') or JointsExtraPart[AnimatedCharacter][Part] then return end
	JointsExtraPart[AnimatedCharacter][Part] = Part.Transparency
	Part.Transparency = 1
end

function RecoverWelds(AnimatedCharacter)
	if not IsCharacter(AnimatedCharacter) then return end
	--if AnimatedCharacter:FindFirstChildOfClass('Humanoid') then local RootPart = AnimatedCharacter:FindFirstChildOfClass('Humanoid').RootPart CreateWeldIfNeeded('RootJoint', RootPart, RootPart, 'UpperTorso', 'Root Joint', CFrame.new()) CreateWeldIfNeeded('RootJoint', RootPart, RootPart, 'Torso', 'Root Joint', CFrame.new()) end
	if FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart') then
		CreateWeldIfNeeded(AnimatedCharacter,'RootJoint', 'HumanoidRootPart', 'HumanoidRootPart', 'UpperTorso', 'Root Joint', CFrame.new())
		CreateWeldIfNeeded(AnimatedCharacter,'LeftHip', 'UpperTorso', 'UpperTorso', 'LeftUpperLeg', 'Left Hip', CFrame.new(-0.5, -2, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'LeftShoulder', 'UpperTorso', 'UpperTorso', 'LeftUpperArm', 'Left Shoulder', CFrame.new(-1.5, 0, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'RightHip', 'UpperTorso', 'UpperTorso', 'RightUpperLeg', 'Right Hip', CFrame.new(0.5, -2, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'RightShoulder', 'UpperTorso', 'UpperTorso', 'RightUpperArm', 'Right Shoulder', CFrame.new(1.5, 0, 0))
		--RegisterTransparency(AnimatedCharacter, FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerLeg', 'BasePart'))
		--RegisterTransparency(AnimatedCharacter, FindFirstChildOfNameAndClass(AnimatedCharacter, 'UpperTorso', 'BasePart'))
		--RegisterTransparency(AnimatedCharacter, FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerLeg', 'BasePart'))
		--RegisterTransparency(AnimatedCharacter, FindFirstChildOfNameAndClass(AnimatedCharacter, 'LeftLowerArm', 'BasePart'))
		--RegisterTransparency(AnimatedCharacter, FindFirstChildOfNameAndClass(AnimatedCharacter, 'RightLowerArm', 'BasePart'))
	else
		CreateWeldIfNeeded(AnimatedCharacter,'RootJoint', 'HumanoidRootPart', 'HumanoidRootPart', 'Torso', 'Root Joint', CFrame.new())
		CreateWeldIfNeeded(AnimatedCharacter,'LeftHip', 'Torso', 'Torso', 'Left Leg', 'Left Hip', CFrame.new(-0.5, -2, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'LeftShoulder', 'Torso', 'Torso', 'Left Arm', 'Left Shoulder', CFrame.new(-1.5, 0, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'RightHip', 'Torso', 'Torso', 'Right Leg', 'Right Hip', CFrame.new(0.5, -2, 0))
		CreateWeldIfNeeded(AnimatedCharacter,'RightShoulder', 'Torso', 'Torso', 'Right Arm', 'Right Shoulder', CFrame.new(1.5, 0, 0))
	end
end

local Character
Tool.Equipped:Connect(function()
	if not IsCharacter(Tool.Parent) or not (FindFirstChildOfNameAndClass(Tool.Parent, 'Right Arm', 'BasePart') or FindFirstChildOfNameAndClass(Tool.Parent, 'RightHand', 'BasePart')) then return end
	local Arms = (FindFirstChildOfNameAndClass(Tool.Parent, 'Right Arm', 'BasePart') or FindFirstChildOfNameAndClass(Tool.Parent, 'RightHand', 'BasePart'))
	if not CheckFalse(Arms, "Instance", 'BasePart') then return end
	local GripWeld: JointInstance = FindFirstChildOfNameAndClass((FindFirstChildOfNameAndClass(Tool.Parent, 'Right Arm', 'BasePart') or FindFirstChildOfNameAndClass(Tool.Parent, 'RightHand', 'BasePart')), 'RightGrip', 'JointInstance')
	if not GripWeld then
		local NewGripWeld = Instance.new('Weld', Arms)
		NewGripWeld.Name = 'RightGrip'
		NewGripWeld.Part1 = FindFirstChildOfNameAndClass(Tool, 'Handle', 'BasePart')
		NewGripWeld.Part0 = Arms
		GripWeld = NewGripWeld
	end
	if not IsJoint(GripWeld) then return end
	Joints[Tool.Parent] = {
		GripWeld = GripWeld
	}
	GripWeld.C0 = CFrame.new()
	GripWeld.C1 = ((FindFirstChildOfNameAndClass(Tool.Parent, 'UpperTorso', 'BasePart') and (CFrame.new(-1.15,0,0))) or CFrame.new())	
	Character = Tool.Parent
	RecoverWelds(Tool.Parent)
	--LockR15toR6(Tool.Parent)
	local AnimateResult: boolean = Animate(Tool.Parent, 'Equip')
	if AnimateResult == true then
		print('Animation Call Success')
	else
		print('Animation Call Failed')
	end
end)
Tool.Unequipped:Connect(function()
	Unrig(Character)
end)]]></ProtectedString>

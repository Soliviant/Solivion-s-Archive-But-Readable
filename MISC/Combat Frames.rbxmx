		</Properties>
		<Item class="Script" referent="RBX30664876A5604C69A3503587331A52B9">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local parentanim = script:FindFirstAncestorWhichIsA('Folder') or script:FindFirstAncestorWhichIsA('Model')
local Anim = {
}
if not parentanim then warn('No Animation To Export, Please Put This script As A Descendant Of A Folder Anlomg With the Animation, R6 Rigs Required') end
for i,v in parentanim:GetChildren() do
	Anim[v.Name] = {}
	for anim,more in v:GetChildren() do
		Anim[v.Name][tostring(more.Name)] = {}
		Anim[v.Name][tostring(more.Name)]['RootJoint'] = more:FindFirstChild('HumanoidRootPart').CFrame:ToObjectSpace(more:FindFirstChild('Torso').CFrame)
		Anim[v.Name][tostring(more.Name)]['RightShoulder'] = more:FindFirstChild('Torso').CFrame:ToObjectSpace(more:FindFirstChild('Right Arm').CFrame)
		Anim[v.Name][tostring(more.Name)]['LeftShoulder'] = more:FindFirstChild('Torso').CFrame:ToObjectSpace(more:FindFirstChild('Left Arm').CFrame)
		Anim[v.Name][tostring(more.Name)]['Neck'] = more:FindFirstChild('Torso').CFrame:ToObjectSpace(more:FindFirstChild('Head').CFrame)
	end
end

print(Anim)]]></ProtectedString>

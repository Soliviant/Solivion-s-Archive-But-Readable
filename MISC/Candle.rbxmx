				<Item class="Script" referent="RBX1B4D7B43483C4BF597B042866451F0B4">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--I firstly uploaded this on my 'throwaway' alt, cuz I was in school using the studio union for 10 mins or so, then scripted it poorly then published it on @Aztrylle
--Union and Script By @Solivion

local ParticleUpdateRate: number = 1/20
local ParticleRate: number = .1

local EffectInstance = {}
local Character: Model?
local Tool, GenHandle = script:FindFirstChildWhichIsA('BasePart'), script:FindFirstChildWhichIsA('BasePart')
local FlameBurns= true
local TweenService = game:FindFirstChildOfClass('TweenService')
local Debris = game:FindFirstChildOfClass('Debris')
local function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal)
	local reflection = rayDirection - 2 * dotProduct * normal
	return reflection :: Vector3
end
function Classic_Flagstand_Effect(Coordinate: CFrame?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?, Enable_Gravity: boolean?)
	task.desynchronize()
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Tool:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	task.synchronize()
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		task.synchronize()
		local effect = Instance.new("FlagStand", Parent)
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.Position or GenHandle.Position or Tool:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Enable_Gravity and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		coroute = coroutine.create(function()
			task.synchronize()
			local altr = Fade_Duration
			local lastamtick = tick()
			while task.wait(ParticleUpdateRate or .01) and altr > 0 and script:FindFirstAncestorWhichIsA('Actor') do
				task.desynchronize()
				local delta = tick() - lastamtick
				local speed = 1 - .000001 ^ delta
				altr = altr - delta
				lastamtick = tick()
				task.desynchronize()
				if effect then
					local targetc = effect.CFrame targetc = (effect.CFrame + (Motion/1.25 + breakApart/1.25) * speed )* CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					local targett = effect.Transparency + 1 * speed/Fade_Duration
					local Sizeb = effect.Size + effect.Size * Size_Rate * speed/Fade_Duration
					local Sizes = effect.Size - effect.Size * Size_Rate * speed/Fade_Duration
					task.synchronize()
					--print('ea')
					effect.CFrame = targetc
					effect.Transparency = targett
					if ShrinkOrExpand == 'Expand' then
						effect.Size = Sizeb  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = Sizes
					end
				end
				task.desynchronize()
				if not hit and Motion ~= Vector3.new() and Enable_Gravity then
					task.desynchronize()
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos - Motion, (effect.Position - lastpos) + Motion,RaycastParam) or workspace:Raycast(lastpos + Motion, (effect.Position - lastpos) - Motion,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos + Motion, (lastpos - effect.Position) - Motion,RaycastParam) or workspace:Raycast(lastpos - Motion, (lastpos - effect.Position) + Motion,RaycastParam) or workspace:Raycast(lastpos,-Motion,RaycastParam) or workspace:Raycast(effect.Position,Motion,RaycastParam) or workspace:Raycast(lastpos,Motion,RaycastParam) or workspace:Raycast(effect.Position,-Motion,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							if table.find(EffectInstance, effect) then
								table.remove(EffectInstance, table.find(EffectInstance, effect))
							end
							task.synchronize()effect:Destroy()
						else
							task.synchronize()
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							if table.find(EffectInstance, effect) then
								table.remove(EffectInstance, table.find(EffectInstance, effect))
							end
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								if cloneeffect then
									cloneeffect.Anchored = false
								end
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01)
							if TweenService then
								TweenService:Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) task.delay(9, function() if table.find(EffectInstance, cloneeffect) then
										table.remove(EffectInstance, table.find(EffectInstance, cloneeffect))
									end end) end
						end
					elseif not hit then
						task.desynchronize()
						lastpos = effect.Position
						if Enable_Gravity then
							if Motion.Y < (-0.5 * 25) then

								Motion = Motion + Vector3.new(0,0.1,0) -- slow rec as it inverse accelerates
								GravityStack = GravityStack - 1
							else -- until gravity balanced out
								Motion = Motion + Vector3.new(0,-0.25,0) -- high gain as it accelerates
								GravityStack = GravityStack + 1
							end	
						end
					end
				elseif not hit and Motion ~= Vector3.new() and not Enable_Gravity then
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos - Motion, (effect.Position - lastpos) + Motion,RaycastParam) or workspace:Raycast(lastpos + Motion, (effect.Position - lastpos) - Motion,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos + Motion, (lastpos - effect.Position) - Motion,RaycastParam) or workspace:Raycast(lastpos - Motion, (lastpos - effect.Position) + Motion,RaycastParam) or workspace:Raycast(lastpos,Motion,RaycastParam) or workspace:Raycast(effect.Position,-Motion,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit and hit.Instance and hit.Material ~= Enum.Material.ForceField and (not hit.Instance:IsDescendantOf(Tool)) then
						Motion = calculateBounceAngle(Motion,hit)
						if FlameBurns and hit.Instance and (hit.Material == Enum.Material.Wood or hit.Material == Enum.Material.WoodPlanks) then
							task.synchronize()
							if not hit.Instance:GetAttribute('Duration') then
								hit.Instance:SetAttribute('Duration', 99)
							else
								hit.Instance:SetAttribute('Duration', hit.Instance:GetAttribute('Duration') - 1)
								hit.Instance.Transparency += 0.01
								if hit.Instance:GetAttribute('Duration') <= 0 then
									hit.Instance:Destroy()
								end
							end
							task.desynchronize()
						end
						if FlameBurns and hit.Instance and hit.Instance:FindFirstAncestorOfClass('Model') and hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid') then
							task.synchronize()
							hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').Health = hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').Health - hit.Instance:FindFirstAncestorOfClass('Model'):FindFirstChildOfClass('Humanoid').MaxHealth/150
							task.desynchronize()
						end
					end
				end
				task.desynchronize()
				if (i >= Fade_Duration) or (hit and Enable_Gravity) or not effect then
					coroute = nil
					if corouteDis then
						task.synchronize()
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						if table.find(EffectInstance, effect) then
							table.remove(EffectInstance, table.find(EffectInstance, effect))
						end
						task.synchronize()
						effect:Destroy()
					end
					break
				end
				task.desynchronize()
				if (i >= Fade_Duration) or not effect or (hit and Enable_Gravity) then
					return
				end
			end
			if not script:FindFirstAncestorWhichIsA('Actor') then
				if effect then effect:Destroy() end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = script:FindFirstAncestorWhichIsA('Part').Destroying:Connect(function()
			task.desynchronize()
			if coroute then
				task.synchronize() coroutine.close(coroute)
			end
			task.desynchronize()
			if effect then
				task.synchronize() effect:Destroy()
			end
		end)
	end
end
while task.wait(ParticleRate or 0.1) do
	Classic_Flagstand_Effect(script:FindFirstAncestorWhichIsA('BasePart').CFrame, math.random(90,110)/1000, script:FindFirstAncestorWhichIsA('BasePart'), 1, 9, Color3.new(1, 1, 0), Enum.Material.Neon, Vector3.new(0,0.1,0), 'Shrink', 1)
	task.desynchronize()
	if script:FindFirstAncestorWhichIsA('BasePart') and script:FindFirstAncestorWhichIsA('BasePart'):FindFirstChildOfClass('PointLight') then
		local random = .5 + math.noise(tick(), 0, math.cos(tick() * 2))/4
		task.synchronize()
		script:FindFirstAncestorWhichIsA('BasePart'):FindFirstChildOfClass('PointLight').Range = random * 8
		script:FindFirstAncestorWhichIsA('BasePart'):FindFirstChildOfClass('PointLight').Color = Color3.new(1, 1, 0)
		script:FindFirstAncestorWhichIsA('BasePart'):FindFirstChildOfClass('PointLight').Brightness = random * 4
	end
end]]></ProtectedString>
						<bool name="Disabled">false</bool>
						<Content name="LinkedSource"><null></null></Content>

			<Item class="Script" referent="RBXB7579B7232854749B0FB65F3F06AF5FE">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local RequiredServerStorage = game:FindFirstChildOfClass('ServerStorage') or game:FindFirstChildOfClass('ReplicatedStorage')
local Remote = RequiredServerStorage:FindFirstChild('GAME_EVENT_TRIGGER')
repeat wait() Remote = RequiredServerStorage:FindFirstChild('GAME_EVENT_TRIGGER') if Remote then break end until Remote
if Remote then Remote:Fire('Integrate', script.Parent) end]]></ProtectedString>
